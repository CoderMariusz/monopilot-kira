   450	async function incrementSuppliedOutputLpQuantity(
   451	  ctx: OrgContextLike,
   452	  params: { lpId: string; qtyKg: string; actorUserId: string },
   453	): Promise<void> {
   454	  const { rows } = await ctx.client.query<{ id: string; quantity: string }>(
   455	    `update public.license_plates
   456	        set quantity = quantity + $2::numeric,
   457	            updated_by = $3::uuid,
   458	            updated_at = now()
   459	      where org_id = app.current_org_id()
   460	        and id = $1::uuid
   461	    returning id::text, quantity::text`,
   462	    [params.lpId, params.qtyKg, params.actorUserId],
   463	  );
   464	  if (!rows[0]) {
   465	    throw new ProductionActionError('persistence_failed', 500);
   466	  }
   467	}
