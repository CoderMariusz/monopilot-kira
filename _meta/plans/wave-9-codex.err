   181	// ─── Fixed-point decimal helpers (NUMERIC-exact, no binary float on kg) ──────────
   182	// We keep kg as integer micro-units (1e-6) internally so summation/division for
   183	// the catch-weight summary is exact to 6 fractional digits, then render back to
   184	// trimmed decimal strings. wo_outputs.qty_kg is NUMERIC(12,3); the per-unit
   185	// summary is informational and we publish 3-decimal kg + a 4-decimal variance.
   186	const SCALE = 1_000_000n;
   187	
   188	function toMicro(decimal: string): bigint {
   189	  const neg = decimal.startsWith('-');
   190	  const body = neg ? decimal.slice(1) : decimal;
   350	    [woId, outputType],
   351	  );
   352	  const seq = Number(rows[0]?.seq ?? '0') + 1;
   353	  return `${woNumber}-OUT-${String(seq).padStart(3, '0')}`;
   354	}
   355	
   356	/**
   357	 * Genealogy source (F-B08): net consumed qty per LP from the canonical consumption
   358	 * ledger (wo_material_consumption — the only consume writer), including negative
   359	 * reversal counter-rows. Parents with net <= 0 are excluded; per-parent genealogy
   360	 * qty is the net contribution, not the full output qty.
   361	 */
   362	async function loadConsumedLpContributions(
   363	  ctx: OrgContextLike,
   364	  woId: string,
   365	): Promise<ConsumedLpContribution[]> {
   366	  const { rows } = await ctx.client.query<ConsumedLpContribution>(
   367	    `select lp_id::text as lp_id,
   368	            sum(qty_consumed)::text as net_qty
   369	       from public.wo_material_consumption
   370	      where org_id = app.current_org_id()
   371	        and wo_id = $1::uuid
   372	        and lp_id <> '00000000-0000-0000-0000-000000000000'::uuid
   373	      group by lp_id
   374	     having sum(qty_consumed) > 0::numeric
   375	      order by min(consumed_at) asc, lp_id asc`,
   376	    [woId],
   377	  );
   378	  return rows;
   379	}
   380	
   381	/**
   382	 * Caller-supplied output LP: lock, validate product/site/UoM/status/QA/WO ownership,
   383	 * then increment quantity atomically in the same txn as the receipt move.
   384	 */
   385	async function validateAndLockSuppliedOutputLp(
   386	  ctx: OrgContextLike,
   387	  params: {
   388	    lpId: string;
   389	    productId: string;
   390	    qtyKg: string;
   391	    uom: string;
   392	    woId: string;
   393	    woSiteId: string | null;
   394	  },
   395	): Promise<SuppliedOutputLpRow> {
   396	  const { rows } = await ctx.client.query<SuppliedOutputLpRow>(
   397	    `select lp.id::text as id,
   398	            lp.product_id::text as product_id,
   399	            lp.quantity::text as quantity,
   400	            lp.uom,
   401	            lp.status,
   402	            lp.qa_status,
   403	            lp.site_id::text as site_id,
   404	            lp.wo_id::text as wo_id,
   405	            lp.location_id::text as location_id
   406	       from public.license_plates lp
   407	      where lp.org_id = app.current_org_id()
   408	        and lp.id = $1::uuid
   409	      limit 1
   410	      for update of lp`,
   411	    [params.lpId],
   412	  );
   413	  const lp = rows[0];
   414	  if (!lp) {
   415	    throw new ProductionActionError('invalid_reference', 422, { field: 'lp_id' });
   416	  }
   417	  if (lp.product_id !== params.productId) {
   418	    throw new ProductionActionError('invalid_reference', 422, {
   419	      field: 'lp_id',
   420	      message: 'Supplied license plate product does not match the output product.',
   421	    });
   422	  }
   423	  if (lp.uom !== params.uom) {
   424	    throw new ProductionActionError('uom_mismatch', 409, { uom: lp.uom, expected_uom: params.uom });
   425	  }
   426	  if (params.woSiteId && lp.site_id && lp.site_id !== params.woSiteId) {
   427	    throw new ProductionActionError('invalid_reference', 422, {
   428	      field: 'lp_id',
   429	      message: 'Supplied license plate site does not match the work order site.',
   430	    });
   431	  }
   432	  if (lp.wo_id && lp.wo_id !== params.woId) {
   433	    throw new ProductionActionError('invalid_reference', 422, {
   434	      field: 'lp_id',
   435	      message: 'Supplied license plate is linked to a different work order.',
   436	    });
   437	  }
