    28	-- license_plates — atomic inventory unit (T-002, WH §5.2).
    29	-- ===========================================================================
    30	create table if not exists public.license_plates (
    31	  id                       uuid primary key default gen_random_uuid(),
    32	  org_id                   uuid not null references public.organizations(id) on delete cascade,
    33	  site_id                  uuid,
    34	
    35	  -- Identity / numbering — UNIQUE per (org, warehouse); lp_number_seq is per-warehouse (T-016).
    36	  warehouse_id             uuid not null,            -- soft FK to 02-Settings warehouses
    37	  lp_number                text not null,
    38	  lp_code                  text,                     -- GS1-128 rendered code (T-023)
    39	
    40	  -- What it holds — dual-UoM (quantity + uom + catch_weight_kg).
    41	  product_id               uuid not null,            -- soft FK to 03-Technical items
    42	  quantity                 numeric(18, 6) not null,
    43	  reserved_qty             numeric(18, 6) not null default 0,
    44	  uom                      text not null,
    45	  catch_weight_kg          numeric(18, 6),
    46	
    47	  -- State — status owned by warehouse; qa_status owned by 09-Quality (mirrored here).
    48	  status                   text not null default 'available',
    49	  qa_status                text not null default 'pending',
    50	
    51	  -- Batch / barcode.
    52	  batch_number             text,
    53	  supplier_batch_number    text,
    54	  gtin                     text,
    55	
    56	  -- Expiry — FEFO key. shelf_life_mode/date_code snapshot from 03-Technical at receipt.
    57	  expiry_date              timestamptz,
    58	  best_before_date         timestamptz,
    59	  shelf_life_mode_snapshot text,
    60	  date_code_rendered       text,
    61	
    62	  -- Location — soft FK to 02-Settings locations (ltree zone roll-up).
    63	  location_id              uuid,
    64	
    65	  -- Origin — GRN (receipt) or production (output LP) etc.
    66	  origin                   text not null default 'grn',
    67	
    68	  -- Lineage — genealogy parent + WO/GRN references (soft FKs).
    69	  parent_lp_id             uuid,
    70	  grn_id                   uuid,
    71	  wo_id                    uuid,
    72	  reserved_for_wo_id       uuid,
    73	  consumed_by_wo_id        uuid,
    74	  source_so_id             uuid,                     -- 11-Shipping sales order on ship
    75	
    76	  -- Scanner lock protocol (§6.6, T-020) — 5-min auto-release enforced service-side.
    77	  locked_by                uuid references public.users(id) on delete set null,
    78	  locked_at                timestamptz,
    79	
    80	  -- Extensions (ADR-028).
    81	  ext_jsonb                jsonb not null default '{}'::jsonb,
    82	  private_jsonb            jsonb not null default '{}'::jsonb,
    83	  schema_version           integer not null default 1,
    84	
    85	  -- R13 audit.
    86	  created_by               uuid references public.users(id) on delete set null,
    87	  updated_by               uuid references public.users(id) on delete set null,
    88	  created_at               timestamptz not null default pg_catalog.now(),
    89	  updated_at               timestamptz not null default pg_catalog.now(),
    90	
    91	  constraint license_plates_org_warehouse_lp_number_uq unique (org_id, warehouse_id, lp_number),
    92	  constraint license_plates_quantity_nonneg_check check (quantity >= 0),
    93	  constraint license_plates_reserved_qty_nonneg_check check (reserved_qty >= 0),
    94	  constraint license_plates_reserved_qty_le_quantity_check check (reserved_qty <= quantity),
    95	  constraint license_plates_status_check check (
    96	    status in ('received', 'available', 'reserved', 'allocated', 'consumed',
    97	               'blocked', 'merged', 'shipped', 'returned', 'quarantine')
    98	  ),
    99	  constraint license_plates_qa_status_check check (
   100	    qa_status in ('pending', 'released', 'on_hold', 'rejected')
   120	  /** Set when this call CREATED the output LP (F-A04/F-B08); null on caller-supplied lp_id. */
