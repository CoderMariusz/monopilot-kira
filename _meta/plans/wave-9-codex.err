   726	  const resolvedQtyKg = await resolveQtyKg(ctx.client, wo, input);
   727	  // V-PROD-03: registered output quantity must be > 0.
   728	  if (toMicro(resolvedQtyKg) <= 0n) {
   729	    throw new ProductionActionError('invalid_input', 422, { fields: ['qty_kg'] });
   730	  }
   731	  const item = await loadItem(ctx, input.product_id);
   732	
   733	  const wacContribution = await resolveOutputWacContribution(ctx.client, {
   734	    woId,
   735	    qtyKg: resolvedQtyKg,
   736	    standardCostPerKg: item.cost_per_kg,
   737	  });
   738	  if (
   739	    !wacContribution.applied &&
   740	    wacContribution.excluded === 'un_costed' &&
   741	    wacContribution.unCostedLines.length > 0
