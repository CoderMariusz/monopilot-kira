   121	function wallClockMatches(
   122	  formatted: WallClockParts,
   123	  requested: WallClockParts,
   124	  blockDate: string,
   125	  time: string,
   126	): boolean {
   127	  if (formatWallDate(formatted) !== blockDate) return false;
   128	  if (time.length <= 5) {
   129	    return formatted.hour === requested.hour && formatted.minute === requested.minute;
   130	  }
   131	  return (
   132	    formatted.hour === requested.hour
   133	    && formatted.minute === requested.minute
   134	    && formatted.second === requested.second
   135	  );
   136	}
   137	
   138	function instantFromOffset(parts: WallClockParts, offsetMs: number): number {
   139	  return utcMsFromParts(parts) - offsetMs;
   140	}
   141	
   142	function findExactWallClockInstants(
   143	  parts: WallClockParts,
   144	  blockDate: string,
   145	  time: string,
   146	  timeZone: string,
   147	): number[] {
   148	  const requested = parseWallClockParts(blockDate, time);
   149	  if (!requested) return [];
   150	
   151	  const naiveUtc = utcMsFromParts(parts);
   152	  const offsetAtNaive = getTimeZoneOffsetMs(naiveUtc, timeZone);
   153	  const candidates = new Set<number>([instantFromOffset(parts, offsetAtNaive)]);
   154	
   155	  const offsetOneHourEarlier = getTimeZoneOffsetMs(naiveUtc - 60 * 60 * 1000, timeZone);
   156	  const offsetOneHourLater = getTimeZoneOffsetMs(naiveUtc + 60 * 60 * 1000, timeZone);
   157	  candidates.add(instantFromOffset(parts, offsetOneHourEarlier));
   158	  candidates.add(instantFromOffset(parts, offsetOneHourLater));
   159	
   160	  return [...candidates].filter((candidate) =>
   161	    wallClockMatches(formatWallClockInZone(candidate, timeZone), requested, blockDate, time),
   162	  );
   163	}
   164	
   165	/**
   166	 * Resolve a wall-clock instant in `timeZone`. For ambiguous fall-back times, picks
   167	 * standard (non-DST) offset. For spring-forward gaps, advances to the next valid minute.
   168	 */
   169	export function wallClockToInstant(
   170	  blockDate: string,
   171	  time: string,
   172	  timeZone: string,
   173	): number | null {
   174	  const parts = parseWallClockParts(blockDate, time);
   175	  if (!parts) return null;
   176	
   177	  const includeSeconds = time.length > 5;
   178	  for (let minuteDelta = 0; minuteDelta <= 180; minuteDelta += 1) {
   179	    const probeParts = minuteDelta === 0 ? parts : addWallMinutes(parts, minuteDelta);
   180	    const probeDate = formatWallDate(probeParts);
   181	    const probeTime = formatWallTime(probeParts, includeSeconds);
   182	    const valid = findExactWallClockInstants(probeParts, probeDate, probeTime, timeZone);
   183	    if (valid.length === 0) continue;
   184	
   185	    valid.sort((a, b) => getTimeZoneOffsetMs(a, timeZone) - getTimeZoneOffsetMs(b, timeZone));
   186	    return valid[0] ?? null;
   187	  }
   188	
   189	  return null;
   190	}
