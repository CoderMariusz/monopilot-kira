   175	
   176	function canReserveCapacity(
   177	  lineKey: string,
   178	  startMs: number,
   179	  runDurationMs: number,
   180	  capacityMs: number,
   181	  dayUsageMs: Map<string, number>,
   182	): boolean {
   183	  const endMs = startMs + runDurationMs;
   184	  for (const overlap of utcDayOverlapsForInterval(startMs, endMs)) {
   185	    const usedMs = bucketUsedMs(lineKey, overlap.dayStartMs, dayUsageMs);
   186	    if (overlap.overlapMs > capacityMs - usedMs) return false;
   187	  }
   188	  return true;
   189	}
   190	
   191	function reserveCapacity(
   192	  lineKey: string,
   193	  startMs: number,
   194	  runDurationMs: number,
   195	  dayUsageMs: Map<string, number>,
   196	): void {
   197	  const endMs = startMs + runDurationMs;
   198	  for (const overlap of utcDayOverlapsForInterval(startMs, endMs)) {
   199	    const bucketKey = dayBucketKey(lineKey, overlap.dayStartMs);
   200	    dayUsageMs.set(bucketKey, (dayUsageMs.get(bucketKey) ?? 0) + overlap.overlapMs);
   201	  }
   202	}
   203	
   204	function nextCapacityRetryStart(
   205	  lineKey: string,
   206	  startMs: number,
   207	  runDurationMs: number,
   208	  capacityMs: number,
   209	  dayUsageMs: Map<string, number>,
   210	): number {
   211	  const endMs = startMs + runDurationMs;
   212	  let advanceTo = startMs + 60 * 1000;
   213	  for (const overlap of utcDayOverlapsForInterval(startMs, endMs)) {
   214	    const usedMs = bucketUsedMs(lineKey, overlap.dayStartMs, dayUsageMs);
   215	    const remainingMs = capacityMs - usedMs;
   216	    if (overlap.overlapMs <= remainingMs) continue;
   217	    if (remainingMs <= 0) {
   218	      advanceTo = Math.max(advanceTo, overlap.dayStartMs + DAY_MS);
   219	      continue;
   220	    }
   221	    advanceTo = Math.max(advanceTo, startMs + (overlap.overlapMs - remainingMs));
   222	  }
   223	  return advanceTo;
   224	}
