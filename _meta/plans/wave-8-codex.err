    36	  const piece = normalizePieceUom(trimmed);
    37	  if (piece === 'pcs') return 'each';
    38	  return trimmed;
    39	}
    40	
    41	/**
    42	 * SQL: convert an entered order quantity to the item's canonical inventory quantity
    43	 * (license_plates.quantity grain) using exact NUMERIC pack factors.
    44	 *
    45	 * Count inventory (output_uom each/box or uom_base pcs): box/case → × each_per_box;
    46	 * pallet → × boxes_per_pallet × each_per_box.
    47	 * Weight inventory (uom_base kg): each → × net_qty_per_each; box/case → × each_per_box × net_qty_per_each;
    48	 * pallet → × boxes_per_pallet × each_per_box × net_qty_per_each.
    49	 */
    50	export const ORDER_QTY_TO_INVENTORY_SQL = `select (
    51	       case
    52	         when lower($2::text) in (lower(coalesce(i.uom_base, '')), 'base')
    53	           then $1::numeric
    54	         when lower($2::text) = lower(coalesce(i.uom_base, ''))
    55	           then $1::numeric
    56	         when lower($2::text) in ('pcs', 'ea', 'szt', 'each')
    57	           then case
    58	                  when lower(coalesce(i.uom_base, '')) = 'kg'
    59	                       and i.net_qty_per_each is not null
    60	                       and i.net_qty_per_each > 0
    61	                    then $1::numeric * i.net_qty_per_each
    62	                  when lower(coalesce(i.uom_base, '')) in ('pcs', 'ea', 'szt')
    63	                       or i.output_uom in ('each', 'box')
    64	                    then $1::numeric
    65	                  else null
    66	                end
    67	         when lower($2::text) in ('box', 'cases', 'case', 'carton', 'cartons', 'pack', 'boxes')
    68	           then case
    69	                  when lower(coalesce(i.uom_base, '')) = 'kg'
    70	                       and i.net_qty_per_each is not null
    71	                       and i.net_qty_per_each > 0
    72	                       and i.each_per_box is not null
    73	                       and i.each_per_box > 0
    74	                    then $1::numeric * i.each_per_box::numeric * i.net_qty_per_each
    75	                  when i.each_per_box is not null and i.each_per_box > 0
    76	                    then $1::numeric * i.each_per_box::numeric
    77	                  else null
    78	                end
    79	         when lower($2::text) = 'pallet'
    80	           then case
    81	                  when i.boxes_per_pallet is not null
    82	                       and i.boxes_per_pallet > 0
    83	                       and i.each_per_box is not null
    84	                       and i.each_per_box > 0
    85	                       and lower(coalesce(i.uom_base, '')) = 'kg'
    86	                       and i.net_qty_per_each is not null
    87	                       and i.net_qty_per_each > 0
    88	                    then $1::numeric
    89	                         * i.boxes_per_pallet::numeric
    90	                         * i.each_per_box::numeric
    91	                         * i.net_qty_per_each
    92	                  when i.boxes_per_pallet is not null
    93	                       and i.boxes_per_pallet > 0
    94	                       and i.each_per_box is not null
    95	                       and i.each_per_box > 0
    96	                    then $1::numeric * i.boxes_per_pallet::numeric * i.each_per_box::numeric
    97	                  else null
    98	                end
    99	         else null
   100	       end
   101	     )::text as inventory_qty,
   102	     (
   103	       case
   104	         when lower($2::text) in (lower(coalesce(i.uom_base, '')), 'base') then true
   105	         when lower($2::text) = lower(coalesce(i.uom_base, '')) then true
   106	         when lower($2::text) in ('pcs', 'ea', 'szt', 'each')
   107	           then (
   108	             (lower(coalesce(i.uom_base, '')) = 'kg' and i.net_qty_per_each is not null and i.net_qty_per_each > 0)
   109	             or lower(coalesce(i.uom_base, '')) in ('pcs', 'ea', 'szt')
   110	             or i.output_uom in ('each', 'box')
   111	           )
   112	         when lower($2::text) in ('box', 'cases', 'case', 'carton', 'cartons', 'pack', 'boxes')
   113	           then (
   114	             (lower(coalesce(i.uom_base, '')) = 'kg'
   115	              and i.net_qty_per_each is not null and i.net_qty_per_each > 0
   116	              and i.each_per_box is not null and i.each_per_box > 0)
   117	             or (i.each_per_box is not null and i.each_per_box > 0)
   118	           )
   119	         when lower($2::text) = 'pallet'
   120	           then i.boxes_per_pallet is not null and i.boxes_per_pallet > 0
   121	                and i.each_per_box is not null and i.each_per_box > 0
   122	                and (
   123	                  lower(coalesce(i.uom_base, '')) <> 'kg'
   124	                  or (i.net_qty_per_each is not null and i.net_qty_per_each > 0)
   125	                )
   126	         else false
   127	       end
   128	     ) as resolved
   129	       from public.items i
   130	      where i.org_id = app.current_org_id()
   131	        and i.id = $3::uuid
   132	      limit 1`;
   133	
   134	export async function resolveOrderQtyToInventoryQty(
   135	  client: QueryClient,
   136	  input: { itemId: string; orderQty: string; orderUom: string },
   137	): Promise<string> {
   138	  const orderUom = input.orderUom.trim();
   139	  const { rows } = await client.query<{ inventory_qty: string | null; resolved: boolean }>(
   140	    ORDER_QTY_TO_INVENTORY_SQL,
   141	    [input.orderQty, orderUom, input.itemId],
   142	  );
   143	  const row = rows[0];
   144	  if (!row?.resolved || row.inventory_qty == null) {
   145	    throw new OrderLineUomError('unresolved_uom', { uom: orderUom, qty: input.orderQty });
   146	  }
   147	  return row.inventory_qty;
   148	}
