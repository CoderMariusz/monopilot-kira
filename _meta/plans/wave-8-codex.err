   221	     shipment_lp_snapshots as (
   222	       select snapshot.lp_id::uuid as lp_id,
   223	              snapshot.shipped_qty::numeric as shipped_qty,
   224	              snapshot.prior_status,
   225	              snapshot.prior_reserved_qty::numeric as prior_reserved_qty
   226	         from public.shipments sh
   227	        cross join lateral jsonb_to_recordset(coalesce(sh.ext_data->'shipped_license_plates', '[]'::jsonb))
