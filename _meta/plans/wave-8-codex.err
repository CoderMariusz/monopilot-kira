    23	export async function releaseShipmentLiveAllocationsInContext(
    24	  ctx: ShippingContext,
    25	  shipmentId: string,
    26	  soId: string,
    27	): Promise<void> {
    28	  const { rows: allocations } = await ctx.client.query<AllocationReleaseRow>(
    29	    `select ia.id::text,
    30	            ia.license_plate_id::text as lp_id,
    31	            ia.quantity_allocated::text as qty,
    32	            ia.sales_order_line_id::text
    33	       from public.inventory_allocations ia
    34	       join public.sales_order_lines sol on sol.id = ia.sales_order_line_id
    35	        and sol.org_id = app.current_org_id()
    36	        and sol.sales_order_id = $2::uuid
    37	        and sol.deleted_at is null
    38	       join public.shipment_box_contents sbc on sbc.license_plate_id = ia.license_plate_id
    39	        and sbc.org_id = app.current_org_id()
    40	        and sbc.deleted_at is null
    41	       join public.shipment_boxes sb on sb.id = sbc.shipment_box_id
    42	        and sb.org_id = app.current_org_id()
    43	        and sb.shipment_id = $1::uuid
    44	        and sb.deleted_at is null
    45	      where ia.org_id = app.current_org_id()
    46	        and ia.deleted_at is null
    47	        and ${LIVE_ALLOCATION_SQL}
    48	      for update of ia`,
    49	    [shipmentId, soId],
    50	  );
    51	
    52	  for (const allocation of allocations) {
    53	    await ctx.client.query(
    54	      `update public.license_plates
    55	          set reserved_qty = greatest(0, reserved_qty - $2::numeric),
    56	              updated_by = $3::uuid
    57	        where org_id = app.current_org_id()
    58	          and id = $1::uuid`,
    59	      [allocation.lp_id, allocation.qty, ctx.userId],
    60	    );
    61	  }
    62	
    63	  if (allocations.length > 0) {
    64	    await ctx.client.query(
    65	      `update public.inventory_allocations ia
    66	          set status = 'released',
    67	              released_at = now(),
    68	              updated_by = $2::uuid
    69	         from public.shipment_box_contents sbc
    70	         join public.shipment_boxes sb on sb.id = sbc.shipment_box_id
    71	          and sb.org_id = app.current_org_id()
    72	          and sb.shipment_id = $1::uuid
    73	          and sb.deleted_at is null
    74	        where ia.id = any($3::uuid[])
    75	          and sbc.license_plate_id = ia.license_plate_id
    76	          and sbc.org_id = app.current_org_id()
    77	          and sbc.deleted_at is null
    78	          and ia.org_id = app.current_org_id()`,
    79	      [shipmentId, ctx.userId, allocations.map((row) => row.id)],
    80	    );
    81	
    82	    for (const allocation of allocations) {
    83	      await ctx.client.query(
    84	        `update public.sales_order_lines
    85	            set quantity_allocated = greatest(0, quantity_allocated - $2::numeric),
    86	                updated_by = $3::uuid
    87	          where org_id = app.current_org_id()
    88	            and id = $1::uuid`,
    89	        [allocation.sales_order_line_id, allocation.qty, ctx.userId],
    90	      );
    91	    }
    92	  }
    93	}
