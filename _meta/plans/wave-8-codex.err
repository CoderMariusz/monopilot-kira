   156	function unitsToDecimal(value: bigint): string {
   157	  const sign = value < 0n ? '-' : '';
   158	  const abs = value < 0n ? -value : value;
   159	  const whole = abs / 1_000_000n;
   160	  const fraction = (abs % 1_000_000n).toString().padStart(6, '0').replace(/0+$/, '');
