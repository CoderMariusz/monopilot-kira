   184	function mapSalesOrderListRow(row: {
   185	  id: string;
   186	  so_number: string | null;
   187	  customer_name: string | null;
   188	  customer_code: string | null;
   189	  status: SalesOrderStatus;
   190	  line_count: number | string | bigint | null;
   191	  total: string | null;
   192	  created_at: string | Date;
   193	  expected_ship_date: string | Date | null;
   194	}): SalesOrderListRow {
   195	  return {
   196	    id: row.id,
   197	    so_number: row.so_number ?? '',
   198	    customer_name: row.customer_name,
   199	    customer_code: row.customer_code,
   200	    status: row.status,
   201	    line_count: toNumber(row.line_count),
   202	    total: row.total ?? '0',
   203	    created_at: toText(row.created_at) ?? '',
   204	    expected_ship_date: toDate(row.expected_ship_date),
   205	  };
   206	}
