   271	                   else coalesce(so.promised_ship_date, so.required_delivery_date, so.order_date)
   272	                 end)::text as need_date,
   273	                sum(greatest(sol.quantity_ordered - coalesce(shipped.shipped_qty, 0), 0))::text as qty
   274	           from public.sales_order_lines sol
