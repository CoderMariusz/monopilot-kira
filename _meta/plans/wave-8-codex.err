   294	                          and coalesce(i_s.each_per_box, 0) > 0
   295	                          then sbc.quantity / (i_s.net_qty_per_each * i_s.each_per_box)
   296	                        else null
   297	                      end
   298	                    ) as shipped_qty
   299	               from public.shipment_box_contents sbc
   300	               join public.sales_order_lines sol_s
   301	                 on sol_s.id = sbc.sales_order_line_id
   302	                and sol_s.org_id = app.current_org_id()
   303	                and sol_s.deleted_at is null
   304	               join public.items i_s
   305	                 on i_s.id = sol_s.product_id
   306	                and i_s.org_id = app.current_org_id()
   307	               join public.shipment_boxes sb
   308	                 on sb.id = sbc.shipment_box_id
   309	                and sb.org_id = app.current_org_id()
   310	                and sb.deleted_at is null
   311	               join public.shipments sh
   312	                 on sh.id = sb.shipment_id
   313	                and sh.org_id = app.current_org_id()
   314	                and sh.deleted_at is null
   315	                and sh.status in ('shipped', 'delivered')
   316	              where sbc.org_id = app.current_org_id()
   317	                and sbc.deleted_at is null
   318	                and sbc.sales_order_line_id is not null
   319	                and sbc.quantity is not null
   320	                and sbc.quantity > 0
   321	              group by sbc.sales_order_line_id
   322	           ) shipped on shipped.sales_order_line_id = sol.id
   323	          where sol.org_id = app.current_org_id()
   324	            and sol.deleted_at is null
   325	            and (case
   326	                   when so.promised_ship_date is null and so.required_delivery_date is null
   327	                   then $3::date
   328	                   else coalesce(so.promised_ship_date, so.required_delivery_date, so.order_date)
   329	                 end) <= $2::date
   330	          group by sol.product_id,
   331	                   coalesce(sol.ext_data->>'order_uom', i.uom_base),
   332	                   case
   333	                     when so.promised_ship_date is null and so.required_delivery_date is null
   334	                     then $3::date
   335	                     else coalesce(so.promised_ship_date, so.required_delivery_date, so.order_date)
   336	                   end`,
   337	        [OPEN_SO_DEMAND_STATUSES, horizonEnd, today],
   338	      );
   339	
   340	      const undatedSo = await c.query<{ undated_lines: string }>(
   341	        `select count(distinct sol.id)::text as undated_lines
   342	           from public.sales_order_lines sol
   343	           join public.sales_orders so
   344	             on so.id = sol.sales_order_id
   345	            and so.org_id = app.current_org_id()
   346	            and so.deleted_at is null
   347	            and so.status = any($1::text[])
   348	          where sol.org_id = app.current_org_id()
   349	            and sol.deleted_at is null
   350	            and so.promised_ship_date is null
