+run('registerOutput genealogy allocation — real Postgres (Wave 9 Bug 2)', () => {
+  beforeAll(async () => {
+    // eslint-disable-next-line no-restricted-syntax -- integration owner pool for seed/assert
+    owner = new pg.Pool({ connectionString: databaseUrl });
