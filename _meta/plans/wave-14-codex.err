    params: readonly unknown[] = [],
  ): Promise<{ rows: T[]; rowCount?: number | null }> => {
    const normalized = sql.replace(/\s+/g, ' ').trim().toLowerCase();
    let rows: unknown[] = [];

    if (normalized.includes('from public.user_roles')) {
