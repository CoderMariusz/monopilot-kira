  +          supplier_name: null,
  +          destination_warehouse_id: params[2],
  +          destination_warehouse_name: null,
  +          status: params[3],
  +          expected_delivery: params[4],
  +          currency: params[5],
  +          notes: params[6],
  +          created_at: '2026-06-23T12:00:00.000Z',
  +          updated_at: '2026-06-23T12:00:00.000Z',
