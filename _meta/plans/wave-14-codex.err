    72	/**
    73	 * Compute + persist catch-weight variance for `orgId` over `day` (YYYY-MM-DD).
    74	 * Must run inside an open transaction with org context already set.
    75	 */
    76	export async function computeCatchWeightVarianceForOrg(
    77	  client: pg.PoolClient,
    78	  orgId: string,
    79	  day: string,
    80	): Promise<CatchWeightVarianceSummary> {
    81	  const thresholdPct = await resolveCatchWeightThresholdPct(client, orgId);
    82	
    83	  const { rows: skippedRows } = await client.query<{
    84	    item_id: string;
    85	    site_id: string | null;
    86	    skip_reason: 'missing_nominal' | 'zero_nominal';
    87	  }>(
    88	    `with weighings as (
    89	       select
    90	         woi.item_id,
    91	         woi.site_id,
    92	         coalesce(woi.nominal_weight, item_row.nominal_weight) as nominal_weight
    93	       from public.work_order_items woi
    94	       join public.items item_row on item_row.id = woi.item_id and item_row.org_id = woi.org_id
    95	       where woi.org_id = $1::uuid
    96	         and item_row.weight_mode = 'catch'
    97	         and woi.actual_weight is not null
    98	         and woi.captured_at >= $2::date
    99	         and woi.captured_at <  ($2::date + interval '1 day')
   100	     )
   101	     select distinct
   102	       weighings.item_id,
   103	       weighings.site_id,
   104	       case
   105	         when weighings.nominal_weight is null then 'missing_nominal'::text
   106	         else 'zero_nominal'::text
   107	       end as skip_reason
   108	     from weighings
   109	     where weighings.nominal_weight is null or weighings.nominal_weight <= 0`,
   110	    [orgId, day],
   111	  );
   112	
   113	  const skipped: CatchWeightSkippedSample[] = skippedRows.map((row) => ({
   114	    itemId: row.item_id,
   115	    siteId: row.site_id,
   116	    reason: row.skip_reason,
   117	  }));
   118	
   119	  const { rows: agg } = await client.query<{
   120	    item_id: string;
   121	    site_id: string | null;
   122	    samples: string;
   123	    avg_variance_pct: string | null;
   124	    stddev: string | null;
   125	  }>(
   126	    `with weighings as (
   127	       select
   128	         woi.item_id,
   129	         woi.site_id,
   130	         coalesce(woi.nominal_weight, item_row.nominal_weight) as nominal_weight,
   131	         woi.actual_weight as actual_weight
   132	       from public.work_order_items woi
   133	       join public.items item_row on item_row.id = woi.item_id and item_row.org_id = woi.org_id
   134	       where woi.org_id = $1::uuid
   135	         and item_row.weight_mode = 'catch'
   136	         and woi.actual_weight is not null
   137	         and woi.captured_at >= $2::date
   138	         and woi.captured_at <  ($2::date + interval '1 day')
   139	     ),
   140	     scored as (
   141	       select
   142	         weighings.item_id,
   143	         weighings.site_id,
   144	         weighings.actual_weight,
   145	         weighings.nominal_weight,
   146	         abs(weighings.actual_weight - weighings.nominal_weight) / weighings.nominal_weight * 100.0 as variance_pct
   147	       from weighings
   148	       where weighings.nominal_weight is not null and weighings.nominal_weight > 0
   149	     )
   150	     select
   151	       scored.item_id,
   152	       scored.site_id,
   153	       count(*) as samples,
   154	       avg(scored.variance_pct) as avg_variance_pct,
   155	       stddev_samp(scored.variance_pct) as stddev
   156	     from scored
   157	     group by scored.item_id, scored.site_id`,
   158	    [orgId, day],
   159	  );
   160	
   161	  const rows: CatchWeightVarianceRow[] = [];
   162	  let alertsEmitted = 0;
   163	
   164	  for (const r of agg) {
   165	    const samples = Number.parseInt(r.samples, 10);
   166	    if (!Number.isFinite(samples) || samples <= 0) continue;
   167	
   168	    const avgVariancePct = r.avg_variance_pct === null ? 0 : Number(r.avg_variance_pct);
   169	    const stddev = r.stddev === null ? null : Number(r.stddev);
   170	    const alerted = avgVariancePct > thresholdPct;
   171	
   172	    await client.query(
   173	      `insert into public.catch_weight_variance_daily
   174	         (org_id, site_id, item_id, day, avg_variance_pct, stddev, samples, threshold_pct, alerted)
   175	       values ($1::uuid, $2::uuid, $3::uuid, $4::date, $5::numeric, $6::numeric, $7::int, $8::numeric, $9::boolean)
   176	       on conflict (org_id, item_id, site_id, day) do update set
   177	         avg_variance_pct = excluded.avg_variance_pct,
   178	         stddev           = excluded.stddev,
   179	         samples          = excluded.samples,
   180	         threshold_pct    = excluded.threshold_pct,
   181	         alerted          = excluded.alerted,
   182	         computed_at      = pg_catalog.now()`,
   183	      [orgId, r.site_id, r.item_id, day, avgVariancePct, stddev, samples, thresholdPct, alerted],
   184	    );
   185	
   186	    if (alerted) {
   187	      await client.query(
   188	        `insert into public.outbox_events
   189	           (org_id, event_type, aggregate_type, aggregate_id, payload, app_version)
   190	         values ($1::uuid, $2, $3, $4, $5::jsonb, $6)`,
   191	        [
   192	          orgId,
   193	          CATCH_WEIGHT_VARIANCE_EVENT,
   194	          'catch_weight_variance',
   195	          r.item_id,
   196	          JSON.stringify({
   197	            item_id: r.item_id,
   198	            site_id: r.site_id,
   199	            day,
   200	            avg_variance_pct: avgVariancePct,
   201	            threshold_pct: thresholdPct,
   202	            samples,
   203	          }),
   204	          CATCH_WEIGHT_VARIANCE_APP_VERSION,
   205	        ],
   206	      );
   207	      alertsEmitted += 1;
   208	    }
   209	
   210	    rows.push({
     1	-- ============================================================================
     2	-- 477 — catch_weight_variance_daily per-site roll-up key (Wave 14 / N-62)
     3	--
     4	-- LOUDLY: this migration AUTO-APPLIES on Vercel via @monopilot/db migrate BEFORE build.
     5	-- Safe additive change: swaps unique key from (org,item,day) → (org,item,site,day).
     6	-- Existing blended rows (min(site_id) pin) are superseded on the next cron run;
     7	-- no manual backfill required — row count is typically low (nightly roll-ups only).
     8	-- ============================================================================
     9	
    10	drop index if exists public.catch_weight_variance_daily_org_item_day_uq;
    11	
    12	create unique index if not exists catch_weight_variance_daily_org_item_site_day_uq
    13	  on public.catch_weight_variance_daily (org_id, item_id, site_id, day) nulls not distinct;
    14	
    15	comment on index public.catch_weight_variance_daily_org_item_site_day_uq is
    16	  'Wave 14 N-62: one variance roll-up per org/item/site/day (NULL site_id treated as one bucket).';
