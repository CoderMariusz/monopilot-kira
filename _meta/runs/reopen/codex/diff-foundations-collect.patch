+async function seedOrgs(adminPool: pg.Pool): Promise<void> {
+  await adminPool.query(
+    `insert into public.tenants (id, name, region_cluster, data_plane_url)
+     values ($1, 'T-shipping Tenant', 'eu', 'https://t-shipping.example.test')
