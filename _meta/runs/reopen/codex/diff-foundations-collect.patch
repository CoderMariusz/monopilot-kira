+-- Backfill every existing org.
+do $$
+declare
+  v_org_id uuid;
+begin
+  for v_org_id in select id from public.organizations loop
+    perform public.seed_warehouse_waveb_permissions_for_org(v_org_id);
+  end loop;
+end
+$$;
