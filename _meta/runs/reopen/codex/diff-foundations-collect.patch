+// ===========================================================================
+// d365_finance_dlq — dead-letter queue for permanent D365 export failures (T-027, FIN §6.4).
+//   Permanent-error replay is admin-only (V-FIN-INT-05). Export-only (R15).
+// ===========================================================================
+export const d365FinanceDlq = pgTable(
