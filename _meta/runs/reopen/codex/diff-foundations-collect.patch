+// ---------------------------------------------------------------------------
+// customers — customer master (T-001, §9.1).
+// ---------------------------------------------------------------------------
+export const customers = pgTable(
+  'customers',
+  {
+    id: uuid('id').defaultRandom().primaryKey(),
