+  it('AC8 — cross-org isolation: org B cannot see org A customers/SO under app_user RLS', async () => {
+    const custA = await insertCustomer(adminPool, orgAId, 'C-ISO');
+    const soA = await insertSo(adminPool, orgAId, custA);
+
