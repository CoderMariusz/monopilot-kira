+// ---------------------------------------------------------------------------
+// quality_holds — central hold registry (T-004, §6.3).
+// ---------------------------------------------------------------------------
+export const qualityHolds = pgTable(
+  'quality_holds',
+  {
+    id: uuid('id').defaultRandom().primaryKey(),
