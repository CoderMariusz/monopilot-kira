FILE apps/web/app/(npd)/pipeline/[projectId]/formulation/_actions/compare-versions.ts
     1	'use server';
     2	
     3	/**
     4	 * T-065 — `compareVersions` Server Action (01-NPD-g, PRD §17.11.1).
     5	 *
     6	 * Loads the ingredient lists for two formulation versions (org-scoped via
     7	 * `withOrgContext` → RLS enforced as `app_user` with `app.current_org_id()`)
     8	 * and returns a side-by-side diff (up to 50 rows × 2 versions) flagging
     9	 * ADDED / REMOVED / CHANGED / UNCHANGED per row. READ-ONLY — no writes.
    10	 *
    11	 * The diff math itself is the pure `compareFormulationVersions` helper in
    12	 * `@monopilot/domain` (deterministic, unit-tested without a DB). This action
    13	 * only does the org-scoped reads + zod validation + shaping.
    14	 */
    15	
    16	import { z } from 'zod';
    17	import {
    18	  compareFormulationVersions,
    19	  MAX_COMPARE_ROWS,
    20	  type CompareIngredient,
    21	  type CompareResult,
    22	} from '@monopilot/domain';
    23	
    24	import { withOrgContext } from '../../../../../../lib/auth/with-org-context';
    25	
    26	const InputSchema = z.object({
    27	  projectId: z.string().min(1),
    28	  versionAId: z.string().min(1),
    29	  versionBId: z.string().min(1),
    30	});
    31	
    32	export type CompareVersionsInput = z.infer<typeof InputSchema>;
    33	
    34	interface IngredientRow {
    35	  sequence: number;
    36	  rm_code: string;
    37	  pct: string | null;
    38	  qty_kg: string | null;
    39	  cost_per_kg_eur: string | null;
    40	}
    41	
    42	interface VersionExistsRow {
    43	  id: string;
    44	}
    45	
    46	export async function compareVersions(rawInput: CompareVersionsInput): Promise<CompareResult> {
    47	  const input = InputSchema.parse(rawInput);
    48	
    49	  return withOrgContext(async ({ client }) => {
    50	    // ── existence check: BOTH versions must belong to the org's project ──────
    51	    // A missing or wrong-project version must be a not-found error, NOT a
    52	    // silently-empty formulation (which would mis-render every row as ADDED /
    53	    // REMOVED). RLS already scopes to the org; the formulations.project_id join
