   154	export async function getHandoff(raw: unknown): Promise<GetHandoffResult> {
   155	  const parsed = Input.safeParse(raw);
   156	  if (!parsed.success) {
   157	    return { ok: false, error: 'invalid_input', message: parsed.error.message };
   158	  }
   159	  const { projectId } = parsed.data;
   160	
   161	  try {
   162	    return await withOrgContext(async (rawCtx) => {
   163	      const ctx = rawCtx as { userId: string; orgId: string; client: QueryClient };
   164	
   165	      if (!(await hasHandoffPermission(ctx, READ_PERMISSION))) {
   166	        return { ok: false as const, error: 'forbidden' as const };
   167	      }
   168	
   169	      const checklistRes = await ctx.client.query<ChecklistRow>(
   170	        // NB: qualify EVERY select-list column with `hc.` — handoff_checklists and
   171	        // bom_headers share columns (id, created_at, notes, org_id, updated_at), so a
   172	        // bare `id`/`org_id` here is `42702: column reference "id" is ambiguous`. This is
   173	        // a PLAN-time error (fires for any project, even zero rows), which is why the
   174	        // handoff tab dead-ended ("Unable to load…") for every at/past-handoff project.
   175	        `select hc.id,
   176	                hc.bom_verification_status,
   177	                hc.destination_bom_code,
   178	                case
   179	                  when hc.destination_bom_code ~* '^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'
   180	                    then coalesce(bh.fa_code, bh.product_id) || ' v' || bh.version::text
   181	                  else hc.destination_bom_code
   182	                end as destination_bom_display_code,
   183	                hc.promote_to_production_date::text as promote_to_production_date,
   184	                hc.destination_warehouse_id
   185	           from public.handoff_checklists hc
   186	           left join public.bom_headers bh
   187	             on bh.org_id = hc.org_id
   188	            and hc.destination_bom_code ~* '^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'
   189	            and bh.id = hc.destination_bom_code::uuid
   190	          where hc.project_id = $1::uuid
   191	            and hc.org_id = app.current_org_id()
   192	          limit 1`,
   193	        [projectId],
   194	      );
   195	      let checklist = checklistRes.rows[0];
   196	      if (!checklist) {
   197	        // Self-heal (live deadlock 2026-06-10): projects that ENTERED handoff before
   198	        // the advance-transition started seeding the checklist have no row and the
   199	        // stage was a button-less dead end. Seed it here for at/past-handoff projects;
   200	        // pre-handoff stages legitimately have none.
   201	        const stageRes = await ctx.client.query<{ current_stage: string }>(
   202	          `select current_stage
   203	             from public.npd_projects
   204	            where id = $1::uuid
   205	              and org_id = app.current_org_id()
   206	            limit 1`,
   207	          [projectId],
   208	        );
   209	        const stage = stageRes.rows[0]?.current_stage;
   210	        if (stage !== 'handoff' && stage !== 'launched') {
   211	          return { ok: false as const, error: 'not_found' as const };
   212	        }
   213	        await seedHandoffChecklist(
   214	          ctx as Parameters<typeof seedHandoffChecklist>[0],
   215	          { id: projectId },
   216	        );
   217	        const reread = await ctx.client.query<ChecklistRow>(
   218	          // Qualify select-list columns with `hc.` (see note on the first query above):
   219	          // bare `id`/`org_id` are ambiguous against the joined bom_headers (42702).
   220	          `select hc.id,
   221	                  hc.bom_verification_status,
   222	                  hc.destination_bom_code,
   223	                  case
   224	                    when hc.destination_bom_code ~* '^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'
   225	                      then coalesce(bh.fa_code, bh.product_id) || ' v' || bh.version::text
   226	                    else hc.destination_bom_code
   227	                  end as destination_bom_display_code,
   228	                  hc.promote_to_production_date::text as promote_to_production_date,
   229	                  hc.destination_warehouse_id
   230	             from public.handoff_checklists hc
   231	             left join public.bom_headers bh
   232	               on bh.org_id = hc.org_id
   233	              and hc.destination_bom_code ~* '^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'
   234	              and bh.id = hc.destination_bom_code::uuid
   235	            where hc.project_id = $1::uuid
   236	              and hc.org_id = app.current_org_id()
   237	            limit 1`,
   238	          [projectId],
   239	        );
   240	        checklist = reread.rows[0];
   241	        if (!checklist) {
   242	          return { ok: false as const, error: 'not_found' as const };
   243	        }
   244	      }
   245	
   246	      const itemsRes = await ctx.client.query<ItemRow>(
   247	        `select id, label, is_checked, display_order
   248	           from public.handoff_checklist_items
   249	          where handoff_checklist_id = $1::uuid
   250	            and org_id = app.current_org_id()
   251	          order by display_order asc, label asc`,
   252	        [checklist.id],
   253	      );
   254	
   255	      const projectRes = await ctx.client.query<ProjectRow>(
   256	        `select np.product_code,
   257	                p.product_name,
   258	                p.private_jsonb ->> 'npd_locked_for_release_at' as npd_locked_for_release_at
   259	           from public.npd_projects np
   260	           left join public.product p
   261	             on p.product_code = np.product_code
   262	            and p.org_id = np.org_id
   263	          where np.id = $1::uuid
   264	            and np.org_id = app.current_org_id()
   265	          limit 1`,
   266	        [projectId],
   267	      );
   268	      const project = projectRes.rows[0] ?? {
   269	        product_code: null,
   270	        product_name: null,
   271	        npd_locked_for_release_at: null,
   272	      };
   273	
   274	      let warehouseName: string | null = null;
   275	      if (checklist.destination_warehouse_id) {
   276	        const whRes = await ctx.client.query<WarehouseRow>(
   277	          `select name
   278	             from public.warehouses
   279	            where id = $1::uuid
   280	              and org_id = app.current_org_id()
   281	            limit 1`,
   282	          [checklist.destination_warehouse_id],
   283	        );
   284	        warehouseName = whRes.rows[0]?.name ?? null;
   285	      }
   286	
   287	      const releaseRes = await ctx.client.query<ReleaseRow>(
   288	        `select frs.release_status,
   289	                frs.active_bom_header_id,
   290	                case
   291	                  when bh.id is null then null
   292	                  else coalesce(bh.fa_code, bh.product_id) || ' v' || bh.version::text
   293	                end as bom_display_code
   294	           from public.factory_release_status frs
   295	           left join public.bom_headers bh
   296	             on bh.id = frs.active_bom_header_id
   297	            and bh.org_id = frs.org_id
   298	          where frs.project_id = $1::uuid
   299	            and frs.org_id = app.current_org_id()
   300	          limit 1`,
   301	        [projectId],
   302	      );
   303	      const release = releaseRes.rows[0] ?? null;
   304	
   305	      // Read-only release-gate probe — surfaces WHY Promote is blocked. Never
   306	      // throws (probe returns all-unmet for a missing project), so a probe
   307	      // failure can never turn the screen into a dead end.
   308	      const releaseGates = await probeReleaseGates(ctx, projectId);
   309	      const releaseGatesMet = releaseGates.length > 0 && releaseGates.every((g) => g.met);
   310	
   311	      const items = itemsRes.rows.map((r) => ({
   312	        id: r.id,
   313	        label: r.label,
   314	        isChecked: r.is_checked,
   315	        displayOrder: r.display_order,
   316	      }));
   317	      const ready = items.length > 0 && items.every((i) => i.isChecked);
   318	      const promoted =
   319	        release?.release_status === 'released_to_factory' ||
   320	        checklist.promote_to_production_date !== null;
   321	      // Mirror revertToNpd releaseLocked — drives Revert-to-NPD visibility (C7a wedge).
   322	      const releaseLocked =
   323	        project.npd_locked_for_release_at !== null ||
   324	        checklist.bom_verification_status === 'promoted' ||
   325	        checklist.promote_to_production_date !== null ||
   326	        release?.release_status === 'released_to_factory';
   327	      const canRevertToNpd = await hasHandoffPermission(ctx, GATE_APPROVE_PERMISSION);
   328	
   329	      return {
   330	        ok: true as const,
   331	        data: {
   332	          checklistId: checklist.id,
   333	          projectId,
   334	          bomVerificationStatus: checklist.bom_verification_status,
   335	          promoteToProductionDate: checklist.promote_to_production_date,
   336	          ready,
   337	          promoted,
   338	          releaseLocked,
   339	          canRevertToNpd,
   340	          checklist: items,
   341	          releaseGates,
   342	          releaseGatesMet,
   343	          destinationBom: {
   344	            // Fallback resolves bom_headers to a HUMAN-READABLE identity (fa_code /
   345	            // product code + version) — never the raw active_bom_header_id uuid.
   346	            // When neither exists the screen renders its notSet em-dash.
   347	            bomCode: checklist.destination_bom_display_code ?? checklist.destination_bom_code ?? release?.bom_display_code ?? null,
   348	            productSku: project.product_code,
   349	            productName: project.product_name,
   350	            effectiveFrom: checklist.promote_to_production_date,
   351	            warehouseName,
   352	            releaseStatus: release?.release_status ?? null,
   353	            releaseBomHeaderId: release?.active_bom_header_id ?? null,
   354	          },
   355	        },
   356	      };
   357	    });
   358	  } catch (error) {
   359	    // Surface the STRUCTURED pg error (code/detail/where) so a future failure of this
   360	    // class (e.g. 42702 ambiguous column, 42P01 missing relation, 22P02 bad cast) is
   361	    // root-causable from the logs instead of being flattened to a generic message.
   362	    const pg = error as { code?: string; detail?: string; hint?: string; where?: string };
   363	    console.error('[getHandoff] org-scoped read failed:', {
   364	      projectId,
   365	      code: pg.code,
   366	      detail: pg.detail,
   367	      hint: pg.hint,
   368	      where: pg.where,
   369	      message: error instanceof Error ? error.message : String(error),
   370	    });
   371	    return { ok: false, error: 'persistence_failed' };
   372	  }
   373	}
FILE apps/web/app/[locale]/(app)/(npd)/pipeline/[projectId]/handoff/_actions/promote-to-production.ts
     1	'use server';
     2	
     3	/**
     4	 * NPD HANDOFF stage — `promoteToProduction` Server Action.
     5	 *
     6	 * The "✓ Promote to production BOM" footer button. Gate = `npd.handoff.promote`
     7	 * (BYTE-IDENTICAL to the seeded permission string in migration 236).
     8	 *
     9	 * Order of operations (all inside ONE org-scoped transaction so any failure
    10	 * rolls back atomically):
    11	 *   1. RBAC — npd.handoff.promote (else `forbidden`).
    12	 *   2. Load the project's handoff checklist + items (else `not_found`).
    13	 *   3. Gate: the checklist must be COMPLETE (≥1 item, every item checked) — else
    14	 *      `checklist_incomplete`. The screen also disables the button, but the
    15	 *      server is the source of truth and never trusts the client.
    16	 *   4. REUSE the existing factory-release flow (T-096
    17	 *      `releaseNpdProjectToFactory`) — this is the real initial-BOM / factory
    18	 *      release path. We do NOT author a new BOM-creation path here. Its own
    19	 *      preflight (G4, FG candidate, active shared BOM, factory-spec) and its own
    20	 *      RBAC (`npd.gate.approve`) still apply; a release blocker surfaces as
    21	 *      `release_blocked` and a release-RBAC failure as `forbidden`.
    22	 *   5. Record the handoff as promoted: set promote_to_production_date = today,
    23	 *      bom_verification_status = 'promoted', stamp the destination_bom_code from
    24	 *      the release result when present, + an append-only audit_events row.
    25	 *
    26	 * If the release flow reports it is not callable (e.g. preflight blockers), we do
    27	 * NOT fake a BOM — we surface `release_blocked` honestly and leave the handoff
    28	 * un-promoted.
    29	 */
    30	
    31	import { z } from 'zod';
    32	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    33	import { releaseNpdProjectToFactory } from '../../../../../../../(npd)/builder/_actions/release-npd-project-to-factory';
    34	import { hasHandoffPermission } from './get-handoff';
    35	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
    36	
    37	const Input = z.object({
    38	  projectId: z.string().uuid(),
    39	});
    40	
    41	export type PromoteToProductionInput = z.infer<typeof Input>;
    42	
    43	export type PromoteToProductionError =
    44	  | 'invalid_input'
    45	  | 'forbidden'
    46	  | 'not_found'
    47	  | 'launched_is_terminal'
    48	  | 'checklist_incomplete'
    49	  | 'release_blocked'
    50	  | 'persistence_failed';
    51	
    52	export type PromoteToProductionResult =
