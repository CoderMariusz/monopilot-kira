   361	/** Postgres SQLSTATE for "undefined_table" (relation does not exist). */
   362	const PG_UNDEFINED_TABLE = '42P01';
   363	
   364	/**
   365	 * F8 — load the org's canonical allergen code list from Reference."Allergens"
   366	 * (EU-14 seed + org-custom rows, mig 082). Returns null when the reference
   367	 * table is not provisioned (42P01) — the caller then skips validation rather
   368	 * than dropping every carried code blind.
   369	 */
   370	async function loadCanonicalAllergenCodes(client: {
   371	  query<T = Record<string, unknown>>(sql: string, params?: readonly unknown[]): Promise<{ rows: T[] }>;
   372	}): Promise<Set<string> | null> {
   373	  try {
   374	    const { rows } = await client.query<{ allergen_code: string }>(
   375	      `select allergen_code
   376	         from "Reference"."Allergens"
   377	        where org_id = app.current_org_id()`,
   378	    );
   379	    return new Set(rows.map((row) => row.allergen_code));
   380	  } catch (error) {
   381	    if ((error as { code?: string })?.code === PG_UNDEFINED_TABLE) return null;
   382	    throw error;
   383	  }
   384	}
   385	
   386	function parseIngredients(value: unknown): IngredientInput[] | null {
   387	  if (!Array.isArray(value)) return null;
   388	  const seen = new Set<number>();
   389	  const parsed = value.map(parseIngredient);
   390	  if (parsed.some((item) => item === null)) return null;
   391	  for (const item of parsed) {
   392	    if (!item || seen.has(item.sequence)) return null;
   393	    seen.add(item.sequence);
   394	  }
   395	  return parsed as IngredientInput[];
   396	}
   397	
   398	function parseIngredient(value: unknown): IngredientInput | null {
   399	  if (!value || typeof value !== 'object' || Array.isArray(value)) return null;
   400	  const candidate = value as Record<string, unknown>;
   401	  const rmCode = normalizeRmCode(candidate.rmCode);
   402	  const itemId = normalizeUuidOrNull(candidate.itemId);
   403	  const wipDefinitionId = normalizeUuidOrNull(candidate.wipDefinitionId);
   404	  const substituteItemId = normalizeUuidOrNull(candidate.substituteItemId);
   405	  const qtyKg = normalizeNumeric(candidate.qtyKg);
   406	  const costPerKgEur = normalizeNumeric(candidate.costPerKgEur);
   407	  const costCurrency = normalizeOptionalText(candidate.costCurrency);
   408	  const sequence = candidate.sequence;
   409	  const allergensInherited = parseTextArray(candidate.allergensInherited);
   410	  if (!rmCode || itemId === undefined || wipDefinitionId === undefined || substituteItemId === undefined || qtyKg === undefined || costPerKgEur === undefined) {
   411	    return null;
   412	  }
   413	  if (typeof sequence !== 'number' || !Number.isInteger(sequence) || sequence < 1) return null;
   414	  if (!allergensInherited) return null;
   415	  return { rmCode, itemId, wipDefinitionId, substituteItemId, qtyKg, costPerKgEur, costCurrency, sequence, allergensInherited };
   416	}
   417	
   418	function normalizeRmCode(value: unknown): string | null {
   419	  if (typeof value !== 'string') return null;
   420	  const trimmed = value.trim();
   421	  return trimmed.length > 0 && trimmed.length <= 80 ? trimmed : null;
   422	}
   423	
   424	/** Lane-B: optional uuid → string | null (valid/absent) or undefined (malformed → reject). */
   425	function normalizeUuidOrNull(value: unknown): string | null | undefined {
   426	  if (value === null || value === undefined || value === '') return null;
   427	  if (typeof value !== 'string') return undefined;
   428	  return parseUuid(value) ?? undefined;
   429	}
   430	
   431	function normalizeNumeric(value: unknown): string | null | undefined {
   432	  if (value === null || value === undefined || value === '') return null;
   433	  if (typeof value !== 'string' && typeof value !== 'number') return undefined;
   434	  const text = String(value).trim();
   435	  if (!/^\d+(?:\.\d+)?$/.test(text)) return undefined;
   436	  return text;
   437	}
   438	
   439	function normalizeOptionalText(value: unknown): string | null {
   440	  if (value === null || value === undefined || value === '') return null;
   441	  if (typeof value !== 'string') return null;
   442	  const trimmed = value.trim();
   443	  return trimmed.length > 0 && trimmed.length <= 32 ? trimmed : null;
   444	}
   445	
   446	function normalizeNumericPct(value: unknown): string | null | undefined {
   447	  const normalized = normalizeNumeric(value);
   448	  if (normalized === null || normalized === undefined) return normalized;
   449	  const asNumber = Number(normalized);
   450	  if (!Number.isFinite(asNumber) || asNumber < 0 || asNumber > 100) return undefined;
   451	  return normalized;
   452	}
   453	
   454	function normalizePositiveNumeric(value: unknown): string | null | undefined {
   455	  const normalized = normalizeNumeric(value);
   456	  if (normalized === null || normalized === undefined) return normalized;
   457	  const asNumber = Number(normalized);
   458	  if (!Number.isFinite(asNumber) || asNumber <= 0) return undefined;
   459	  return normalized;
   460	}
   461	
   462	function parseTextArray(value: unknown): string[] | null {
   463	  if (value === undefined) return [];
   464	  if (!Array.isArray(value)) return null;
   465	  return value.every((item) => typeof item === 'string' && item.trim().length <= 80)
   466	    ? value.map((item) => item.trim()).filter(Boolean)
   467	    : null;
   468	}
   469	
   470	function parseUuid(value: unknown): string | null {
   471	  return typeof value === 'string' &&
   472	    /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(value)
   473	    ? value
   474	    : null;
   475	}
