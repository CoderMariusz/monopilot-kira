     1	'use server';
     2	
     3	import { withOrgContext } from '../../../../../../lib/auth/with-org-context';
     4	
     5	import type {
     6	  RecipeCascadeNode,
     7	  RecipeCascadeSubLine,
     8	  RecipeCascadeSubRecipe,
     9	} from './load-recipe-cascade.types';
    10	
    11	type QueryClient = {
    12	  query<T = Record<string, unknown>>(sql: string, params?: readonly unknown[]): Promise<{ rows: T[] }>;
    13	};
    14	
    15	type IngredientLineRow = {
    16	  ingredient_line_id: string;
    17	  item_code: string | null;
    18	  item_name: string | null;
    19	};
    20	
    21	type RecipeVersionRow = {
    22	  version_id: string;
    23	};
    24	
    25	type RecipeComponentRow = {
    26	  item_code: string | null;
    27	  item_name: string | null;
    28	  pct: string | null;
    29	  qty_kg: string | null;
    30	  unit_cost: string | null;
    31	  nutrition_per_100g: Record<string, unknown> | null;
    32	};
    33	
    34	const MAX_DEPTH = 3;
    35	const PG_UNDEFINED_TABLE = '42P01';
    36	
    37	export async function loadRecipeCascade(
    38	  projectId: string,
    39	  formulationVersionId: string,
    40	): Promise<RecipeCascadeNode[]> {
    41	  if (!parseUuid(projectId) || !parseUuid(formulationVersionId)) return [];
    42	
    43	  try {
    44	    return await withOrgContext(async ({ client }) => {
    45	      const ingredients = await client.query<IngredientLineRow>(
    46	        `select fi.id::text as ingredient_line_id,
    47	                i.item_code,
    48	                i.name as item_name
    49	           from public.formulations f
    50	           join public.formulation_versions fv
    51	             on fv.formulation_id = f.id
    52	            and fv.id = $2::uuid
    53	           join public.formulation_ingredients fi
    54	             on fi.version_id = fv.id
    55	           left join public.items i
    56	             on i.id = fi.item_id
    57	            and i.org_id = app.current_org_id()
    58	          where f.project_id = $1::uuid
    59	            and f.org_id = app.current_org_id()
    60	          order by fi.sequence`,
    61	        [projectId, formulationVersionId],
    62	      );
    63	
    64	      const nodes: RecipeCascadeNode[] = [];
    65	      for (const ingredient of ingredients.rows) {
    66	        const itemCode = ingredient.item_code ?? '';
    67	        const itemName = ingredient.item_name ?? itemCode;
    68	        const subRecipe = itemCode
    69	          ? await loadSubRecipe(client, itemCode, 1, new Set([itemCode]))
    70	          : undefined;
    71	        nodes.push({
    72	          ingredientLineId: ingredient.ingredient_line_id,
    73	          itemCode,
    74	          itemName,
    75	          hasSubRecipe: Boolean(subRecipe),
    76	          ...(subRecipe ? { subRecipe } : {}),
    77	        });
    78	      }
    79	      return nodes;
    80	    });
    81	  } catch {
    82	    return [];
    83	  }
    84	}
    85	
    86	async function loadSubRecipe(
    87	  client: QueryClient,
    88	  itemCode: string,
    89	  depth: number,
    90	  visited: Set<string>,
    91	): Promise<RecipeCascadeSubRecipe | undefined> {
    92	  const version = await findActiveRecipeVersion(client, itemCode);
    93	  if (!version) return undefined;
    94	  if (depth >= MAX_DEPTH) {
    95	    return { lines: [], totalCost: 0, maxDepthReached: true };
    96	  }
    97	
    98	  const components = await loadRecipeComponents(client, version.version_id);
    99	  const lines: RecipeCascadeSubLine[] = [];
   100	  let totalCost = 0;
   101	
   102	  for (const component of components.rows) {
   103	    const componentCode = component.item_code ?? '';
   104	    const pct = toNumber(component.pct);
   105	    const unitCost = toNumber(component.unit_cost);
   106	    const qtyKg = toNumber(component.qty_kg);
   107	    totalCost += unitCost * qtyKg;
   108	
   109	    const nutritionPer100g = normalizeNutrition(component.nutrition_per_100g);
   110	    const line: RecipeCascadeSubLine = {
   111	      itemCode: componentCode,
   112	      itemName: component.item_name ?? componentCode,
   113	      pct,
   114	      unitCost,
   115	      ...(nutritionPer100g ? { nutritionPer100g } : {}),
   116	    };
   117	
   118	    if (componentCode) {
   119	      if (visited.has(componentCode)) {
   120	        line.hasSubRecipe = true;
   121	        line.subRecipe = { lines: [], totalCost: 0, cycle: true };
   122	      } else {
   123	        const nextVisited = new Set(visited);
   124	        nextVisited.add(componentCode);
   125	        const child = await loadSubRecipe(client, componentCode, depth + 1, nextVisited);
   126	        if (child) {
   127	          line.hasSubRecipe = true;
   128	          line.subRecipe = child;
   129	        }
   130	      }
   131	    }
   132	
   133	    lines.push(line);
   134	  }
   135	
   136	  return { lines, totalCost };
   137	}
   138	
   139	async function findActiveRecipeVersion(client: QueryClient, itemCode: string): Promise<RecipeVersionRow | null> {
   140	  const result = await client.query<RecipeVersionRow>(
   141	    `select fv.id::text as version_id
   142	       from public.formulations f
   143	       join public.formulation_versions fv
   144	         on fv.formulation_id = f.id
   145	      where f.org_id = app.current_org_id()
   146	        and f.product_code = $1::text
   147	        and fv.state in ('locked', 'active')
   148	      order by (fv.id = f.current_version_id) desc,
   149	               fv.version_number desc
   150	      limit 1`,
   151	    [itemCode],
   152	  );
   153	  return result.rows[0] ?? null;
   154	}
   155	
   156	async function loadRecipeComponents(client: QueryClient, versionId: string): Promise<{ rows: RecipeComponentRow[] }> {
   157	  try {
   158	    return await client.query<RecipeComponentRow>(
   159	      `select coalesce(i.item_code, fi.rm_code) as item_code,
   160	              coalesce(i.name, fi.rm_code) as item_name,
   161	              fi.pct::text,
   162	              fi.qty_kg::text,
   163	              vec.amount::text as unit_cost,
   164	              rm.nutrition_per_100g
   165	         from public.formulation_ingredients fi
   166	         left join public.items i
   167	           on i.id = fi.item_id
   168	          and i.org_id = app.current_org_id()
   169	         left join public.v_item_effective_cost vec
   170	           on vec.item_id = i.id
   171	          and vec.org_id = app.current_org_id()
   172	         left join "Reference"."RawMaterials" rm
   173	           on rm.org_id = app.current_org_id()
   174	          and rm.rm_code = coalesce(i.item_code, fi.rm_code)
   175	        where fi.version_id = $1::uuid
   176	        order by fi.sequence`,
   177	      [versionId],
   178	    );
   179	  } catch (err) {
   180	    if ((err as { code?: string })?.code !== PG_UNDEFINED_TABLE) throw err;
   181	    return await client.query<RecipeComponentRow>(
   182	      `select coalesce(i.item_code, fi.rm_code) as item_code,
   183	              coalesce(i.name, fi.rm_code) as item_name,
   184	              fi.pct::text,
   185	              fi.qty_kg::text,
   186	              vec.amount::text as unit_cost,
   187	              null::jsonb as nutrition_per_100g
   188	         from public.formulation_ingredients fi
   189	         left join public.items i
   190	           on i.id = fi.item_id
   191	          and i.org_id = app.current_org_id()
   192	         left join public.v_item_effective_cost vec
   193	           on vec.item_id = i.id
   194	          and vec.org_id = app.current_org_id()
   195	        where fi.version_id = $1::uuid
   196	        order by fi.sequence`,
   197	      [versionId],
   198	    );
   199	  }
   200	}
   201	
   202	function normalizeNutrition(src: Record<string, unknown> | null): Record<string, number> | undefined {
   203	  if (!src) return undefined;
   204	  const out: Record<string, number> = {};
   205	  for (const [key, value] of Object.entries(src)) {
   206	    const numeric = typeof value === 'number' ? value : Number(value);
   207	    if (Number.isFinite(numeric)) out[key] = numeric;
   208	  }
   209	  return Object.keys(out).length > 0 ? out : undefined;
   210	}
   211	
   212	function toNumber(value: string | null): number {
   213	  if (!value) return 0;
   214	  const numeric = Number(value);
   215	  return Number.isFinite(numeric) ? numeric : 0;
   216	}
