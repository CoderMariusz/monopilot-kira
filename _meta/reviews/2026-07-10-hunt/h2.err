     7	  project_id: string;
     8	  product_code: string | null;
     9	  locked_at: string | null;
    10	  locked_by_user: string | null;
    11	  version_id: string | null;
    12	  version_number: number | null;
    13	  state: string | null;
    14	  batch_size_kg: string | null;
    15	  target_yield_pct: string | null;
    16	  target_price_eur: string | null;
    17	  processing_overhead_pct: string | null;
    18	  cost_json: unknown | null;
    19	  nutrition_json: unknown | null;
    20	  allergen_json: unknown | null;
    21	  computed_at: string | null;
    22	};
    23	
    24	type IngredientRow = {
    25	  id: string;
    26	  rm_code: string;
    27	  /** Lane-B: FK to the real items master row (null for legacy free text). */
    28	  item_id: string | null;
    29	  /** W3-L10: reusable WIP definition referenced by this recipe line (null for RM rows). */
    30	  wip_definition_id: string | null;
    31	  /** W3-L10: display name from the joined wip_definitions row. */
    32	  wip_definition_name: string | null;
    33	  /** Lane-B: display name from the joined items row (empty when no item). */
    34	  item_name: string | null;
    35	  /** F6-D17: optional substitute item for this component line. */
    36	  substitute_item_id: string | null;
    37	  substitute_item_code: string | null;
    38	  substitute_item_name: string | null;
    39	  npd_wip_process_id: string | null;
    40	  qty_kg: string | null;
    41	  pct: string | null;
    42	  cost_per_kg_eur: string | null;
