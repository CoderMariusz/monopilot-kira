   275	         min(coalesce(dc.display_order, 0)),
   276	         true
   277	    from "Reference"."DeptColumns" dc
   278	   where dc.org_id = v_org
   279	     and dc.dept_code <> 'System'
   280	     and dc.dept_code is not null
   281	     and btrim(dc.dept_code) <> ''
   282	   group by dc.org_id, dc.dept_code
   283	  on conflict (org_id, code) do update
   284	    set name = excluded.name,
   285	        stage_code = excluded.stage_code,
   286	        display_order = excluded.display_order,
   287	        active = true;
   288	
   289	  insert into public.npd_field_catalog (org_id, code, label, data_type, validation_json, help_text, active)
   290	  select distinct on (dc.org_id, dc.column_key)
   291	         dc.org_id,
   292	         dc.column_key,
   293	         replace(initcap(replace(dc.column_key, '_', ' ')), ' Mrp ', ' MRP ') as label,
   294	         case
   295	           when dc.dropdown_source is not null and btrim(dc.dropdown_source) <> '' then 'dropdown'
   296	           when coalesce(dc.data_type, dc.field_type) = 'string'   then 'text'
   297	           when coalesce(dc.data_type, dc.field_type) = 'enum'     then 'dropdown'
   298	           when coalesce(dc.data_type, dc.field_type) = 'integer'  then 'integer'
   299	           when coalesce(dc.data_type, dc.field_type) = 'datetime' then 'datetime'
   300	           when coalesce(dc.data_type, dc.field_type) = 'boolean'  then 'boolean'
   301	           when coalesce(dc.data_type, dc.field_type) = 'date'     then 'date'
   302	           when coalesce(dc.data_type, dc.field_type) = 'number'   then 'number'
   303	           when coalesce(dc.data_type, dc.field_type) = 'formula'  then 'formula'
   304	           else 'text'
   305	         end as data_type,
   306	         dc.validation_dsl as validation_json,
   307	         null as help_text,
   308	         true as active
   309	    from "Reference"."DeptColumns" dc
   310	   where dc.org_id = v_org
   311	     and dc.dept_code <> 'System'
   312	     and dc.column_key is not null
   313	     and btrim(dc.column_key) <> ''
   314	     and dc.column_key not like 'Done\_%' escape '\'
   315	     and dc.column_key <> 'Benchmark'
   316	     and dc.column_key <> 'Number_of_Cases'
   317	   order by dc.org_id, dc.column_key, coalesce(dc.display_order, 0)
   318	  on conflict (org_id, code) do update
   319	    set label = excluded.label,
   320	        data_type = excluded.data_type,
   321	        validation_json = excluded.validation_json,
   322	        active = true;
   323	
   324	  insert into public.npd_department_field
   325	    (org_id, department_id, field_id, required, visible, display_order)
   326	  select dc.org_id, d.id, f.id, dc.required_for_done, true, coalesce(dc.display_order, 0)
   327	    from "Reference"."DeptColumns" dc
   328	    join public.npd_departments   d on d.org_id = dc.org_id and d.code = dc.dept_code
   329	    join public.npd_field_catalog f on f.org_id = dc.org_id and f.code = dc.column_key
   330	   where dc.org_id = v_org
   331	     and dc.dept_code <> 'System'
   332	     and dc.column_key not like 'Done\_%' escape '\'
   333	     and dc.column_key <> 'Benchmark'
   334	     and dc.column_key <> 'Number_of_Cases'
   335	  on conflict (org_id, department_id, field_id) do update
   336	    set required = excluded.required,
   337	        visible = excluded.visible,
   338	        display_order = excluded.display_order;
   339	
   340	  return new;
   341	end;
