     1	'use server';
     2	
     3	/**
     4	 * NPD HANDOFF — `generateProductionBom` Server Action.
     5	 *
     6	 * Breaks the handoff DEADLOCK: the "Promote to production BOM" button is disabled
     7	 * until the ACTIVE_SHARED_BOM_REQUIRED + FACTORY_SPEC_REQUIRED release gates pass,
     8	 * but those gates were only ever satisfied INSIDE the promote transaction — so the
     9	 * user could never click promote to create the very BOM the button required. This
    10	 * action runs the real BOM-materialization (`materializeNpdBom`) on its own, so the
    11	 * user can GENERATE the production BOM (RM from the locked recipe + packaging PM
    12	 * lines), review/correct it, and only THEN promote.
    13	 *
    14	 * It is idempotent: a later promote re-runs materialize, finds the existing active
    15	 * BOM + factory_spec, and reuses them — so manual corrections to the generated BOM
    16	 * survive. No project archive / release happens here (that is promote's job).
    17	 *
    18	 * Gate = `npd.handoff.promote` (same as the promote button; the materialize itself
    19	 * is org-scoped via app.current_org_id()). NOTE: the production code currently equals
    20	 * the NPD product_code — the FG-002 rename is deferred to the product→items merge.
    21	 */
    22	
    23	import { z } from 'zod';
    24	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    25	import { materializeNpdBom } from '../../../../../../../(npd)/pipeline/_actions/_lib/materialize-npd-bom';
    26	import { materializeNpdRouting } from '../../../../../../../(npd)/pipeline/_actions/_lib/materialize-npd-routing';
    27	import { hasHandoffPermission } from './get-handoff';
    28	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
    29	
    30	const Input = z.object({ projectId: z.string().uuid() });
    31	
    32	export type GenerateProductionBomRoutingWarningCode = 'no_processes' | 'no_line' | 'routing_draft';
    33	
    34	export type GenerateProductionBomRoutingWarning = {
    35	  code: GenerateProductionBomRoutingWarningCode;
    36	};
    37	
    38	export type GenerateProductionBomError =
    39	  | 'invalid_input'
    40	  | 'forbidden'
    41	  | 'no_recipe'
    42	  | 'production_code_conflict'
    43	  | 'packs_per_box_required'
    44	  | 'packaging_unlinked'
    45	  | 'bom_materialization_failed'
    46	  | 'persistence_failed';
    47	
    48	export type GenerateProductionBomResult =
    49	  | {
    50	      ok: true;
    51	      data: {
    52	        productionCode: string | null;
    53	        bomHeaderId: string | null;
    54	        yieldPromptRequired: boolean;
    55	        warnings: GenerateProductionBomRoutingWarning[];
    56	      };
    57	    }
    58	  | {
    59	      ok: false;
    60	      error: GenerateProductionBomError;
    61	      message?: string;
    62	      /** Present when error === 'packaging_unlinked'. */
    63	      unlinkedComponents?: string[];
    64	    };
    65	
    66	const PERMISSION = 'npd.handoff.promote';
    67	
    68	type QueryClient = {
    69	  query<T = Record<string, unknown>>(sql: string, params?: readonly unknown[]): Promise<{ rows: T[] }>;
    70	};
    71	
    72	type PackagingUnlinkedRow = { component_name: string };
    73	
    74	async function findUnlinkedPackagingComponents(client: QueryClient, projectId: string): Promise<string[]> {
    75	  const { rows } = await client.query<PackagingUnlinkedRow>(
    76	    `select component_name
    77	       from public.packaging_components
    78	      where org_id = app.current_org_id()
    79	        and project_id = $1::uuid
    80	        and item_id is null
    81	      order by display_order, component_name`,
    82	    [projectId],
    83	  );
    84	  return rows.map((row) => row.component_name);
    85	}
    86	
    87	type InnerGenerateResult =
    88	  | {
    89	      ok: true;
    90	      productionCode: string | null;
    91	      bomHeaderId: string | null;
    92	      yieldPromptRequired: boolean;
    93	      warnings: GenerateProductionBomRoutingWarning[];
    94	    }
    95	  | {
    96	      ok: false;
    97	      error: GenerateProductionBomError;
    98	      message?: string;
    99	      unlinkedComponents?: string[];
   100	    };
   101	
   102	function packagingUnlinkedFailure(unlinkedComponents: string[]): InnerGenerateResult {
   103	  const names = unlinkedComponents.join(', ');
   104	  return {
   105	    ok: false,
   106	    error: 'packaging_unlinked',
   107	    unlinkedComponents,
   108	    message: `packaging components not linked to items: ${names}`,
   109	  };
   110	}
   111	
   112	export async function generateProductionBom(raw: unknown): Promise<GenerateProductionBomResult> {
   113	  const parsed = Input.safeParse(raw);
   114	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   115	  const { projectId } = parsed.data;
   116	
   117	  try {
   118	    const result = await withOrgContext(async (rawCtx) => {
   119	      const ctx = rawCtx as { userId: string; orgId: string; client: QueryClient };
   120	
   121	      if (!(await hasHandoffPermission(ctx, PERMISSION))) {
   122	        return { ok: false as const, error: 'forbidden' as const };
   123	      }
   124	
   125	      const unlinkedComponents = await findUnlinkedPackagingComponents(ctx.client, projectId);
   126	      if (unlinkedComponents.length > 0) {
   127	        return packagingUnlinkedFailure(unlinkedComponents);
   128	      }
   129	
   130	      const materialized = await materializeNpdBom(ctx, { projectId });
   131	      if (materialized.code === 'PRODUCTION_CODE_CONFLICT') {
   132	        return { ok: false as const, error: 'production_code_conflict' as const };
   133	      }
   134	      if (materialized.code === 'PACKS_PER_BOX_REQUIRED') {
   135	        return { ok: false as const, error: 'packs_per_box_required' as const };
   136	      }
   137	      // No locked formulation / no ingredients ⇒ no BOM could be built.
   138	      if (!materialized.bomHeaderId) {
   139	        return { ok: false as const, error: 'no_recipe' as const };
   140	      }
   141	
   142	      const warnings: GenerateProductionBomRoutingWarning[] = [];
   143	      const routing = await materializeNpdRouting(ctx.client, projectId);
   144	      if (!routing.ok && routing.code !== 'routing_exists') {
   145	        if (routing.code === 'no_processes' || routing.code === 'no_line') {
   146	          warnings.push({ code: routing.code });
   147	        }
   148	      } else if (routing.ok) {
   149	        // L8 MED-1: the materialized routing is a DRAFT — WOs copy operations
   150	        // only from an ACTIVE routing, so tell the user to approve it in
   151	        // Technical instead of leaving a silent dead end.
   152	        warnings.push({ code: 'routing_draft' });
   153	      }
   154	
   155	      return {
   156	        ok: true as const,
   157	        productionCode: materialized.productionCode ?? materialized.productCode,
   158	        bomHeaderId: materialized.bomHeaderId,
   159	        yieldPromptRequired: materialized.yieldPromptRequired,
   160	        warnings,
   161	      };
   162	    });
   163	
   164	    if (!result.ok) return result;
   165	
   166	    safeRevalidatePath(`/[locale]/(app)/(npd)/pipeline/${projectId}/handoff`);
   167	
   168	    return {
   169	      ok: true,
   170	      data: {
   171	        productionCode: result.productionCode,
   172	        bomHeaderId: result.bomHeaderId,
   173	        yieldPromptRequired: result.yieldPromptRequired,
   174	        warnings: result.warnings,
   175	      },
   176	    };
   177	  } catch (error) {
   178	    const message = error instanceof Error ? error.message : String(error);
   179	    if (message.startsWith('Could not generate production BOM header:')) {
   180	      console.error('[generateProductionBom] bom_materialization_failed:', message);
   181	      return { ok: false, error: 'bom_materialization_failed', message };
   182	    }
   183	    console.error('[generateProductionBom] persistence_failed:', error);
   184	    return { ok: false, error: 'persistence_failed' };
   185	  }
   186	}
   187	
   188	function safeRevalidatePath(path: string): void {
   189	  try {
   190	    revalidateLocalized(path, 'page');
   191	  } catch {
   192	    // Vitest imports Server Actions outside a Next request store.
   193	  }
   194	}
