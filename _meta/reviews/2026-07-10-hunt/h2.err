   259	  v_org uuid := new.id;
   260	begin
   261	  insert into public.npd_departments (org_id, code, name, stage_code, display_order, active)
   262	  select dc.org_id,
   263	         dc.dept_code,
   264	         dc.dept_code,
   265	         case lower(dc.dept_code)
   266	           when 'core'        then 'brief'
   267	           when 'planning'    then 'recipe'
   268	           when 'commercial'  then 'approval'
   269	           when 'production'  then 'pilot'
   270	           when 'technical'   then 'recipe'
   271	           when 'mrp'         then 'packaging'
   272	           when 'procurement' then 'packaging'
