    55	    const assertVersionInProject = async (versionId: string): Promise<void> => {
    56	      const res = await client.query<VersionExistsRow>(
    57	        `select fv.id
    58	           from formulation_versions fv
    59	           join formulations f on f.id = fv.formulation_id
