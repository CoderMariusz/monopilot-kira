     1	'use server';
     2	
     3	/**
     4	 * NPD PACKAGING stage — `listPackagingComponents` read Server Action.
     5	 *
     6	 * Org-scoped read of public.packaging_components for a project. Wrapped in
     7	 * withOrgContext (RLS via app.current_org_id() as app_user). RBAC: requires
     8	 * `npd.packaging.read`. cost_per_unit is cast ::text → decimal STRING (never a
     9	 * JS float). Returns the whitelisted read-model only.
    10	 */
    11	
    12	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    13	import {
    14	  ListPackagingComponentsSchema,
    15	  PACKAGING_READ_PERMISSION,
    16	  hasPermission,
    17	  type ListPackagingResult,
    18	  type PackagingComponentRow,
    19	  type PackagingStatus,
    20	  type PackagingTier,
    21	  type QueryClient,
    22	} from './shared';
    23	
    24	type LoaderRow = {
    25	  id: string;
    26	  tier: string;
    27	  component_name: string;
    28	  material: string | null;
    29	  supplier_code: string | null;
    30	  supplier_id: string | null;
    31	  spec: string | null;
    32	  cost_per_unit: string | null;
    33	  /** NUMERIC(5,2) — the pg driver may hand this back as a string; coerced on map. */
    34	  scrap_pct: string | number | null;
    35	  waste_pct: string | number | null;
    36	  qty_per_pack: string | number | null;
    37	  status: string;
    38	  artwork_file_id: string | null;
    39	  artwork_status: string | null;
    40	  display_order: number;
    41	  item_id: string | null;
    42	  item_code: string | null;
    43	};
    44	
    45	export async function listPackagingComponents(raw: unknown): Promise<ListPackagingResult> {
    46	  const parsed = ListPackagingComponentsSchema.safeParse(raw);
    47	  if (!parsed.success) {
    48	    return { ok: false, error: 'invalid_input', message: parsed.error.message };
    49	  }
    50	  const { projectId } = parsed.data;
    51	
    52	  try {
    53	    return await withOrgContext(async ({ userId, orgId, client }) => {
    54	      const queryClient = client as unknown as QueryClient;
    55	
    56	      const canRead = await hasPermission(queryClient, userId, orgId, PACKAGING_READ_PERMISSION);
    57	      if (!canRead) return { ok: false as const, error: 'forbidden' as const };
    58	
    59	      // Confirm the project belongs to this org (RLS already scopes, but a
    60	      // not_found is the correct surface for a foreign/absent project).
    61	      const proj = await queryClient.query<{ id: string }>(
    62	        `select id from public.npd_projects
    63	          where id = $1::uuid and org_id = app.current_org_id() limit 1`,
    64	        [projectId],
    65	      );
    66	      if (proj.rows.length === 0) return { ok: false as const, error: 'not_found' as const };
    67	
    68	      const { rows } = await queryClient.query<LoaderRow>(
    69	        `select pc.id,
    70	                pc.tier,
    71	                pc.component_name,
    72	                pc.material,
    73	                pc.supplier_id::text as supplier_id,
    74	                pc.supplier_code,
    75	                pc.spec,
    76	                pc.cost_per_unit::text as cost_per_unit,
    77	                coalesce(pc.scrap_pct, 0) as scrap_pct,
    78	                coalesce(pc.waste_pct, 0) as waste_pct,
    79	                pc.qty_per_pack,
    80	                pc.status,
    81	                pc.artwork_file_id,
    82	                pc.artwork_status,
    83	                pc.display_order,
    84	                pc.item_id,
    85	                i.item_code
    86	           from public.packaging_components pc
    87	           left join public.items i
    88	             on i.id = pc.item_id
    89	            and i.org_id = pc.org_id
    90	          where pc.org_id = app.current_org_id()
    91	            and pc.project_id = $1::uuid
    92	          order by pc.tier asc, pc.display_order asc, pc.component_name asc`,
    93	        [projectId],
    94	      );
    95	
    96	      const data: PackagingComponentRow[] = rows.map((r) => ({
    97	        id: r.id,
    98	        tier: r.tier as PackagingTier,
    99	        componentName: r.component_name,
   100	        material: r.material,
   101	        supplierId: r.supplier_id,
   102	        supplierCode: r.supplier_code,
   103	        spec: r.spec,
   104	        costPerUnit: r.cost_per_unit,
   105	        scrapPct: Number(r.scrap_pct ?? 0),
   106	        wastePct: Number(r.waste_pct ?? 0),
   107	        qtyPerPack: r.qty_per_pack == null ? null : Number(r.qty_per_pack),
   108	        status: r.status as PackagingStatus,
   109	        artworkFileId: r.artwork_file_id,
   110	        artworkStatus: r.artwork_status,
   111	        displayOrder: r.display_order,
   112	        itemId: r.item_id,
   113	        itemCode: r.item_code,
   114	      }));
   115	
   116	      return { ok: true as const, data };
   117	    });
   118	  } catch (error) {
   119	    console.error('[listPackagingComponents] org-scoped read failed:', error);
   120	    return { ok: false, error: 'persistence_failed' };
   121	  }
   122	}
FILE apps/web/app/[locale]/(app)/(npd)/pipeline/[projectId]/packaging/_actions/update-project-packs-per-case.ts
     1	'use server';
     2	
     3	import { z } from 'zod';
     4	
     5	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
     6	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
     7	import {
     8	  PACKAGING_WRITE_PERMISSION,
     9	  hasPermission,
    10	  type QueryClient,
    11	} from './shared';
    12	
    13	const inputSchema = z.object({
    14	  projectId: z.string().uuid(),
    15	  packsPerCase: z.number().int().min(0),
    16	});
    17	
    18	export type UpdateProjectPacksPerCaseResult =
    19	  | { ok: true }
    20	  | { ok: false; error: 'invalid_input' | 'forbidden' | 'not_found' | 'persistence_failed' };
    21	
    22	export async function updateProjectPacksPerCase(raw: unknown): Promise<UpdateProjectPacksPerCaseResult> {
    23	  const parsed = inputSchema.safeParse(raw);
    24	  if (!parsed.success) return { ok: false, error: 'invalid_input' };
    25	
    26	  try {
    27	    return await withOrgContext(async ({ userId, orgId, client }) => {
    28	      const queryClient = client as unknown as QueryClient;
    29	      if (!(await hasPermission(queryClient, userId, orgId, PACKAGING_WRITE_PERMISSION))) {
    30	        return { ok: false as const, error: 'forbidden' as const };
    31	      }
    32	
    33	      const updated = await queryClient.query<{ id: string }>(
    34	        `update public.npd_projects
    35	            set packs_per_case = $2::integer
    36	          where id = $1::uuid
    37	            and org_id = app.current_org_id()
    38	          returning id`,
    39	        [parsed.data.projectId, parsed.data.packsPerCase],
    40	      );
    41	      if (updated.rows.length === 0) return { ok: false as const, error: 'not_found' as const };
    42	
    43	      if (parsed.data.packsPerCase > 0) {
    44	        await queryClient.query(
    45	          `update public.items
    46	              set each_per_box = $2
    47	            where org_id = app.current_org_id()
    48	              and npd_project_id = $1::uuid
    49	              and item_type = 'fg'
    50	              and coalesce(each_per_box, 0) <> $2`,
    51	          [parsed.data.projectId, parsed.data.packsPerCase],
    52	        );
    53	      }
    54	
    55	      revalidateLocalized(`/pipeline/${parsed.data.projectId}/packaging`, 'page');
    56	      revalidateLocalized(`/pipeline/${parsed.data.projectId}/brief`, 'page');
    57	      return { ok: true as const };
    58	    });
    59	  } catch (error) {
    60	    console.error('[updateProjectPacksPerCase] persistence_failed', error);
    61	    return { ok: false, error: 'persistence_failed' };
    62	  }
    63	}
FILE apps/web/app/[locale]/(app)/(npd)/pipeline/[projectId]/packaging/_actions/uploadArtworkVersion.ts
     1	'use server';
     2	
     3	/**
     4	 * NPD PACKAGING stage — upload artwork version Server Action.
     5	 *
     6	 * Server-side upload via the service-role storage client to
     7	 *   <orgId>/artwork/<projectId>/v<N>-<uuid>-<sanitized-name>
     8	 * where N = (highest existing version) + 1. orgId ALWAYS from withOrgContext.
     9	 *
    10	 * Versioning decision (documented): the `v<N>-` object-name prefix IS the
    11	 * version; the CURRENT artwork is the highest N. No set-current action —
    12	 * deleting the newest version falls back to the previous one.
    13	 *
    14	 * Validation: pdf/png/jpg, max 20 MB. RBAC write: `npd.packaging.write`.
    15	 */
    16	
    17	import { randomUUID } from 'node:crypto';
    18	
    19	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    20	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
    21	import { PACKAGING_WRITE_PERMISSION } from './shared';
    22	import {
    23	  ARTWORK_MIME_TYPES,
    24	  NPD_ATTACHMENTS_BUCKET,
    25	  NPD_ATTACHMENT_MAX_BYTES,
    26	  artworkPrefix,
    27	  createNpdStorageAdmin,
    28	  ensureNpdAttachmentsBucket,
    29	  hasNpdPermission,
    30	  parseArtworkObjectName,
    31	  projectExistsInOrg,
    32	  sanitizeFileName,
    33	  writeNpdStorageAudit,
    34	  type NpdStorageErrorCode,
    35	  type QueryClient,
    36	} from '../../../../../../../../lib/storage/npd-attachments';
    37	
    38	export type UploadArtworkVersionResult =
    39	  | { ok: true; objectName: string; version: number }
    40	  | { ok: false; code: NpdStorageErrorCode };
    41	
    42	export async function uploadArtworkVersion(formData: FormData): Promise<UploadArtworkVersionResult> {
    43	  if (!formData || typeof formData.get !== 'function') return { ok: false, code: 'INVALID_INPUT' };
    44	
    45	  const projectId = formData.get('projectId');
    46	  const file = formData.get('file');
    47	  if (typeof projectId !== 'string' || !/^[0-9a-f-]{36}$/i.test(projectId) || !(file instanceof File)) {
    48	    return { ok: false, code: 'INVALID_INPUT' };
    49	  }
    50	  if (file.size <= 0) return { ok: false, code: 'INVALID_INPUT' };
    51	  if (file.size > NPD_ATTACHMENT_MAX_BYTES) return { ok: false, code: 'FILE_TOO_LARGE' };
    52	  if (!ARTWORK_MIME_TYPES.has(file.type)) return { ok: false, code: 'UNSUPPORTED_MIME_TYPE' };
    53	
    54	  try {
    55	    return await withOrgContext<UploadArtworkVersionResult>(async ({ userId, orgId, client }) => {
    56	      const queryClient = client as unknown as QueryClient;
    57	
    58	      await queryClient.query(`select pg_advisory_xact_lock(hashtextextended($1::text, 0))`, [projectId]);
    59	
    60	      if (!(await hasNpdPermission(queryClient, userId, orgId, PACKAGING_WRITE_PERMISSION))) {
    61	        return { ok: false, code: 'FORBIDDEN' };
    62	      }
    63	      if (!(await projectExistsInOrg(queryClient, projectId))) {
    64	        return { ok: false, code: 'PROJECT_NOT_FOUND' };
    65	      }
    66	
    67	      const prefix = artworkPrefix(orgId, projectId);
    68	      const admin = await createNpdStorageAdmin();
    69	      await ensureNpdAttachmentsBucket(admin);
    70	
    71	      const { data: entries, error: listError } = await admin.storage
    72	        .from(NPD_ATTACHMENTS_BUCKET)
    73	        .list(prefix, { limit: 200 });
    74	      if (listError) return { ok: false, code: 'STORAGE_FAILED' };
    75	
    76	      const highest = (entries ?? []).reduce((max, entry) => {
    77	        const parsed = parseArtworkObjectName(entry.name);
    78	        return parsed && parsed.version > max ? parsed.version : max;
    79	      }, 0);
    80	      const version = highest + 1;
    81	
    82	      const objectName = `v${version}-${randomUUID()}-${sanitizeFileName(file.name || 'artwork')}`;
    83	      const path = `${prefix}/${objectName}`;
    84	      const bytes = await file.arrayBuffer();
    85	      const { error } = await admin.storage
    86	        .from(NPD_ATTACHMENTS_BUCKET)
    87	        .upload(path, bytes, { contentType: file.type, upsert: false });
    88	      if (error) return { ok: false, code: 'STORAGE_FAILED' };
    89	
    90	      await writeNpdStorageAudit(queryClient, {
    91	        orgId,
    92	        actorUserId: userId,
    93	        action: 'npd.artwork.uploaded',
    94	        resourceType: 'npd_artwork',
    95	        resourceId: path,
    96	        afterState: {
    97	          project_id: projectId,
    98	          object_name: objectName,
    99	          version,
   100	          mime_type: file.type,
   101	          file_size_bytes: file.size,
   102	        },
   103	      });
   104	
   105	      revalidateLocalized(`/pipeline/${projectId}/packaging`, 'page');
   106	      return { ok: true, objectName, version };
   107	    });
   108	  } catch (error) {
   109	    console.error('[uploadArtworkVersion] failed:', error);
   110	    return { ok: false, code: 'PERSISTENCE_FAILED' };
   111	  }
   112	}
FILE apps/web/app/[locale]/(app)/(npd)/pipeline/[projectId]/packaging/_actions/upsertPackagingComponent.ts
     1	'use server';
     2	
     3	/**
     4	 * NPD PACKAGING stage — `upsertPackagingComponent` write Server Action.
     5	 *
     6	 * INSERT (no id) or UPDATE (id present) a packaging component. Org-scoped via
     7	 * withOrgContext (RLS as app_user). RBAC: requires `npd.packaging.write`. Writes
     8	 * an audit_log row in the SAME txn and revalidates the packaging route.
     9	 *
    10	 * NUMERIC-exact: cost_per_unit is bound as a decimal STRING ::numeric, never a
    11	 * JS float. Red lines: zod-validate before the txn; map DB errors to the closed
    12	 * enum; never echo internal columns.
    13	 */
    14	
    15	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    16	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
    17	import {
