     1	'use server';
     2	
     3	import { signEvent } from '@monopilot/e-sign';
     4	import type { ESignTxOptions } from '@monopilot/e-sign';
     5	import { createLogger } from '@monopilot/observability';
     6	import { z } from 'zod';
     7	
     8	import { hasPermission } from '../../../../../../lib/auth/has-permission';
     9	import { withOrgContext } from '../../../../../../lib/auth/with-org-context';
    10	
    11	const logger = createLogger({ name: 'npd-formulation-lifecycle' });
    12	
    13	const inputSchema = z.object({
    14	  projectId: z.string().uuid(),
    15	  versionId: z.string().uuid(),
    16	  pin: z.string().min(1),
    17	  reason: z.string().optional(),
    18	});
    19	
    20	type VersionRow = {
    21	  formulation_id: string;
    22	  version_id: string;
    23	  state: string;
    24	  product_code: string | null;
    25	};
    26	
    27	type UnlockVersionResult =
    28	  | { ok: true; data: { versionId: string } }
    29	  | {
    30	      ok: false;
    31	      error: 'invalid_input' | 'forbidden' | 'not_found' | 'VERSION_NOT_LOCKED' | 'esign_failed' | 'persistence_failed';
    32	    };
    33	
    34	export async function unlockVersion(input: unknown): Promise<UnlockVersionResult> {
    35	  const parsed = inputSchema.safeParse(input);
    36	  if (!parsed.success) return { ok: false, error: 'invalid_input' };
    37	
    38	  const { projectId, versionId, pin, reason } = parsed.data;
    39	
    40	  try {
    41	    return await withOrgContext(async (ctx) => {
    42	      if (!(await hasPermission(ctx, 'npd.formulation.unlock'))) return { ok: false, error: 'forbidden' };
    43	
    44	      const loaded = await ctx.client.query<VersionRow>(
    45	        `select
    46	           f.id as formulation_id,
    47	           fv.id as version_id,
    48	           fv.state,
    49	           f.product_code
    50	         from public.formulations f
    51	         join public.formulation_versions fv on fv.formulation_id = f.id
    52	        where f.project_id = $1::uuid
    53	          and f.org_id = app.current_org_id()
    54	          and fv.id = $2::uuid
    55	        for update of f, fv`,
    56	        [projectId, versionId],
    57	      );
    58	
    59	      const row = loaded.rows[0];
    60	      if (!row) return { ok: false, error: 'not_found' };
    61	      if (row.state !== 'locked') return { ok: false, error: 'VERSION_NOT_LOCKED' };
    62	
    63	      try {
    64	        await signEvent(
    65	          {
    66	            signerUserId: ctx.userId,
    67	            pin,
    68	            intent: 'formulation.unlocked',
    69	            subject: {
    70	              versionId,
    71	              formulationId: row.formulation_id,
    72	              productCode: row.product_code,
    73	            },
    74	            nonce: `formulation.unlocked:${versionId}:${Date.now()}`,
    75	            reason,
    76	          },
    77	          { client: ctx.client as ESignTxOptions['client'] },
    78	        );
    79	      } catch {
    80	        return { ok: false, error: 'esign_failed' };
    81	      }
    82	
    83	      await ctx.client.query(
    84	        `update public.formulation_versions
    85	            set state = 'draft'
    86	          where id = $1::uuid
    87	            and state = 'locked'`,
    88	        [versionId],
    89	      );
    90	      await ctx.client.query(
    91	        `update public.formulations
    92	            set locked_at = null,
    93	                locked_by_user = null
    94	          where id = $1::uuid
    95	            and current_version_id = $2::uuid
    96	            and org_id = app.current_org_id()`,
    97	        [row.formulation_id, versionId],
    98	      );
    99	
   100	      await ctx.client.query(
   101	        `insert into public.formulation_audit_log
   102	           (org_id, formulation_id, version_id, event_type, event_payload, actor_user_id)
   103	         values (app.current_org_id(), $1::uuid, $2::uuid, 'formulation.unlocked', $3::jsonb, $4::uuid)`,
   104	        [row.formulation_id, versionId, JSON.stringify({ productCode: row.product_code, reason }), ctx.userId],
   105	      );
   106	      // TODO(A6): emit formulation.unlocked once the outbox event_type CHECK includes it
   107	
   108	      return { ok: true, data: { versionId } };
   109	    });
   110	  } catch (error) {
   111	    logger.error(
   112	      { err: error, projectId, versionId, action: 'unlockVersion' },
   113	      'formulation lifecycle action failed',
   114	    );
   115	    return { ok: false, error: 'persistence_failed' };
   116	  }
   117	}
FILE apps/web/app/[locale]/(app)/(npd)/pipeline/[projectId]/packaging/_actions/deleteArtworkVersion.ts
     1	'use server';
     2	
     3	/**
     4	 * NPD PACKAGING stage — delete artwork version Server Action.
     5	 *
     6	 * Removes <orgId>/artwork/<projectId>/<objectName>. `objectName` must be a
     7	 * single safe path segment (isSafeObjectName) — no traversal outside the
     8	 * org/project prefix. Deleting the newest version makes the previous one
     9	 * CURRENT (versioning = `v<N>-` ordering). RBAC write: `npd.packaging.write`.
    10	 */
    11	
    12	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    13	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
    14	import { PACKAGING_WRITE_PERMISSION } from './shared';
    15	import {
    16	  NPD_ATTACHMENTS_BUCKET,
    17	  artworkPrefix,
    18	  createNpdStorageAdmin,
    19	  hasNpdPermission,
    20	  isSafeObjectName,
    21	  projectExistsInOrg,
    22	  writeNpdStorageAudit,
    23	  type NpdStorageErrorCode,
    24	  type QueryClient,
    25	} from '../../../../../../../../lib/storage/npd-attachments';
    26	
    27	export type DeleteArtworkVersionResult =
    28	  | { ok: true }
    29	  | { ok: false; code: NpdStorageErrorCode };
    30	
    31	export async function deleteArtworkVersion(input: {
    32	  projectId: string;
    33	  objectName: string;
    34	}): Promise<DeleteArtworkVersionResult> {
    35	  const projectId = input?.projectId;
    36	  const objectName = input?.objectName;
    37	  if (
    38	    typeof projectId !== 'string' ||
    39	    !/^[0-9a-f-]{36}$/i.test(projectId) ||
    40	    !isSafeObjectName(objectName)
    41	  ) {
    42	    return { ok: false, code: 'INVALID_INPUT' };
    43	  }
    44	
    45	  try {
    46	    return await withOrgContext<DeleteArtworkVersionResult>(async ({ userId, orgId, client }) => {
    47	      const queryClient = client as unknown as QueryClient;
    48	
    49	      if (!(await hasNpdPermission(queryClient, userId, orgId, PACKAGING_WRITE_PERMISSION))) {
    50	        return { ok: false, code: 'FORBIDDEN' };
    51	      }
    52	      if (!(await projectExistsInOrg(queryClient, projectId))) {
    53	        return { ok: false, code: 'PROJECT_NOT_FOUND' };
    54	      }
    55	
    56	      const path = `${artworkPrefix(orgId, projectId)}/${objectName}`;
    57	      const admin = await createNpdStorageAdmin();
