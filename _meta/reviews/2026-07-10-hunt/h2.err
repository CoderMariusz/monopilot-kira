   115	      if (value === null || value === undefined) continue;
   116	      // Coerce to string at the boundary; the pure function keeps it exact.
   117	      perNutrient[nutrient] = String(value);
   118	    }
   119	    out.set(row.rm_code, perNutrient);
   120	  }
   121	  return out;
