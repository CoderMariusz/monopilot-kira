    78	   */
    79	  releaseGates: ReleaseGateStatus[];
    80	  /** True ⇔ every release gate is met (Promote precondition, in addition to the checklist). */
    81	  releaseGatesMet: boolean;
    82	};
    83	
    84	export type GetHandoffError = 'invalid_input' | 'forbidden' | 'not_found' | 'persistence_failed';
    85	
    86	export type GetHandoffResult =
