     1	'use server';
     2	
     3	import { hasPermission } from '../../../../../../lib/auth/has-permission';
     4	import { withOrgContext } from '../../../../../../lib/auth/with-org-context';
     5	import { createLogger } from '@monopilot/observability';
     6	
     7	const logger = createLogger({ name: 'npd-formulation-lifecycle' });
     8	
     9	type VersionRow = {
    10	  formulation_id: string;
    11	  version_id: string;
    12	  state: string;
    13	  product_code: string | null;
    14	};
    15	
    16	type LockVersionResult =
    17	  | { ok: true; data: { versionId: string; formulationId: string; recipeComponents: string | null } }
    18	  | {
    19	      ok: false;
    20	      error: 'invalid_input' | 'forbidden' | 'not_found' | 'VERSION_LOCKED' | 'VERSION_NOT_SUBMITTED' | 'persistence_failed';
    21	    };
    22	
    23	export async function lockVersion(input: { projectId?: unknown; versionId?: unknown }): Promise<LockVersionResult> {
    24	  const projectId = parseUuid(input?.projectId);
    25	  const versionId = parseUuid(input?.versionId);
    26	  if (!projectId || !versionId) return { ok: false, error: 'invalid_input' };
    27	
    28	  try {
    29	    return await withOrgContext(async (ctx) => {
    30	      if (!(await hasPermission(ctx, 'npd.formulation.lock'))) return { ok: false, error: 'forbidden' };
    31	
    32	      const loaded = await ctx.client.query<VersionRow>(
    33	        `select
    34	           f.id as formulation_id,
    35	           fv.id as version_id,
    36	           fv.state,
    37	           f.product_code
    38	         from public.formulations f
    39	         join public.formulation_versions fv on fv.formulation_id = f.id
    40	        where f.project_id = $1::uuid
    41	          and f.org_id = app.current_org_id()
    42	          and fv.id = $2::uuid
    43	        for update of f, fv`,
    44	        [projectId, versionId],
    45	      );
    46	
    47	      const row = loaded.rows[0];
    48	      if (!row) return { ok: false, error: 'not_found' };
    49	      if (row.state === 'locked') return { ok: false, error: 'VERSION_LOCKED' };
    50	      if (row.state !== 'submitted_for_trial' && row.state !== 'draft') {
    51	        return { ok: false, error: 'VERSION_NOT_SUBMITTED' };
    52	      }
    53	
    54	      await ctx.client.query(
    55	        `update public.formulation_versions
    56	            set state = 'locked'
    57	          where id = $1::uuid
    58	            and state in ('submitted_for_trial', 'draft')`,
    59	        [versionId],
    60	      );
    61	      await ctx.client.query(
    62	        `update public.formulations
    63	            set locked_at = now(),
    64	                locked_by_user = $3::uuid
    65	          where id = $1::uuid
    66	            and current_version_id = $2::uuid
    67	            and org_id = app.current_org_id()`,
    68	        [row.formulation_id, versionId, ctx.userId],
    69	      );
    70	
    71	      const cascade = row.product_code
    72	        ? await ctx.client.query<{ recipe_components: string | null }>(
    73	            `with generated as (
    74	               select
    75	                 string_agg(fi.rm_code, ', ' order by fi.sequence) as recipe_components,
    76	                 string_agg(
    77	                   'ING' || nullif(regexp_replace(fi.rm_code, '\\D', '', 'g'), ''),
    78	                   ', ' order by fi.sequence
    79	                 ) filter (where nullif(regexp_replace(fi.rm_code, '\\D', '', 'g'), '') is not null) as ingredient_codes
    80	               from public.formulation_ingredients fi
    81	              where fi.version_id = $2::uuid
    82	             )
    83	             update public.product p
    84	                set recipe_components = generated.recipe_components,
    85	                    ingredient_codes = generated.ingredient_codes
    86	               from generated
    87	              where p.product_code = $1
    88	                and p.org_id = app.current_org_id()
    89	              returning p.recipe_components`,
    90	            [row.product_code, versionId],
    91	          )
    92	        : { rows: [{ recipe_components: null }] };
    93	      const recipeComponents = cascade.rows[0]?.recipe_components ?? null;
    94	
    95	      await ctx.client.query(
    96	        `insert into public.formulation_audit_log
    97	           (org_id, formulation_id, version_id, event_type, event_payload, actor_user_id)
    98	         values (app.current_org_id(), $1::uuid, $2::uuid, 'formulation.locked', $3::jsonb, $4::uuid)`,
    99	        [row.formulation_id, versionId, JSON.stringify({ productCode: row.product_code, recipeComponents }), ctx.userId],
   100	      );
   101	      await ctx.client.query(
   102	        `insert into public.outbox_events
   103	           (org_id, event_type, aggregate_type, aggregate_id, payload, dedup_key, app_version)
   104	         values (
   105	           app.current_org_id(),
   106	           'formulation.locked',
   107	           'formulation',
   108	           $1::uuid::text,
   109	           $2::jsonb,
   110	           'formulation.locked:' || $1::uuid::text,
   111	           'npd-formulation-lifecycle-v1'
   112	         )
   113	         on conflict (org_id, dedup_key) where dedup_key is not null do nothing`,
   114	        [
   115	          versionId,
   116	          JSON.stringify({
   117	            formulationId: row.formulation_id,
   118	            productCode: row.product_code,
   119	            recipeComponents,
   120	          }),
   121	        ],
   122	      );
   123	
   124	      return { ok: true, data: { versionId, formulationId: row.formulation_id, recipeComponents } };
   125	    });
   126	  } catch (error) {
   127	    logger.error(
   128	      { err: error, projectId, versionId, action: 'lockVersion' },
   129	      'formulation lifecycle action failed',
   130	    );
   131	    return { ok: false, error: 'persistence_failed' };
   132	  }
   133	}
   134	
   135	function parseUuid(value: unknown): string | null {
   136	  return typeof value === 'string' &&
   137	    /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(value)
   138	    ? value
   139	    : null;
   140	}
FILE apps/web/app/(npd)/pipeline/[projectId]/formulation/_actions/recompute.ts
     1	'use server';
     2	
     3	/**
     4	 * T-065 — `recomputeAndCache` Server Action (01-NPD-g, PRD §17.11.1).
     5	 *
     6	 * Loads a formulation version's parameters + ingredients (org-scoped via
     7	 * `withOrgContext`), runs the pure `recomputeCalc` helper from
     8	 * `@monopilot/domain`, and upserts the result into `formulation_calc_cache`
     9	 * (cost / nutrition / allergen JSON). Invoked on saveDraft.
    10	 *
    11	 * All compute (cost roll-up, per-100g nutrition, allergen union, totalPct gate)
    12	 * happens in the pure function — this action only does I/O (org-scoped reads +
    13	 * the cache upsert) and zod validation. Money stays NUMERIC-exact: ingredient
    14	 * pct / cost arrive as strings from Postgres NUMERIC and are passed through to
    15	 * `recomputeCalc` without `Number()`.
    16	 *
    17	 * NUTRITION SOURCE (PRD §17.11.1 / §17.11.2):
    18	 * Per-100g nutrient values are loaded from the canonical raw-material master
    19	 * `Reference.RawMaterials.nutrition_per_100g` (jsonb), keyed by `rm_code`, and
    20	 * attached to each ingredient before the weighted-sum runs. The values are kept
    21	 * as NUMERIC strings end-to-end so `nutrition_json` is exact, never a float.
    22	 *
    23	 * GRACEFUL DEGRADATION: `Reference.RawMaterials` is provisioned by migration
    24	 * 103. If a (legacy) environment has not yet applied it, the nutrition load is
    25	 * skipped and `nutrition_json` is written as `{}` — the cost/allergen path is
    26	 * unaffected. This is logged via a thrown undefined_table catch, never silent.
    27	 */
    28	
    29	import { z } from 'zod';
    30	import { Dec, recomputeCalc, type RecomputeIngredient, type RecomputeResult } from '@monopilot/domain';
    31	
    32	import { withOrgContext } from '../../../../../../lib/auth/with-org-context';
    33	
    34	/** Pack weight grams (NUMERIC string) → kilograms (NUMERIC string), exact. Null/0 → null. */
    35	function packWeightKgFromGrams(grams: string | null): string | null {
    36	  if (grams === null || grams === '') return null;
    37	  const kg = Dec.from(grams).div(Dec.from('1000'));
    38	  return kg.isZero() ? null : kg.toFixed(6);
    39	}
    40	
    41	const InputSchema = z.object({
    42	  projectId: z.string().min(1),
    43	  versionId: z.string().min(1),
    44	});
    45	
    46	export type RecomputeInput = z.infer<typeof InputSchema>;
    47	
    48	interface VersionMetaRow {
    49	  batch_size_kg: string | null;
    50	  target_price_eur: string | null;
    51	  target_yield_pct: string | null;
    52	  processing_overhead_pct: string | null;
    53	  /** Costing v2: pack net weight in grams (the recipe batch size), from npd_projects. */
    54	  pack_weight_g: string | null;
    55	}
    56	
    57	interface IngredientRow {
    58	  rm_code: string;
    59	  /** Costing v2: amount used in ONE pack, kg. */
    60	  qty_kg: string | null;
    61	  pct: string | null;
    62	  cost_per_kg_eur: string | null;
    63	  allergens_inherited: string[] | null;
    64	}
    65	
    66	interface RawMaterialNutritionRow {
    67	  rm_code: string;
    68	  nutrition_per_100g: Record<string, unknown> | null;
    69	}
    70	
    71	/** Postgres SQLSTATE for "undefined_table" (relation does not exist). */
    72	const PG_UNDEFINED_TABLE = '42P01';
    73	
    74	/**
    75	 * Load per-100g nutrition for the given rm_codes from the canonical
    76	 * `Reference.RawMaterials` master, returning a map of rm_code → { nutrient:
    77	 * numeric-string }. Values are coerced to strings so the weighted-sum stays
    78	 * exact (never a binary float). Returns an empty map (graceful degradation)
    79	 * when the canonical table has not yet been provisioned.
