   211	     set department_id = null
   212	   where department_id = p_department_id
   213	     and org_id = v_org_id;
   214	
   215	  delete from public.gate_checklist_items
   216	   where org_id = v_org_id
   217	     and (
   218	       item_text ilike ('Done_' || v_dept_code || ':%')
   219	       or item_text ilike ('Done ' || v_dept_code || ':%')
   220	       or item_text ilike ('%' || v_dept_code || ' department NPD data closed%')
   221	     );
