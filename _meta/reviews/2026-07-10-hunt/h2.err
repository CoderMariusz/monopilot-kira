    88	  | { ok: false; error: GetHandoffError; message?: string };
    89	
    90	type QueryClient = {
    91	  query<T = Record<string, unknown>>(sql: string, params?: readonly unknown[]): Promise<{ rows: T[] }>;
    92	};
    93	
    94	const READ_PERMISSION = 'npd.handoff.read';
    95	
    96	/**
    97	 * Shared RBAC probe for the handoff stage. Checks BOTH normalized
    98	 * role_permissions and the legacy roles.permissions jsonb cache (some orgs are
    99	 * seeded only via the jsonb path — mirrors pipeline/_actions/shared.hasPermission).
   100	 */
   101	export async function hasHandoffPermission(
   102	  ctx: { userId: string; orgId: string; client: QueryClient },
   103	  permission: string,
   104	): Promise<boolean> {
   105	  const { rows } = await ctx.client.query<{ ok: boolean }>(
   106	    `select true as ok
   107	       from public.user_roles ur
   108	       join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
   109	       left join public.role_permissions rp on rp.role_id = r.id and rp.permission = $3
   110	      where ur.user_id = $1::uuid
   111	        and ur.org_id = $2::uuid
   112	        and (
   113	          rp.permission is not null
   114	          or coalesce(r.permissions, '[]'::jsonb) ? $3
   115	        )
   116	      limit 1`,
   117	    [ctx.userId, ctx.orgId, permission],
   118	  );
   119	  return rows.length > 0;
   120	}
