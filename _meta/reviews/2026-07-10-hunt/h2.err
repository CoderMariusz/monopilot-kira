     1	'use server';
     2	
     3	import { hasPermission } from '../../../../../../lib/auth/has-permission';
     4	import { withOrgContext } from '../../../../../../lib/auth/with-org-context';
     5	import { createLogger } from '@monopilot/observability';
     6	import { NUTRIENT_CODES } from '@monopilot/domain';
     7	
     8	const logger = createLogger({ name: 'npd-formulation-lifecycle' });
     9	
    10	type GateRow = {
    11	  formulation_id: string;
    12	  version_id: string;
    13	  state: string;
    14	  product_code: string | null;
    15	  total_pct: string | null;
    16	  missing_cost_count: string | number;
    17	  missing_nutrition_target_count: string | number;
    18	};
    19	
    20	export type SubmitForTrialResult =
    21	  | { ok: true; data: { versionId: string; trialCreated: boolean } }
    22	  | {
    23	      ok: false;
    24	      error:
    25	        | 'invalid_input'
    26	        | 'forbidden'
    27	        | 'not_found'
    28	        | 'VERSION_NOT_LOCKED'
    29	        | 'TOTAL_PCT_OUT_OF_RANGE'
    30	        | 'MISSING_COST'
    31	        | 'MISSING_NUTRITION_TARGET'
    32	        | 'persistence_failed';
    33	    };
    34	
    35	export async function submitForTrial(input: { projectId?: unknown; versionId?: unknown }): Promise<SubmitForTrialResult> {
    36	  const projectId = parseUuid(input?.projectId);
    37	  const versionId = parseUuid(input?.versionId);
    38	  if (!projectId || !versionId) return { ok: false, error: 'invalid_input' };
    39	
    40	  try {
    41	    return await withOrgContext(async (ctx) => {
    42	      if (!(await hasPermission(ctx, 'npd.recipe.submit_for_trial'))) return { ok: false, error: 'forbidden' };
    43	
    44	      const loaded = await ctx.client.query<GateRow>(
    45	        `with locked_version as (
    46	           select
    47	             f.id as formulation_id,
    48	             fv.id as version_id,
    49	             fv.state,
    50	             f.product_code
    51	           from public.formulations f
    52	           join public.formulation_versions fv on fv.formulation_id = f.id
    53	          where f.project_id = $1::uuid
    54	            and f.org_id = app.current_org_id()
    55	            and fv.id = $2::uuid
    56	          for update of fv
    57	         )
    58	         select
    59	           lv.formulation_id,
    60	           lv.version_id,
    61	           lv.state,
    62	           lv.product_code,
    63	           coalesce(sum(fi.pct), 0)::text as total_pct,
    64	           count(*) filter (where fi.cost_per_kg_eur is null) as missing_cost_count,
    65	           case
    66	             when fcc.version_id is null then cardinality($3::text[])
    67	             else (
    68	               select count(*)
    69	                 from unnest($3::text[]) as required(nutrient_code)
    70	                where not (coalesce(fcc.nutrition_json, '{}'::jsonb) ? required.nutrient_code)
    71	             )
    72	           end as missing_nutrition_target_count
    73	         from locked_version lv
    74	         left join public.formulation_ingredients fi on fi.version_id = lv.version_id
    75	         left join public.formulation_calc_cache fcc on fcc.version_id = lv.version_id
    76	        group by lv.formulation_id, lv.version_id, lv.state, lv.product_code, fcc.version_id, fcc.nutrition_json`,
    77	        [projectId, versionId, NUTRIENT_CODES],
    78	      );
    79	
    80	      const row = loaded.rows[0];
    81	      if (!row) return { ok: false, error: 'not_found' };
    82	      if (row.state !== 'locked') return { ok: false, error: 'VERSION_NOT_LOCKED' };
    83	      if (!isTotalPctInRange(row.total_pct)) return { ok: false, error: 'TOTAL_PCT_OUT_OF_RANGE' };
    84	      if (Number(row.missing_cost_count) > 0) return { ok: false, error: 'MISSING_COST' };
    85	      if (Number(row.missing_nutrition_target_count) > 0) {
    86	        return { ok: false, error: 'MISSING_NUTRITION_TARGET' };
    87	      }
    88	
    89	      const existingTrial = await ctx.client.query<{ id: string }>(
    90	        `select id from public.trial_batches
    91	          where project_id = $1::uuid and org_id = app.current_org_id()
    92	          limit 1`,
    93	        [projectId],
    94	      );
    95	      const trialAlreadyExists = existingTrial.rows.length > 0;
    96	
    97	      if (!trialAlreadyExists) {
    98	        await ctx.client.query(
    99	          `insert into public.trial_batches
   100	             (org_id, project_id, trial_no, batch_size_kg, result, created_by, updated_by)
   101	           values (
   102	             app.current_org_id(), $1::uuid, 'T-1',
   103	             (select batch_size_kg from public.formulation_versions where id = $2::uuid),
   104	             'pending', $3::uuid, $3::uuid
   105	           )`,
   106	          [projectId, versionId, ctx.userId],
   107	        );
   108	      }
   109	
   110	      await ctx.client.query(
   111	        `insert into public.formulation_audit_log
   112	           (org_id, formulation_id, version_id, event_type, event_payload, actor_user_id)
   113	         values (app.current_org_id(), $1::uuid, $2::uuid, 'formulation.submitted_for_trial', $3::jsonb, $4::uuid)`,
   114	        [row.formulation_id, versionId, JSON.stringify({ productCode: row.product_code, trialCreated: !trialAlreadyExists }), ctx.userId],
   115	      );
   116	      await ctx.client.query(
   117	        `insert into public.outbox_events
   118	           (org_id, event_type, aggregate_type, aggregate_id, payload, dedup_key, app_version)
   119	         values (
   120	           app.current_org_id(),
   121	           'formulation.submitted_for_trial',
   122	           'formulation',
   123	           $1::uuid::text,
   124	           $2::jsonb,
   125	           'formulation.submitted_for_trial:' || $1::uuid::text,
   126	           'npd-formulation-lifecycle-v1'
   127	         )
   128	         on conflict (org_id, dedup_key) where dedup_key is not null do nothing`,
   129	        [versionId, JSON.stringify({ formulationId: row.formulation_id, productCode: row.product_code, trialCreated: !trialAlreadyExists })],
   130	      );
   131	
   132	      return { ok: true, data: { versionId, trialCreated: !trialAlreadyExists } };
   133	    });
   134	  } catch (error) {
   135	    logger.error(
   136	      { err: error, projectId, versionId, action: 'submitForTrial' },
   137	      'formulation lifecycle action failed',
   138	    );
   139	    return { ok: false, error: 'persistence_failed' };
   140	  }
   141	}
   142	
   143	function isTotalPctInRange(value: string | null): boolean {
   144	  if (value === null) return false;
   145	  const numeric = Number(value);
   146	  return numeric >= 99.99 && numeric <= 100.01;
   147	}
   148	
   149	function parseUuid(value: unknown): string | null {
   150	  return typeof value === 'string' &&
   151	    /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(value)
   152	    ? value
   153	    : null;
   154	}
