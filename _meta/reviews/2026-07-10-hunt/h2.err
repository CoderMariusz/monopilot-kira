    16	/**
    17	 * Create the FIRST formulation draft for a project (the "Create a draft version"
    18	 * affordance on the empty Recipe stage). Inserts a `formulations` row (if none yet)
    19	 * + a `formulation_versions` row (version 1, state 'draft') and points
    20	 * formulations.current_version_id at it. Idempotent: if a draft version already
    21	 * exists it returns that versionId. RBAC: npd.formulation.create_draft.
    22	 */
    23	export async function createFormulationDraft(input: { projectId?: unknown }): Promise<CreateDraftResult> {
    24	  const projectId = parseUuid(input?.projectId);
    25	  if (!projectId) return { ok: false, error: 'invalid_input' };
    26	
    27	  try {
    28	    return await withOrgContext(async (rawCtx): Promise<CreateDraftResult> => {
    29	      const ctx = rawCtx as Ctx;
    30	      if (!(await hasPermission(ctx, 'npd.formulation.create_draft'))) return { ok: false, error: 'forbidden' };
    31	
    32	      const proj = await ctx.client.query<{ product_code: string | null }>(
    33	        `select product_code from public.npd_projects
    34	          where id = $1::uuid and org_id = app.current_org_id() limit 1`,
    35	        [projectId],
    36	      );
    37	      if (proj.rows.length === 0) return { ok: false, error: 'not_found' };
    38	
    39	      const existing = await ctx.client.query<{ formulation_id: string; current_version_id: string | null }>(
    40	        `select id as formulation_id, current_version_id from public.formulations
    41	          where project_id = $1::uuid and org_id = app.current_org_id() limit 1`,
    42	        [projectId],
    43	      );
    44	
    45	      let formulationId: string;
    46	      if (existing.rows[0]) {
    47	        formulationId = existing.rows[0].formulation_id;
    48	        if (proj.rows[0].product_code) {
    49	          await ctx.client.query(
    50	            `update public.formulations
    51	                set product_code = $2
    52	              where id = $1::uuid
    53	                and org_id = app.current_org_id()
    54	                and product_code is null`,
    55	            [formulationId, proj.rows[0].product_code],
    56	          );
    57	        }
    58	        if (existing.rows[0].current_version_id) {
    59	          return { ok: true, data: { versionId: existing.rows[0].current_version_id } };
    60	        }
    61	      } else {
    62	        const inserted = await ctx.client.query<{ id: string }>(
    63	          `insert into public.formulations (org_id, project_id, product_code, created_by_user)
    64	           values (app.current_org_id(), $1::uuid, $2, $3::uuid)
    65	           returning id`,
    66	          [projectId, proj.rows[0].product_code ?? null, ctx.userId],
    67	        );
    68	        formulationId = inserted.rows[0]!.id;
    69	      }
    70	
    71	      const nextNum = await ctx.client.query<{ n: number }>(
    72	        `select coalesce(max(version_number), 0) + 1 as n
    73	           from public.formulation_versions where formulation_id = $1::uuid`,
    74	        [formulationId],
    75	      );
    76	      const version = await ctx.client.query<{ id: string }>(
    77	        `insert into public.formulation_versions (formulation_id, version_number, state, created_by_user)
    78	         values ($1::uuid, $2, 'draft', $3::uuid)
    79	         returning id`,
    80	        [formulationId, nextNum.rows[0]!.n, ctx.userId],
    81	      );
    82	      const versionId = version.rows[0]!.id;
    83	
    84	      await ctx.client.query(
    85	        `update public.formulations set current_version_id = $2::uuid
    86	          where id = $1::uuid and org_id = app.current_org_id()`,
    87	        [formulationId, versionId],
    88	      );
    89	
    90	      return { ok: true, data: { versionId } };
    91	    });
    92	  } catch {
    93	    return { ok: false, error: 'persistence_failed' };
    94	  }
    95	}
