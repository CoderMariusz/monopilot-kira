    90	export async function getFormulation(input: {
    91	  projectId?: unknown;
    92	  /**
    93	   * Optional: load THIS specific version's ingredients + state instead of the
    94	   * formulation's `current_version_id`. When provided it must be a valid UUID
    95	   * that belongs to the project's formulation (enforced in SQL via the join +
    96	   * the org predicate); an unknown/foreign id falls back to the current version
    97	   * (the join below only matches it when fv.formulation_id = f.id, otherwise
    98	   * `current_version_id` is used). This keeps the DISPLAYED version and the
    99	   * save target identical — picking v1 actually loads v1's rows, so saveDraft
   100	   * can never overwrite the wrong version.
   101	   */
   102	  versionId?: unknown;
   103	}): Promise<GetFormulationResult> {
   104	  const projectId = parseUuid(input?.projectId);
   105	  if (!projectId) return { ok: false, error: 'invalid_input' };
   106	  // Optional explicit version. A non-UUID is ignored (→ current version);
   107	  // a syntactically valid id that does not belong to this formulation also
   108	  // falls back, because the SQL only resolves it when it joins to f.
   109	  const requestedVersionId =
   110	    input?.versionId === undefined || input?.versionId === null ? null : parseUuid(input.versionId);
   111	
   112	  try {
   113	    return await withOrgContext(async ({ client }) => {
   114	      const formulation = await client.query<FormulationRow>(
   115	        `select
   116	           f.id as formulation_id,
   117	           f.project_id,
   118	           f.product_code,
   119	           f.locked_at::text,
   120	           f.locked_by_user::text,
   121	           fv.id as version_id,
   122	           fv.version_number,
   123	           fv.state,
   124	           fv.batch_size_kg::text,
   125	           fv.target_yield_pct::text,
   126	           coalesce(fv.target_price_eur, np.target_retail_price_eur)::text as target_price_eur,
   127	           fv.processing_overhead_pct::text,
   128	           fcc.cost_json,
   129	           fcc.nutrition_json,
   130	           fcc.allergen_json,
   131	           fcc.computed_at::text
   132	         from public.formulations f
   133	         left join public.npd_projects np
   134	           on np.id = f.project_id
   135	          and np.org_id = f.org_id
   136	         -- When a specific (org-scoped, in-formulation) versionId is requested,
   137	         -- load THAT version; otherwise fall back to the formulation's current
   138	         -- version. The id is matched only against versions of THIS formulation
   139	         -- (fv.formulation_id = f.id), so a foreign/unknown id silently resolves
   140	         -- to the current version rather than leaking another project's rows.
   141	         left join public.formulation_versions fv
   142	           on fv.id = coalesce(
   143	                (
   144	                  select rfv.id
   145	                    from public.formulation_versions rfv
   146	                   where rfv.formulation_id = f.id
   147	                     and rfv.id = $2::uuid
   148	                   limit 1
   149	                ),
   150	                f.current_version_id
   151	              )
   152	         left join public.formulation_calc_cache fcc on fcc.version_id = fv.id
   153	        where f.project_id = $1::uuid
   154	          and f.org_id = app.current_org_id()
   155	        limit 1`,
   156	        [projectId, requestedVersionId],
   157	      );
   158	
   159	      const row = formulation.rows[0];
   160	      if (!row) return { ok: false, error: 'not_found' };
   161	
   162	      const ingredients = row.version_id ? await loadIngredients(client, row.version_id) : { rows: [] };
   163	
   164	      return {
   165	        ok: true,
   166	        data: {
   167	          formulation: {
   168	            id: row.formulation_id,
   169	            projectId: row.project_id,
   170	            productCode: row.product_code,
   171	            lockedAt: row.locked_at,
   172	            lockedByUser: row.locked_by_user,
   173	          },
   174	          currentVersion:
   175	            row.version_id && row.version_number && row.state
   176	              ? {
   177	                  id: row.version_id,
   178	                  versionNumber: row.version_number,
   179	                  state: row.state,
   180	                  batchSizeKg: row.batch_size_kg,
   181	                  targetYieldPct: row.target_yield_pct,
   182	                  targetPriceEur: row.target_price_eur,
   183	                  processingOverheadPct: row.processing_overhead_pct,
   184	                }
   185	              : null,
   186	          ingredients: ingredients.rows,
   187	          cachedCalc: row.version_id
   188	            ? {
   189	                costJson: row.cost_json ?? {},
   190	                nutritionJson: row.nutrition_json ?? {},
   191	                allergenJson: row.allergen_json ?? {},
   192	                computedAt: row.computed_at,
   193	              }
   194	            : null,
   195	        },
   196	      };
   197	    });
   198	  } catch {
   199	    return { ok: false, error: 'persistence_failed' };
   200	  }
   201	}
   202	
   203	/** Postgres SQLSTATE for "undefined_table" (relation does not exist). */
   204	const PG_UNDEFINED_TABLE = '42P01';
   205	
   206	type QueryClient = {
   207	  query<T = Record<string, unknown>>(sql: string, params?: readonly unknown[]): Promise<{ rows: T[] }>;
   208	};
   209	
   210	/**
   211	 * Shared SELECT list for the ingredient read.
   212	 *
   213	 * F-A06 — allergens: item-linked lines resolve the FULL allergen array LIVE
   214	 * from the SSOT `public.item_allergen_profiles` (all intensities; a truly-empty
   215	 * profile reads as `{}` — never falls back to the stale stored cache). Only
   216	 * legacy free-text lines (item_id IS NULL) read the stored derived column.
   217	 *
   218	 * F6/N+1 (W9 cross-review): the SSOT resolution is a pre-aggregated CTE keyed
   219	 * by item_id + ONE left join (PROFILE_ALLERGENS_CTE below) instead of a
   220	 * correlated per-row subquery — the same shape recompute.ts uses.
   221	 */
   222	const PROFILE_ALLERGENS_CTE = `
   223	  with profile_allergens as (
   224	    select iap.item_id,
   225	           array_agg(distinct iap.allergen_code order by iap.allergen_code) as codes
   226	      from public.item_allergen_profiles iap
   227	     where iap.org_id = app.current_org_id()
   228	       and iap.item_id in (
   229	         select fi2.item_id
   230	           from public.formulation_ingredients fi2
   231	          where fi2.version_id = $1::uuid
   232	            and fi2.item_id is not null
   233	       )
   234	     group by iap.item_id
   235	  )`;
   236	
   237	const INGREDIENT_SELECT = `
   238	  fi.id::text,
   239	  fi.rm_code,
   240	  fi.item_id::text,
   241	  fi.wip_definition_id::text,
   242	  wd.name as wip_definition_name,
   243	  it.name as item_name,
   244	  fi.substitute_item_id::text,
   245	  substitute.item_code as substitute_item_code,
   246	  substitute.name as substitute_item_name,
   247	  fi.npd_wip_process_id::text,
   248	  fi.qty_kg::text,
   249	  fi.pct::text,
   250	  fi.cost_per_kg_eur::text,
   251	  case
   252	    when fi.item_id is not null then coalesce(pa.codes, '{}'::text[])
   253	    else coalesce(fi.allergens_inherited, '{}'::text[])
   254	  end as allergens_inherited,
   255	  fi.sequence`;
   256	
   257	/**
   258	 * F-B05 — ingredient read WITH the nutrition join to the canonical
   259	 * `Reference.RawMaterials.nutrition_per_100g` (mirrors recompute.ts's source,
   260	 * keyed by rm_code; RLS + the explicit org predicate scope the catalog).
   261	 * Degrades gracefully (like recompute.ts) when migration 107 has not been
   262	 * applied: on 42P01 the query is retried without the join and every
   263	 * nutrition_per_100g is null.
   264	 */
   265	async function loadIngredients(client: QueryClient, versionId: string): Promise<{ rows: IngredientRow[] }> {
   266	  try {
   267	    return await client.query<IngredientRow>(
   268	      `${PROFILE_ALLERGENS_CTE}
   269	       select${INGREDIENT_SELECT},
   270	         rm.nutrition_per_100g
   271	       from public.formulation_ingredients fi
   272	       left join public.items it on it.id = fi.item_id
   273	       left join public.wip_definitions wd on wd.id = fi.wip_definition_id
   274	       left join public.items substitute on substitute.id = fi.substitute_item_id
   275	       left join profile_allergens pa on pa.item_id = fi.item_id
   276	       left join "Reference"."RawMaterials" rm
   277	         on rm.org_id = app.current_org_id()
   278	        and rm.rm_code = fi.rm_code
   279	      where fi.version_id = $1::uuid
   280	      order by fi.sequence`,
   281	      [versionId],
   282	    );
   283	  } catch (err) {
   284	    if ((err as { code?: string })?.code !== PG_UNDEFINED_TABLE) throw err;
   285	    const fallback = await client.query<Omit<IngredientRow, 'nutrition_per_100g'>>(
   286	      `${PROFILE_ALLERGENS_CTE}
   287	       select${INGREDIENT_SELECT}
   288	       from public.formulation_ingredients fi
   289	       left join public.items it on it.id = fi.item_id
   290	       left join public.wip_definitions wd on wd.id = fi.wip_definition_id
   291	       left join public.items substitute on substitute.id = fi.substitute_item_id
   292	       left join profile_allergens pa on pa.item_id = fi.item_id
   293	      where fi.version_id = $1::uuid
   294	      order by fi.sequence`,
   295	      [versionId],
   296	    );
   297	    return { rows: fallback.rows.map((r) => ({ ...r, nutrition_per_100g: null })) };
   298	  }
   299	}
   300	
   301	function parseUuid(value: unknown): string | null {
   302	  return typeof value === 'string' &&
   303	    /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(value)
   304	    ? value
   305	    : null;
