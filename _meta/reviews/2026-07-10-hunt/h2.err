    37	            and f.org_id = app.current_org_id()
    38	          for update of f`,
    39	        [projectId],
    40	      );
    41	      const row = formulation.rows[0];
    42	      if (!row) return { ok: false, error: 'not_found' };
    43	
    44	      const sourceVersionId = requestedSourceVersionId ?? row.current_version_id;
    45	      if (!sourceVersionId) return { ok: false, error: 'not_found' };
    46	
    47	      const nextNum = await ctx.client.query<{ n: number }>(
    48	        `select coalesce(max(version_number), 0) + 1 as n
    49	           from public.formulation_versions
    50	          where formulation_id = $1::uuid`,
    51	        [row.id],
    52	      );
    53	      const versionNumber = nextNum.rows[0]!.n;
    54	
    55	      const version = await ctx.client.query<{ id: string; version_number: number }>(
    56	        `insert into public.formulation_versions (
    57	           formulation_id,
    58	           version_number,
    59	           state,
    60	           batch_size_kg,
    61	           target_yield_pct,
    62	           target_price_eur,
