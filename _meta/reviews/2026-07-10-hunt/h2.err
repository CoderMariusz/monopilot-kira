    51	      const proj = await queryClient.query<{ id: string }>(
    52	        `select id from public.npd_projects
    53	          where id = $1::uuid and org_id = app.current_org_id() limit 1`,
    54	        [input.projectId],
    55	      );
    56	      if (proj.rows.length === 0) return { ok: false as const, error: 'not_found' as const };
    57	
    58	      const material = input.material ?? null;
    59	      const spec = input.spec ?? null;
    60	      const costPerUnit = input.costPerUnit ?? null;
    61	      const scrapPct = unifiedWastePct;
    62	      const wastePct = unifiedWastePct;
    63	      const qtyPerPack = input.qtyPerPack ?? null;
    64	      const displayOrder = input.displayOrder ?? 0;
    65	      const itemIdProvided = 'itemId' in rawRecord;
    66	
    67	      async function validatePackagingItemId(candidate: string | null): Promise<boolean> {
    68	        if (!candidate) return true;
    69	        const item = await queryClient.query<{ id: string }>(
    70	          `select id from public.items
    71	            where id = $1::uuid
    72	              and org_id = app.current_org_id()
    73	              and item_type = 'packaging'
    74	            limit 1`,
    75	          [candidate],
    76	        );
    77	        return item.rows.length > 0;
    78	      }
    79	
    80	      let beforeRow: { supplier_id: string | null; supplier_code: string | null } | null = null;
    81	      if (input.id) {
    82	        const before = await queryClient.query<{ supplier_id: string | null; supplier_code: string | null }>(
    83	          `select supplier_id::text as supplier_id, supplier_code
    84	             from public.packaging_components
    85	            where id = $1::uuid and org_id = app.current_org_id() limit 1`,
    86	          [input.id],
    87	        );
    88	        if (before.rows.length === 0) return { ok: false as const, error: 'not_found' as const };
    89	        beforeRow = before.rows[0] ?? null;
    90	      }
    91	
    92	      let supplierId: string | null = input.supplierId ?? null;
    93	      let supplierCode: string | null = null;
    94	
    95	      if (supplierId) {
    96	        const supplier = await queryClient.query<{ id: string; code: string | null }>(
    97	          `select id::text, code
    98	             from public.suppliers
    99	            where org_id = app.current_org_id()
   100	              and id = $1::uuid
   101	              and status = 'active'
   102	            limit 1`,
   103	          [supplierId],
   104	        );
   105	        if (supplier.rows.length === 0) return { ok: false as const, error: 'invalid_input' as const };
   106	        supplierCode = supplier.rows[0]?.code ?? null;
   107	      } else if (input.legacySupplierCode?.trim()) {
