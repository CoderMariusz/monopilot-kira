     8	  project_id uuid not null references public.npd_projects(id) on delete cascade,
     9	  product_code text references public.product(product_code) on delete set null,
    10	  current_version_id uuid,
    11	  locked_at timestamptz,
    12	  locked_by_user uuid references public.users(id),
    13	  created_at timestamptz not null default pg_catalog.now(),
    14	  created_by_user uuid references public.users(id),
