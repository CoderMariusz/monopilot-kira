/bin/zsh -lc "nl -ba packages/db/migrations/421-npd-dept-stage-and-cascade.sql; nl -ba packages/db/migrations/093-formulations.sql | sed -n '1,115p'; nl -ba packages/db/migrations/232-npd-packaging-components.sql; nl -ba packages/db/migrations/235-npd-handoff-checklists.sql; rtk rg -n \"references public\\.npd_projects\\(id\\)|project_id uuid|formulation_id uuid|version_id uuid|handoff_checklist_id uuid\" packages/db/migrations | rtk rg \"npd|formulation|packaging|handoff|trial|pilot|costing|nutrition\"" in /Users/mariuszkrawczyk/Projects/monopilot-kira
 succeeded in 0ms:
     1	-- Migration 421 — NPD department-owned stage assignment + hard delete cascades.
     2	--
     3	-- D2/D4: stage_code moves from field assignment to department. Deleting a
     4	-- department or field must remove its catalog rows, stored dynamic FG values,
     5	-- and legacy checklist dependencies in the current org context.
     6	
     7	alter table public.npd_departments
     8	  add column if not exists stage_code text not null default 'brief';
     9	
    10	alter table public.npd_departments
    11	  alter column stage_code set default 'brief';
    12	
    13	do $$
    14	begin
    15	  if not exists (
    16	    select 1
    17	      from pg_constraint
    18	     where conname = 'npd_departments_stage_code_check'
    19	       and conrelid = 'public.npd_departments'::regclass
    20	  ) then
    21	    alter table public.npd_departments
    22	      add constraint npd_departments_stage_code_check
    23	      check (stage_code in (
    24	        'brief', 'recipe', 'packaging', 'costing_nutrition', 'trial',
    25	        'sensory', 'pilot', 'approval', 'handoff'
    26	      ));
    27	  end if;
    28	end
    29	$$;
    30	
    31	-- Backfill dept.stage_code from the legacy assignment-level column. Guarded +
    32	-- dynamic: on a RE-RUN the source column is already dropped (below), so the
    33	-- statement must not even be parsed then.
    34	do $$
    35	begin
    36	  if exists (
    37	    select 1
    38	      from information_schema.columns
    39	     where table_schema = 'public'
    40	       and table_name = 'npd_department_field'
    41	       and column_name = 'stage_code'
    42	  ) then
    43	    execute $sql$
    44	      with ranked_stage as (
    45	        select department_id,
    46	               stage_code,
    47	               row_number() over (
    48	                 partition by department_id
    49	                 order by count(*) desc, stage_code
    50	               ) as rn
    51	          from public.npd_department_field
    52	         where stage_code is not null
    53	           and stage_code in (
    54	             'brief', 'recipe', 'packaging', 'costing_nutrition', 'trial',
    55	             'sensory', 'pilot', 'approval', 'handoff'
    56	           )
    57	         group by department_id, stage_code
    58	      )
    59	      update public.npd_departments d
    60	         set stage_code = ranked_stage.stage_code
    61	        from ranked_stage
    62	       where ranked_stage.department_id = d.id
    63	         and ranked_stage.rn = 1
    64	    $sql$;
    65	  end if;
    66	end
    67	$$;
    68	
    69	update public.npd_departments
    70	   set stage_code = 'brief'
    71	 where stage_code is null
    72	    or stage_code not in (
    73	      'brief', 'recipe', 'packaging', 'costing_nutrition', 'trial',
    74	      'sensory', 'pilot', 'approval', 'handoff'
    75	    );
    76	
    77	alter table public.npd_departments
    78	  alter column stage_code set not null;
