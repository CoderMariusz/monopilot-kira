     1	/**
     2	 * NPD HANDOFF stage — read-only release-gate probe.
     3	 *
     4	 * The "✓ Promote to production BOM" button reuses the REAL factory-release flow
     5	 * (`releaseNpdProjectToFactory` → `runReleasePreflight`). That preflight is the
     6	 * source of truth, but it (a) takes a `for update` row lock and (b) throws on the
     7	 * FIRST blocker as a `ReleasePreflightError` — neither is appropriate for a GET.
     8	 *
     9	 * This probe mirrors the SAME invariants the preflight checks, but read-only and
    10	 * NON-throwing, so the screen can surface — per gate — whether it is met and WHY
    11	 * it is not (the dead-end the user reported: promote looked permanently disabled
    12	 * with no explanation). The actual promote still runs the real preflight, so this
    13	 * is purely a surfacing aid and never the authority.
    14	 *
    15	 * Org-scoped via RLS (app.current_org_id()); no mocks, no hard-coded rows.
    16	 */
    17	
    18	type QueryClient = {
    19	  query<T = Record<string, unknown>>(sql: string, params?: readonly unknown[]): Promise<{ rows: T[] }>;
    20	};
    21	
    22	export type ReleaseGateProbeCtx = { userId: string; orgId: string; client: QueryClient };
    23	
    24	/** Stable gate codes surfaced on the handoff screen (subset of preflight blockers). */
    25	export type ReleaseGateCode =
    26	  | 'G4_REQUIRED'
    27	  | 'FG_CANDIDATE_REQUIRED'
    28	  | 'ACTIVE_SHARED_BOM_REQUIRED'
    29	  | 'FACTORY_SPEC_REQUIRED'
    30	  | 'V18_OPEN_HIGH_RISK';
    31	
    32	export type ReleaseGateStatus = {
    33	  code: ReleaseGateCode;
    34	  met: boolean;
    35	};
    36	
    37	/** The fixed gate order surfaced on the screen (stable for tests + a11y). */
    38	export const RELEASE_GATE_ORDER: ReleaseGateCode[] = [
    39	  'G4_REQUIRED',
    40	  'FG_CANDIDATE_REQUIRED',
    41	  'ACTIVE_SHARED_BOM_REQUIRED',
    42	  'FACTORY_SPEC_REQUIRED',
    43	  'V18_OPEN_HIGH_RISK',
    44	];
    45	
    46	type ProjectRow = { current_gate: string; product_code: string | null };
    47	
    48	/**
    49	 * Probe the release gates for a project, read-only. Returns a status per gate in
    50	 * RELEASE_GATE_ORDER. A missing project (RLS / not in org) reports every gate as
    51	 * unmet rather than throwing — the screen renders the unmet panel, never a crash.
    52	 */
    53	export async function probeReleaseGates(
    54	  ctx: ReleaseGateProbeCtx,
    55	  projectId: string,
    56	): Promise<ReleaseGateStatus[]> {
    57	  const projectRes = await ctx.client.query<ProjectRow>(
    58	    `select current_gate, product_code
    59	       from public.npd_projects
    60	      where id = $1::uuid
    61	        and org_id = app.current_org_id()
    62	      limit 1`,
    63	    [projectId],
    64	  );
    65	  const project = projectRes.rows[0];
    66	  if (!project) {
    67	    return RELEASE_GATE_ORDER.map((code) => ({ code, met: false }));
    68	  }
    69	
    70	  const g4Met = project.current_gate === 'G4' || project.current_gate === 'Launched';
    71	  const productCode = project.product_code;
    72	  const fgMet = Boolean(productCode);
    73	
    74	  let highRiskMet = true;
    75	  let activeBomMet = false;
    76	  let factorySpecMet = false;
    77	
    78	  if (productCode) {
    79	    const risks = await ctx.client.query<{ open_high_count: string | number }>(
    80	      `select count(*)::text as open_high_count
    81	         from public.risks
    82	        where org_id = app.current_org_id()
    83	          and product_code = $1
    84	          and bucket = 'High'
    85	          and state = 'Open'`,
    86	      [productCode],
    87	    );
    88	    highRiskMet = Number(risks.rows[0]?.open_high_count ?? 0) === 0;
    89	
    90	    const bom = await ctx.client.query<{ id: string; line_count: string | number }>(
    91	      `select h.id, count(l.id)::text as line_count
    92	         from public.bom_headers h
    93	         join public.bom_lines l
    94	           on l.org_id = h.org_id
    95	          and l.bom_header_id = h.id
    96	        where h.org_id = app.current_org_id()
    97	          and h.npd_project_id = $1::uuid
    98	          and h.product_id = $2
    99	          and h.origin_module = 'npd'
   100	          and h.status = 'active'
   101	        group by h.id
   102	        order by h.id
   103	        limit 1`,
   104	      [projectId, productCode],
   105	    );
   106	    activeBomMet = Boolean(bom.rows[0]) && Number(bom.rows[0]?.line_count ?? 0) > 0;
   107	
   108	    const spec = await ctx.client.query<{ id: string }>(
   109	      `select fs.id
   110	         from public.factory_specs fs
   111	         join public.items i
   112	           on i.org_id = fs.org_id
   113	          and i.id = fs.fg_item_id
   114	        where fs.org_id = app.current_org_id()
   115	          and i.item_code = $1
   116	          and i.item_type = 'fg'
   117	          and fs.status in ('approved_for_factory', 'released_to_factory')
   118	        limit 1`,
   119	      [productCode],
   120	    );
   121	    factorySpecMet = Boolean(spec.rows[0]);
   122	  }
   123	
   124	  const metByCode: Record<ReleaseGateCode, boolean> = {
   125	    G4_REQUIRED: g4Met,
   126	    FG_CANDIDATE_REQUIRED: fgMet,
   127	    ACTIVE_SHARED_BOM_REQUIRED: activeBomMet,
   128	    FACTORY_SPEC_REQUIRED: factorySpecMet,
   129	    V18_OPEN_HIGH_RISK: highRiskMet,
   130	  };
   131	
   132	  return RELEASE_GATE_ORDER.map((code) => ({ code, met: metByCode[code] }));
   133	}
FILE apps/web/app/[locale]/(app)/(npd)/pipeline/[projectId]/handoff/_actions/release-to-factory.ts
     1	'use server';
     2	
     3	/**
     4	 * NPD HANDOFF — explicit owner "Release to factory" gate.
     5	 *
     6	 * Records factory_release_status.release_status = 'released_to_factory' and
     7	 * transitions the active factory_spec to released_to_factory so recall becomes
     8	 * reachable. Reuses the authoritative T-096 release preflight + outbox path.
     9	 *
    10	 * RBAC: npd.gate.approve (same permission as releaseNpdProjectToFactory).
    11	 */
    12	
    13	import { z } from 'zod';
    14	
    15	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    16	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
    17	import { releaseNpdProjectToFactory } from '../../../../../../../(npd)/builder/_actions/release-npd-project-to-factory';
    18	import type { ReleaseToFactoryResult } from './release-to-factory-types';
    19	
    20	const Input = z.object({
    21	  projectId: z.string().uuid(),
    22	});
    23	
    24	type QueryClient = {
    25	  query<T = Record<string, unknown>>(sql: string, params?: readonly unknown[]): Promise<{ rows: T[] }>;
    26	};
    27	
    28	export async function releaseToFactory(raw: unknown): Promise<ReleaseToFactoryResult> {
    29	  const parsed = Input.safeParse(raw);
    30	  if (!parsed.success) {
    31	    return { ok: false, error: 'invalid_input', message: parsed.error.message };
    32	  }
    33	  const { projectId } = parsed.data;
    34	
    35	  try {
    36	    const result = await withOrgContext(async (rawCtx) => {
    37	      const ctx = rawCtx as { userId: string; orgId: string; client: QueryClient };
    38	
    39	      const projectRes = await ctx.client.query<{ id: string }>(
    40	        `select id::text as id
    41	           from public.npd_projects
    42	          where id = $1::uuid
    43	            and org_id = app.current_org_id()
    44	          limit 1`,
    45	        [projectId],
    46	      );
    47	      if (!projectRes.rows[0]) return { ok: false as const, error: 'not_found' as const };
    48	
    49	      const release = await releaseNpdProjectToFactory(projectId, ctx);
    50	      if (!release.ok) {
    51	        if (release.error === 'FORBIDDEN') return { ok: false as const, error: 'forbidden' as const };
    52	        if (release.error === 'INVALID_INPUT') return { ok: false as const, error: 'invalid_input' as const };
    53	        if (release.error === 'PRECONDITION_BLOCKERS' || release.error === 'PACKAGING_UNLINKED') {
    54	          return {
    55	            ok: false as const,
    56	            error: 'release_blocked' as const,
    57	            message: release.blockers?.map((b) => b.code).join(',') ?? release.message,
    58	          };
    59	        }
    60	        return {
    61	          ok: false as const,
    62	          error: 'persistence_failed' as const,
    63	          message: release.message,
    64	        };
    65	      }
    66	
    67	      return {
    68	        ok: true as const,
    69	        data: {
    70	          projectId: release.data.projectId,
    71	          productCode: release.data.productCode,
    72	          releaseStatus: release.data.releaseStatus,
    73	          activeBomHeaderId: release.data.activeBomHeaderId,
    74	          activeFactorySpecId: release.data.activeFactorySpecId,
    75	        },
    76	      };
    77	    });
    78	
    79	    if (!result.ok) return result;
    80	
    81	    safeRevalidatePath(`/[locale]/(app)/(npd)/pipeline/${projectId}/handoff`);
    82	    safeRevalidatePath('/planning/work-orders');
    83	
    84	    return result;
    85	  } catch (error) {
    86	    console.error('[releaseToFactory] persistence_failed:', error);
    87	    const pg = error as { code?: string; message?: string };
    88	    return { ok: false, error: 'persistence_failed', message: pg.message };
    89	  }
    90	}
