    18	  sourceVersionId?: unknown;
    19	}): Promise<CreateVersionResult> {
    20	  const projectId = parseUuid(input?.projectId);
    21	  const requestedSourceVersionId = input?.sourceVersionId === undefined || input?.sourceVersionId === null
    22	    ? null
    23	    : parseUuid(input.sourceVersionId);
    24	  if (!projectId || (input?.sourceVersionId !== undefined && input?.sourceVersionId !== null && !requestedSourceVersionId)) {
    25	    return { ok: false, error: 'invalid_input' };
