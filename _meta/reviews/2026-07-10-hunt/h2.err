    55	
    56	export type HandoffData = {
    57	  checklistId: string;
    58	  projectId: string;
    59	  bomVerificationStatus: string | null;
    60	  promoteToProductionDate: string | null;
    61	  /** True ⇔ a checklist exists with ≥1 item and every item is checked. */
    62	  ready: boolean;
    63	  /** True once the factory release has been recorded for this project. */
    64	  promoted: boolean;
    65	  /**
    66	   * True when the project matches revertToNpd preconditions (release-locked wedge):
    67	   * product npd_locked_for_release_at, handoff promoted markers, or factory release.
    68	   */
    69	  releaseLocked: boolean;
    70	  /** True when the caller may revert a release-locked project (npd.gate.approve). */
    71	  canRevertToNpd: boolean;
