     1	'use server';
     2	
     3	/**
     4	 * NPD HANDOFF — `revertToNpd` Server Action.
     5	 *
     6	 * Reverses a promote-to-production / factory-release wedge: unlocks the NPD
     7	 * project back to the handoff stage without deleting versioned BOMs or specs.
     8	 *
     9	 * Preconditions: the linked product is release-locked (`npd_locked_for_release_at`)
    10	 * and/or the handoff checklist was promoted / factory release is active.
    11	 *
    12	 * When a released factory spec still exists, recalls it (same guards as
    13	 * recallFactorySpec) before clearing the NPD lock. Active released/in-progress
    14	 * work orders referencing the spec block the revert with the same message.
    15	 */
    16	
    17	import { randomUUID } from 'node:crypto';
    18	import { z } from 'zod';
    19	
    20	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    21	import {
    22	  GATE_APPROVE_PERMISSION,
    23	  updateProjectStage,
    24	} from '../../../../../../../(npd)/pipeline/_actions/_lib/gate-helpers';
    25	import { hasPermission } from '../../../../../../../(npd)/pipeline/_actions/shared';
    26	import {
    27	  formatBlockingWorkOrdersError,
    28	  recallFactorySpecInTransaction,
    29	} from '../../../../../../../../lib/technical/recall-factory-spec-core';
    30	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
    31	
    32	import type { RevertToNpdResult } from './revert-to-npd.types';
    33	
    34	const REVERT_TO_NPD_AUDIT_ACTION = 'npd.project.reverted_to_npd';
    35	
    36	const Input = z.object({
    37	  projectId: z.string().uuid(),
    38	  reason: z.string().trim().min(1).max(2000),
    39	});
    40	
    41	type QueryClient = {
    42	  query<T = Record<string, unknown>>(sql: string, params?: readonly unknown[]): Promise<{ rows: T[] }>;
    43	};
    44	
    45	type OrgCtx = { userId: string; orgId: string; client: QueryClient };
    46	
    47	type ProjectRevertRow = {
    48	  id: string;
    49	  code: string;
    50	  product_code: string | null;
    51	  current_stage: string;
    52	  current_gate: string;
    53	  npd_locked_for_release_at: string | null;
    54	};
    55	
    56	type HandoffRow = {
    57	  id: string;
    58	  bom_verification_status: string | null;
    59	  promote_to_production_date: string | null;
    60	};
    61	
    62	type ReleaseRow = {
    63	  release_status: string | null;
    64	  active_factory_spec_id: string | null;
    65	};
    66	
    67	type BlockingWorkOrderRow = { wo_number: string };
    68	
    69	export async function revertToNpd(raw: unknown): Promise<RevertToNpdResult> {
    70	  const parsed = Input.safeParse(raw);
    71	  if (!parsed.success) {
    72	    return { ok: false, error: 'invalid_input', message: parsed.error.message };
    73	  }
    74	
    75	  const { projectId, reason } = parsed.data;
    76	
    77	  try {
    78	    const result = await withOrgContext(async (rawCtx) => {
    79	      const ctx = rawCtx as OrgCtx;
    80	
    81	      if (!(await hasPermission(ctx, GATE_APPROVE_PERMISSION))) {
    82	        return { ok: false as const, error: 'forbidden' as const };
    83	      }
    84	
    85	      const project = await loadProjectForRevert(ctx, projectId);
    86	      const handoff = await loadHandoffForUpdate(ctx, projectId);
    87	      if (!handoff) return { ok: false as const, error: 'not_found' as const };
    88	
    89	      const release = await loadReleaseStatus(ctx, projectId);
    90	      const releaseLocked =
    91	        project.npd_locked_for_release_at !== null ||
    92	        handoff.bom_verification_status === 'promoted' ||
    93	        handoff.promote_to_production_date !== null ||
    94	        release?.release_status === 'released_to_factory';
    95	
    96	      if (!releaseLocked) {
    97	        return { ok: false as const, error: 'not_release_locked' as const };
    98	      }
    99	
   100	      let factorySpecRecalled = false;
   101	      const activeFactorySpecId = release?.active_factory_spec_id ?? null;
   102	
   103	      if (activeFactorySpecId) {
   104	        const blockingWoCodes = await loadBlockingWorkOrders(ctx, activeFactorySpecId);
   105	        if (blockingWoCodes.length > 0) {
   106	          return {
   107	            ok: false as const,
   108	            error: 'active_work_orders' as const,
   109	            message: formatBlockingWorkOrdersError(blockingWoCodes),
   110	          };
   111	        }
   112	
   113	        const recall = await recallFactorySpecInTransaction(ctx, {
   114	          specId: activeFactorySpecId,
   115	          reason,
   116	          requireReleased: false,
   117	        });
   118	        if (!recall.ok) {
   119	          if (recall.error.includes('work orders reference it')) {
   120	            return {
   121	              ok: false as const,
   122	              error: 'active_work_orders' as const,
   123	              message: recall.error,
   124	            };
   125	          }
   126	          return { ok: false as const, error: 'persistence_failed' as const, message: recall.error };
   127	        }
   128	        factorySpecRecalled = recall.recalled;
   129	      }
   130	
   131	      if (project.product_code) {
   132	        await ctx.client.query(
   133	          `update public.product
   134	              set private_jsonb = private_jsonb - 'npd_locked_for_release_at'
   135	            where org_id = app.current_org_id()
   136	              and product_code = $1`,
   137	          [project.product_code],
   138	        );
   139	      }
   140	
   141	      await ctx.client.query(
   142	        `update public.handoff_checklists
   143	            set bom_verification_status = case
   144	                  when bom_verification_status = 'promoted' then 'pending'
   145	                  else bom_verification_status
   146	                end,
   147	                promote_to_production_date = null,
   148	                updated_by = $2::uuid
   149	          where id = $1::uuid
   150	            and org_id = app.current_org_id()`,
   151	        [handoff.id, ctx.userId],
   152	      );
   153	
   154	      if (project.current_stage === 'launched' || project.current_gate === 'Launched') {
   155	        await updateProjectStage(ctx, project.id, 'handoff');
   156	      } else if (project.current_stage !== 'handoff') {
   157	        await updateProjectStage(ctx, project.id, 'handoff');
   158	      }
   159	
   160	      await ctx.client.query(
   161	        `insert into public.audit_events
   162	           (org_id, actor_user_id, actor_type, action, resource_type, resource_id,
   163	            before_state, after_state, request_id, retention_class)
   164	         values (app.current_org_id(), $1::uuid, 'user', $2, 'npd_project', $3,
   165	                 $4::jsonb, $5::jsonb, $6::uuid, 'security')`,
   166	        [
   167	          ctx.userId,
   168	          REVERT_TO_NPD_AUDIT_ACTION,
   169	          project.id,
   170	          JSON.stringify({
   171	            projectId: project.id,
   172	            projectCode: project.code,
   173	            productCode: project.product_code,
   174	            previousStage: project.current_stage,
   175	            previousGate: project.current_gate,
   176	            npdLockedForReleaseAt: project.npd_locked_for_release_at,
   177	            handoffBomVerificationStatus: handoff.bom_verification_status,
   178	            promoteToProductionDate: handoff.promote_to_production_date,
   179	            releaseStatus: release?.release_status ?? null,
   180	            activeFactorySpecId,
   181	          }),
   182	          JSON.stringify({
   183	            currentStage: 'handoff',
   184	            currentGate: 'G4',
   185	            reason,
   186	            factorySpecRecalled,
   187	          }),
   188	          randomUUID(),
   189	        ],
   190	      );
   191	
   192	      return { ok: true as const, factorySpecRecalled };
   193	    });
   194	
   195	    if (!result.ok) return result;
   196	
   197	    safeRevalidatePath(`/[locale]/(app)/(npd)/pipeline/${projectId}/handoff`);
   198	    safeRevalidatePath(`/npd/pipeline/${projectId}`);
   199	    safeRevalidatePath('/technical/factory-specs');
   200	
   201	    return {
   202	      ok: true,
   203	      data: { projectId, factorySpecRecalled: result.factorySpecRecalled },
   204	    };
   205	  } catch (error) {
   206	    console.error('[revertToNpd] persistence_failed:', error);
   207	    const pg = error as { code?: string; constraint?: string; message?: string };
   208	    const detail = [pg.code, pg.constraint ?? pg.message?.slice(0, 120)].filter(Boolean).join(' ');
   209	    return { ok: false, error: 'persistence_failed', message: detail || undefined };
   210	  }
   211	}
   212	
   213	async function loadProjectForRevert(ctx: OrgCtx, projectId: string): Promise<ProjectRevertRow> {
   214	  const { rows } = await ctx.client.query<ProjectRevertRow>(
   215	    `select p.id,
   216	            p.code,
   217	            p.product_code,
   218	            p.current_stage,
   219	            p.current_gate,
   220	            product.private_jsonb ->> 'npd_locked_for_release_at' as npd_locked_for_release_at
   221	       from public.npd_projects p
   222	       left join public.product product
   223	         on product.org_id = p.org_id
   224	        and product.product_code = p.product_code
   225	      where p.id = $1::uuid
   226	        and p.org_id = app.current_org_id()
   227	      for update of p`,
   228	    [projectId],
   229	  );
   230	  const project = rows[0];
   231	  if (!project) throw new Error('NOT_FOUND');
   232	  return project;
   233	}
   234	
   235	async function loadHandoffForUpdate(ctx: OrgCtx, projectId: string): Promise<HandoffRow | null> {
   236	  const { rows } = await ctx.client.query<HandoffRow>(
   237	    `select id,
   238	            bom_verification_status,
   239	            promote_to_production_date::text as promote_to_production_date
   240	       from public.handoff_checklists
   241	      where project_id = $1::uuid
   242	        and org_id = app.current_org_id()
   243	      limit 1
   244	      for update`,
   245	    [projectId],
   246	  );
   247	  return rows[0] ?? null;
   248	}
   249	
   250	async function loadReleaseStatus(ctx: OrgCtx, projectId: string): Promise<ReleaseRow | null> {
   251	  const { rows } = await ctx.client.query<ReleaseRow>(
   252	    `select release_status,
   253	            active_factory_spec_id::text as active_factory_spec_id
   254	       from public.factory_release_status
   255	      where project_id = $1::uuid
   256	        and org_id = app.current_org_id()
   257	      limit 1`,
   258	    [projectId],
   259	  );
   260	  return rows[0] ?? null;
   261	}
   262	
   263	async function loadBlockingWorkOrders(ctx: OrgCtx, specId: string): Promise<string[]> {
   264	  const { rows } = await ctx.client.query<BlockingWorkOrderRow>(
   265	    `select wo_number
   266	       from public.work_orders
   267	      where org_id = app.current_org_id()
   268	        and active_factory_spec_id = $1::uuid
   269	        and upper(status) in ('RELEASED', 'IN_PROGRESS')
   270	      order by wo_number asc
   271	      limit 25`,
   272	    [specId],
   273	  );
   274	  return rows.map((row) => row.wo_number);
   275	}
   276	
   277	function safeRevalidatePath(path: string): void {
   278	  try {
   279	    revalidateLocalized(path, 'page');
   280	  } catch {
   281	    // Vitest imports Server Actions outside a Next request store.
   282	  }
   283	}
FILE apps/web/app/[locale]/(app)/(npd)/pipeline/[projectId]/handoff/_actions/toggle-handoff-checklist-item.ts
     1	'use server';
     2	
     3	/**
     4	 * NPD HANDOFF stage — `toggleHandoffChecklistItem` write Server Action.
     5	 *
     6	 * Toggles a single handoff-checklist item's checked state. Org-scoped via
     7	 * withOrgContext → RLS with app.current_org_id(). The checklist toggle is a
     8	 * low-risk edit consistent with the sibling stages (pilot/trial), so it gates on
     9	 * `npd.handoff.read` (BYTE-IDENTICAL to the seeded permission string in
    10	 * migration 236) — the high-risk promote action gates on `npd.handoff.promote`.
    11	 *
    12	 * Writes an append-only audit_events row and revalidates the handoff route.
    13	 */
    14	
    15	import { z } from 'zod';
    16	
    17	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    18	import { hasHandoffPermission } from './get-handoff';
    19	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
    20	
    21	const Input = z.object({
    22	  projectId: z.string().uuid(),
    23	  itemId: z.string().uuid(),
    24	  isChecked: z.boolean(),
    25	});
    26	
    27	export type ToggleHandoffChecklistItemInput = z.infer<typeof Input>;
    28	
    29	export type ToggleHandoffChecklistItemError =
    30	  | 'invalid_input'
    31	  | 'forbidden'
    32	  | 'not_found'
    33	  | 'persistence_failed';
    34	
    35	export type ToggleHandoffChecklistItemResult =
    36	  | { ok: true; data: { itemId: string; isChecked: boolean } }
    37	  | { ok: false; error: ToggleHandoffChecklistItemError; message?: string };
    38	
    39	const TOGGLE_PERMISSION = 'npd.handoff.read';
    40	
    41	export async function toggleHandoffChecklistItem(
    42	  raw: unknown,
    43	): Promise<ToggleHandoffChecklistItemResult> {
    44	  const parsed = Input.safeParse(raw);
    45	  if (!parsed.success) {
    46	    return { ok: false, error: 'invalid_input', message: parsed.error.message };
    47	  }
    48	  const input = parsed.data;
    49	
    50	  try {
    51	    return await withOrgContext(async (ctx) => {
    52	      if (!(await hasHandoffPermission(ctx, TOGGLE_PERMISSION))) {
    53	        return { ok: false as const, error: 'forbidden' as const };
    54	      }
    55	
    56	      // RLS scopes the update to the org; the join guard ties the item to the
    57	      // checklist owned by the given project so a foreign item id cannot flip.
    58	      const updated = await ctx.client.query<{ id: string; is_checked: boolean }>(
    59	        `update public.handoff_checklist_items ci
    60	            set is_checked = $3,
    61	                updated_by = $4::uuid
    62	           from public.handoff_checklists hc
    63	          where ci.id = $1::uuid
    64	            and ci.org_id = app.current_org_id()
    65	            and hc.id = ci.handoff_checklist_id
    66	            and hc.project_id = $2::uuid
    67	            and hc.org_id = app.current_org_id()
    68	            and hc.bom_verification_status is distinct from 'promoted'
    69	          returning ci.id, ci.is_checked`,
    70	        [input.itemId, input.projectId, input.isChecked, ctx.userId],
    71	      );
    72	      const row = updated.rows[0];
    73	      if (!row) return { ok: false as const, error: 'not_found' as const };
    74	
    75	      await ctx.client.query(
    76	        `insert into public.audit_events
    77	           (org_id, actor_user_id, actor_type, action, resource_type, resource_id,
    78	            after_state, request_id, retention_class)
    79	         values (app.current_org_id(), $1::uuid, 'user',
    80	                 'npd.handoff.checklist.toggled', 'handoff_checklist_item', $2,
    81	                 $3::jsonb, gen_random_uuid(), 'standard')`,
    82	        [ctx.userId, row.id, JSON.stringify({ isChecked: row.is_checked })],
    83	      );
    84	
    85	      revalidateLocalized(`/pipeline/${input.projectId}/handoff`, 'page');
    86	
    87	      return { ok: true as const, data: { itemId: row.id, isChecked: row.is_checked } };
    88	    });
    89	  } catch (error) {
    90	    console.error('[toggleHandoffChecklistItem] persistence_failed:', error);
    91	    return { ok: false, error: 'persistence_failed' };
    92	  }
    93	}
FILE apps/web/app/[locale]/(app)/(npd)/pipeline/[projectId]/handoff/_actions/update-bom-yield.ts
     1	'use server';
     2	
     3	/**
     4	 * NPD HANDOFF stage — `updateBomYield` write Server Action.
     5	 *
     6	 * Sets the target (actual) yield % on the production BOM that was just auto-built
     7	 * by `promoteToProduction`. This powers the inline "Actual yield % for this
     8	 * product" prompt shown on the handoff screen when the promote result reports
     9	 * `yieldPromptRequired === true` (the recipe had no target yield).
    10	 *
    11	 * Org-scoped via withOrgContext → RLS with app.current_org_id(). RBAC gate =
    12	 * `npd.handoff.promote` (BYTE-IDENTICAL to the seeded permission string in
    13	 * migration 236, the SAME gate the promote action uses) via the shared dual-store
    14	 * `hasHandoffPermission` probe (normalized role_permissions OR legacy
    15	 * roles.permissions jsonb cache).
    16	 *
    17	 * Only an ACTIVE bom_header may be updated — the freshly-promoted production BOM
    18	 * is active; an inactive/superseded header is never re-yielded here. A no-op (no
    19	 * matching active row) returns `not_found` (never throws). Writes an append-only
    20	 * audit_events row.
    21	 *
    22	 * A 'use server' module may export ONLY async functions; the zod schema +
    23	 * error/result types live in the non-'use server' sibling `./update-bom-yield-types`.
    24	 */
    25	
    26	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    27	import { hasHandoffPermission } from './get-handoff';
    28	import {
    29	  UpdateBomYieldInput,
    30	  type UpdateBomYieldResult,
    31	} from './update-bom-yield-types';
    32	import { revalidateLocalized } from '../../../../../../../../lib/i18n/revalidate-localized';
    33	
    34	const YIELD_PERMISSION = 'npd.handoff.promote';
    35	
    36	type QueryClient = {
    37	  query<T = Record<string, unknown>>(sql: string, params?: readonly unknown[]): Promise<{ rows: T[] }>;
    38	};
    39	
    40	export async function updateBomYield(raw: unknown): Promise<UpdateBomYieldResult> {
    41	  const parsed = UpdateBomYieldInput.safeParse(raw);
    42	  if (!parsed.success) {
    43	    return { ok: false, code: 'invalid_input' };
    44	  }
    45	  const { bomHeaderId, yieldPct } = parsed.data;
    46	
    47	  try {
    48	    return await withOrgContext(async (rawCtx) => {
    49	      const ctx = rawCtx as { userId: string; orgId: string; client: QueryClient };
    50	
    51	      if (!(await hasHandoffPermission(ctx, YIELD_PERMISSION))) {
    52	        return { ok: false as const, code: 'forbidden' as const };
    53	      }
    54	
    55	      const updated = await ctx.client.query<{ id: string }>(
    56	        `update public.bom_headers
    57	            set yield_pct = $2::numeric
    58	          where id = $1::uuid
    59	            and org_id = app.current_org_id()
    60	            and status = 'active'
    61	          returning id`,
    62	        [bomHeaderId, yieldPct],
    63	      );
    64	      const row = updated.rows[0];
    65	      if (!row) return { ok: false as const, code: 'not_found' as const };
    66	
    67	      await ctx.client.query(
    68	        `insert into public.audit_events
    69	           (org_id, actor_user_id, actor_type, action, resource_type, resource_id,
    70	            after_state, request_id, retention_class)
    71	         values (app.current_org_id(), $1::uuid, 'user',
    72	                 'npd.handoff.bom_yield_set', 'bom_header', $2,
    73	                 $3::jsonb, gen_random_uuid(), 'standard')`,
    74	        [ctx.userId, row.id, JSON.stringify({ yieldPct })],
    75	      );
    76	
    77	      safeRevalidatePath('/[locale]/technical/bom');
    78	
    79	      return { ok: true as const };
    80	    });
    81	  } catch (error) {
    82	    console.error('[updateBomYield] persistence_failed:', error);
    83	    return { ok: false, code: 'persistence_failed' };
    84	  }
    85	}
    86	
    87	function safeRevalidatePath(path: string): void {
    88	  try {
    89	    revalidateLocalized(path, 'page');
    90	  } catch {
    91	    // Vitest imports Server Actions outside a Next request store.
    92	  }
    93	}

