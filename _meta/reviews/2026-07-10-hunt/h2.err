    89	           qty_kg,
    90	           pct,
    91	           cost_per_kg_eur,
    92	           allergens_inherited,
    93	           sequence,
    94	           schema_version
    95	         )
    96	         select
    97	           $1::uuid,
    98	           rm_code,
    99	           item_id,
   100	           qty_kg,
   101	           pct,
   102	           cost_per_kg_eur,
