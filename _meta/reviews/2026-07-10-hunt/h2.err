    81	async function loadRmNutrition(
    82	  client: { query: (sql: string, params?: unknown[]) => Promise<{ rows: RawMaterialNutritionRow[] }> },
    83	  rmCodes: string[],
    84	): Promise<Map<string, Record<string, string>>> {
    85	  const out = new Map<string, Record<string, string>>();
    86	  if (rmCodes.length === 0) return out;
    87	  const uniqueCodes = [...new Set(rmCodes)];
    88	
    89	  let rows: RawMaterialNutritionRow[];
    90	  try {
    91	    const res = await client.query(
    92	      `select rm_code, nutrition_per_100g
    93	         from "Reference"."RawMaterials"
    94	        where rm_code = any($1::text[])`,
    95	      [uniqueCodes],
    96	    );
    97	    rows = res.rows;
    98	  } catch (err) {
    99	    // Canonical RM-nutrition source not yet provisioned → degrade gracefully to
   100	    // empty nutrition rather than failing the whole recompute. Never silent.
   101	    if ((err as { code?: string })?.code === PG_UNDEFINED_TABLE) {
   102	      console.warn(
   103	        '[recomputeAndCache] Reference.RawMaterials missing (migration 103 not applied) — nutrition_json will be empty',
   104	      );
   105	      return out;
   106	    }
   107	    throw err;
   108	  }
