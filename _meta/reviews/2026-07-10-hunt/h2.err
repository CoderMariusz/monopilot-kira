    89	create or replace function public.npd_delete_field(p_field_id uuid)
    90	returns void
    91	language plpgsql
    92	security invoker
    93	set search_path = pg_catalog, public, pg_temp
    94	as $fn$
    95	declare
    96	  v_org_id uuid := app.current_org_id();
    97	  v_field_code text;
    98	  v_column_name text;
    99	begin
   100	  if v_org_id is null then
   101	    raise exception 'npd_delete_field requires app.current_org_id()';
   102	  end if;
   103	
   104	  select code
   105	    into v_field_code
   106	    from public.npd_field_catalog
   107	   where id = p_field_id
   108	     and org_id = v_org_id;
   109	
   110	  if v_field_code is null then
   111	    return;
   112	  end if;
   113	
   114	  v_column_name := lower(regexp_replace(regexp_replace(v_field_code, '([a-z0-9])([A-Z])', '\1_\2', 'g'), '[^a-zA-Z0-9]+', '_', 'g'));
   115	  v_column_name := btrim(v_column_name, '_');
   116	
   117	  if exists (
   118	    select 1
   119	      from information_schema.columns
   120	     where table_schema = 'public'
   121	       and table_name = 'fg_npd_ext'
   122	       and column_name = v_column_name
   123	       and is_nullable = 'YES'
   124	  ) then
   125	    execute format('update public.fg_npd_ext set %I = null, updated_at = now() where org_id = $1', v_column_name)
   126	      using v_org_id;
   127	  end if;
   128	
   129	  delete from public.npd_department_field
   130	   where field_id = p_field_id
   131	     and org_id = v_org_id;
   132	
   133	  delete from public.npd_field_catalog
   134	   where id = p_field_id
   135	     and org_id = v_org_id;
   136	end;
   137	$fn$;
