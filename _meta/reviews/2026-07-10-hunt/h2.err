    26	import { probeReleaseGates, type ReleaseGateStatus } from './release-gate-status';
    27	
    28	const Input = z.object({
    29	  projectId: z.string().uuid(),
    30	});
    31	export type GetHandoffInput = z.infer<typeof Input>;
    32	
    33	export type HandoffChecklistItemDto = {
    34	  id: string;
    35	  label: string;
    36	  isChecked: boolean;
    37	  displayOrder: number;
    38	};
    39	
    40	export type HandoffDestinationBomDto = {
    41	  /** destination_bom_code (soft-ref to bom_headers, 03-technical). */
