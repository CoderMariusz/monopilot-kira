   139	create or replace function public.npd_delete_department(p_department_id uuid)
   140	returns void
   141	language plpgsql
   142	security invoker
   143	set search_path = pg_catalog, public, pg_temp
   144	as $fn$
   145	declare
   146	  v_org_id uuid := app.current_org_id();
   147	  v_dept_code text;
   148	  v_dept_slug text;
   149	  v_field record;
   150	  v_column_name text;
   151	begin
   152	  if v_org_id is null then
   153	    raise exception 'npd_delete_department requires app.current_org_id()';
   154	  end if;
   155	
   156	  select code
   157	    into v_dept_code
   158	    from public.npd_departments
   159	   where id = p_department_id
   160	     and org_id = v_org_id;
   161	
   162	  if v_dept_code is null then
   163	    return;
   164	  end if;
   165	
   166	  for v_field in
   167	    select f.code
   168	      from public.npd_department_field df
   169	      join public.npd_field_catalog f
   170	        on f.id = df.field_id
   171	       and f.org_id = df.org_id
   172	     where df.department_id = p_department_id
   173	       and df.org_id = v_org_id
   174	  loop
   175	    v_column_name := lower(regexp_replace(regexp_replace(v_field.code, '([a-z0-9])([A-Z])', '\1_\2', 'g'), '[^a-zA-Z0-9]+', '_', 'g'));
   176	    v_column_name := btrim(v_column_name, '_');
   177	
   178	    if exists (
   179	      select 1
   180	        from information_schema.columns
   181	       where table_schema = 'public'
   182	         and table_name = 'fg_npd_ext'
   183	         and column_name = v_column_name
   184	         and is_nullable = 'YES'
   185	    ) then
   186	      execute format('update public.fg_npd_ext set %I = null, updated_at = now() where org_id = $1', v_column_name)
   187	        using v_org_id;
   188	    end if;
   189	  end loop;
   190	
   191	  v_dept_slug := lower(regexp_replace(regexp_replace(v_dept_code, '([a-z0-9])([A-Z])', '\1_\2', 'g'), '[^a-zA-Z0-9]+', '_', 'g'));
   192	  v_dept_slug := btrim(v_dept_slug, '_');
   193	
   194	  for v_column_name in
   195	    select unnest(array['closed_' || v_dept_slug, 'done_' || v_dept_slug])
   196	  loop
   197	    if exists (
   198	      select 1
   199	        from information_schema.columns
   200	       where table_schema = 'public'
   201	         and table_name = 'fg_npd_ext'
   202	         and column_name = v_column_name
   203	         and is_nullable = 'YES'
   204	    ) then
   205	      execute format('update public.fg_npd_ext set %I = null, updated_at = now() where org_id = $1', v_column_name)
   206	        using v_org_id;
   207	    end if;
   208	  end loop;
   209	
