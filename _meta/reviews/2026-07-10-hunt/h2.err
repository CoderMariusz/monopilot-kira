   123	
   124	export async function recomputeAndCache(rawInput: RecomputeInput): Promise<RecomputeResult> {
   125	  const input = InputSchema.parse(rawInput);
   126	
   127	  return withOrgContext(async ({ client }) => {
   128	    // ── version parameters (batch / target price / yield) ────────────────────
   129	    // RLS-scoped; the join to formulations confirms the version is in the org's
   130	    // project before we compute / cache anything.
   131	    const metaRes = await client.query<VersionMetaRow>(
   132	      `select fv.batch_size_kg, fv.target_price_eur, fv.target_yield_pct,
   133	              fv.processing_overhead_pct::text as processing_overhead_pct,
   134	              p.pack_weight_g::text as pack_weight_g
   135	         from formulation_versions fv
   136	         join formulations f on f.id = fv.formulation_id
   137	         left join npd_projects p on p.id = f.project_id and p.org_id = app.current_org_id()
   138	        where fv.id = $1::uuid
   139	          and f.project_id = $2::uuid`,
   140	      [input.versionId, input.projectId],
   141	    );
   142	    const meta = metaRes.rows[0];
   143	    if (!meta) {
   144	      throw new Error(`recomputeAndCache: formulation version ${input.versionId} not found for project`);
   145	    }
   146	
   147	    // ── ingredient rows ──────────────────────────────────────────────────────
   148	    // F6 (W9 cross-review BLOCKER): allergens for ITEM-LINKED lines are resolved
   149	    // LIVE from the SSOT public.item_allergen_profiles (pre-aggregated CTE keyed
   150	    // by item_id, single left join — same shape as get-formulation.ts), so a
   151	    // recompute against a locked/legacy version can never union a stale stored
   152	    // cache into allergen_json. The stored column is read ONLY for legacy
   153	    // free-text lines (item_id IS NULL), which have no SSOT source.
   154	    const ingRes = await client.query<IngredientRow>(
   155	      `with profile_allergens as (
   156	         select iap.item_id,
   157	                array_agg(distinct iap.allergen_code order by iap.allergen_code) as codes
   158	           from public.item_allergen_profiles iap
   159	          where iap.org_id = app.current_org_id()
   160	            and iap.item_id in (
   161	              select fi2.item_id
   162	                from formulation_ingredients fi2
   163	               where fi2.version_id = $1::uuid
   164	                 and fi2.item_id is not null
   165	            )
   166	          group by iap.item_id
   167	       )
   168	       select fi.rm_code, fi.qty_kg::text as qty_kg, fi.pct, fi.cost_per_kg_eur,
   169	              case
   170	                when fi.item_id is not null then coalesce(pa.codes, '{}'::text[])
   171	                else coalesce(fi.allergens_inherited, '{}'::text[])
   172	              end as allergens_inherited
   173	         from formulation_ingredients fi
   174	         left join profile_allergens pa on pa.item_id = fi.item_id
   175	        where fi.version_id = $1::uuid
   176	        order by fi.sequence asc`,
   177	      [input.versionId],
   178	    );
   179	
   180	    // ── per-RM nutrition (canonical Reference.RawMaterials.nutrition_per_100g) ─
   181	    const nutritionByRm = await loadRmNutrition(
   182	      client,
   183	      ingRes.rows.map((r) => r.rm_code),
   184	    );
   185	
   186	    const ingredients: RecomputeIngredient[] = ingRes.rows.map((r) => {
   187	      const nutritionPer100g = nutritionByRm.get(r.rm_code);
   188	      return {
   189	        rmCode: r.rm_code,
   190	        qtyKg: r.qty_kg,
   191	        pct: r.pct,
   192	        costPerKgEur: r.cost_per_kg_eur,
   193	        allergensInherited: r.allergens_inherited ?? [],
   194	        ...(nutritionPer100g ? { nutritionPer100g } : {}),
   195	      };
   196	    });
   197	
   198	    const result = recomputeCalc({
   199	      ingredients,
   200	      batchKg: meta.batch_size_kg,
   201	      targetPriceEur: meta.target_price_eur,
   202	      yieldPct: meta.target_yield_pct,
   203	      processingOverheadPct: meta.processing_overhead_pct ?? undefined,
   204	      // Costing v2: pack weight (g) is the batch size; recipe stage adds no packaging.
   205	      packWeightKg: packWeightKgFromGrams(meta.pack_weight_g),
   206	    });
   207	
   208	    // ── upsert the cache row (single statement) ──────────────────────────────
   209	    const costJson = {
   210	      totalPct: result.totalPct,
   211	      totalPctValid: result.totalPctValid,
   212	      totalQtyKg: result.totalQtyKg,
   213	      qtyBalanceValid: result.qtyBalanceValid,
   214	      qtyBalanceUnset: result.qtyBalanceUnset,
   215	      allRmHaveCost: result.allRmHaveCost,
   216	      rawCostPerPack: result.rawCostPerPack,
   217	      rawCost: result.rawCost,
   218	      yieldedCost: result.yieldedCost,
   219	      processing: result.processing,
   220	      packaging: result.packaging,
   221	      costPerKg: result.costPerKg,
   222	      revenuePerKg: result.revenuePerKg,
   223	      marginPct: result.marginPct,
   224	    };
   225	
   226	    await client.query(
   227	      `insert into formulation_calc_cache (version_id, cost_json, nutrition_json, allergen_json, computed_at)
   228	       values ($1::uuid, $2::jsonb, $3::jsonb, $4::jsonb, now())
   229	       on conflict (version_id) do update
   230	         set cost_json = excluded.cost_json,
   231	             nutrition_json = excluded.nutrition_json,
   232	             allergen_json = excluded.allergen_json,
   233	             computed_at = excluded.computed_at`,
   234	      [
   235	        input.versionId,
   236	        JSON.stringify(costJson),
   237	        JSON.stringify(result.nutrition),
   238	        JSON.stringify({ allergens: result.allergens }),
   239	      ],
   240	    );
   241	
   242	    return result;
   243	  });
   244	}
