FILE apps/web/app/[locale]/(app)/(npd)/pipeline/[projectId]/packaging/_actions/listArtworkVersions.ts
     1	'use server';
     2	
     3	/**
     4	 * NPD PACKAGING stage — list artwork versions Server Action.
     5	 *
     6	 * Lists <orgId>/artwork/<projectId>/ and returns the parsed versions sorted
     7	 * DESC (versions[0] = CURRENT) with short-lived signed URLs. No metadata
     8	 * table — the storage listing is the source of truth (least new infra).
     9	 *
    10	 * RBAC read: `npd.packaging.read`.
    11	 */
    12	
    13	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    14	import { PACKAGING_READ_PERMISSION } from './shared';
    15	import {
    16	  IMAGE_MIME_TYPES,
    17	  NPD_ATTACHMENTS_BUCKET,
    18	  NPD_SIGNED_URL_TTL_SECONDS,
    19	  artworkPrefix,
    20	  createNpdStorageAdmin,
    21	  hasNpdPermission,
    22	  parseArtworkObjectName,
    23	  projectExistsInOrg,
    24	  type ArtworkVersionDto,
    25	  type NpdStorageErrorCode,
    26	  type QueryClient,
    27	} from '../../../../../../../../lib/storage/npd-attachments';
    28	
    29	export type ListArtworkVersionsResult =
    30	  | { ok: true; versions: ArtworkVersionDto[] }
    31	  | { ok: false; code: NpdStorageErrorCode };
    32	
    33	export async function listArtworkVersions(input: {
    34	  projectId: string;
    35	}): Promise<ListArtworkVersionsResult> {
    36	  const projectId = input?.projectId;
    37	  if (typeof projectId !== 'string' || !/^[0-9a-f-]{36}$/i.test(projectId)) {
    38	    return { ok: false, code: 'INVALID_INPUT' };
    39	  }
    40	
    41	  try {
    42	    return await withOrgContext<ListArtworkVersionsResult>(async ({ userId, orgId, client }) => {
    43	      const queryClient = client as unknown as QueryClient;
    44	
    45	      if (!(await hasNpdPermission(queryClient, userId, orgId, PACKAGING_READ_PERMISSION))) {
    46	        return { ok: false, code: 'FORBIDDEN' };
    47	      }
    48	      if (!(await projectExistsInOrg(queryClient, projectId))) {
    49	        return { ok: false, code: 'PROJECT_NOT_FOUND' };
    50	      }
    51	
    52	      const prefix = artworkPrefix(orgId, projectId);
    53	      const admin = await createNpdStorageAdmin();
    54	      const { data: entries, error } = await admin.storage
    55	        .from(NPD_ATTACHMENTS_BUCKET)
    56	        .list(prefix, { limit: 200 });
    57	      if (error) return { ok: false, code: 'STORAGE_FAILED' };
    58	
    59	      const parsed = (entries ?? [])
    60	        .filter((e) => e.name && e.metadata)
    61	        .map((e) => ({ entry: e, meta: parseArtworkObjectName(e.name) }))
    62	        .filter((p): p is typeof p & { meta: NonNullable<(typeof p)['meta']> } => p.meta !== null)
    63	        .sort((a, b) => b.meta.version - a.meta.version);
    64	
    65	      if (parsed.length === 0) return { ok: true, versions: [] };
    66	
    67	      const { data: signed, error: signError } = await admin.storage
    68	        .from(NPD_ATTACHMENTS_BUCKET)
    69	        .createSignedUrls(
    70	          parsed.map((p) => `${prefix}/${p.entry.name}`),
    71	          NPD_SIGNED_URL_TTL_SECONDS,
    72	        );
    73	      if (signError || !signed) return { ok: false, code: 'STORAGE_FAILED' };
    74	
    75	      const urlByPath = new Map(signed.map((s) => [s.path ?? '', s.signedUrl]));
    76	      const versions: ArtworkVersionDto[] = parsed.map(({ entry, meta }) => {
    77	        const mimeType = entry.metadata?.mimetype ?? '';
    78	        return {
    79	          version: meta.version,
    80	          objectName: entry.name,
    81	          fileName: meta.fileName,
    82	          sizeBytes: Number(entry.metadata?.size ?? 0),
    83	          uploadedAt: entry.created_at ?? entry.updated_at ?? '',
    84	          signedUrl: urlByPath.get(`${prefix}/${entry.name}`) ?? '',
    85	          mimeType,
    86	          isImage: IMAGE_MIME_TYPES.has(mimeType),
    87	        };
    88	      });
    89	
    90	      return { ok: true, versions };
    91	    });
    92	  } catch (error) {
    93	    console.error('[listArtworkVersions] failed:', error);
    94	    return { ok: false, code: 'PERSISTENCE_FAILED' };
    95	  }
    96	}
