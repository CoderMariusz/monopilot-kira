   128	        const existingItemId = (before.rows[0].item_id as string | null | undefined) ?? null;
   129	        const itemId = itemIdProvided ? (input.itemId ?? null) : existingItemId;
   130	
   131	        if (!(await validatePackagingItemId(itemId))) {
   132	          return { ok: false as const, error: 'invalid_input' as const };
   133	        }
   134	
   135	        const updated = await queryClient.query<{ id: string }>(
   136	          `update public.packaging_components
   137	              set tier          = $2,
   138	                  component_name = $3,
   139	                  material       = $4,
   140	                  supplier_id    = $5::uuid,
   141	                  supplier_code  = $6,
   142	                  spec           = $7,
   143	                  cost_per_unit  = $8::numeric,
   144	                  scrap_pct      = $9::numeric,
   145	                  waste_pct      = $10::numeric,
   146	                  qty_per_pack   = $11::numeric,
   147	                  status         = $12,
   148	                  display_order  = $13,
   149	                  item_id        = $14::uuid,
   150	                  updated_by     = $15::uuid
   151	            where id = $1::uuid and org_id = app.current_org_id()
   152	            returning id`,
   153	          [
   154	            input.id,
   155	            input.tier,
   156	            input.componentName,
   157	            material,
   158	            supplierId,
   159	            supplierCode,
   160	            spec,
   161	            costPerUnit,
   162	            scrapPct,
   163	            wastePct,
   164	            qtyPerPack,
   165	            input.status,
   166	            displayOrder,
   167	            itemId,
   168	            userId,
   169	          ],
   170	        );
   171	        const id = updated.rows[0]?.id;
   172	        if (!id) return { ok: false as const, error: 'not_found' as const };
   173	
   174	        await writeAudit(queryClient, {
   175	          orgId,
   176	          actorUserId: userId,
   177	          action: 'npd.packaging.component.updated',
   178	          resourceId: id,
   179	          beforeState: before.rows[0],
   180	          afterState: {
   181	            tier: input.tier,
   182	            componentName: input.componentName,
   183	            material,
   184	            supplierId,
   185	            supplierCode,
   186	            spec,
   187	            costPerUnit,
   188	            scrapPct,
   189	            wastePct,
   190	            qtyPerPack,
   191	            status: input.status,
   192	            displayOrder,
   193	            itemId,
   194	          },
   195	        });
   196	
   197	        revalidateLocalized(`/pipeline/${input.projectId}/packaging`, 'page');
   198	        return { ok: true as const, data: { id } };
   199	      }
   200	
   201	      // ─── INSERT ─────────────────────────────────────────────────────────────
   202	      const itemId = input.itemId ?? null;
   203	      if (!(await validatePackagingItemId(itemId))) {
   204	        return { ok: false as const, error: 'invalid_input' as const };
   205	      }
   206	
   207	      const inserted = await queryClient.query<{ id: string }>(
   208	        `insert into public.packaging_components
   209	           (org_id, project_id, tier, component_name, material, supplier_id, supplier_code, spec,
   210	            cost_per_unit, scrap_pct, waste_pct, qty_per_pack, status, display_order, item_id, created_by, updated_by)
   211	         values
   212	           (app.current_org_id(), $1::uuid, $2, $3, $4, $5::uuid, $6, $7,
   213	            $8::numeric, $9::numeric, $10::numeric, $11::numeric, $12, $13, $14::uuid, $15::uuid, $16::uuid)
   214	         returning id`,
   215	        [
   216	          input.projectId,
   217	          input.tier,
   218	          input.componentName,
   219	          material,
   220	          supplierId,
   221	          supplierCode,
   222	          spec,
   223	          costPerUnit,
   224	          scrapPct,
   225	          wastePct,
   226	          qtyPerPack,
   227	          input.status,
   228	          displayOrder,
   229	          itemId,
   230	          userId,
   231	          userId,
   232	        ],
   233	      );
   234	      const id = inserted.rows[0]?.id;
   235	      if (!id) throw new Error('packaging_component_insert_returned_no_id');
   236	
   237	      await writeAudit(queryClient, {
   238	        orgId,
   239	        actorUserId: userId,
   240	        action: 'npd.packaging.component.created',
   241	        resourceId: id,
   242	        beforeState: null,
   243	        afterState: {
   244	          projectId: input.projectId,
   245	          tier: input.tier,
   246	          componentName: input.componentName,
   247	          material,
   248	          supplierId,
   249	          supplierCode,
   250	          spec,
   251	          costPerUnit,
   252	          scrapPct,
   253	          wastePct,
   254	          qtyPerPack,
   255	          status: input.status,
   256	          displayOrder,
   257	          itemId,
   258	        },
   259	      });
   260	
   261	      revalidateLocalized(`/pipeline/${input.projectId}/packaging`, 'page');
   262	      return { ok: true as const, data: { id } };
   263	    });
   264	  } catch (err) {
   265	    const code = (err as { code?: string }).code;
   266	    if (code === '23503') return { ok: false, error: 'not_found' };
   267	    console.error('[upsertPackagingComponent] persistence_failed', {
   268	      projectId: input.projectId,
   269	      id: input.id,
   270	      err: err instanceof Error ? err.message : String(err),
   271	    });
   272	    return { ok: false, error: 'persistence_failed' };
   273	  }
   274	}
