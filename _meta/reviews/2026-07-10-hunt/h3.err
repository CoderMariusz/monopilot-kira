     3	export type RecallFactorySpecCoreContext = {
     4	  userId: string;
     5	  client: {
     6	    query<T = Record<string, unknown>>(
     7	      sql: string,
     8	      params?: readonly unknown[],
     9	    ): Promise<{ rows: T[] }>;
    10	  };
    11	};
    12	
    13	type FactorySpecRow = {
    14	  id: string;
    15	  spec_code: string;
    16	  version: number;
    17	  status: string;
    18	  approved_by: string | null;
    19	  approved_at: string | null;
    20	  released_by: string | null;
    21	  released_at: string | null;
    22	};
    23	
    24	type BlockingWorkOrderRow = {
    25	  wo_number: string;
    26	};
    27	
    28	export type RecallFactorySpecCoreResult =
    29	  | { ok: true; recalled: boolean }
    30	  | { ok: false; error: string };
    31	
    32	export function formatBlockingWorkOrdersError(woNumbers: string[]): string {
    33	  return `Factory spec cannot be recalled while released or in-progress work orders reference it: ${woNumbers.join(', ')}`;
    34	}
    35	
    36	async function loadFactorySpecForUpdate(
    37	  client: RecallFactorySpecCoreContext['client'],
    38	  specId: string,
    39	): Promise<FactorySpecRow | null> {
    40	  const { rows } = await client.query<FactorySpecRow>(
    41	    `select id::text as id,
    42	            spec_code,
    43	            version,
    44	            status,
    45	            approved_by::text as approved_by,
    46	            approved_at::text as approved_at,
    47	            released_by::text as released_by,
    48	            released_at::text as released_at
    49	       from public.factory_specs
    50	      where org_id = app.current_org_id()
    51	        and id = $1::uuid
    52	      limit 1
    53	      for update`,
    54	    [specId],
    55	  );
    56	  return rows[0] ?? null;
    57	}
    58	
    59	async function loadBlockingWorkOrders(
    60	  client: RecallFactorySpecCoreContext['client'],
    61	  specId: string,
    62	): Promise<string[]> {
    63	  const { rows } = await client.query<BlockingWorkOrderRow>(
    64	    `select wo_number
    65	       from public.work_orders
    66	      where org_id = app.current_org_id()
    67	        and active_factory_spec_id = $1::uuid
    68	        and upper(status) in ('RELEASED', 'IN_PROGRESS')
    69	      order by wo_number asc
    70	      limit 25`,
    71	    [specId],
    72	  );
    73	  return rows.map((row) => row.wo_number);
    74	}
    75	
    76	async function writeRecallAudit(
    77	  ctx: RecallFactorySpecCoreContext,
    78	  params: {
    79	    spec: FactorySpecRow;
    80	    reason: string | null;
    81	  },
    82	): Promise<void> {
    83	  await ctx.client.query(
    84	    `insert into public.audit_events
    85	       (org_id, actor_user_id, actor_type, action, resource_type, resource_id,
    86	        before_state, after_state, request_id, retention_class)
    87	     values
    88	       (app.current_org_id(), $1::uuid, 'user', 'technical.factory_spec.recalled',
    89	        'factory_spec', $2, $3::jsonb, $4::jsonb, $5::uuid, 'operational')`,
    90	    [
    91	      ctx.userId,
    92	      params.spec.id,
    93	      JSON.stringify({
    94	        spec_id: params.spec.id,
    95	        spec_code: params.spec.spec_code,
    96	        version: params.spec.version,
    97	        status: params.spec.status,
    98	        approved_by: params.spec.approved_by,
    99	        approved_at: params.spec.approved_at,
   100	        released_by: params.spec.released_by,
   101	        released_at: params.spec.released_at,
   102	      }),
   103	      JSON.stringify({
   104	        status: 'draft',
   105	        reason: params.reason,
   106	      }),
   107	      randomUUID(),
   108	    ],
   109	  );
   110	}
   111	
   112	/**
   113	 * Recall a released factory spec inside an existing org-scoped transaction.
   114	 * Canonical SQL lives here; recall-spec.ts and revert-to-npd.ts both route through it.
   115	 */
   116	export async function recallFactorySpecInTransaction(
   117	  ctx: RecallFactorySpecCoreContext,
   118	  input: { specId: string; reason?: string | null; requireReleased?: boolean },
   119	): Promise<RecallFactorySpecCoreResult> {
   120	  const reason =
   121	    typeof input.reason === 'string' && input.reason.trim().length > 0 ? input.reason.trim() : null;
   122	  const requireReleased = input.requireReleased ?? true;
   123	
   124	  const spec = await loadFactorySpecForUpdate(ctx.client, input.specId);
   125	  if (!spec) return { ok: false, error: 'factory_spec not found' };
   126	  if (spec.status !== 'released_to_factory') {
   127	    if (requireReleased) {
   128	      return { ok: false, error: `factory_spec is ${spec.status}; expected released_to_factory` };
   129	    }
   130	    return { ok: true, recalled: false };
   131	  }
   132	
   133	  const blockingWoCodes = await loadBlockingWorkOrders(ctx.client, spec.id);
   134	  if (blockingWoCodes.length > 0) {
   135	    return { ok: false, error: formatBlockingWorkOrdersError(blockingWoCodes) };
   136	  }
   137	
   138	  const { rows } = await ctx.client.query<{ id: string }>(
   139	    `update public.factory_specs
   140	        set status = 'draft',
   141	            approved_by = null,
   142	            approved_at = null,
   143	            released_by = null,
   144	            released_at = null,
   145	            updated_at = now()
   146	      where org_id = app.current_org_id()
   147	        and id = $1::uuid
   148	        and status = 'released_to_factory'
   149	      returning id::text as id`,
   150	    [spec.id],
   151	  );
   152	  if (!rows[0]) return { ok: false, error: 'factory_spec no longer released_to_factory' };
   153	
   154	  await ctx.client.query(
   155	    `update public.factory_release_status
   156	        set release_status = 'approved_for_factory',
   157	            updated_at = now()
   158	      where org_id = app.current_org_id()
   159	        and active_factory_spec_id = $1::uuid
   160	        and release_status = 'released_to_factory'`,
   161	    [spec.id],
   162	  );
   163	
   164	  await writeRecallAudit(ctx, { spec, reason });
   165	  return { ok: true, recalled: true };
   166	}

