    13	
    14	export async function approveChangeOrder(rawInput: unknown): Promise<MutateEcoResult> {
    15	  const parsed = ApproveEcoInput.safeParse(rawInput);
    16	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    17	
    18	  try {
    19	    return await withOrgContext(async ({ userId, orgId, client }): Promise<MutateEcoResult> => {
    20	      const qc = client as QueryClient;
    21	      const ctx: OrgActionContext = { userId, orgId, client: qc };
    22	      if (!(await hasPermission(ctx, ECO_APPROVE_PERMISSION))) return { ok: false, error: 'forbidden' };
    23	
    24	      const { rows } = await qc.query<{ id: string; previous_status: string; status: string }>(
    25	        `update public.technical_change_orders
    26	            set status = 'approved',
    27	                approver_user_id = $2::uuid,
    28	                approved_at = pg_catalog.now(),
    29	                updated_by = $2::uuid
