    12	  fg_name: string;
    13	  component_qty: number;
    14	  component_uom: string;
    15	};
    16	
    17	type SortKey = 'fg_code' | 'fg_name' | 'component_qty' | 'component_uom';
    18	
    19	function sortRows(rows: WhereUsedResult[], key: SortKey, direction: 'asc' | 'desc') {
    20	  return [...rows].sort((a, b) => {
    21	    const av = a[key];
    22	    const bv = b[key];
    23	    const result = typeof av === 'number' && typeof bv === 'number'
    24	      ? av - bv
    25	      : String(av).localeCompare(String(bv));
    26	    return direction === 'asc' ? result : -result;
    27	  });
    28	}
    29	
    30	export default function TechnicalWhereUsedPage() {
    31	  const searchParams = useSearchParams();
    32	  const initialCode = searchParams.get('code') ?? '';
    33	  const [code, setCode] = useState(initialCode);
    34	  const [rows, setRows] = useState<WhereUsedResult[]>([]);
    35	  const [error, setError] = useState(false);
    36	  const [sortKey, setSortKey] = useState<SortKey>('fg_code');
    37	  const [sortDirection, setSortDirection] = useState<'asc' | 'desc'>('asc');
    38	  const [pending, startTransition] = useTransition();
    39	
    40	  useEffect(() => {
    41	    setCode(initialCode);
    42	    setError(false);
    43	    if (!initialCode.trim()) {
    44	      setRows([]);
    45	      return;
    46	    }
    47	    startTransition(async () => {
    48	      try {
    49	        setRows(await listWhereUsed(initialCode));
    50	      } catch (err) {
    51	        console.error('[technical/where-used] client_load_failed', err);
    52	        setRows([]);
    53	        setError(true);
    54	      }
    55	    });
    56	  }, [initialCode]);
    57	
    58	  const filtered = useMemo(() => {
    59	    const q = code.trim().toLowerCase();
    60	    const base = q
    61	      ? rows.filter((row) =>
    62	          [row.fg_code, row.fg_name, row.component_uom].some((value) => value.toLowerCase().includes(q)),
    63	        )
    64	      : rows;
    65	    return sortRows(base, sortKey, sortDirection);
    66	  }, [code, rows, sortDirection, sortKey]);
    67	
    68	  function toggleSort(key: SortKey) {
    69	    if (sortKey === key) {
    70	      setSortDirection((current) => (current === 'asc' ? 'desc' : 'asc'));
    71	      return;
    72	    }
    73	    setSortKey(key);
    74	    setSortDirection('asc');
    75	  }
    76	
    77	  return (
    78	    <main data-screen="technical-where-used" className="flex w-full flex-col gap-4 px-6 py-6">
    79	      <nav className="breadcrumb" aria-label="Breadcrumb">
    80	        Technical / Where used
    81	      </nav>
    82	
    83	      <header>
    84	        <h1 className="page-title">Where used</h1>
    85	        <p className="helper mt-1 max-w-3xl">Find every FG BOM that uses an ingredient or item code as a component.</p>
    86	      </header>
    87	
    88	      <section className="flex flex-col gap-3 rounded border border-slate-200 bg-white p-4">
    89	        <label className="flex max-w-md flex-col gap-1 text-sm font-medium">
    90	          Ingredient or item code
    91	          <Input
    92	            type="search"
    93	            value={code}
    94	            onChange={(event) => setCode(event.target.value)}
    95	            placeholder="Filter loaded results"
    96	          />
    97	        </label>
    98	
    99	        {!initialCode.trim() ? (
   100	          <div className="empty-state" data-testid="where-used-empty-query">
   101	            <div className="empty-state-title">Enter a code in the URL</div>
   102	            <div className="empty-state-body">Use ?code=RM-1001 to load where-used results.</div>
   103	          </div>
   104	        ) : error ? (
   105	          <div role="alert" className="alert alert-red" data-testid="where-used-error">
   106	            <div className="alert-title">Could not load where-used results.</div>
   107	          </div>
   108	        ) : pending ? (
   109	          <div aria-busy="true" data-testid="where-used-loading" className="h-44 animate-pulse rounded bg-slate-100" />
   110	        ) : filtered.length === 0 ? (
   111	          <div className="empty-state" data-testid="where-used-empty">
   112	            <div className="empty-state-title">No FG usage found</div>
   113	            <div className="empty-state-body">No loaded BOM uses this component code.</div>
   114	          </div>
   115	        ) : (
   116	          <div className="overflow-x-auto">
   117	            <table className="w-full border-collapse text-sm" data-testid="where-used-table">
   118	              <thead>
   119	                <tr className="border-b border-slate-200 text-left">
   120	                  {[
   121	                    ['fg_code', 'FG code'],
   122	                    ['fg_name', 'FG name'],
   123	                    ['component_qty', 'Component quantity'],
   124	                    ['component_uom', 'UoM'],
   125	                  ].map(([key, label]) => (
   126	                    <th key={key} className="px-3 py-2">
   127	                      <button type="button" className="font-semibold" onClick={() => toggleSort(key as SortKey)}>
   128	                        {label}
   129	                      </button>
   130	                    </th>
   131	                  ))}
   132	                </tr>
   133	              </thead>
   134	              <tbody>
   135	                {filtered.map((row) => (
   136	                  <tr key={`${row.fg_code}-${row.component_uom}`} className="border-b border-slate-100">
   137	                    <td className="px-3 py-2 font-mono">{row.fg_code}</td>
