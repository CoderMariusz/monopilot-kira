     1	'use server';
     2	
     3	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
     4	import { applyEcoOnClose, EcoApplyAbort } from '../../../../../../../lib/technical/eco-apply-service';
     5	import {
     6	  ECO_WRITE_PERMISSION,
     7	  EcoCloseAbort,
     8	  hasPermission,
     9	  type MutateEcoResult,
    10	  type OrgActionContext,
    11	  type QueryClient,
    12	  TransitionEcoInput,
    13	  writeEcoAudit,
    14	} from './shared';
    15	
    16	export async function closeChangeOrder(rawInput: unknown): Promise<MutateEcoResult> {
    17	  const parsed = TransitionEcoInput.safeParse(rawInput);
    18	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    19	
    20	  try {
    21	    return await withOrgContext(async ({ userId, orgId, client }): Promise<MutateEcoResult> => {
    22	      const qc = client as QueryClient;
    23	      const ctx: OrgActionContext = { userId, orgId, client: qc };
    24	      if (!(await hasPermission(ctx, ECO_WRITE_PERMISSION))) return { ok: false, error: 'forbidden' };
    25	
    26	      const { rows: locked } = await qc.query<{ id: string; status: string }>(
    27	        `select id, status
    28	           from public.technical_change_orders
    29	          where org_id = app.current_org_id()
    30	            and id = $1::uuid
    31	            and status = 'implementing'
    32	          for update`,
    33	        [parsed.data.id],
    34	      );
    35	      const lockedOrder = locked[0];
    36	      if (!lockedOrder) {
    37	        const exists = await qc.query<{ id: string }>(
    38	          `select id from public.technical_change_orders where org_id = app.current_org_id() and id = $1::uuid`,
    39	          [parsed.data.id],
    40	        );
    41	        if (!exists.rows[0]) return { ok: false, error: 'not_found' };
    42	        return { ok: false, error: 'invalid_state' };
    43	      }
    44	
    45	      const apply = await applyEcoOnClose(ctx, parsed.data.id);
    46	      if (!apply.ok) {
    47	        return {
    48	          ok: false,
    49	          error: apply.error,
    50	          message: apply.message,
    51	        };
    52	      }
    53	
    54	      const { rows } = await qc.query<{ id: string; status: string }>(
    55	        `update public.technical_change_orders
    56	            set status = 'closed',
    57	                closed_at = pg_catalog.now(),
    58	                updated_by = $2::uuid
    59	          where org_id = app.current_org_id()
    60	            and id = $1::uuid
    61	            and status = 'implementing'
    62	          returning id, status`,
    63	        [parsed.data.id, userId],
    64	      );
    65	      const order = rows[0];
    66	      if (!order) {
    67	        throw new EcoCloseAbort('invalid_state', 'change order is no longer implementing');
    68	      }
    69	
    70	      await qc.query(
    71	        `insert into public.technical_change_order_approvals
    72	           (org_id, change_order_id, action, from_status, to_status, actor_user_id, comment)
    73	         values (app.current_org_id(), $1::uuid, 'close', 'implementing', 'closed', $2::uuid, $3)`,
    74	        [order.id, userId, parsed.data.comment ?? null],
    75	      );
    76	      await writeEcoAudit(qc, {
    77	        orgId,
    78	        changeOrderId: order.id,
    79	        actorUserId: userId,
    80	        action: apply.data.applied ? 'eco.applied' : 'eco.closed',
    81	        fromStatus: 'implementing',
    82	        toStatus: 'closed',
    83	        payload: {
    84	          comment: parsed.data.comment ?? null,
    85	          apply: apply.data,
    86	        },
    87	      });
    88	
    89	      return { ok: true, data: { id: order.id, status: 'closed' } };
    90	    });
    91	  } catch (error) {
    92	    if (error instanceof EcoCloseAbort) {
    93	      return { ok: false, error: error.code, message: error.detail };
    94	    }
    95	    if (error instanceof EcoApplyAbort) {
    96	      return { ok: false, error: error.code, message: error.detail };
    97	    }
    98	    console.error('[technical/eco] closeChangeOrder failed', {
    99	      err: error instanceof Error ? error.message : String(error),
   100	    });
   101	    return { ok: false, error: 'persistence_failed' };
   102	  }
   103	}
