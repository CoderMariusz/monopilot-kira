    61	function isPgError(err: unknown): err is { code: string } {
    62	  return typeof err === 'object' && err !== null && typeof (err as { code?: unknown }).code === 'string';
    63	}
    64	
    65	async function requireFactorySpec(
    66	  client: QueryClient,
    67	  specId: string,
    68	): Promise<SpecRow | null> {
    69	  const { rows } = await client.query<SpecRow>(
    70	    `select fs.id,
    71	            fs.status,
    72	            fs.fg_item_id,
    73	            i.item_code as fg_item_code,
    74	            fs.bom_header_id,
    75	            fs.bom_version
    76	       from public.factory_specs fs
    77	       join public.items i on i.id = fs.fg_item_id and i.org_id = fs.org_id
    78	      where fs.id = $1::uuid
    79	        and fs.org_id = app.current_org_id()
    80	      limit 1`,
    81	    [specId],
    82	  );
    83	  return rows[0] ?? null;
    84	}
    85	
    86	async function requireFactorySpecForRelease(
    87	  client: QueryClient,
    88	  specId: string,
    89	): Promise<ReleaseSpecRow | null> {
    90	  const { rows } = await client.query<ReleaseSpecRow>(
    91	    `select fs.id,
    92	            fs.status,
    93	            fs.fg_item_id,
    94	            i.item_code as fg_item_code,
    95	            fs.bom_header_id,
    96	            fs.bom_version,
    97	            fs.approved_by::text as approved_by,
    98	            fs.approved_at::text as approved_at
    99	       from public.factory_specs fs
   100	       join public.items i on i.id = fs.fg_item_id and i.org_id = fs.org_id
   101	      where fs.id = $1::uuid
   102	        and fs.org_id = app.current_org_id()
   103	      limit 1
   104	      for update`,
   105	    [specId],
   106	  );
   107	  return rows[0] ?? null;
   108	}
