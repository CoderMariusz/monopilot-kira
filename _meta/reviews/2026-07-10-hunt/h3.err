   205	export async function publishWipDefinitionFromComponent(input: PublishWipDefinitionFromComponentInput): Promise<ActionResult<{ id: string }>> {
   206	  const parsed = publishWipDefinitionFromComponentInputSchema.safeParse(input);
   207	  if (!parsed.success) return { ok: false, error: 'Invalid publish input', code: 'VALIDATION_ERROR' };
   208	
   209	  return withOrgContext<ActionResult<{ id: string }>>(async (ctx) => {
   210	    if (!(await hasPermission(ctx, NPD_PRODUCTION_WRITE_PERMISSION))) {
   211	      return { ok: false, error: `${NPD_PRODUCTION_WRITE_PERMISSION} is required`, code: 'FORBIDDEN', status: 403 };
   212	    }
   213	
   214	    // D42: the WIP's base unit = the creating process's OUTPUT unit — taken from the
   215	    // LAST process in the component chain (throughput_uom, mig 429); fallback 'kg'.
   216	    const component = await ctx.client.query<{ project_id: string | null; output_uom: string }>(
   217	      `select p.id as project_id,
   218	              coalesce(last_proc.throughput_uom, 'kg') as output_uom
   219	         from public.prod_detail pd
   220	         left join public.npd_projects p on p.product_code = pd.product_code and p.org_id = pd.org_id
   221	         left join lateral (
   222	           select wp.throughput_uom
   223	             from public.npd_wip_processes wp
   224	            where wp.org_id = pd.org_id
   225	              and wp.prod_detail_id = pd.id
   226	              and wp.throughput_uom in ('kg', 'g', 'each', 'pack')
   227	            order by wp.display_order desc
   228	            limit 1
   229	         ) last_proc on true
   230	        where pd.id = $1::uuid
   231	          and pd.org_id = app.current_org_id()
   232	        limit 1`,
   233	      [parsed.data.prodDetailId],
   234	    );
   235	    const componentRow = component.rows[0];
   236	    if (!componentRow) return { ok: false, error: 'Production component not found', code: 'NOT_FOUND', status: 404 };
   237	
   238	    // Idempotency: a component publishes at most one definition — a re-submit
   239	    // returns the existing one instead of minting duplicates (review M2).
   240	    const alreadyPublished = await ctx.client.query<{ wip_definition_id: string }>(
   241	      `select wip_definition_id::text
   242	         from public.npd_wip_processes
   243	        where org_id = app.current_org_id()
   244	          and prod_detail_id = $1::uuid
   245	          and wip_definition_id is not null
   246	        limit 1`,
   247	      [parsed.data.prodDetailId],
   248	    );
   249	    const existingDefinitionId = alreadyPublished.rows[0]?.wip_definition_id;
   250	    if (existingDefinitionId) return { ok: true, id: existingDefinitionId };
   251	
   252	    const itemId = await ensureDefinitionItem(ctx, parsed.data.name, componentRow.output_uom ?? 'kg');
   253	    const inserted = await ctx.client.query<{ id: string }>(
   254	      `insert into public.wip_definitions
   255	         (org_id, item_id, name, base_uom, status, reusable, source_project_id, created_by)
   256	       values
   257	         (app.current_org_id(), $1::uuid, $2, $3, 'active', true, $4::uuid, $5::uuid)
   258	       returning id`,
   259	      [itemId, parsed.data.name, componentRow.output_uom ?? 'kg', componentRow.project_id, ctx.userId],
   260	    );
   261	    const definitionId = inserted.rows[0]?.id;
   262	    if (!definitionId) throw new Error('Could not publish WIP definition');
   263	
   264	    const processes = await ctx.client.query<{
   265	      id: string;
   266	      process_name: string;
   267	      display_order: number;
   268	      duration_hours: string | number;
   269	      additional_cost: string | number;
   270	      throughput_per_hour: string | number | null;
   271	      throughput_uom: string | null;
   272	      setup_cost: string | number;
   273	      yield_pct: string | number;
   274	    }>(
   275	      `select id, process_name, display_order, duration_hours, additional_cost,
   276	              throughput_per_hour, throughput_uom, setup_cost, yield_pct
   277	         from public.npd_wip_processes
   278	        where org_id = app.current_org_id()
   279	          and prod_detail_id = $1::uuid
   280	        order by display_order asc`,
   281	      [parsed.data.prodDetailId],
   282	    );
   283	
   284	    for (const process of processes.rows) {
   285	      const copied = await ctx.client.query<{ id: string }>(
   286	        `insert into public.wip_definition_processes
   287	           (org_id, wip_definition_id, process_name, display_order, duration_hours, additional_cost,
   288	            throughput_per_hour, throughput_uom, setup_cost, yield_pct)
   289	         values
   290	           (app.current_org_id(), $1::uuid, $2, $3::int, $4::numeric, $5::numeric, $6::numeric, $7, $8::numeric, $9::numeric)
   291	         returning id`,
   292	        [
   293	          definitionId,
   294	          process.process_name,
   295	          process.display_order,
   296	          process.duration_hours,
   297	          process.additional_cost,
   298	          process.throughput_per_hour,
   299	          process.throughput_uom,
   300	          process.setup_cost,
   301	          process.yield_pct ?? 100,
   302	        ],
   303	      );
   304	      const copiedId = copied.rows[0]?.id;
   305	      if (!copiedId) throw new Error('Could not copy WIP process');
   306	      await ctx.client.query(
   307	        `insert into public.wip_definition_roles
   308	           (org_id, process_id, role_group, headcount, rate_per_hour)
   309	         select app.current_org_id(), $2::uuid, role_group, headcount, rate_per_hour
   310	           from public.npd_wip_process_roles
   311	          where org_id = app.current_org_id()
   312	            and process_id = $1::uuid`,
   313	        [process.id, copiedId],
   314	      );
   315	    }
   316	
   317	    await ctx.client.query(
   318	      `update public.npd_wip_processes
   319	          set wip_definition_id = $2::uuid,
   320	              wip_item_id = $3::uuid,
   321	              updated_at = now()
   322	        where org_id = app.current_org_id()
   323	          and prod_detail_id = $1::uuid`,
   324	      [parsed.data.prodDetailId, definitionId, itemId],
   325	    );
   326	
   327	    return { ok: true, id: definitionId };
   328	  });
   329	}
