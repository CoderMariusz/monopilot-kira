   110	async function writeAuditEvent(
   111	  client: QueryClient,
   112	  params: {
   113	    orgId: string;
   114	    actorUserId: string;
   115	    action: string;
   116	    resourceId: string;
   117	    beforeState: unknown;
   118	    afterState: unknown;
   119	  },
   120	): Promise<void> {
   121	  await client.query(
   122	    `insert into public.audit_events
   123	       (org_id, actor_user_id, actor_type, action, resource_type, resource_id,
   124	        before_state, after_state, request_id, retention_class)
   125	     values
   126	       ($1::uuid, $2::uuid, 'user', $3, 'factory_spec', $4,
   127	        $5::jsonb, $6::jsonb, $7::uuid, 'standard')`,
   128	    [
   129	      params.orgId,
   130	      params.actorUserId,
   131	      params.action,
   132	      params.resourceId,
   133	      JSON.stringify(params.beforeState),
   134	      JSON.stringify(params.afterState),
   135	      randomUUID(),
   136	    ],
   137	  );
   138	}
   139	
   140	export async function submitFactorySpecForReview(rawInput: unknown): Promise<SubmitFactorySpecForReviewResult> {
   141	  const parsed = SubmitFactorySpecInput.safeParse(rawInput);
   142	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   143	
   144	  try {
   145	    return await withOrgContext(async ({ userId, orgId, client }): Promise<SubmitFactorySpecForReviewResult> => {
   146	      const db = client as QueryClient;
   147	      const ctx: OrgActionContext = { userId, orgId, client: db };
   148	      if (!(await canApproveFactorySpec(ctx))) return { ok: false, error: 'forbidden' };
   149	
   150	      const spec = await requireFactorySpec(db, parsed.data.specId);
   151	      if (!spec) return { ok: false, error: 'not_found' };
   152	      if (spec.status !== 'draft') {
   153	        return {
   154	          ok: false,
   155	          error: 'invalid_state',
   156	          message: `factory_spec is ${spec.status}; expected draft`,
   157	        };
   158	      }
   159	
   160	      const transition = guardStatusTransition(spec.status, 'in_review');
   161	      if (!transition.ok) {
   162	        return { ok: false, error: 'invalid_state', message: transition.message };
   163	      }
   164	
   165	      const { rows } = await db.query<{ id: string }>(
   166	        `update public.factory_specs
   167	            set status = 'in_review'
   168	          where id = $1::uuid
   169	            and org_id = app.current_org_id()
   170	            and status = 'draft'
   171	          returning id`,
   172	        [spec.id],
   173	      );
   174	      if (!rows[0]) {
   175	        return { ok: false, error: 'invalid_state', message: 'factory_spec no longer draft' };
   176	      }
   177	
   178	      await writeAuditEvent(db, {
   179	        orgId,
   180	        actorUserId: userId,
   181	        action: 'factory_spec.submitted_for_review',
   182	        resourceId: spec.id,
   183	        beforeState: { status: spec.status },
   184	        afterState: { status: 'in_review' },
   185	      });
   186	
   187	      safeRevalidatePath('/technical/factory-specs');
   188	      return { ok: true, data: { specId: spec.id, status: 'in_review' } };
   189	    });
   190	  } catch (err) {
   191	    if (isPgError(err) && err.code === '23514') return { ok: false, error: 'invalid_state' };
   192	    console.error('[technical/factory-specs] submitFactorySpecForReview persistence_failed', {
   193	      err: err instanceof Error ? err.message : String(err),
   194	    });
   195	    return { ok: false, error: 'persistence_failed' };
   196	  }
   197	}
   198	
   199	export async function linkFactorySpecBom(rawInput: unknown): Promise<LinkFactorySpecBomResult> {
   200	  const parsed = LinkFactorySpecBomInput.safeParse(rawInput);
   201	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   202	
   203	  try {
   204	    return await withOrgContext(async ({ userId, orgId, client }): Promise<LinkFactorySpecBomResult> => {
   205	      const db = client as QueryClient;
   206	      const ctx: OrgActionContext = { userId, orgId, client: db };
   207	      if (!(await canApproveFactorySpec(ctx))) return { ok: false, error: 'forbidden' };
   208	
   209	      const spec = await requireFactorySpec(db, parsed.data.specId);
   210	      if (!spec) return { ok: false, error: 'not_found' };
   211	
   212	      const editGuard = guardBusinessFieldEdit(spec.status);
   213	      if (!editGuard.ok || !['draft', 'in_review'].includes(spec.status)) {
   214	        return {
   215	          ok: false,
   216	          error: 'invalid_state',
   217	          message: editGuard.ok
   218	            ? `factory_spec is ${spec.status}; expected draft or in_review`
   219	            : editGuard.message,
   220	        };
   221	      }
   222	
   223	      const { rows: bomRows } = await db.query<BomRow>(
   224	        `select id, product_id, version, status
   225	           from public.bom_headers
   226	          where id = $1::uuid
   227	            and org_id = app.current_org_id()
   228	          limit 1`,
   229	        [parsed.data.bomHeaderId],
   230	      );
   231	      const bom = bomRows[0];
   232	      if (!bom) return { ok: false, error: 'not_found', message: 'BOM header not found' };
   233	      if (bom.product_id !== spec.fg_item_code) {
   234	        return {
   235	          ok: false,
   236	          error: 'product_mismatch',
   237	          message: `BOM product ${bom.product_id ?? 'none'} does not match factory_spec FG ${spec.fg_item_code}`,
   238	        };
   239	      }
   240	
   241	      const { rows } = await db.query<{ id: string }>(
   242	        `update public.factory_specs
   243	            set bom_header_id = $2::uuid,
   244	                bom_version = $3::integer
   245	          where id = $1::uuid
   246	            and org_id = app.current_org_id()
   247	            and status in ('draft', 'in_review')
   248	          returning id`,
   249	        [spec.id, bom.id, bom.version],
   250	      );
   251	      if (!rows[0]) {
   252	        return { ok: false, error: 'invalid_state', message: 'factory_spec no longer draft/in_review' };
   253	      }
   254	
   255	      await writeAuditEvent(db, {
   256	        orgId,
   257	        actorUserId: userId,
   258	        action: 'factory_spec.bom_linked',
   259	        resourceId: spec.id,
   260	        beforeState: { bomHeaderId: spec.bom_header_id, bomVersion: spec.bom_version },
   261	        afterState: { bomHeaderId: bom.id, bomVersion: bom.version, bomStatus: bom.status },
   262	      });
   263	
   264	      safeRevalidatePath('/technical/factory-specs');
   265	      return {
   266	        ok: true,
   267	        data: {
   268	          specId: spec.id,
   269	          bomHeaderId: bom.id,
   270	          bomVersion: Number(bom.version),
   271	          bomStatus: bom.status,
   272	        },
   273	      };
   274	    });
   275	  } catch (err) {
   276	    if (isPgError(err) && err.code === '23503') return { ok: false, error: 'not_found' };
   277	    if (isPgError(err) && err.code === '23514') return { ok: false, error: 'invalid_state' };
   278	    console.error('[technical/factory-specs] linkFactorySpecBom persistence_failed', {
   279	      err: err instanceof Error ? err.message : String(err),
   280	    });
   281	    return { ok: false, error: 'persistence_failed' };
   282	  }
   283	}
   284	
   285	async function loadFgNpdProjectId(client: QueryClient, fgItemId: string): Promise<string | null> {
   286	  const { rows } = await client.query<{ npd_project_id: string | null }>(
   287	    `select i.npd_project_id::text as npd_project_id
   288	       from public.items i
   289	      where i.id = $1::uuid
   290	        and i.org_id = app.current_org_id()
   291	      limit 1`,
   292	    [fgItemId],
   293	  );
   294	  return rows[0]?.npd_project_id ?? null;
   295	}
   296	
   297	export async function releaseFactorySpecToFactory(rawInput: unknown): Promise<ReleaseFactorySpecResult> {
   298	  const parsed = ReleaseFactorySpecInput.safeParse(rawInput);
   299	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   300	
   301	  try {
   302	    return await withOrgContext(async ({ userId, orgId, client }): Promise<ReleaseFactorySpecResult> => {
   303	      const db = client as QueryClient;
   304	      const ctx: OrgActionContext = { userId, orgId, client: db };
   305	      if (!(await canApproveFactorySpec(ctx))) return { ok: false, error: 'forbidden' };
   306	
   307	      const spec = await requireFactorySpecForRelease(db, parsed.data.specId);
   308	      if (!spec) return { ok: false, error: 'not_found' };
   309	      if (spec.status !== 'approved_for_factory') {
   310	        return {
   311	          ok: false,
   312	          error: 'invalid_state',
   313	          message: `factory_spec is ${spec.status}; expected approved_for_factory`,
   314	        };
   315	      }
   316	      if (!spec.approved_by || !spec.approved_at) {
   317	        return { ok: false, error: 'invalid_state', message: 'factory_spec lacks approval evidence' };
   318	      }
   319	      if (!spec.bom_header_id || spec.bom_version == null) {
   320	        return { ok: false, error: 'invalid_state', message: 'factory_spec has no paired BOM bundle' };
   321	      }
   322	
   323	      const npdProjectId = await loadFgNpdProjectId(db, spec.fg_item_id);
   324	      if (npdProjectId) {
   325	        return {
   326	          ok: false,
   327	          error: 'npd_handoff_required',
   328	          message: 'NPD-backed specifications must be released via NPD Handoff',
   329	        };
   330	      }
   331	
   332	      const transition = guardStatusTransition(spec.status, 'released_to_factory');
   333	      if (!transition.ok) {
   334	        return { ok: false, error: 'invalid_state', message: transition.message };
   335	      }
   336	
   337	      const releaseCtx = { orgId, userId, client: db };
   338	      const releaseEventId = await insertReleasedToFactoryEvent(releaseCtx, {
   339	        productCode: spec.fg_item_code,
   340	        activeBomHeaderId: spec.bom_header_id,
   341	        activeFactorySpecId: spec.id,
   342	      });
   343	
   344	      await supersedePriorReleasedFactorySpecs(db, spec.fg_item_id, spec.id);
   345	      await transitionFactorySpecToReleased(releaseCtx, { factorySpecId: spec.id });
   346	      await syncFactoryReleaseStatusForReleasedSpec(releaseCtx, {
   347	        activeBomHeaderId: spec.bom_header_id,
   348	        activeFactorySpecId: spec.id,
   349	        releaseEventId,
   350	      });
   351	
   352	      await writeAuditEvent(db, {
   353	        orgId,
   354	        actorUserId: userId,
   355	        action: 'factory_spec.released_to_factory',
   356	        resourceId: spec.id,
   357	        beforeState: { status: spec.status },
   358	        afterState: { status: 'released_to_factory', releaseEventId },
   359	      });
   360	
   361	      safeRevalidatePath('/technical/factory-specs');
   362	      safeRevalidatePath('/planning/work-orders');
   363	      return { ok: true, data: { specId: spec.id, status: 'released_to_factory' } };
   364	    });
   365	  } catch (err) {
   366	    if (isPgError(err) && err.code === '23514') return { ok: false, error: 'invalid_state' };
   367	    console.error('[technical/factory-specs] releaseFactorySpecToFactory persistence_failed', {
   368	      err: err instanceof Error ? err.message : String(err),
   369	    });
   370	    return { ok: false, error: 'persistence_failed' };
   371	  }
   372	}
