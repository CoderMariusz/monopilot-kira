     1	/**
     2	 * ECO apply-on-close — NN-TEC-3.
     3	 *
     4	 * ECO line items are descriptive metadata (action/target/before/after) and are NOT
     5	 * an executable change payload. The honest Phase-2-minimum variant:
     6	 *   1. During `implementing`, the engineer clones/edits the target BOM or factory
     7	 *      spec through the normal Technical workflows.
     8	 *   2. They link the superseding version on the ECO (`linkEcoSupersession`).
     9	 *   3. On close (`applying` = implementing → closed), this service validates the
    10	 *      linkage and publishes the linked BOM via `publishBomVersion` (canonical
    11	 *      supersede machinery). Factory-spec ECOs only validate the linked spec has
    12	 *      reached an approved/released terminal state (release bundle stays separate).
    13	 */
    14	
    15	import { publishBomVersion } from './bom-publish-service';
    16	import type { OrgActionContext, QueryClient } from '../../app/[locale]/(app)/(modules)/technical/eco/_actions/shared';
    17	import {
    18	  ECO_EXT_SUPERSEDING_BOM_HEADER_ID,
    19	  ECO_EXT_SUPERSEDING_FACTORY_SPEC_ID,
    20	} from '../../app/[locale]/(app)/(modules)/technical/eco/_actions/shared';
    21	
    22	export type EcoApplyError = 'supersession_required' | 'supersession_invalid' | 'forbidden' | 'persistence_failed';
    23	
    24	/** Thrown after apply-on-close has performed writes so withOrgContext rolls back. */
    25	export class EcoApplyAbort extends Error {
    26	  constructor(
    27	    readonly code: EcoApplyError,
    28	    readonly detail?: string,
    29	  ) {
    30	    super(detail ?? code);
    31	    this.name = 'EcoApplyAbort';
    32	  }
    33	}
    34	
    35	export type EcoApplyResult =
    36	  | {
    37	      ok: true;
    38	      data: {
    39	        applied: boolean;
    40	        bomPublished?: { bomHeaderId: string; productId: string; version: number };
    41	        factorySpecLinked?: { factorySpecId: string; status: string };
    42	      };
    43	    }
    44	  | { ok: false; error: EcoApplyError; message?: string };
    45	
    46	type EcoTargetRow = {
    47	  id: string;
    48	  target_bom_header_id: string | null;
    49	  target_factory_spec_id: string | null;
    50	  target_item_id: string | null;
    51	  ext_jsonb: Record<string, unknown>;
    52	};
    53	
    54	type BomRow = {
    55	  id: string;
    56	  product_id: string | null;
    57	  version: number;
    58	  status: string;
    59	  supersedes_bom_header_id: string | null;
    60	};
    61	
    62	type FactorySpecRow = {
    63	  id: string;
    64	  version: number;
    65	  status: string;
    66	  supersedes_factory_spec_id: string | null;
    67	};
    68	
    69	function readUuid(ext: Record<string, unknown>, key: string): string | null {
    70	  const value = ext[key];
    71	  return typeof value === 'string' && value.length > 0 ? value : null;
    72	}
    73	
    74	async function loadEcoTarget(client: QueryClient, changeOrderId: string): Promise<EcoTargetRow | null> {
    75	  const { rows } = await client.query<EcoTargetRow>(
    76	    `select id,
    77	            target_bom_header_id,
    78	            target_factory_spec_id,
    79	            target_item_id,
    80	            ext_jsonb
    81	       from public.technical_change_orders
    82	      where org_id = app.current_org_id()
    83	        and id = $1::uuid`,
    84	    [changeOrderId],
    85	  );
    86	  const row = rows[0];
    87	  if (!row) return null;
    88	  return {
    89	    ...row,
    90	    ext_jsonb:
    91	      row.ext_jsonb && typeof row.ext_jsonb === 'object' && !Array.isArray(row.ext_jsonb)
    92	        ? (row.ext_jsonb as Record<string, unknown>)
    93	        : {},
    94	  };
    95	}
    96	
    97	async function loadBom(client: QueryClient, bomHeaderId: string): Promise<BomRow | null> {
    98	  const { rows } = await client.query<BomRow>(
    99	    `select id, product_id, version, status, supersedes_bom_header_id
   100	       from public.bom_headers
   101	      where org_id = app.current_org_id()
   102	        and id = $1::uuid`,
   103	    [bomHeaderId],
   104	  );
   105	  return rows[0] ?? null;
   106	}
   107	
   108	async function loadFactorySpec(client: QueryClient, specId: string): Promise<FactorySpecRow | null> {
   109	  const { rows } = await client.query<FactorySpecRow>(
   110	    `select id, version, status, supersedes_factory_spec_id
   111	       from public.factory_specs
   112	      where org_id = app.current_org_id()
   113	        and id = $1::uuid`,
   114	    [specId],
   115	  );
   116	  return rows[0] ?? null;
   117	}
   118	
   119	function validateSupersedingBom(target: BomRow, superseding: BomRow): string | null {
   120	  if (target.product_id !== superseding.product_id) {
   121	    return 'superseding BOM must belong to the same product as the ECO target BOM';
   122	  }
   123	  const directLineage = superseding.supersedes_bom_header_id === target.id;
   124	  const newerVersion = Number(superseding.version) > Number(target.version);
   125	  if (!directLineage && !newerVersion) {
   126	    return 'superseding BOM must be a newer version or clone-on-write child of the ECO target BOM';
   127	  }
   128	  if (!['technical_approved', 'active'].includes(superseding.status)) {
   129	    return `superseding BOM is ${superseding.status}; expected technical_approved or active`;
   130	  }
   131	  return null;
   132	}
   133	
   134	function validateSupersedingFactorySpec(target: FactorySpecRow, superseding: FactorySpecRow): string | null {
   135	  const directLineage = superseding.supersedes_factory_spec_id === target.id;
   136	  const newerVersion = Number(superseding.version) > Number(target.version);
   137	  if (!directLineage && !newerVersion) {
   138	    return 'superseding factory spec must be a newer version or clone-on-write child of the ECO target spec';
   139	  }
   140	  if (!['approved_for_factory', 'released_to_factory'].includes(superseding.status)) {
   141	    return `superseding factory spec is ${superseding.status}; complete Technical release before closing the ECO`;
   142	  }
   143	  return null;
   144	}
   145	
   146	export async function applyEcoOnClose(ctx: OrgActionContext, changeOrderId: string): Promise<EcoApplyResult> {
   147	  const eco = await loadEcoTarget(ctx.client, changeOrderId);
   148	  if (!eco) return { ok: false, error: 'persistence_failed', message: 'change order not found' };
   149	
   150	  const supersedingBomHeaderId = readUuid(eco.ext_jsonb, ECO_EXT_SUPERSEDING_BOM_HEADER_ID);
   151	  const supersedingFactorySpecId = readUuid(eco.ext_jsonb, ECO_EXT_SUPERSEDING_FACTORY_SPEC_ID);
   152	
   153	  if (eco.target_bom_header_id) {
   154	    if (!supersedingBomHeaderId) {
   155	      return {
   156	        ok: false,
   157	        error: 'supersession_required',
   158	        message: 'link the superseding BOM version before closing this ECO',
   159	      };
   160	    }
   161	
   162	    const [targetBom, supersedingBom] = await Promise.all([
   163	      loadBom(ctx.client, eco.target_bom_header_id),
   164	      loadBom(ctx.client, supersedingBomHeaderId),
   165	    ]);
   166	    if (!targetBom || !supersedingBom) {
   167	      return { ok: false, error: 'supersession_invalid', message: 'linked BOM header not found' };
   168	    }
   169	
   170	    const bomValidation = validateSupersedingBom(targetBom, supersedingBom);
   171	    if (bomValidation) return { ok: false, error: 'supersession_invalid', message: bomValidation };
   172	
   173	    if (supersedingBom.status === 'technical_approved') {
   174	      // publishBomVersion defaults to conflict on already-active; ECO close skips publish
   175	      // when the linked superseding BOM is already active (idempotent path below).
   176	      const publish = await publishBomVersion(ctx, {
   177	        bomHeaderId: supersedingBom.id,
   178	        productId: supersedingBom.product_id!,
   179	        version: Number(supersedingBom.version),
   180	      });
   181	      if (!publish.ok) {
   182	        if (publish.error === 'forbidden') return { ok: false, error: 'forbidden', message: publish.message };
   183	        throw new EcoApplyAbort('supersession_invalid', publish.message ?? publish.error);
   184	      }
   185	      return {
   186	        ok: true,
   187	        data: {
   188	          applied: true,
   189	          bomPublished: {
   190	            bomHeaderId: publish.data.bomHeaderId,
   191	            productId: publish.data.productId,
   192	            version: publish.data.version,
   193	          },
   194	        },
   195	      };
   196	    }
   197	
   198	    return {
   199	      ok: true,
   200	      data: {
   201	        applied: true,
   202	        bomPublished: {
   203	          bomHeaderId: supersedingBom.id,
   204	          productId: supersedingBom.product_id!,
   205	          version: Number(supersedingBom.version),
   206	        },
   207	      },
   208	    };
   209	  }
   210	
   211	  if (eco.target_factory_spec_id) {
   212	    if (!supersedingFactorySpecId) {
   213	      return {
   214	        ok: false,
   215	        error: 'supersession_required',
   216	        message: 'link the superseding factory spec before closing this ECO',
   217	      };
   218	    }
   219	
   220	    const [targetSpec, supersedingSpec] = await Promise.all([
   221	      loadFactorySpec(ctx.client, eco.target_factory_spec_id),
   222	      loadFactorySpec(ctx.client, supersedingFactorySpecId),
   223	    ]);
   224	    if (!targetSpec || !supersedingSpec) {
   225	      return { ok: false, error: 'supersession_invalid', message: 'linked factory spec not found' };
   226	    }
   227	
   228	    const specValidation = validateSupersedingFactorySpec(targetSpec, supersedingSpec);
   229	    if (specValidation) return { ok: false, error: 'supersession_invalid', message: specValidation };
   230	
   231	    return {
   232	      ok: true,
   233	      data: {
   234	        applied: true,
   235	        factorySpecLinked: { factorySpecId: supersedingSpec.id, status: supersedingSpec.status },
   236	      },
   237	    };
   238	  }
   239	
   240	  return { ok: true, data: { applied: false } };
   241	}
   242	
   243	export async function validateEcoSupersessionLink(
   244	  client: QueryClient,
   245	  params: {
   246	    changeOrderId: string;
   247	    supersedingBomHeaderId?: string | null;
   248	    supersedingFactorySpecId?: string | null;
   249	  },
   250	): Promise<{ ok: true } | { ok: false; error: 'supersession_invalid' | 'invalid_state'; message: string }> {
   251	  const eco = await loadEcoTarget(client, params.changeOrderId);
   252	  if (!eco) return { ok: false, error: 'invalid_state', message: 'change order not found' };
   253	
   254	  if (params.supersedingBomHeaderId) {
   255	    if (!eco.target_bom_header_id) {
   256	      return { ok: false, error: 'supersession_invalid', message: 'this ECO does not target a BOM' };
   257	    }
   258	    const [targetBom, supersedingBom] = await Promise.all([
   259	      loadBom(client, eco.target_bom_header_id),
   260	      loadBom(client, params.supersedingBomHeaderId),
   261	    ]);
   262	    if (!targetBom || !supersedingBom) {
   263	      return { ok: false, error: 'supersession_invalid', message: 'BOM header not found' };
   264	    }
   265	    const message = validateSupersedingBom(targetBom, supersedingBom);
   266	    if (message) return { ok: false, error: 'supersession_invalid', message };
   267	  }
   268	
   269	  if (params.supersedingFactorySpecId) {
   270	    if (!eco.target_factory_spec_id) {
   271	      return { ok: false, error: 'supersession_invalid', message: 'this ECO does not target a factory spec' };
   272	    }
   273	    const [targetSpec, supersedingSpec] = await Promise.all([
   274	      loadFactorySpec(client, eco.target_factory_spec_id),
   275	      loadFactorySpec(client, params.supersedingFactorySpecId),
   276	    ]);
   277	    if (!targetSpec || !supersedingSpec) {
   278	      return { ok: false, error: 'supersession_invalid', message: 'factory spec not found' };
   279	    }
   280	    const message = validateSupersedingFactorySpec(targetSpec, supersedingSpec);
   281	    if (message) return { ok: false, error: 'supersession_invalid', message };
   282	  }
   283	
   284	  return { ok: true };
   285	}
     1	'use server';
     2	
     3	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
     4	import type { QueryClient } from '../../cost/_actions/shared';
     5	
     6	type WhereUsedRow = {
     7	  fg_code: string;
     8	  fg_name: string | null;
     9	  component_qty: string;
    10	  component_uom: string;
    11	};
    12	
    13	type WhereUsedResult = {
    14	  fg_code: string;
    15	  fg_name: string;
    16	  component_qty: number;
    17	  component_uom: string;
    18	};
    19	
    20	export async function listWhereUsed(rawCode: unknown): Promise<WhereUsedResult[]> {
    21	  const code = typeof rawCode === 'string' ? rawCode.trim() : '';
    22	  if (!code) return [];
    23	
    24	  try {
    25	    return await withOrgContext(async ({ client }): Promise<WhereUsedResult[]> => {
    26	      const qc = client as QueryClient;
    27	      const { rows } = await qc.query<WhereUsedRow>(
    28	        `select distinct on (i.item_code)
    29	                i.item_code as fg_code,
    30	                i.name as fg_name,
    31	                bl.quantity::text as component_qty,
    32	                bl.uom as component_uom
    33	           from public.bom_lines bl
    34	           join public.bom_headers ph
    35	             on ph.id = bl.bom_header_id and ph.org_id = bl.org_id
    36	           left join public.items i
    37	             on i.org_id = ph.org_id and i.id = ph.item_id
    38	          where bl.org_id = app.current_org_id()
    39	            and bl.component_code = $1
    40	            and ph.item_id is not null
    41	            and ph.item_id <> (
    42	              select id
    43	                from public.items
    44	               where org_id = app.current_org_id()
    45	                 and item_code = $1
    46	            )
    47	          order by i.item_code, ph.version desc
    48	          limit 100`,
    49	        [code],
    50	      );
    51	
    52	      return rows.map((row) => ({
    53	        fg_code: row.fg_code,
    54	        fg_name: row.fg_name ?? '',
    55	        component_qty: Number(row.component_qty),
    56	        component_uom: row.component_uom,
    57	      }));
    58	    });
    59	  } catch (error) {
    60	    console.error('[technical/where-used] listWhereUsed load_failed', {
    61	      err: error instanceof Error ? error.message : String(error),
    62	    });
    63	    return [];
    64	  }
    65	}
     1	'use server';
     2	
     3	/**
     4	 * Wave 8b Lane IA — items draft→active promotion (audit finding #8).
     5	 *
     6	 * `items.status = 'draft'` previously had NO UI path to 'active' — items created
     7	 * as drafts (import, NPD handoff) were stuck without SQL. This action moves an
     8	 * item along the explicit lifecycle validated by isAllowedStatusTransition():
     9	 * draft→active (Activate), active→deprecated (Deprecate), deprecated→active
    10	 * (Reactivate). 'blocked' remains owned by deactivateItem (TEC-081) and nothing
    11	 * ever returns to 'draft'.
    12	 *
    13	 * Gated on `technical.items.edit` (the same write permission as updateItem —
    14	 * a status change is a master-data edit, not a TEC-081 removal). RLS-scoped
    15	 * under withOrgContext; audited like the deactivate neighbor.
    16	 *
    17	 * Activation data gate (pragmatic, this wave): draft→active requires uom_base
    18	 * to be one of the CANONICAL_UOMS (migration 267 closed list). Legacy pre-267
    19	 * rows can carry free text like 'eac'; activating those would leak a broken
    20	 * unit into BOMs/planning. Everything else required for activation is already
    21	 * NOT NULL on the table (name, item_type, uom_base presence).
    22	 */
    23	
    24	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
    25	import { normalizePieceUom } from '../../../../../../../lib/uom/piece';
    26	import { safeRevalidatePath } from './revalidate';
    27	import {
    28	  CANONICAL_UOMS,
    29	  hasPermission,
    30	  isAllowedStatusTransition,
    31	  ITEMS_EDIT_PERMISSION,
    32	  type ItemStatus,
    33	  type OrgActionContext,
    34	  type QueryClient,
    35	  TransitionItemStatusInput,
    36	  type TransitionItemStatusResult,
    37	  writeAudit,
    38	} from './shared';
    39	
    40	const CANONICAL_UOM_SET = new Set<string>(CANONICAL_UOMS);
    41	
    42	export async function transitionItemStatus(rawInput: unknown): Promise<TransitionItemStatusResult> {
    43	  const parsed = TransitionItemStatusInput.safeParse(rawInput);
    44	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    45	  const input = parsed.data;
    46	
    47	  try {
    48	    return await withOrgContext(async ({ userId, orgId, client }): Promise<TransitionItemStatusResult> => {
    49	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
    50	      if (!(await hasPermission(ctx, ITEMS_EDIT_PERMISSION))) return { ok: false, error: 'forbidden' };
    51	
    52	      const before = await (client as QueryClient).query<{ status: string; uom_base: string }>(
    53	        `select status, uom_base from public.items
    54	          where org_id = app.current_org_id() and id = $1::uuid`,
    55	        [input.id],
    56	      );
    57	      const current = before.rows[0];
    58	      if (!current) return { ok: false, error: 'not_found' };
    59	
    60	      // Idempotent: re-applying the status the item already has is a no-op success.
    61	      if (current.status === input.toStatus) {
    62	        return { ok: true, data: { id: input.id, status: input.toStatus as ItemStatus } };
    63	      }
    64	
    65	      if (!isAllowedStatusTransition(current.status, input.toStatus)) {
    66	        return {
    67	          ok: false,
    68	          error: 'invalid_transition',
    69	          message: `transition ${current.status} -> ${input.toStatus} is not allowed`,
    70	        };
    71	      }
    72	
    73	      // Activation data gate: a draft may only go live with a canonical base UoM.
    74	      const canonicalUomBase = normalizePieceUom(current.uom_base) ?? current.uom_base;
    75	      if (current.status === 'draft' && input.toStatus === 'active' && !CANONICAL_UOM_SET.has(canonicalUomBase)) {
    76	        return {
    77	          ok: false,
    78	          error: 'activation_gate_failed',
    79	          message: `uom_base '${current.uom_base}' is not canonical (${CANONICAL_UOMS.join(', ')})`,
    80	        };
    81	      }
    82	
    83	      const { rows } = await (client as QueryClient).query<{ id: string; status: string }>(
    84	        `update public.items
    85	            set status = $2
    86	          where org_id = app.current_org_id()
    87	            and id = $1::uuid
    88	        returning id, status`,
    89	        [input.id, input.toStatus],
    90	      );
    91	      const updated = rows[0];
    92	      if (!updated) return { ok: false, error: 'not_found' };
    93	
    94	      await writeAudit(client as QueryClient, {
    95	        orgId,
    96	        actorUserId: userId,
    97	        action: 'item.status_transitioned',
    98	        resourceId: input.id,
    99	        beforeState: { status: current.status },
   100	        afterState: { status: input.toStatus },
   101	      });
   102	
   103	      safeRevalidatePath('/technical/items');
   104	      return { ok: true, data: { id: updated.id, status: updated.status as ItemStatus } };
   105	    });
   106	  } catch (err) {
   107	    console.error('[technical/items] transitionItemStatus persistence_failed', {
   108	      err: err instanceof Error ? err.message : String(err),
   109	    });
   110	    return { ok: false, error: 'persistence_failed' };
   111	  }
   112	}
     1	'use server';
     2	
     3	/**
     4	 * Lane A — 03-technical Items Master: update Server Action (T-010).
     5	 *
     6	 * Gated on the real `technical.items.edit` RBAC permission. RLS-scoped UPDATE of
     7	 * the descriptive + commercial attributes (item_code is immutable — it is the
     8	 * org-scoped natural key). zod-validated against migration 153 CHECK constraints.
     9	 */
    10	
    11	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
    12	import { validateActiveCategoryCode } from '../../../../../../../actions/reference/product-categories/validate-category-code';
    13	import { safeRevalidatePath } from './revalidate';
    14	import {
    15	  hasPermission,
    16	  isAllowedStatusTransition,
    17	  isPgError,
    18	  ITEMS_EDIT_PERMISSION,
    19	  type OrgActionContext,
    20	  type QueryClient,
    21	  UpdateItemInput,
    22	  type UpdateItemResult,
    23	  writeAudit,
    24	} from './shared';
    25	
    26	type BeforeRow = {
    27	  name: string;
    28	  item_type: string;
    29	  status: string;
    30	  uom_base: string;
    31	  weight_mode: string;
    32	  nominal_weight: string | null;
    33	  tare_weight: string | null;
    34	  gross_weight_max: string | null;
    35	  gs1_gtin: string | null;
    36	  output_uom: string | null;
    37	  net_qty_per_each: string | null;
    38	  each_per_box: number | null;
    39	  boxes_per_pallet: number | null;
    40	  list_price_gbp: string | null;
    41	};
    42	
    43	export async function updateItem(rawInput: unknown): Promise<UpdateItemResult> {
    44	  const parsed = UpdateItemInput.safeParse(rawInput);
    45	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    46	  const input = parsed.data;
    47	
    48	  try {
    49	    return await withOrgContext(async ({ userId, orgId, client }): Promise<UpdateItemResult> => {
    50	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
    51	      if (!(await hasPermission(ctx, ITEMS_EDIT_PERMISSION))) return { ok: false, error: 'forbidden' };
    52	
    53	      const categoryCheck = await validateActiveCategoryCode(client as QueryClient, input.categoryCode);
    54	      if (!categoryCheck.ok) return { ok: false, error: 'invalid_category' };
    55	
    56	      const before = await (client as QueryClient).query<BeforeRow>(
    57	        `select name, item_type, status, uom_base, weight_mode,
    58	                nominal_weight, tare_weight, gross_weight_max, gs1_gtin,
    59	                output_uom, net_qty_per_each, each_per_box, boxes_per_pallet,
    60	                list_price_gbp
    61	           from public.items
    62	          where org_id = app.current_org_id() and id = $1::uuid`,
    63	        [input.id],
    64	      );
    65	      if (before.rows.length === 0) return { ok: false, error: 'not_found' };
    66	      const beforeRow = before.rows[0];
    67	      if (input.status !== beforeRow.status) {
    68	        if (input.status === 'blocked' || !isAllowedStatusTransition(beforeRow.status, input.status)) {
    69	          return { ok: false, error: 'invalid_input', message: 'invalid_transition' };
    70	        }
    71	      }
    72	
    73	      const { rows, rowCount } = await (client as QueryClient).query<{ id: string }>(
    74	        `update public.items
    75	            set name = $2,
    76	                item_type = $3,
    77	                status = $4,
    78	                uom_base = $5,
    79	                weight_mode = $6,
    80	                description = $7,
    81	                product_group = $8,
    82	                category_code = $9,
    83	                uom_secondary = $10,
    84	                gs1_gtin = $11,
    85	                nominal_weight = $12::numeric,
    86	                tare_weight = $13::numeric,
    87	                gross_weight_max = $14::numeric,
    88	                variance_tolerance_pct = $15::numeric,
    89	                shelf_life_days = $16::integer,
    90	                shelf_life_mode = $17,
    91	                output_uom = $18,
    92	                net_qty_per_each = $19::numeric,
    93	                each_per_box = $20::integer,
    94	                boxes_per_pallet = $21::integer,
    95	                list_price_gbp = $22::numeric
    96	          where org_id = app.current_org_id()
    97	            and id = $1::uuid
    98	        returning id`,
    99	        [
   100	          input.id,
   101	          input.name,
   102	          input.itemType,
   103	          input.status,
   104	          input.uomBase,
   105	          input.weightMode,
   106	          input.description ?? null,
   107	          input.productGroup ?? null,
   108	          input.categoryCode ?? null,
   109	          input.uomSecondary ?? null,
   110	          input.gs1Gtin ?? null,
   111	          input.nominalWeight ?? null,
   112	          input.tareWeight ?? null,
   113	          input.grossWeightMax ?? null,
   114	          input.varianceTolerancePct ?? null,
   115	          input.shelfLifeDays ?? null,
   116	          input.shelfLifeMode ?? null,
   117	          input.outputUom,
   118	          input.netQtyPerEach ?? null,
   119	          input.eachPerBox ?? null,
   120	          input.boxesPerPallet ?? null,
   121	          input.listPriceGbp ?? null,
   122	        ],
   123	      );
   124	      if ((rowCount ?? rows.length) < 1 || !rows[0]) return { ok: false, error: 'not_found' };
   125	
   126	      await writeAudit(client as QueryClient, {
   127	        orgId,
   128	        actorUserId: userId,
   129	        action: 'item.updated',
   130	        resourceId: input.id,
   131	        beforeState: beforeRow,
   132	        afterState: {
   133	          name: input.name,
   134	          itemType: input.itemType,
   135	          status: input.status,
   136	          uomBase: input.uomBase,
   137	          weightMode: input.weightMode,
   138	          nominalWeight: input.nominalWeight ?? null,
   139	          tareWeight: input.tareWeight ?? null,
   140	          grossWeightMax: input.grossWeightMax ?? null,
   141	          gs1Gtin: input.gs1Gtin ?? null,
   142	          outputUom: input.outputUom,
   143	          netQtyPerEach: input.netQtyPerEach ?? null,
   144	          eachPerBox: input.eachPerBox ?? null,
   145	          boxesPerPallet: input.boxesPerPallet ?? null,
   146	          listPriceGbp: input.listPriceGbp ?? null,
   147	        },
   148	      });
   149	
   150	      safeRevalidatePath('/technical/items');
   151	      return { ok: true, data: { id: input.id } };
   152	    });
   153	  } catch (err) {
   154	    if (isPgError(err) && err.code === '23514') return { ok: false, error: 'invalid_input' };
   155	    console.error('[technical/items] updateItem persistence_failed', {
   156	      err: err instanceof Error ? err.message : String(err),
   157	    });
   158	    return { ok: false, error: 'persistence_failed' };
   159	  }
   160	}

