    27	const SubmitFactorySpecInput = z.object({
    28	  specId: z.string().uuid(),
    29	});
    30	
    31	const ReleaseFactorySpecInput = z.object({
    32	  specId: z.string().uuid(),
    33	});
    34	
    35	const LinkFactorySpecBomInput = z.object({
    36	  specId: z.string().uuid(),
    37	  bomHeaderId: z.string().uuid(),
