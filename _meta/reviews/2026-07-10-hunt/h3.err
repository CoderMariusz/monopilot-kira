 succeeded in 0ms:
     1	'use server';
     2	
     3	/**
     4	 * 03-technical shared BOM SSOT — create draft Server Action (T-013).
     5	 *
     6	 * POST equivalent for `/api/technical/items/:code/boms`. Creates a NEW BOM version
     7	 * in status 'draft' (never auto-publishes), transactionally writing header + lines
     8	 * + co-products. Validation (PRD §7.4/§7.6):
     9	 *   - V-TEC-13 cycle / self-reference (DFS over the org's ACTIVE BOM graph).
    10	 *   - V-TEC-12 non-byproduct allocation sum (parent + non-byproduct co-products)
    11	 *     must equal 100 (rounded to 3 dp).
    12	 *   - V-TEC-14 every component item must pass the canonical RM usability chain.
    13	 *   - V-TEC-11 advisory warnings returned in `warnings` (NOT a 422).
    14	 * version = previous_max(version for this product_id) + 1.
    15	 *
    16	 * Red-lines: status stays 'draft' (no auto-publish); NO bom_snapshots write here
    17	 * (snapshots are WO-time only, T-024); RLS scopes every statement to the org.
    18	 */
    19	
    20	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
    21	import { safeRevalidatePath } from './revalidate';
    22	import { buildGraph, detectCycle } from './cycle-detection';
    23	import {
    24	  AUDIT_BOM_CREATED,
    25	  BOM_CREATE_PERMISSION,
    26	  type BomValidationCode,
    27	  CreateBomDraftInput,
    28	  type CreateBomDraftResult,
    29	  EVENT_BOM_VERSION_SUBMITTED,
    30	  hasPermission,
    31	  isPgError,
    32	  type OrgActionContext,
    33	  type QueryClient,
    34	  formatRmUsabilityFailures,
    35	  validateBomLineRmUsability,
    36	  writeAudit,
    37	  writeOutbox,
    38	} from './shared';
    39	
    40	function round3(n: number): number {
    41	  return Math.round(n * 1000) / 1000;
    42	}
    43	
    44	async function ensureBomProductReference(
    45	  c: QueryClient,
    46	  input: { productId: string; userId: string },
    47	): Promise<{ ok: true } | { ok: false; message: string }> {
    48	  const { rows: productRows } = await c.query<{ product_code: string }>(
    49	    `select product_code
    50	       from public.product
    51	      where org_id = app.current_org_id()
    52	        and product_code = $1
    53	      limit 1`,
    54	    [input.productId],
    55	  );
    56	  if (productRows[0]) return { ok: true };
    57	
    58	  const { rows: itemRows } = await c.query<{
    59	    item_code: string;
    60	    name: string | null;
    61	    status: string;
    62	    item_type: string;
    63	  }>(
    64	    `select item_code, name, status, item_type
    65	       from public.items
    66	      where org_id = app.current_org_id()
    67	        and item_code = $1
    68	      limit 1`,
    69	    [input.productId],
    70	  );
    71	  const item = itemRows[0];
    72	  if (!item || item.item_type !== 'fg' || item.status !== 'active') {
    73	    return { ok: false, message: 'invalid reference' };
    74	  }
    75	
    76	  // product is a VIEW post-merge-cut (no ON CONFLICT — 42P10). Ensure the row exists WITHOUT
    77	  // disturbing an existing one: a plain INSERT through the view re-runs the INSTEAD-OF insert and
    78	  // would overwrite fg_npd_ext with the sparse NEW values, so insert ONLY when absent.
    79	  const existingProduct = await c.query(
    80	    `select 1 from public.product where org_id = app.current_org_id() and product_code = $1 limit 1`,
    81	    [item.item_code],
    82	  );
    83	  if (existingProduct.rows.length === 0) {
    84	    await c.query(
    85	      `insert into public.product
    86	         (org_id, product_code, product_name, status_overall, created_by_user, app_version)
    87	       values
    88	         (app.current_org_id(), $1, $2, $3, $4::uuid, 'technical-bom-v1')`,
    89	      [item.item_code, item.name ?? item.item_code, item.status, input.userId],
    90	    );
    91	  }
    92	  return { ok: true };
    93	}
    94	
    95	export async function createBomDraft(rawInput: unknown): Promise<CreateBomDraftResult> {
    96	  const parsed = CreateBomDraftInput.safeParse(rawInput);
    97	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    98	  const input = parsed.data;
    99	  const warnings: BomValidationCode[] = [];
   100	
   101	  if (input.bom_type === 'disassembly') {
   102	    return {
   103	      ok: false,
   104	      error: 'invalid_input',
   105	      message: 'Disassembly BOMs must be created with createDisassemblyBomDraft',
   106	    };
   107	  }
   108	
   109	  try {
   110	    return await withOrgContext(async ({ userId, orgId, client }): Promise<CreateBomDraftResult> => {
   111	      const c = client as QueryClient;
   112	      const ctx: OrgActionContext = { userId, orgId, client: c };
   113	      if (!(await hasPermission(ctx, BOM_CREATE_PERMISSION))) return { ok: false, error: 'forbidden' };
   114	
   115	      // ── V-TEC-13: self-reference (early) + cycle over ACTIVE BOMs ──────────────
   116	      const componentCodes = input.lines.map((l) => l.componentCode);
   117	      if (componentCodes.includes(input.productId)) {
   118	        return { ok: false, error: 'validation_failed', code: 'V-TEC-13', message: 'BOM line references its own parent item' };
   119	      }
   120	      const { rows: edgeRows } = await c.query<{ parent: string; component: string }>(
   121	        `select i.item_code as parent, l.component_code as component
   122	           from public.bom_headers h
   123	           join public.items i on i.id = h.item_id and i.org_id = h.org_id
   124	           join public.bom_lines l on l.bom_header_id = h.id and l.org_id = h.org_id
   125	          where h.org_id = app.current_org_id()
   126	            and h.status = 'active'
   127	            and h.item_id is not null`,
   128	      );
   129	      const graph = buildGraph(edgeRows);
   130	      if (detectCycle(graph, input.productId, componentCodes)) {
   131	        return { ok: false, error: 'validation_failed', code: 'V-TEC-13', message: 'BOM would introduce a cycle' };
   132	      }
   133	
   134	      // ── V-TEC-12: non-byproduct allocation sum (parent + non-byproduct co-products) == 100 ──
   135	      const nonByproductCoProductSum = input.coProducts
   136	        .filter((cp) => !cp.isByproduct)
   137	        .reduce((acc, cp) => acc + cp.allocationPct, 0);
   138	      const coverage = round3(input.parentAllocationPct + nonByproductCoProductSum);
   139	      if (coverage !== 100) {
   140	        return {
   141	          ok: false,
   142	          error: 'validation_failed',
   143	          code: 'V-TEC-12',
   144	          message: `non-byproduct allocation sums to ${coverage}, must equal 100`,
   145	        };
   146	      }
   147	
   148	      // ── V-TEC-14: every component item passes canonical RM usability ──────────
   149	      const rmUsabilityFailures = await validateBomLineRmUsability(c, input.lines, 'bom_edit', input.productId);
   150	      if (rmUsabilityFailures.length > 0) {
   151	        return {
   152	          ok: false,
   153	          error: 'validation_failed',
   154	          code: 'V-TEC-14',
   155	          message: formatRmUsabilityFailures(rmUsabilityFailures),
   156	          rmUsabilityFailures,
   157	        };
   158	      }
   159	
   160	      // ── V-TEC-11 advisory: warn (non-blocking) if any line scrap_pct >= 50 ──────
   161	      if (input.lines.some((l) => (l.scrapPct ?? 0) >= 50)) warnings.push('V-TEC-11');
   162	
   163	      const productReference = await ensureBomProductReference(c, { productId: input.productId, userId });
   164	      if (!productReference.ok) {
   165	        return { ok: false, error: 'invalid_input', message: productReference.message };
   166	      }
   167	
   168	      // ── version = previous_max + 1 (org + product scoped) ──────────────────────
   169	      const { rows: verRows } = await c.query<{ next_version: number }>(
   170	        `select coalesce(max(version), 0) + 1 as next_version
   171	           from public.bom_headers
   172	          where org_id = app.current_org_id()
   173	            and item_id = (select id from public.items where org_id = app.current_org_id() and item_code = $1)`,
   174	        [input.productId],
   175	      );
   176	      const version = Number(verRows[0]?.next_version ?? 1);
   177	
   178	      // ── INSERT header (draft) + lines + co-products, atomically in the txn ─────
   179	      const { rows: headerRows } = await c.query<{ id: string }>(
   180	        `insert into public.bom_headers
   181	           (org_id, product_id, item_id, origin_module, status, version, yield_pct, effective_from, notes, created_by_user, app_version, bom_type)
   182	         values
   183	           (app.current_org_id(), $1, (select id from public.items where org_id = app.current_org_id() and item_code = $1), 'technical', 'draft', $2, $3::numeric, coalesce($4::date, current_date), $5, $6::uuid, 'technical-bom-v1', $7)
   184	         returning id`,
   185	        [input.productId, version, input.yieldPct, input.effectiveFrom ?? null, input.notes ?? null, userId, input.bom_type],
   186	      );
   187	      const headerId = headerRows[0]?.id;
   188	      if (!headerId) return { ok: false, error: 'persistence_failed' };
   189	
   190	      for (let i = 0; i < input.lines.length; i++) {
   191	        const line = input.lines[i]!;
   192	        await c.query(
   193	          `insert into public.bom_lines
   194	             (org_id, bom_header_id, line_no, item_id, component_code, component_type, quantity, uom, scrap_pct,
   195	              manufacturing_operation_name, sequence, is_phantom)
   196	           values
   197	             (app.current_org_id(), $1::uuid, $2, $3::uuid, $4, $5, $6::numeric, $7, $8::numeric, $9, $10, $11)`,
   198	          [
   199	            headerId,
   200	            i + 1,
   201	            line.itemId ?? null,
   202	            line.componentCode,
   203	            line.componentType ?? null,
   204	            line.quantity,
   205	            line.uom,
   206	            line.scrapPct ?? 0,
   207	            line.manufacturingOperationName ?? null,
   208	            line.sequence ?? null,
   209	            line.isPhantom ?? false,
   210	          ],
   211	        );
   212	      }
   213	
   214	      for (const cp of input.coProducts) {
   215	        await c.query(
   216	          `insert into public.bom_co_products
   217	             (org_id, bom_header_id, co_product_item_id, quantity, uom, allocation_pct, is_byproduct)
   218	           values
   219	             (app.current_org_id(), $1::uuid, $2::uuid, $3::numeric, $4, $5::numeric, $6)`,
   220	          [headerId, cp.coProductItemId, cp.quantity, cp.uom, cp.allocationPct, cp.isByproduct ?? false],
   221	        );
   222	      }
   223	
   224	      await writeAudit(c, {
   225	        orgId,
   226	        actorUserId: userId,
   227	        action: AUDIT_BOM_CREATED,
   228	        resourceId: headerId,
   229	        beforeState: null,
   230	        afterState: { productId: input.productId, version, status: 'draft', lineCount: input.lines.length },
   231	      });
   232	
   233	      // Outbox: a draft version submitted into the shared BOM lifecycle.
   234	      await writeOutbox(c, {
   235	        orgId,
   236	        eventType: EVENT_BOM_VERSION_SUBMITTED,
   237	        aggregateType: 'bom_header',
   238	        aggregateId: headerId,
   239	        payload: { product_id: input.productId, version, status: 'draft', actor_user_id: userId },
   240	      });
   241	
   242	      safeRevalidatePath('/technical/bom');
   243	      return { ok: true, data: { id: headerId, version, warnings } };
   244	    });
   245	  } catch (err) {
   246	    if (isPgError(err) && err.code === '23505') return { ok: false, error: 'conflict', message: 'duplicate BOM version' };
   247	    if (isPgError(err) && err.code === '23514') return { ok: false, error: 'invalid_input' };
   248	    if (isPgError(err) && err.code === '23503') return { ok: false, error: 'invalid_input', message: 'invalid reference' };
   249	    console.error('[technical/bom] createBomDraft persistence_failed', {
   250	      err: err instanceof Error ? err.message : String(err),
   251	    });
   252	    return { ok: false, error: 'persistence_failed' };
   253	  }
   254	}
     1	'use server';
     2	
     3	/**
     4	 * 03-technical shared BOM SSOT — approve + publish Server Actions (T-014).
     5	 *
     6	 * The version state machine (PRD §7.4/§7.6): draft -> technical_approved -> active,
     7	 * superseding any prior active version atomically.
     8	 *
     9	 *   approveBom  : draft|in_review -> technical_approved. Requires technical.bom.approve.
    10	 *                 Re-validates cycle-freeness at approve time (red-line) and stamps
    11	 *                 approved_by/approved_at (DB CHECK requires both for the approved status).
    12	 *                 Audit action='bom.approve'.
    13	 *   publishBom  : technical_approved -> active. Requires technical.bom.version_publish.
    14	 *                 V-TEC-10: a non-approved version cannot publish (-> validation_failed).
    15	 *                 Prior active version for the same product flips to 'superseded' in the
    16	 *                 SAME txn (atomic supersede). Audit action='bom.publish'; emits
    17	 *                 fg.bom.released.
    18	 *
    19	 * Clone-on-write red-line: we NEVER mutate approved/active CONTENT — only the status
    20	 * column transitions (the migration-090 immutability trigger permits status-only moves).
    21	 * Rollback to a prior version = re-running publishBom on that version.
    22	 */
    23	
    24	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
    25	import { publishBomVersion } from '../../../../../../../lib/technical/bom-publish-service';
    26	import { safeRevalidatePath } from './revalidate';
    27	import {
    28	  AUDIT_BOM_APPROVE,
    29	  BOM_APPROVE_PERMISSION,
    30	  BOM_VERSION_PUBLISH_PERMISSION,
    31	  type BomWorkflowResult,
    32	  BomVersionRefInput,
    33	  EVENT_FG_BOM_RELEASED,
    34	  formatRmUsabilityFailures,
    35	  hasPermission,
    36	  isPgError,
    37	  type OrgActionContext,
    38	  type QueryClient,
    39	  validateBomApprovalGuards,
    40	  writeAudit,
    41	} from './shared';
    42	
    43	type HeaderState = { id: string; status: string; product_id: string | null };
    44	
    45	async function loadVersion(c: QueryClient, productId: string, version: number): Promise<HeaderState | null> {
    46	  const { rows } = await c.query<HeaderState>(
    47	    `select h.id, h.status, i.item_code as product_id
    48	       from public.bom_headers h
    49	       join public.items i on i.id = h.item_id and i.org_id = h.org_id
    50	      where h.org_id = app.current_org_id()
    51	        and h.item_id = (select id from public.items where org_id = app.current_org_id() and item_code = $1)
    52	        and h.version = $2`,
    53	    [productId, version],
    54	  );
    55	  return rows[0] ?? null;
    56	}
    57	
    58	export async function approveBom(rawInput: unknown): Promise<BomWorkflowResult> {
    59	  const parsed = BomVersionRefInput.safeParse(rawInput);
    60	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    61	  const { productId, version } = parsed.data;
    62	
    63	  try {
    64	    return await withOrgContext(async ({ userId, orgId, client }): Promise<BomWorkflowResult> => {
    65	      const c = client as QueryClient;
    66	      const ctx: OrgActionContext = { userId, orgId, client: c };
    67	      if (!(await hasPermission(ctx, BOM_APPROVE_PERMISSION))) return { ok: false, error: 'forbidden' };
    68	
    69	      const header = await loadVersion(c, productId, version);
    70	      if (!header) return { ok: false, error: 'not_found' };
    71	      if (header.status === 'technical_approved' || header.status === 'active') {
    72	        return { ok: false, error: 'conflict', message: `version already ${header.status}` };
    73	      }
    74	      if (header.status !== 'draft' && header.status !== 'in_review') {
    75	        return { ok: false, error: 'conflict', message: `cannot approve from status ${header.status}` };
    76	      }
    77	
    78	      const { rows: thisLines } = await c.query<{ item_id: string | null; component_code: string }>(
    79	        `select item_id, component_code from public.bom_lines
    80	          where org_id = app.current_org_id() and bom_header_id = $1`,
    81	        [header.id],
    82	      );
    83	      const guard = await validateBomApprovalGuards(
    84	        c,
    85	        productId,
    86	        thisLines.map((l) => ({ itemId: l.item_id, componentCode: l.component_code })),
    87	        { cycleBlockedMessage: 'BOM has a cycle; cannot approve' },
    88	      );
    89	      if (!guard.ok) {
    90	        return {
    91	          ok: false,
    92	          error: 'validation_failed',
    93	          code: guard.code,
    94	          message: guard.message,
    95	          ...(guard.rmUsabilityFailures ? { rmUsabilityFailures: guard.rmUsabilityFailures } : {}),
    96	        };
    97	      }
    98	
    99	      const { rows: updated } = await c.query<{ version: number }>(
   100	        `update public.bom_headers
   101	            set status = 'technical_approved', approved_by = $2::uuid, approved_at = pg_catalog.now()
   102	          where org_id = app.current_org_id() and id = $1::uuid and status in ('draft', 'in_review')
   103	          returning version`,
   104	        [header.id, userId],
   105	      );
   106	      if (updated.length === 0) return { ok: false, error: 'conflict' };
   107	
   108	      await writeAudit(c, {
   109	        orgId,
   110	        actorUserId: userId,
   111	        action: AUDIT_BOM_APPROVE,
   112	        resourceId: header.id,
   113	        beforeState: { status: header.status },
   114	        afterState: { status: 'technical_approved', productId, version },
   115	      });
   116	
   117	      safeRevalidatePath('/technical/bom');
   118	      return { ok: true, data: { id: header.id, status: 'technical_approved', version } };
   119	    });
   120	  } catch (err) {
   121	    if (isPgError(err) && err.code === '23514') return { ok: false, error: 'invalid_input' };
   122	    console.error('[technical/bom] approveBom persistence_failed', {
   123	      err: err instanceof Error ? err.message : String(err),
   124	    });
   125	    return { ok: false, error: 'persistence_failed' };
   126	  }
   127	}
   128	
   129	export async function publishBom(rawInput: unknown): Promise<BomWorkflowResult> {
   130	  const parsed = BomVersionRefInput.safeParse(rawInput);
   131	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   132	  const { productId, version } = parsed.data;
   133	
   134	  try {
   135	    return await withOrgContext(async ({ userId, orgId, client }): Promise<BomWorkflowResult> => {
   136	      const c = client as QueryClient;
   137	      const ctx: OrgActionContext = { userId, orgId, client: c };
   138	      if (!(await hasPermission(ctx, BOM_VERSION_PUBLISH_PERMISSION))) return { ok: false, error: 'forbidden' };
   139	
   140	      const header = await loadVersion(c, productId, version);
   141	      if (!header) return { ok: false, error: 'not_found' };
   142	
   143	      const published = await publishBomVersion(ctx, {
   144	        bomHeaderId: header.id,
   145	        productId,
   146	        version,
   147	      });
   148	      if (!published.ok) {
   149	        if (published.error === 'forbidden') return { ok: false, error: 'forbidden' };
   150	        if (published.error === 'validation_failed') {
   151	          return {
   152	            ok: false,
   153	            error: 'validation_failed',
   154	            code: published.code,
   155	            message: published.message,
   156	          };
   157	        }
   158	        if (published.error === 'conflict') {
   159	          return { ok: false, error: 'conflict', message: published.message };
   160	        }
   161	        return { ok: false, error: published.error };
   162	      }
   163	
   164	      safeRevalidatePath('/technical/bom');
   165	      return { ok: true, data: { id: header.id, status: 'active', version } };
   166	    });
   167	  } catch (err) {
   168	    if (isPgError(err) && err.code === '23505') return { ok: false, error: 'conflict', message: 'another active version exists' };
   169	    if (isPgError(err) && err.code === '23514') return { ok: false, error: 'invalid_input' };
   170	    console.error('[technical/bom] publishBom persistence_failed', {
   171	      err: err instanceof Error ? err.message : String(err),
   172	    });
   173	    return { ok: false, error: 'persistence_failed' };
   174	  }
   175	}
