   129	export async function saveWipDefinition(input: SaveWipDefinitionInput): Promise<ActionResult<{ id: string; version: number }>> {
   130	  const parsed = saveWipDefinitionInputSchema.safeParse(input);
   131	  if (!parsed.success) return { ok: false, error: 'Invalid WIP definition input', code: 'VALIDATION_ERROR' };
   132	  const data = preserveProcessYieldPct(parsed.data, input);
   133	
   134	  return withOrgContext<ActionResult<{ id: string; version: number }>>(async (ctx) => {
   135	    const requiredPermission = data.id ? EDIT_PERMISSION : CREATE_PERMISSION;
   136	    if (!(await hasPermission(ctx, requiredPermission))) {
   137	      return { ok: false, error: `${requiredPermission} is required`, code: 'FORBIDDEN', status: 403 };
   138	    }
   139	
   140	    const existing = data.id ? await loadExistingDefinition(ctx, data.id) : null;
   141	    if (data.id && !existing) return { ok: false, error: 'WIP definition not found', code: 'NOT_FOUND', status: 404 };
   142	
   143	    const beforeContent = existing ? await loadDefinitionContent(ctx, existing.id, existing) : null;
   144	    const afterContent = canonicalInputContent(data);
   145	    const contentChanged = !beforeContent || JSON.stringify(beforeContent) !== JSON.stringify(afterContent);
   146	    const nextVersion = existing ? existing.version + (contentChanged ? 1 : 0) : 1;
   147	
   148	    const itemId = existing?.item_id ?? await ensureDefinitionItem(ctx, data.name, data.baseUom);
   149	    // U3: the "reusable" toggle IS the publication decision — a reusable
   150	    // definition must be pickable, and the recipe picker requires 'active'.
   151	    // Without this, library-authored definitions were draft dead-ends
   152	    // (Gate-5b re-walk HIGH). Un-toggling never downgrades an active row.
   153	    const saved = existing
   154	      ? await ctx.client.query<{ id: string; version: number }>(
   155	          `update public.wip_definitions
   156	              set name = $2,
   157	                  description = $3,
   158	                  base_uom = $4,
   159	                  yield_pct = $5::numeric,
   160	                  reusable = $6::boolean,
   161	                  item_id = $7::uuid,
   162	                  version = $8::int,
   163	                  status = case when $6::boolean and status = 'draft' then 'active' else status end,
   164	                  updated_at = now()
   165	            where id = $1::uuid
   166	              and org_id = app.current_org_id()
   167	          returning id, version`,
   168	          [
   169	            existing.id,
   170	            data.name,
   171	            data.description ?? null,
   172	            data.baseUom,
   173	            data.yieldPct,
   174	            data.reusable,
   175	            itemId,
   176	            nextVersion,
   177	          ],
   178	        )
   179	      : await ctx.client.query<{ id: string; version: number }>(
   180	          `insert into public.wip_definitions
   181	             (org_id, item_id, name, description, base_uom, yield_pct, version, status, reusable, created_by)
   182	           values
   183	             (app.current_org_id(), $1::uuid, $2, $3, $4, $5::numeric, 1,
   184	              case when $6::boolean then 'active' else 'draft' end, $6::boolean, $7::uuid)
   185	           returning id, version`,
   186	          [itemId, data.name, data.description ?? null, data.baseUom, data.yieldPct, data.reusable, ctx.userId],
   187	        );
   188	
   189	    const definitionId = saved.rows[0]?.id;
   190	    if (!definitionId) throw new Error('Could not save WIP definition');
   191	
   192	    await replaceDefinitionIngredients(ctx, definitionId, data.ingredients);
   193	    await replaceDefinitionProcesses(ctx, definitionId, data.processes);
   194	    await refreshWipItemAllergens(ctx, itemId, data.ingredients.map((ingredient) => ingredient.itemId));
   195	
   196	    if (existing && contentChanged) {
   197	      await emitDefinitionUpdated(ctx, definitionId, nextVersion);
   198	      await fanOutDefinitionNotifications(ctx, definitionId, data.name, nextVersion);
   199	    }
   200	
   201	    return { ok: true, id: definitionId, version: nextVersion };
   202	  });
   203	}
