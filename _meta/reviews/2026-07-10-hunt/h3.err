   342	
   343	  function onSubmit() {
   344	    if (!picked || !canSubmit) return;
   345	    setError(null);
   346	    startTransition(async () => {
   347	      // Re-check usability server-side at the save seam (AC5 — never cosmetic).
   348	      const gate = await validateBomComponent({ itemId: picked.id });
   349	      if (!gate.ok && gate.error === 'blocked' && gate.verdict) {
   350	        setUsability(verdictToBlocked(gate.verdict));
   351	        return; // no BOM line mutation
   352	      }
   353	
   354	      const newLine = {
   355	        itemId: picked.id,
   356	        componentCode: picked.itemCode,
   357	        componentType: ITEM_TYPE_TO_COMPONENT_TYPE[picked.itemType],
   358	        quantity: qtyNum,
   359	        uom: picked.uomBase,
   360	        scrapPct: Number(scrap) || 0,
   361	        manufacturingOperationName: operationName.trim(),
   362	      };
   363	
   364	      // F-B01 — three flows, two persistence paths:
   365	      //  (1) EXISTING editable draft/in_review version → APPEND the line in
   366	      //      place via addBomLine (no version fork).
   367	      //  (2) Released/terminal source version → clone-on-write fork via
   368	      //      createBomDraft with ALL existing lines + the new one (+ carried
   369	      //      co-products & yield), so the fork is COMPLETE — never 1-line.
   370	      //  (3) First-authoring (no bomHeaderId) → create the v1 draft with the
   371	      //      single new line (unchanged).
   372	      if (context.bomHeaderId && EDITABLE_STATUSES.has(context.sourceStatus)) {
   373	        const result = await addBomLine({ bomHeaderId: context.bomHeaderId, ...newLine });
   374	        if (result.ok) {
   375	          onAdded?.({ id: context.bomHeaderId, version: context.currentVersion });
   376	          router.refresh();
   377	          onClose();
   378	        } else if (result.error === 'forbidden') {
   379	          setError(t('forbidden'));
   380	        } else if (result.error === 'validation_failed') {
   381	          setUsability({ kind: 'blocked', code: result.code ?? 'V-TEC-14', message: result.message ?? '' });
   382	        } else {
   383	          setError(result.message ?? t('saveError'));
   384	        }
   385	        return;
   386	      }
   387	
   388	      const carriedLines = context.bomHeaderId ? context.existingLines ?? [] : [];
   389	      const carriedCoProducts = context.bomHeaderId ? context.coProducts ?? [] : [];
   390	      // V-TEC-12: parent share = 100 − Σ non-byproduct co-product allocations,
   391	      // reconstructing the validity the source version already satisfied.
   392	      const parentAllocationPct =
   393	        100 - carriedCoProducts.filter((cp) => !cp.isByproduct).reduce((acc, cp) => acc + cp.allocationPct, 0);
   394	
   395	      const result = await createBomDraft({
   396	        productId: context.productId,
   397	        lines: [...carriedLines, newLine],
   398	        coProducts: carriedCoProducts,
   399	        parentAllocationPct,
   400	        ...(context.bomHeaderId && context.yieldPct != null ? { yieldPct: context.yieldPct } : {}),
   401	      });
   402	      if (result.ok) {
   403	        onAdded?.({ id: result.data.id, version: result.data.version });
   404	        router.refresh();
   405	        onClose();
   406	      } else if (result.error === 'forbidden') {
   407	        setError(t('forbidden'));
   408	      } else if (result.error === 'conflict') {
   409	        setError(t('conflict'));
   410	      } else if (result.error === 'validation_failed') {
   411	        setUsability({ kind: 'blocked', code: result.code ?? 'V-TEC-14', message: result.message ?? '' });
   412	      } else {
   413	        setError(result.message ?? t('saveError'));
   414	      }
   415	    });
   416	  }
   417	
   418	  return (
   419	    <Dialog
   420	      open={open}
   421	      onClose={onClose}
   422	      size="wide"
   423	      title={t('addComponent')}
   424	      subtitle={t('addComponentSubtitle')}
   425	      footer={
   426	        <>
   427	          <Button type="button" className="btn-secondary" onClick={onClose}>
   428	            {t('cancel')}
   429	          </Button>
   430	          <Button type="button" className="btn-primary" disabled={!canSubmit} onClick={onSubmit}>
   108	-- 2. Generic clone-on-write: bom_request_version_edit()
   109	-- ===========================================================================
   110	-- Given an immutable (technical_approved or active) BOM version, create a NEW draft version
   111	-- (status='in_review', routed to Technical approval) that supersedes it, copying lines and
   112	-- co-products. The approved/active source row is NEVER mutated. Idempotent per (org, source):
   113	-- if a non-terminal superseding version already exists it is returned instead of a duplicate.
   114	-- Returns a TYPED decision: decision = 'cloned' | 'existing'.
   115	create or replace function public.bom_request_version_edit(
   116	  p_source_bom_header_id uuid,
   117	  p_requested_by uuid,
   118	  p_notes text default null
   119	)
   120	returns table (
   121	  decision text,
   122	  bom_header_id uuid,
   123	  status text,
   124	  version integer,
   125	  supersedes_bom_header_id uuid
   126	)
   127	language plpgsql
   128	as $$
   129	declare
   130	  v_org_id uuid := app.current_org_id();
   131	  v_src public.bom_headers%rowtype;
   132	  v_new_id uuid;
   133	  v_decision text;
   134	begin
   135	  select *
   136	    into v_src
   137	  from public.bom_headers header
   138	  where header.id = p_source_bom_header_id
   139	    and header.org_id = v_org_id;
   140	
   141	  if v_src.id is null then
   142	    raise exception 'BOM version not found in current org: %', p_source_bom_header_id
   143	      using errcode = 'P0002';
   144	  end if;
   145	
   146	  if v_src.status not in ('technical_approved', 'active') then
   147	    raise exception
   148	      'BOM version % is in status % and is directly editable; clone-on-write only applies to technical_approved/active versions',
   149	      p_source_bom_header_id, v_src.status
   150	      using errcode = '23514';
   151	  end if;
   152	
   153	  -- Idempotency: reuse an existing in-flight superseding draft/in_review version if present.
   154	  select header.id
   155	    into v_new_id
   156	  from public.bom_headers header
   157	  where header.org_id = v_org_id
   158	    and header.supersedes_bom_header_id = v_src.id
   159	    and header.status in ('draft', 'in_review')
   160	  order by header.created_at
   161	  limit 1;
   162	
   163	  if v_new_id is not null then
   164	    v_decision := 'existing';
   165	  else
   166	    v_decision := 'cloned';
   167	
   168	    insert into public.bom_headers (
   169	      org_id, product_id, npd_project_id, fa_code, origin_module, status, version,
   170	      supersedes_bom_header_id, yield_pct, effective_from,
   171	      technical_review_requested_by, technical_review_requested_at, notes, created_by_user
   172	    )
   173	    values (
   174	      v_org_id, v_src.product_id, v_src.npd_project_id, v_src.fa_code, 'technical', 'in_review',
   175	      v_src.version + 1, v_src.id, v_src.yield_pct, current_date,
   176	      p_requested_by, pg_catalog.now(),
   177	      coalesce(p_notes, 'Technical post-release edit; new version pending Technical approval (clone-on-write).'),
   178	      p_requested_by
   179	    )
   180	    returning id into v_new_id;
   181	
   182	    insert into public.bom_lines (
   183	      org_id, bom_header_id, line_no, component_code, component_type, item_id, quantity, uom,
   184	      scrap_pct, manufacturing_operation_name, sequence, is_phantom, source, notes
   185	    )
   186	    select
   187	      line.org_id, v_new_id, line.line_no, line.component_code, line.component_type, line.item_id,
   188	      line.quantity, line.uom, line.scrap_pct, line.manufacturing_operation_name, line.sequence,
   189	      line.is_phantom, 'superseded_copy', 'Copied from prior immutable BOM version (clone-on-write).'
   190	    from public.bom_lines line
   191	    where line.org_id = v_org_id
   192	      and line.bom_header_id = v_src.id
   193	    order by line.line_no;
   194	
   195	    insert into public.bom_co_products (
   196	      org_id, bom_header_id, co_product_item_id, quantity, uom, allocation_pct, is_byproduct, site_id
   197	    )
   198	    select
   199	      cp.org_id, v_new_id, cp.co_product_item_id, cp.quantity, cp.uom, cp.allocation_pct,
   200	      cp.is_byproduct, cp.site_id
   201	    from public.bom_co_products cp
   202	    where cp.org_id = v_org_id
   203	      and cp.bom_header_id = v_src.id;
   204	
   205	    -- Reuse the already-registered outbox event (migration 151 SoT). No new event type.
   206	    insert into public.outbox_events (org_id, event_type, aggregate_type, aggregate_id, payload, app_version)
   207	    select
   208	      v_org_id, 'bom.version_submitted', 'bom', v_new_id,
   209	      jsonb_build_object(
   210	        'previous_bom_header_id', v_src.id,
   211	        'bom_header_id', v_new_id,
   212	        'status', 'in_review',
   213	        'origin', 'technical_clone_on_write',
   214	        'requires_technical_approval', true
   215	      ),
   216	      'db-168'
   217	    where not exists (
   218	      select 1 from public.outbox_events event
   219	      where event.org_id = v_org_id
   220	        and event.event_type = 'bom.version_submitted'
   221	        and event.aggregate_id = v_new_id::text
   222	    );
   223	  end if;
   224	
   225	  return query
   226	  select v_decision, header.id, header.status, header.version, header.supersedes_bom_header_id
   227	  from public.bom_headers header
   228	  where header.id = v_new_id
   229	    and header.org_id = v_org_id;
   230	end;
    40	import { deleteBomVersion } from '../_actions/delete-bom-version';
