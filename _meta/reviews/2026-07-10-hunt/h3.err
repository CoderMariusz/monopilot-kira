    13	
    14	export async function startChangeOrderImplementation(rawInput: unknown): Promise<MutateEcoResult> {
    15	  const parsed = TransitionEcoInput.safeParse(rawInput);
    16	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    17	
    18	  try {
    19	    return await withOrgContext(async ({ userId, orgId, client }): Promise<MutateEcoResult> => {
    20	      const qc = client as QueryClient;
    21	      const ctx: OrgActionContext = { userId, orgId, client: qc };
    22	      if (!(await hasPermission(ctx, ECO_WRITE_PERMISSION))) return { ok: false, error: 'forbidden' };
    23	
    24	      const { rows } = await qc.query<{ id: string; status: string }>(
    25	        `update public.technical_change_orders
    26	            set status = 'implementing',
    27	                implementing_at = pg_catalog.now(),
    28	                updated_by = $2::uuid
    29	          where org_id = app.current_org_id()
    30	            and id = $1::uuid
    31	            and status = 'approved'
    32	          returning id, status`,
    33	        [parsed.data.id, userId],
    34	      );
    35	      const order = rows[0];
    36	      if (!order) {
    37	        const exists = await qc.query<{ id: string }>(
    38	          `select id from public.technical_change_orders where org_id = app.current_org_id() and id = $1::uuid`,
    39	          [parsed.data.id],
    40	        );
    41	        if (!exists.rows[0]) return { ok: false, error: 'not_found' };
    42	        return { ok: false, error: 'invalid_state' };
    43	      }
    44	
    45	      await qc.query(
    46	        `insert into public.technical_change_order_approvals
    47	           (org_id, change_order_id, action, from_status, to_status, actor_user_id, comment)
    48	         values (app.current_org_id(), $1::uuid, 'start_implementation', 'approved', 'implementing', $2::uuid, $3)`,
    49	        [order.id, userId, parsed.data.comment ?? null],
    50	      );
    51	      await writeEcoAudit(qc, {
    52	        orgId,
    53	        changeOrderId: order.id,
    54	        actorUserId: userId,
    55	        action: 'eco.implementation_started',
    56	        fromStatus: 'approved',
    57	        toStatus: 'implementing',
    58	        payload: { comment: parsed.data.comment ?? null },
    59	      });
    60	
    61	      return { ok: true, data: { id: order.id, status: 'implementing' } };
    62	    });
    63	  } catch (error) {
    64	    console.error('[technical/eco] startChangeOrderImplementation failed', {
    65	      err: error instanceof Error ? error.message : String(error),
    66	    });
    67	    return { ok: false, error: 'persistence_failed' };
    68	  }
    69	}
