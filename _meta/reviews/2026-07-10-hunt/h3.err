     1	'use server';
     2	
     3	/**
     4	 * 03-technical Routings CRUD (T-022): approve + publish workflow.
     5	 *
     6	 * approveRouting: draft → approved (records approved_by + approved_at).
     7	 * publishRouting: approved → active, and supersedes the item's currently-active
     8	 *   routing (status='superseded', effective_to = today). Each item has zero-or-one
     9	 *   active routing (PRD §12.1) — enforced by superseding the incumbent, never by
    10	 *   deleting it.
    11	 *
    12	 * Gated on `technical.bom.approve`. Runs inside withOrgContext (RLS-scoped). The
    13	 * supersede + activate happen in the same transaction so there is never a window
    14	 * with two active routings for an item.
    15	 */
    16	
    17	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
    18	import { safeRevalidatePath } from '../../items/_actions/revalidate';
    19	import {
    20	  ApproveRoutingInput,
    21	  type ApproveRoutingResult,
    22	  hasPermission,
    23	  isPgError,
    24	  type OrgActionContext,
    25	  type QueryClient,
    26	  ROUTING_APPROVE_PERMISSION,
    27	  type RoutingStatus,
    28	  writeAudit,
    29	} from './shared';
    30	
    31	async function transition(
    32	  rawInput: unknown,
    33	  from: RoutingStatus,
    34	  to: RoutingStatus,
    35	  action: string,
    36	): Promise<ApproveRoutingResult> {
    37	  const parsed = ApproveRoutingInput.safeParse(rawInput);
    38	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    39	  const input = parsed.data;
    40	
    41	  try {
    42	    return await withOrgContext(async ({ userId, orgId, client }): Promise<ApproveRoutingResult> => {
    43	      const qc = client as QueryClient;
    44	      const ctx: OrgActionContext = { userId, orgId, client: qc };
    45	      if (!(await hasPermission(ctx, ROUTING_APPROVE_PERMISSION))) return { ok: false, error: 'forbidden' };
    46	
    47	      const { rows: cur } = await qc.query<{ id: string; status: string; item_id: string }>(
    48	        `select id, status, item_id from public.routings
    49	          where org_id = app.current_org_id() and id = $1::uuid`,
    50	        [input.routingId],
    51	      );
    52	      const routing = cur[0];
    53	      if (!routing) return { ok: false, error: 'not_found' };
    54	      if (routing.status !== from) {
    55	        return { ok: false, error: 'invalid_state', message: `routing must be '${from}' to ${action} (is '${routing.status}')` };
    56	      }
    57	
    58	      // On publish (approved → active), supersede the incumbent active routing
    59	      // for the same item first, so the item keeps zero-or-one active routing.
    60	      if (to === 'active') {
    61	        await qc.query(
    62	          `update public.routings
    63	              set status = 'superseded', effective_to = current_date
    64	            where org_id = app.current_org_id()
    65	              and item_id = $1::uuid
    66	              and status = 'active'
    67	              and id <> $2::uuid`,
    68	          [routing.item_id, input.routingId],
    69	        );
    70	      }
    71	
    72	      // Two explicit statements keep the parameter positions readable. Both guard
    73	      // on `status = from` so a concurrent transition can't double-apply.
    74	      const updated =
    75	        to === 'approved'
    76	          ? await qc.query<{ id: string; status: string }>(
    77	              `update public.routings
    78	                  set status = $2, approved_by = $3::uuid, approved_at = now()
    79	                where org_id = app.current_org_id()
    80	                  and id = $1::uuid
    81	                  and status = $4
    82	              returning id, status`,
    83	              [input.routingId, to, userId, from],
    84	            )
    85	          : await qc.query<{ id: string; status: string }>(
    86	              `update public.routings
    87	                  set status = $2
    88	                where org_id = app.current_org_id()
    89	                  and id = $1::uuid
    90	                  and status = $3
    91	              returning id, status`,
    92	              [input.routingId, to, from],
    93	            );
    94	      const row = updated.rows[0];
    95	      if (!row) return { ok: false, error: 'invalid_state' };
    96	
    97	      await writeAudit(qc, {
    98	        orgId,
    99	        actorUserId: userId,
   100	        action,
   101	        resourceId: row.id,
   102	        beforeState: { status: from },
   103	        afterState: { status: to },
   104	      });
   105	
   106	      safeRevalidatePath('/technical/routings');
   107	      return { ok: true, data: { id: row.id, status: to } };
   108	    });
   109	  } catch (err) {
   110	    if (isPgError(err) && err.code === '23514') return { ok: false, error: 'invalid_input' };
   111	    console.error(`[technical/routings] ${action} persistence_failed`, {
   112	      err: err instanceof Error ? err.message : String(err),
   113	    });
   114	    return { ok: false, error: 'persistence_failed' };
   115	  }
   116	}
   117	
   118	export async function approveRouting(rawInput: unknown): Promise<ApproveRoutingResult> {
   119	  return transition(rawInput, 'draft', 'approved', 'routing.approved');
   120	}
   121	
   122	export async function publishRouting(rawInput: unknown): Promise<ApproveRoutingResult> {
   123	  return transition(rawInput, 'approved', 'active', 'routing.published');
   124	}
     1	'use server';
     2	
     3	/**
     4	 * 03-technical Routings CRUD (T-022): replace the operation set of a DRAFT
     5	 * routing. Only `draft` routings are editable — an approved/active/superseded
     6	 * routing is immutable (clone-on-write a new version instead, per the
     7	 * never-mutate-an-approved-row red line). The full operation set is re-validated
     8	 * (V-TEC-60..63) and atomically replaced.
     9	 *
    10	 * Gated on `technical.bom.create`.
    11	 */
    12	
    13	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
    14	import { z } from 'zod';
    15	import { safeRevalidatePath } from '../../items/_actions/revalidate';
    16	import {
    17	  findUnknownOperationName,
    18	  hasPermission,
    19	  isPgError,
    20	  type OrgActionContext,
    21	  type QueryClient,
    22	  RoutingOperationInput,
    23	  ROUTING_WRITE_PERMISSION,
    24	  UpdateRoutingInput,
    25	  type UpdateRoutingResult,
    26	  validateOperationSet,
    27	  writeAudit,
    28	} from './shared';
    29	
    30	const RoutingCrewMemberInput = z.object({
    31	  roleGroup: z.string().trim().min(1).max(128),
    32	  headcount: z.number().int().positive(),
    33	});
    34	
    35	const UpdateRoutingActionInput = UpdateRoutingInput.extend({
    36	  operations: z.array(
    37	    RoutingOperationInput.omit({ costPerHour: true }).extend({
    38	      crew: z.array(RoutingCrewMemberInput).optional().default([]),
    39	      yieldPct: z
    40	        .union([z.string(), z.number()])
    41	        .transform((v) => (typeof v === 'number' ? String(v) : v.trim()))
    42	        .refine((v) => /^\d+(\.\d+)?$/.test(v) && Number(v) > 0 && Number(v) <= 100, {
    43	          message: 'yieldPct must be > 0 and <= 100',
    44	        })
    45	        .optional()
    46	        .default('100'),
    47	    }),
    48	  ).min(1),
    49	});
    50	
    51	export async function updateRouting(rawInput: unknown): Promise<UpdateRoutingResult> {
    52	  const parsed = UpdateRoutingActionInput.safeParse(rawInput);
    53	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    54	  const input = parsed.data;
    55	
    56	  const setCheck = validateOperationSet(input.operations);
    57	  if (!setCheck.ok) return { ok: false, error: setCheck.error, message: setCheck.message };
    58	
    59	  try {
    60	    return await withOrgContext(async ({ userId, orgId, client }): Promise<UpdateRoutingResult> => {
    61	      const qc = client as QueryClient;
    62	      const ctx: OrgActionContext = { userId, orgId, client: qc };
    63	      if (!(await hasPermission(ctx, ROUTING_WRITE_PERMISSION))) return { ok: false, error: 'forbidden' };
    64	
    65	      const { rows: cur } = await qc.query<{ id: string; status: string }>(
    66	        `select id, status from public.routings
    67	          where org_id = app.current_org_id() and id = $1::uuid`,
    68	        [input.routingId],
    69	      );
    70	      const routing = cur[0];
    71	      if (!routing) return { ok: false, error: 'not_found' };
    72	      if (routing.status !== 'draft') {
    73	        return { ok: false, error: 'invalid_state', message: 'only a draft routing may be edited; clone a new version instead' };
    74	      }
    75	
    76	      const unknown = await findUnknownOperationName(
    77	        qc,
    78	        input.operations.map((o) => o.manufacturingOperationName),
    79	      );
    80	      if (unknown !== null) {
    81	        return {
    82	          ok: false,
    83	          error: 'v_tec_63_unknown_operation',
    84	          message: `manufacturing_operation_name '${unknown}' is not in the manufacturing-operations reference (V-TEC-63)`,
    85	        };
    86	      }
    87	
    88	      // Replace the operation set atomically: delete the draft's ops, re-insert.
    89	      // (Deleting OPERATION rows of a draft is allowed — the no-delete red line is
    90	      // about superseding routing VERSIONS, not editing an unapproved draft.)
    91	      await qc.query(
    92	        `delete from public.routing_operations
    93	          where org_id = app.current_org_id() and routing_id = $1::uuid`,
    94	        [input.routingId],
    95	      );
    96	      for (const op of input.operations) {
    97	        await qc.query(
    98	          `insert into public.routing_operations
    99	             (org_id, routing_id, op_no, op_code, op_name, line_id,
   100	              setup_time_min, run_time_per_unit_sec, manufacturing_operation_name, crew, yield_pct, created_by)
   101	           values
   102	             (app.current_org_id(), $1::uuid, $2::integer, $3, $4, $5::uuid,
   103	              $6::integer, $7::numeric, $8, $9::jsonb, $10::numeric, $11::uuid)`,
   104	          [
   105	            input.routingId,
   106	            op.opNo,
   107	            op.opCode,
   108	            op.opName,
   109	            op.lineId,
   110	            op.setupTimeMin,
   111	            op.runTimePerUnitSec ?? null,
   112	            op.manufacturingOperationName,
   113	            JSON.stringify(op.crew.map((member) => ({ role_group: member.roleGroup, headcount: member.headcount }))),
   114	            op.yieldPct,
   115	            userId,
   116	          ],
   117	        );
   118	      }
   119	
   120	      await writeAudit(qc, {
   121	        orgId,
   122	        actorUserId: userId,
   123	        action: 'routing.operations_replaced',
   124	        resourceId: input.routingId,
   125	        beforeState: null,
   126	        afterState: { operationCount: input.operations.length },
   127	      });
   128	
   129	      safeRevalidatePath('/technical/routings');
   130	      return { ok: true, data: { id: input.routingId } };
   131	    });
   132	  } catch (err) {
   133	    if (isPgError(err) && (err.code === '23514' || err.code === '23503')) {
   134	      return { ok: false, error: 'invalid_input' };
   135	    }
   136	    if (isPgError(err) && err.code === '23505') return { ok: false, error: 'already_exists' };
   137	    console.error('[technical/routings] updateRouting persistence_failed', {
   138	      err: err instanceof Error ? err.message : String(err),
   139	    });
   140	    return { ok: false, error: 'persistence_failed' };
   141	  }
   142	}
