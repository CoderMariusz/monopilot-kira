     2	
     3	import { z } from 'zod';
     4	
     5	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
     6	import { recallFactorySpecInTransaction } from '../../../../../../../lib/technical/recall-factory-spec-core';
     7	import { safeRevalidatePath } from './revalidate';
     8	import {
     9	  hasPermission,
    10	  type OrgActionContext,
    11	  type QueryClient,
    12	} from './shared';
    13	
    14	const FACTORY_SPEC_RECALL_PERMISSION = 'technical.factory_spec.recall';
    15	
    16	const RecallFactorySpecInput = z.object({
    17	  specId: z.string().uuid(),
    18	  reason: z.string().trim().max(2000).optional().nullable(),
    19	});
    20	
    21	export type RecallFactorySpecInput = z.input<typeof RecallFactorySpecInput>;
    22	
    23	export type RecallFactorySpecResult = { success: true } | { error: string };
    24	
    25	function normalizeReason(value: string | null | undefined): string | null {
    26	  const trimmed = typeof value === 'string' ? value.trim() : '';
    27	  return trimmed.length > 0 ? trimmed : null;
    28	}
    29	
    30	export async function recallFactorySpec(rawInput: unknown): Promise<RecallFactorySpecResult> {
    31	  const parsed = RecallFactorySpecInput.safeParse(rawInput);
    32	  if (!parsed.success) return { error: parsed.error.message };
    33	  const reason = normalizeReason(parsed.data.reason);
    34	
    35	  try {
    36	    return await withOrgContext(async ({ userId, orgId, client }): Promise<RecallFactorySpecResult> => {
    37	      const db = client as QueryClient;
    38	      const ctx: OrgActionContext = { userId, orgId, client: db };
    39	      if (!(await hasPermission(ctx, FACTORY_SPEC_RECALL_PERMISSION))) {
    40	        return { error: 'forbidden' };
    41	      }
    42	
    43	      const recall = await recallFactorySpecInTransaction(ctx, {
    44	        specId: parsed.data.specId,
    45	        reason,
    46	      });
    47	      if (!recall.ok) return { error: recall.error };
    48	
    49	      safeRevalidatePath('/technical/factory-specs');
    50	      return { success: true };
    51	    });
    52	  } catch (error) {
    53	    console.error('[technical/factory-specs] recallFactorySpec failed', {
    54	      error: error instanceof Error ? error.message : String(error),
    55	    });
    56	    return { error: 'persistence_failed' };
    57	  }
    58	}

