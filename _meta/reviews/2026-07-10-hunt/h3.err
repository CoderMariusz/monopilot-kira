    40	type SpecRow = {
    41	  id: string;
    42	  status: string;
    43	  fg_item_id: string;
    44	  fg_item_code: string;
    45	  bom_header_id: string | null;
    46	  bom_version: number | null;
    47	};
    48	
    49	type ReleaseSpecRow = SpecRow & {
    50	  approved_by: string | null;
    51	  approved_at: string | null;
