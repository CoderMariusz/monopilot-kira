    57	export async function listWipDefinitions(input?: ListWipDefinitionsInput): Promise<ActionResult<{ definitions: unknown[] }>> {
    58	  const parsed = listWipDefinitionsInputSchema.safeParse(input);
    59	  if (!parsed.success) return { ok: false, error: 'Invalid WIP definition filter', code: 'VALIDATION_ERROR' };
    60	
    61	  return withOrgContext<ActionResult<{ definitions: unknown[] }>>(async (ctx) => {
    62	    // Reads are org-scoped and open (canonical technical/items pattern);
    63	    // technical.wip.* gates WRITES only — viewers get the read-only library.
    64	    const filter = parsed.data ?? {};
    65	    const rows = await ctx.client.query(
    66	      `select d.id,
    67	              d.name,
    68	              d.base_uom as "baseUom",
    69	              d.version,
    70	              d.status,
    71	              d.reusable,
    72	              i.item_code as "itemCode",
    73	              coalesce(proc.process_count, 0)::int as "processCount",
    74	              coalesce(refs.project_count, 0)::int as "referencingProjects"
    75	         from public.wip_definitions d
    76	         left join public.items i on i.id = d.item_id and i.org_id = d.org_id
    77	         left join lateral (
    78	           select count(*)::int as process_count
    79	             from public.wip_definition_processes p
    80	            where p.org_id = d.org_id and p.wip_definition_id = d.id
    81	         ) proc on true
    82	         left join lateral (
    83	           select count(distinct f.project_id)::int as project_count
    84	             from public.formulation_ingredients fi
    85	             join public.formulation_versions fv on fv.id = fi.version_id
    86	             join public.formulations f on f.id = fv.formulation_id and f.org_id = d.org_id
    87	            where fi.wip_definition_id = d.id
    88	         ) refs on true
    89	        where d.org_id = app.current_org_id()
    90	          and ($1::text is null or d.status = $1::text)
    91	          and ($2::boolean is null or d.reusable = $2::boolean)
    92	          and ($3::text is null or d.name ilike '%' || $3::text || '%')
    93	        order by d.updated_at desc, d.name asc`,
    94	      [filter.status ?? null, filter.reusable ?? null, filter.q ?? null],
    95	    );
    96	    return { ok: true, definitions: rows.rows };
    97	  });
    98	}
