   174	async function getDestinationLpBlockers(ctx: OrgActionContext, destLpId: string): Promise<string[]> {
   175	  const { rows } = await ctx.client.query<{ blockers: string[] }>(
   176	    `select array_remove(array[
   177	       case when exists (
   178	         select 1
   179	           from public.inventory_allocations ia
   180	          where ia.org_id = app.current_org_id()
   181	            and ia.license_plate_id = $1::uuid
   182	       ) then 'allocations'::text end,
   183	       case when exists (
   184	         select 1
   185	           from public.shipment_box_contents sbc
   186	          where sbc.org_id = app.current_org_id()
   187	            and sbc.license_plate_id = $1::uuid
   188	       ) or exists (
   189	         select 1
   190	           from public.license_plates lp
   191	          where lp.org_id = app.current_org_id()
   192	            and lp.id = $1::uuid
   193	            and (lp.status = 'shipped' or lp.source_so_id is not null)
   194	       ) then 'outbound_shipments'::text end,
   195	       case when exists (
   196	         select 1
   197	           from public.wo_material_consumption wmc
   198	          where wmc.org_id = app.current_org_id()
   199	            and wmc.lp_id = $1::uuid
   200	            and wmc.correction_of_id is null
   201	       ) then 'consumed_wo_inputs'::text end
   202	     ], null) as blockers`,
   203	    [destLpId],
   204	  );
   205	  return rows[0]?.blockers ?? [];
   206	}
   207	
   208	async function rerollTransferOrderStatus(ctx: OrgActionContext, toId: string): Promise<string> {
   209	  const { rows } = await ctx.client.query<{ received_count: string }>(
   210	    `select count(*) filter (where dest_lp_id is not null)::text as received_count
   211	       from public.transfer_order_line_lps
   212	      where org_id = app.current_org_id()
   213	        and to_id = $1::uuid`,
   214	    [toId],
   215	  );
   216	  const nextStatus = Number(rows[0]?.received_count ?? '0') > 0 ? 'partially_received' : 'in_transit';
   217	  await ctx.client.query(
   218	    `update public.transfer_orders
   219	        set status = $2,
   220	            updated_by = $3::uuid
   221	      where org_id = app.current_org_id()
   222	        and id = $1::uuid`,
   223	    [toId, nextStatus, ctx.userId],
   224	  );
   225	  return nextStatus;
   226	}
