   226	  } catch (error) {
   227	    if (!isPgError(error) || error.code !== '23505') throw error;
   228	    if (input.documentNumber) return { ok: false, error: 'persistence_failed' };
   229	    insertedWo = await insertWorkOrderHeader(await nextDocumentNumber(ctx.client, ctx.orgId, 'wo', new Date()));
   230	  }
   231	  const workOrder = insertedWo.rows[0];
   232	  if (!workOrder) throw new Error('work_order_insert_returned_no_row');
   233	
   234	  let materialRows: WOMaterialRow[] = [];
   235	  if (bom) {
   236	    const insertedMaterials = await ctx.client.query<WOMaterialRow>(
   237	      `insert into public.wo_materials
   238	         (org_id, wo_id, product_id, material_name, required_qty, uom, sequence,
   239	          bom_item_id, bom_version, material_source, notes)
   240	       select app.current_org_id(), $1::uuid, i.id, bl.component_code,
   241	              round((bl.quantity * $2::numeric) / greatest(1 - coalesce(bl.scrap_pct, 0) / 100.0, 0.01), 3), bl.uom, coalesce(bl.sequence, bl.line_no),
   242	              bl.id, $3::integer, 'stock', bl.notes
   243	         from public.bom_lines bl
   244	         left join public.items i
   245	           on i.org_id = app.current_org_id()
   246	          and (i.id = bl.item_id
   247	               or (bl.item_id is null and i.item_code = bl.component_code))
   248	        where bl.org_id = app.current_org_id()
   249	          and bl.bom_header_id = $4::uuid
   250	        order by bl.line_no
   251	       returning id, wo_id, product_id, material_name, required_qty::text as required_qty,
   252	                 consumed_qty::text as consumed_qty, reserved_qty::text as reserved_qty, uom,
   253	                 sequence, material_source, bom_item_id, bom_version, notes`,
   254	      [woId, materialScalar.toFixed(6), bom.version, bom.id],
   255	    );
   256	    materialRows = insertedMaterials.rows;
   257	  }
   258	
   259	  await ctx.client.query(
   260	    `insert into public.wo_operations
   261	       (org_id, site_id, wo_id, sequence, operation_name, line_id,
   262	        expected_duration_minutes, status, notes, crew)
   263	     select app.current_org_id(), ro.site_id, $1::uuid, ro.op_no, ro.op_name,
   264	            ro.line_id,
   265	            case
   266	              when ro.run_time_per_unit_sec is null and ro.setup_time_min is null
   267	                then null
   268	              when coalesce(ro.setup_time_min, 0)::numeric
   269	                   + coalesce(ceil((ro.run_time_per_unit_sec * $2::numeric) / 60.0), 0) > 2147483647
   270	                then null
   271	              else (coalesce(ro.setup_time_min, 0)::numeric
   272	                    + coalesce(ceil((ro.run_time_per_unit_sec * $2::numeric) / 60.0), 0))::integer
   273	            end,
   274	            'pending', ro.op_code, ro.crew
   275	       from public.routing_operations ro
   276	       join public.routings r
   277	         on r.id = ro.routing_id
   278	        and r.org_id = ro.org_id
   279	      where ro.org_id = app.current_org_id()
   280	        and r.item_id = $3::uuid
   281	        and r.status = 'active'
   282	        and r.version = (
   283	          select max(r2.version) from public.routings r2
   284	           where r2.org_id = app.current_org_id()
   285	             and r2.item_id = $3::uuid
   286	             and r2.status = 'active'
   287	        )
   288	      order by ro.op_no
   289	     on conflict (wo_id, sequence) do nothing`,
   290	    [woId, plannedBaseQty, input.productId],
   291	  );
   292	
   293	  const insertedSchedule = await ctx.client.query<ScheduleOutputRow>(
   294	    `insert into public.schedule_outputs
   295	       (org_id, planned_wo_id, product_id, output_role, expected_qty, uom, allocation_pct, disposition, notes)
   296	     values
   297	       (app.current_org_id(), $1::uuid, $2::uuid, 'primary', $3::numeric, $5, 100.00, 'to_stock', $4)
   298	     returning id, planned_wo_id, product_id, output_role, expected_qty::text as expected_qty,
   299	               uom, allocation_pct::text as allocation_pct, disposition, downstream_wo_id, notes`,
   300	    [woId, input.productId, plannedBaseQty, input.notes ?? null, uomSnapshot.uomBase],
   301	  );
   302	  const primarySchedule = insertedSchedule.rows[0];
   303	  if (!primarySchedule) throw new Error('schedule_output_insert_returned_no_row');
   304	
   305	  await ctx.client.query(
   306	    `insert into public.wo_status_history
   307	       (org_id, wo_id, from_status, to_status, action, user_id, context_jsonb)
   308	     values
   309	       (app.current_org_id(), $1::uuid, null, 'DRAFT', 'create', $2::uuid, $3::jsonb)`,
   310	    [woId, ctx.userId, JSON.stringify({ app_version: APP_VERSION, bom_header_id: bom?.id ?? null })],
   311	  );
   312	
   313	  return {
   314	    ok: true,
   315	    workOrder: mapWoHeader(workOrder),
   316	    materials: materialRows.map(mapMaterial),
   317	    primarySchedule: mapSchedule(primarySchedule),
   318	    conversion,
   319	    warning: !bom ? 'no_active_bom' : !spec ? 'no_approved_factory_spec' : undefined,
   320	  };
   321	}
