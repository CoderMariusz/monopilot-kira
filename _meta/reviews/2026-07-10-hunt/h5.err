    15	
    16	const DEFAULT_MIN_DURATION_MS = 60 * 60 * 1000;
    17	const DAY_MS = 24 * 60 * 60 * 1000;
    18	
    19	/**
    20	 * Default solver config. `sequencingStrategy: 'local_search'` is stored in DB but
    21	 * not implemented yet — it falls back to `allergen_optimized`. `pmWindows` is
    22	 * optional caller input (maintenance integration loads these when available).
    23	 */
    24	export const DEFAULT_SEQUENCE_SOLVER_CONFIG: SequenceSolverConfig = {
    25	  sequencingStrategy: 'allergen_optimized',
    26	  changeoverWeight: 1,
    27	  duedateWeight: 1,
    28	  utilizationWeight: 1,
    29	  capacityHoursPerDay: null,
    30	  respectPmWindows: false,
    31	  pmWindows: [],
    32	};
    33	
    34	function cloneDefaultSolverConfig(): SequenceSolverConfig {
    35	  return { ...DEFAULT_SEQUENCE_SOLVER_CONFIG, pmWindows: [] };
    36	}
    37	
    38	function capacityHoursForLine(lineKey: string, config: SequenceSolverConfig): number | null {
    39	  if (lineKey !== '__unassigned__') {
    40	    const perLine = config.capacityHoursPerDayByLine?.[lineKey];
    41	    if (perLine !== undefined) return perLine;
    42	  }
    43	  return config.capacityHoursPerDay;
    44	}
    45	
    46	function dueTime(wo: WorkOrderForScheduling): number {
    47	  return new Date(wo.due_date).getTime();
    48	}
    49	
    50	function compareByDueDateThenId(a: WorkOrderForScheduling, b: WorkOrderForScheduling): number {
    51	  const dueDelta = dueTime(a) - dueTime(b);
    52	  if (dueDelta !== 0) return dueDelta;
    53	  return a.id.localeCompare(b.id);
    54	}
    55	
    56	function timestampMs(value: string | Date | null | undefined): number | null {
    57	  if (value === null || value === undefined) return null;
    58	  const ms = value instanceof Date ? value.getTime() : new Date(value).getTime();
    59	  return Number.isFinite(ms) ? ms : null;
    60	}
    61	
    62	function numericMs(value: string | number | null | undefined): number | null {
    63	  if (value === null || value === undefined) return null;
    64	  const parsed = Number(value);
    65	  return Number.isFinite(parsed) && parsed > 0 ? parsed : null;
    66	}
    67	
    68	function routingDurationMs(wo: WorkOrderForScheduling): number | null {
    69	  return numericMs(wo.routing_duration_ms);
    70	}
    71	
    72	function processDurationMs(wo: WorkOrderForScheduling): number | null {
    73	  return numericMs(wo.process_duration_ms);
    74	}
    75	
    76	/** Derive WO run duration: scheduled/planned window, then routing, then process masters, else 1h floor. */
    77	export function durationMs(wo: WorkOrderForScheduling): number {
    78	  const pairs: Array<[string | Date | null, string | Date | null]> = [
    79	    [wo.scheduled_start_time, wo.scheduled_end_time],
    80	    [wo.planned_start_date, wo.planned_end_date],
    81	  ];
    82	  for (const [startValue, endValue] of pairs) {
    83	    const start = timestampMs(startValue);
    84	    const end = timestampMs(endValue);
    85	    if (start === null || end === null || end <= start) continue;
    86	    return end - start;
    87	  }
    88	
    89	  const routing = routingDurationMs(wo);
    90	  if (routing !== null) return routing;
    91	
    92	  const process = processDurationMs(wo);
    93	  if (process !== null) return process;
    94	
    95	  return DEFAULT_MIN_DURATION_MS;
    96	}
    97	
    98	function changeoverBetween(
    99	  fromWo: WorkOrderForScheduling,
   100	  toWo: WorkOrderForScheduling,
   101	  matrix: ChangeoverMatrixEntry[],
   102	  changeoverWeight: number,
   103	): { cost: number; transitionMinutes: number; feasible: boolean } {
   104	  const transition = resolveChangeoverTransition(
   105	    normalizedAllergenIds(fromWo.allergen_ids),
   106	    normalizedAllergenIds(toWo.allergen_ids),
   107	    toWo.production_line_id,
   108	    matrix,
   109	  );
   110	  return {
   111	    cost: transitionScore(transition, changeoverWeight),
   112	    transitionMinutes: effectiveChangeoverMinutes(transition),
   113	    feasible: transition.feasible,
   114	  };
   115	}
   116	
   117	function dueDatePenalty(candidate: WorkOrderForScheduling, anchorDueMs: number, duedateWeight: number): number {
   118	  if (duedateWeight <= 0) return 0;
   119	  return ((dueTime(candidate) - anchorDueMs) / DAY_MS) * duedateWeight;
   120	}
   121	
   122	function utilizationPenalty(
   123	  transitionMinutes: number,
   124	  candidate: WorkOrderForScheduling,
   125	  utilizationWeight: number,
   126	): number {
   127	  if (utilizationWeight <= 0) return 0;
   128	  const runMinutes = durationMs(candidate) / (60 * 1000);
   129	  if (runMinutes <= 0) return 0;
   130	  return (transitionMinutes / runMinutes) * utilizationWeight;
   131	}
   132	
   133	function startOfUtcDay(ms: number): number {
   134	  const day = new Date(ms);
   135	  day.setUTCHours(0, 0, 0, 0);
   136	  return day.getTime();
   137	}
   138	
   139	function dayBucketKey(lineKey: string, ms: number): string {
   140	  return `${lineKey}|${new Date(ms).toISOString().slice(0, 10)}`;
   141	}
   142	
   143	function pmWindowBlocks(
   144	  lineKey: string,
   145	  startMs: number,
   146	  endMs: number,
   147	  windows: PmWindow[],
   148	): PmWindow | null {
   149	  for (const window of windows) {
   150	    if (window.line_id !== null && window.line_id !== lineKey) continue;
   151	    const windowStart = timestampMs(window.start_at);
   152	    const windowEnd = timestampMs(window.end_at);
   153	    if (windowStart === null || windowEnd === null || windowEnd <= windowStart) continue;
   154	    if (startMs < windowEnd && endMs > windowStart) return window;
   155	  }
   156	  return null;
   157	}
   158	
   159	function resolvePlannedStart(
   160	  lineKey: string,
   161	  earliestMs: number,
   162	  runDurationMs: number,
   163	  config: SequenceSolverConfig,
   164	  dayUsageHours: Map<string, number>,
   165	): number {
   166	  const capacityHours = capacityHoursForLine(lineKey, config);
   167	  const capacityMs =
   168	    capacityHours !== null && capacityHours > 0 ? capacityHours * 60 * 60 * 1000 : null;
   169	  const pmWindows = config.respectPmWindows ? (config.pmWindows ?? []) : [];
   170	  let start = earliestMs;
   171	
   172	  for (let guard = 0; guard < 400; guard += 1) {
   173	    const end = start + runDurationMs;
   174	
   175	    const blocker = pmWindows.length > 0 ? pmWindowBlocks(lineKey, start, end, pmWindows) : null;
   176	    if (blocker) {
   177	      const windowEnd = timestampMs(blocker.end_at);
   178	      if (windowEnd === null) break;
   179	      start = Math.max(start, windowEnd);
   180	      continue;
   181	    }
   182	
   183	    if (capacityMs !== null) {
   184	      const bucketKey = dayBucketKey(lineKey, start);
   185	      const usedMs = (dayUsageHours.get(bucketKey) ?? 0) * 60 * 60 * 1000;
   186	      const remainingMs = capacityMs - usedMs;
   187	      if (remainingMs <= 0 || runDurationMs > remainingMs) {
   188	        start = startOfUtcDay(start) + DAY_MS;
   189	        continue;
   190	      }
   191	    }
   192	
   193	    if (capacityMs !== null) {
   194	      const bucketKey = dayBucketKey(lineKey, start);
   195	      dayUsageHours.set(bucketKey, (dayUsageHours.get(bucketKey) ?? 0) + runDurationMs / (60 * 60 * 1000));
   196	    }
   197	    return start;
   198	  }
   199	
   200	  return earliestMs;
   201	}
   202	
   203	function pickNextIndex(
   204	  tail: WorkOrderForScheduling,
   205	  unscheduled: WorkOrderForScheduling[],
   206	  matrix: ChangeoverMatrixEntry[],
   207	  config: SequenceSolverConfig,
   208	): number {
   209	  const useChangeover = config.sequencingStrategy !== 'greedy';
   210	  let bestIndex = -1;
   211	  let bestScore = Number.POSITIVE_INFINITY;
   212	
   213	  for (let index = 0; index < unscheduled.length; index += 1) {
   214	    const candidate = unscheduled[index];
   215	    const { cost, transitionMinutes, feasible } = changeoverBetween(
   216	      tail,
   217	      candidate,
   218	      matrix,
   219	      config.changeoverWeight,
   220	    );
   221	    if (useChangeover && !feasible) continue;
   222	
   223	    let score = useChangeover
   224	      ? cost + dueDatePenalty(candidate, dueTime(tail), config.duedateWeight)
   225	      : dueDatePenalty(candidate, dueTime(tail), config.duedateWeight);
   226	    if (useChangeover) {
   227	      score += utilizationPenalty(transitionMinutes, candidate, config.utilizationWeight);
   228	    }
   229	
   230	    const tieCandidate =
   231	      bestIndex === -1 ? candidate : unscheduled[bestIndex];
   232	    const dueDelta = compareByDueDateThenId(candidate, tieCandidate);
   233	    if (score < bestScore || (score === bestScore && dueDelta < 0)) {
   234	      bestIndex = index;
   235	      bestScore = score;
   236	    }
   237	  }
   238	
   239	  if (bestIndex === -1) {
   240	    bestIndex = 0;
   241	    for (let index = 1; index < unscheduled.length; index += 1) {
   242	      if (compareByDueDateThenId(unscheduled[index], unscheduled[bestIndex]) < 0) {
   243	        bestIndex = index;
   244	      }
   245	    }
   246	  }
   247	
   248	  return bestIndex;
   249	}
   250	
   251	export function sequenceWorkOrders(
   252	  wos: WorkOrderForScheduling[],
   253	  matrix: ChangeoverMatrixEntry[],
   254	  config: SequenceSolverConfig = cloneDefaultSolverConfig(),
   255	): SequencedAssignment[] {
   256	  if (wos.length === 0) return [];
   257	
   258	  const unscheduled = [...wos].sort(compareByDueDateThenId);
   259	  const sequence: WorkOrderForScheduling[] = [];
   260	
   261	  const first = unscheduled.shift();
   262	  if (!first) return [];
   263	  sequence.push(first);
   264	
   265	  while (unscheduled.length > 0) {
   266	    const tail = sequence[sequence.length - 1];
   267	    const bestIndex = pickNextIndex(tail, unscheduled, matrix, config);
   268	    const [next] = unscheduled.splice(bestIndex, 1);
   269	    sequence.push(next);
   270	  }
   271	
   272	  let cumulative = 0;
   273	  const now = Date.now();
   274	  const plannedEndByLine = new Map<string, number>();
   275	  const dayUsageHours = new Map<string, number>();
   276	
   277	  return sequence.map((workOrder, index) => {
   278	    const previous = index === 0 ? null : sequence[index - 1];
   279	    const profile = normalizedAllergenIds(workOrder.allergen_ids);
   280	    const toKey = allergenProfileKey(profile);
   281	    const { transitionMinutes } = previous
   282	      ? changeoverBetween(previous, workOrder, matrix, config.changeoverWeight)
   283	      : { transitionMinutes: 0 };
   284	    const changeoverCost = transitionMinutes;
   285	    const lineKey = workOrder.production_line_id ?? '__unassigned__';
   286	    const earliestStart = Math.max(now, (plannedEndByLine.get(lineKey) ?? now) + changeoverCost * 60 * 1000);
   287	    const runDuration = durationMs(workOrder);
   288	    const plannedStart = resolvePlannedStart(lineKey, earliestStart, runDuration, config, dayUsageHours);
   289	    const plannedEnd = plannedStart + runDuration;
   290	    plannedEndByLine.set(lineKey, plannedEnd);
   291	    cumulative += changeoverCost;
   292	
   293	    return {
   294	      wo_id: workOrder.id,
   295	      sequence_index: index + 1,
   296	      line_id: workOrder.production_line_id,
   297	      planned_start_at: new Date(plannedStart).toISOString(),
   298	      planned_end_at: new Date(plannedEnd).toISOString(),
   299	      changeover_cost: changeoverCost,
   300	      cumulative_changeover_cost: cumulative,
   301	      allergen_profile_key: toKey,
   302	      work_order: workOrder,
   303	    };
   304	  });
   305	}
     1	/**
     2	 * Pure schedule-board domain helpers + shared types for /planning/schedule.
     3	 *
     4	 * NOT a 'use server' module — the action file may only export async functions,
     5	 * so the board's types, geometry math, and conflict detection live here where
     6	 * both the Server Action and the client component (and tests) can import them.
     7	 */
     8	
     9	import type { PaginatedResult } from '../../../../../../../lib/shared/pagination';
    10	
    11	/** WO statuses that appear on the board (planning-phase + running). */
    12	export const BOARD_STATUSES = ['DRAFT', 'RELEASED', 'IN_PROGRESS'] as const;
    13	
    14	/** WO statuses rescheduleWorkOrder accepts ("planned"=DRAFT + RELEASED). */
    15	export const RESCHEDULE_LEGAL_STATUSES = ['DRAFT', 'RELEASED'] as const;
    16	
    17	/** Board window length — 7 days starting today (UTC midnight). */
    18	export const BOARD_WINDOW_DAYS = 7;
    19	
    20	/** Fallback bar length when scheduled_end_time is NULL (open-ended WO). */
    21	export const OPEN_END_FALLBACK_MS = 60 * 60 * 1000;
    22	
    23	export type ScheduleBoardLine = {
    24	  id: string;
    25	  code: string;
    26	  name: string;
    27	};
    28	
    29	export type ScheduleBoardWo = {
