   812	export async function listChangeoverMatrix(): Promise<ListChangeoverMatrixResult> {
   813	  try {
   814	    return await withOrgContext(async (ctx: OrgActionContext): Promise<ListChangeoverMatrixResult> => {
   815	      if (!(await hasPermission(ctx, SCHEDULER_MATRIX_READ_PERMISSION))) {
   816	        return { ok: false, error: 'forbidden' };
   817	      }
   818	
   819	      const { rows } = await ctx.client.query<ChangeoverMatrixEntry>(
   820	        `select ${MATRIX_SELECT}
   821	           from public.changeover_matrix
   822	          where org_id = app.current_org_id()
   823	          order by line_id nulls first, allergen_from, allergen_to`,
   824	      );
   825	      return { ok: true, entries: rows };
   826	    });
   827	  } catch (error) {
   828	    console.error('[scheduler/listChangeoverMatrix] persistence_failed', error);
   829	    return { ok: false, error: 'persistence_failed' };
   830	  }
   831	}
   832	
   833	export async function upsertChangeoverMatrixEntry(
   834	  entry: Partial<ChangeoverMatrixEntry>,
   835	): Promise<UpsertChangeoverMatrixEntryResult> {
   836	  try {
   837	    return await withOrgContext(async (ctx: OrgActionContext): Promise<UpsertChangeoverMatrixEntryResult> => {
   838	      if (!(await hasPermission(ctx, SCHEDULER_MATRIX_EDIT_PERMISSION))) {
   839	        return { ok: false, error: 'forbidden' };
   840	      }
   841	
   842	      const result = entry.id
   843	        ? await updateMatrixById(ctx, { ...entry, id: entry.id })
   844	        : await upsertMatrixByPair(ctx, entry);
   845	      if (!result) return { ok: false, error: entry.id ? 'not_found' : 'invalid_input' };
   846	      return { ok: true, entry: result };
   847	    });
   848	  } catch (error) {
   849	    console.error('[scheduler/upsertChangeoverMatrixEntry] persistence_failed', error);
   850	    return { ok: false, error: 'persistence_failed' };
   851	  }
   852	}
