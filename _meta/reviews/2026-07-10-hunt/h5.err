   158	const DAY_MS = 24 * 60 * 60 * 1000;
   159	
   160	/** Milliseconds of [startMs, endMs) overlapping a UTC day bucket. */
   161	export function overlapMsWithUtcDay(startMs: number, endMs: number, dayStartMs: number): number {
   162	  const dayEndMs = dayStartMs + DAY_MS;
   163	  const overlapStart = Math.max(startMs, dayStartMs);
   164	  const overlapEnd = Math.min(endMs, dayEndMs);
   165	  return Math.max(0, overlapEnd - overlapStart);
   166	}
   167	
   168	function numericCapacity(value: string | number | null | undefined): number | null {
   169	  if (value === null || value === undefined) return null;
   170	  const parsed = Number(value);
   171	  return Number.isFinite(parsed) && parsed > 0 ? parsed : null;
   172	}
   173	
   174	function resolveLineCapacityHours(
   175	  lineId: string,
   176	  perLine: Map<string, number | null>,
   177	  orgDefault: number | null,
   178	): number | null {
   179	  if (perLine.has(lineId)) return perLine.get(lineId) ?? null;
   180	  return orgDefault;
   181	}
   182	
   183	/**
   184	 * Aggregate scheduled WO hours per line/day and compare to scheduler_config capacity.
   185	 * `capacityRows` uses null line_id for the org-wide default.
   186	 */
   187	export function computeLineDayUtilization(input: {
   188	  lines: readonly ScheduleBoardLine[];
   189	  scheduled: readonly ScheduleBoardWo[];
   190	  capacityRows: ReadonlyArray<{ line_id: string | null; capacity_hours_per_day: string | number | null }>;
   191	  windowStartIso: string;
   192	  days?: number;
   193	}): ScheduleLineDayUtilization[] {
   194	  const days = input.days ?? BOARD_WINDOW_DAYS;
   195	  const windowStartMs = Date.parse(input.windowStartIso);
   196	  const dayKeys = windowDayKeys(input.windowStartIso, days);
   197	
   198	  const perLine = new Map<string, number | null>();
   199	  let orgDefault: number | null = null;
   200	  for (const row of input.capacityRows) {
   201	    const hours = numericCapacity(row.capacity_hours_per_day);
   202	    if (row.line_id === null) orgDefault = hours;
   203	    else perLine.set(row.line_id, hours);
   204	  }
   205	
   206	  const scheduledHours = new Map<string, number>();
   207	  for (const wo of input.scheduled) {
   208	    const interval = barInterval(wo);
   209	    if (!interval?.lineId) continue;
   210	    for (let index = 0; index < days; index += 1) {
   211	      const dayStartMs = windowStartMs + index * DAY_MS;
   212	      const overlapMs = overlapMsWithUtcDay(interval.startMs, interval.endMs, dayStartMs);
   213	      if (overlapMs <= 0) continue;
   214	      const key = `${interval.lineId}|${dayKeys[index]}`;
   215	      scheduledHours.set(key, (scheduledHours.get(key) ?? 0) + overlapMs / (60 * 60 * 1000));
   216	    }
   217	  }
   218	
   219	  const results: ScheduleLineDayUtilization[] = [];
   220	  for (const line of input.lines) {
   221	    const capacityHours = resolveLineCapacityHours(line.id, perLine, orgDefault);
   222	    for (const dayKey of dayKeys) {
   223	      const key = `${line.id}|${dayKey}`;
   224	      const hours = scheduledHours.get(key) ?? 0;
   225	      if (hours <= 0 && capacityHours === null) continue;
   226	      const utilizationPct =
   227	        capacityHours !== null && capacityHours > 0 ? (hours / capacityHours) * 100 : null;
   228	      results.push({
   229	        lineId: line.id,
   230	        dayKey,
   231	        scheduledHours: Math.round(hours * 100) / 100,
   232	        capacityHours,
   233	        utilizationPct: utilizationPct === null ? null : Math.round(utilizationPct * 10) / 10,
   234	      });
   235	    }
   236	  }
   237	  return results;
   238	}
     1	'use server';
     2	
     3	/**
     4	 * /planning/schedule Server Actions — read the line schedule board + the one
     5	 * light write (rescheduleWorkOrder). NO auto-sequencing optimizer lives here;
     6	 * this is the honest read+light-write board that replaces the "Run sequencing"
     7	 * stub (clickthrough §4).
     8	 *
     9	 * RBAC mirrors the planning neighbours exactly:
    10	 *   - read  → 'scheduler.run.read'  (same as _actions/dashboard-data.ts)
    11	 *   - write → PLANNING_WO_WRITE_PERMISSION ('npd.planning.write', the
    12	 *     createWorkOrder/releaseWorkOrder family)
    13	 *
    14	 * V-PLAN-WO-CYCLE (audit F-C14, promised in mig 177 and never built):
    15	 * rescheduleWorkOrder adds NO wo_dependencies edges, so it cannot CREATE a
    16	 * cycle — but per the validator contract it refuses to move a WO whose
    17	 * existing dependency graph is already cyclic (a cycle = silent infinite
    18	 * scheduling loop at solver time). The pure validator lives in
    19	 * ../_lib/wo-cycle.ts and is the canonical implementation for future edge
    20	 * write paths too.
    21	 */
    22	
    23	import { z } from 'zod';
    24	
    25	import { getActiveSiteId } from '../../../../../../../lib/site/site-context';
    26	import {
    27	  DEFAULT_UNSCHEDULED_PAGE_SIZE,
    28	  emptyPaginatedResult,
    29	  normalizePage,
    30	  toPaginatedResult,
    31	} from '../../../../../../../lib/shared/pagination';
    32	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
    33	import {
    34	  PLANNING_WO_WRITE_PERMISSION,
    35	  hasPermission,
    36	  toIso,
    37	  type OrgActionContext,
    38	} from '../../work-orders/_actions/shared';
    39	import {
    40	  BOARD_STATUSES,
    41	  BOARD_WINDOW_DAYS,
    42	  RESCHEDULE_LEGAL_STATUSES,
    43	  computeLineDayUtilization,
    44	  type ScheduleBoardData,
    45	  type ScheduleCapacityBlock,
    46	  type ScheduleBoardLine,
    47	  type ScheduleBoardWo,
    48	} from '../_lib/board';
    49	import { findCycleInvolving, type WoDependencyEdge } from '../_lib/wo-cycle';
    50	
    51	const SCHEDULE_READ_PERMISSION = 'scheduler.run.read';
    52	const APP_VERSION = 'planning-schedule-board-v1';
    53	
    54	export type ScheduleBoardError = 'forbidden' | 'persistence_failed';
    55	
    56	export type GetScheduleBoardResult =
    57	  | { ok: true; data: ScheduleBoardData }
    58	  | { ok: false; error: ScheduleBoardError };
    59	
    60	type WoRow = {
    61	  id: string;
    62	  wo_number: string;
    63	  status: string;
    64	  priority: string;
    65	  production_line_id: string | null;
    66	  scheduled_start_time: Date | string | null;
    67	  scheduled_end_time: Date | string | null;
    68	  planned_quantity: string;
    69	  uom: string;
    70	  item_code: string | null;
    71	  item_name: string | null;
    72	};
    73	
    74	type CapacityBlockRow = {
    75	  id: string;
    76	  line_id: string;
    77	  project_id: string | null;
    78	  trial_id: string | null;
    79	  label: string | null;
    80	  block_date: string;
    81	  start_time: string;
    82	  end_time: string;
    83	  block_type: string;
    84	};
    85	
    86	type SchedulerCapacityRow = {
    87	  line_id: string | null;
    88	  capacity_hours_per_day: string | number | null;
    89	};
    90	
    91	function mapBoardWo(row: WoRow): ScheduleBoardWo {
    92	  return {
    93	    id: row.id,
    94	    woNumber: row.wo_number,
    95	    itemCode: row.item_code,
    96	    itemName: row.item_name,
    97	    status: row.status,
    98	    priority: row.priority,
    99	    productionLineId: row.production_line_id,
   100	    scheduledStart: row.scheduled_start_time ? toIso(row.scheduled_start_time) : null,
   101	    scheduledEnd: row.scheduled_end_time ? toIso(row.scheduled_end_time) : null,
   102	    plannedQuantity: String(row.planned_quantity),
   103	    uom: row.uom,
   104	  };
   105	}
   106	
   107	function mapCapacityBlock(row: CapacityBlockRow): ScheduleCapacityBlock {
   108	  return {
   109	    id: row.id,
   110	    lineId: row.line_id,
   111	    projectId: row.project_id,
   112	    trialId: row.trial_id,
   113	    label: row.label ?? 'NPD trial',
   114	    blockDate: row.block_date,
   115	    startTime: row.start_time.slice(0, 5),
   116	    endTime: row.end_time.slice(0, 5),
   117	    blockType: row.block_type,
   118	  };
   119	}
   120	
   121	const WO_SELECT = `
   122	  select wo.id, wo.wo_number, wo.status, wo.priority, wo.production_line_id,
   123	         wo.scheduled_start_time, wo.scheduled_end_time,
   124	         wo.planned_quantity::text as planned_quantity, wo.uom,
   125	         i.item_code, i.name as item_name
   126	    from public.work_orders wo
   127	    left join public.items i
   128	      on i.id = wo.product_id
   129	     and i.org_id = wo.org_id
   130	   where wo.org_id = app.current_org_id()`;
   131	
   132	export async function getScheduleBoard(input?: {
   133	  unscheduledPage?: number;
   134	}): Promise<GetScheduleBoardResult> {
   135	  const unscheduledPage = normalizePage({
   136	    page: input?.unscheduledPage,
   137	    defaultLimit: DEFAULT_UNSCHEDULED_PAGE_SIZE,
   138	    maxLimit: DEFAULT_UNSCHEDULED_PAGE_SIZE,
   139	  });
   140	
   141	  try {
   142	    return await withOrgContext(async (ctx: OrgActionContext): Promise<GetScheduleBoardResult> => {
   143	      if (!(await hasPermission(ctx, SCHEDULE_READ_PERMISSION))) {
   144	        return { ok: false, error: 'forbidden' };
   145	      }
   146	
   147	      const windowStart = new Date();
   148	      windowStart.setUTCHours(0, 0, 0, 0);
   149	      const windowEnd = new Date(windowStart.getTime() + BOARD_WINDOW_DAYS * 24 * 60 * 60 * 1000);
   150	
   151	      const s = await getActiveSiteId({ client: ctx.client });
   152	      if (!s) {
   153	        return {
   154	          ok: true,
   155	          data: {
   156	            windowStart: windowStart.toISOString(),
   157	            windowEnd: windowEnd.toISOString(),
   158	            lines: [],
   159	            scheduled: [],
   160	            unscheduled: [],
   161	            unscheduledPagination: emptyPaginatedResult(unscheduledPage),
   162	            capacityBlocks: [],
   163	            lineDayUtilization: [],
   164	            noActiveSite: true,
   165	          } as ScheduleBoardData & { noActiveSite: true },
   166	        };
   167	      }
   168	
   169	      const linesResult = await ctx.client.query<ScheduleBoardLine>(
   170	        `select id, code, name
   171	           from public.production_lines
   172	          where org_id = app.current_org_id()
   173	            and status = 'active'
   174	          order by code`,
   175	      );
   176	
   177	      const scheduledResult = await ctx.client.query<WoRow>(
   178	        `${WO_SELECT}
   179	     and wo.status = any($1::text[])
   180	     and wo.site_id = $4::uuid
   181	     and wo.scheduled_start_time is not null
   182	     and wo.scheduled_start_time < $3::timestamptz
   183	     and coalesce(wo.scheduled_end_time, wo.scheduled_start_time + interval '1 hour') > $2::timestamptz
   184	   order by wo.scheduled_start_time`,
   185	        [[...BOARD_STATUSES], windowStart.toISOString(), windowEnd.toISOString(), s],
   186	      );
   187	
   188	      const [unscheduledCountResult, unscheduledResult] = await Promise.all([
   189	        ctx.client.query<{ total: number }>(
   190	          `select count(*)::int as total
   191	             from public.work_orders wo
   192	            where wo.org_id = app.current_org_id()
   193	              and wo.status = any($1::text[])
   194	              and wo.site_id = $2::uuid
   195	              and wo.scheduled_start_time is null`,
   196	          [[...BOARD_STATUSES], s],
   197	        ),
   198	        ctx.client.query<WoRow>(
   199	          `${WO_SELECT}
   200	     and wo.status = any($1::text[])
   201	     and wo.site_id = $2::uuid
   202	     and wo.scheduled_start_time is null
   203	   order by wo.created_at desc, wo.id desc
   204	   limit $3::integer offset $4::integer`,
   205	          [[...BOARD_STATUSES], s, unscheduledPage.limit, unscheduledPage.offset],
   206	        ),
   207	      ]);
   208	
   209	      const unscheduledItems = unscheduledResult.rows.map(mapBoardWo);
   210	      const unscheduledPagination = toPaginatedResult(
   211	        unscheduledItems,
   212	        Number(unscheduledCountResult.rows[0]?.total ?? 0),
   213	        unscheduledPage,
   214	      );
   215	
   216	      const capacityBlocksResult = await ctx.client.query<CapacityBlockRow>(
   217	        `select pcb.id::text as id,
   218	                pcb.line_id::text as line_id,
   219	                pcb.project_id::text as project_id,
   220	                pcb.trial_id::text as trial_id,
   221	                pcb.label,
   222	                to_char(pcb.block_date, 'YYYY-MM-DD') as block_date,
   223	                pcb.start_time::text as start_time,
   224	                pcb.end_time::text as end_time,
   225	                pcb.block_type
   226	           from public.planning_capacity_blocks pcb
   227	           join public.production_lines pl
   228	             on pl.org_id = pcb.org_id
   229	            and pl.id = pcb.line_id
   230	          where pcb.org_id = app.current_org_id()
   231	            and pl.site_id = $3::uuid
   232	            and pcb.block_date >= $1::date
   233	            and pcb.block_date < $2::date
   234	          order by pcb.block_date, pcb.start_time`,
   235	        [windowStart.toISOString().slice(0, 10), windowEnd.toISOString().slice(0, 10), s],
   236	      );
   237	
   238	      const schedulerCapacityResult = await ctx.client.query<SchedulerCapacityRow>(
   239	        `select line_id, capacity_hours_per_day::text as capacity_hours_per_day
   240	           from public.scheduler_config
   241	          where org_id = app.current_org_id()`,
   242	      );
   243	
   244	      const scheduled = scheduledResult.rows.map(mapBoardWo);
   245	      const lines = linesResult.rows;
   246	
   247	      return {
   248	        ok: true,
   249	        data: {
   250	          windowStart: windowStart.toISOString(),
   251	          windowEnd: windowEnd.toISOString(),
   252	          lines,
   253	          scheduled,
   254	          unscheduled: unscheduledItems,
   255	          unscheduledPagination,
   256	          capacityBlocks: capacityBlocksResult.rows.map(mapCapacityBlock),
   257	          lineDayUtilization: computeLineDayUtilization({
   258	            lines,
   259	            scheduled,
   260	            capacityRows: schedulerCapacityResult.rows,
   261	            windowStartIso: windowStart.toISOString(),
   262	          }),
   263	        },
   264	      };
   265	    });
   266	  } catch (error) {
   267	    console.error('[getScheduleBoard] read_failed', error);
   268	    return { ok: false, error: 'persistence_failed' };
   269	  }
   270	}
   271	
   272	export type RescheduleWorkOrderError =
   273	  | 'invalid_input'
   274	  | 'invalid_range'
   275	  | 'forbidden'
   276	  | 'not_found'
   277	  | 'invalid_state'
   278	  | 'invalid_line'
   279	  | 'line_site_mismatch'
   280	  | 'dependency_cycle'
   281	  | 'persistence_failed';
   282	
   283	export type RescheduleWorkOrderResult =
   284	  | { ok: true; workOrder: ScheduleBoardWo }
   285	  | { ok: false; error: RescheduleWorkOrderError; issues?: z.ZodIssue[]; cycle?: string[] };
   286	
   287	const RescheduleWorkOrderInput = z.object({
   288	  woId: z.string().uuid(),
   289	  lineId: z.string().uuid().optional(),
   290	  scheduledStart: z.string().datetime({ offset: true }),
   291	  scheduledEnd: z.string().datetime({ offset: true }),
   292	});
   293	
   294	export async function rescheduleWorkOrder(params: {
   295	  woId: string;
   296	  lineId?: string;
   297	  scheduledStart: string;
   298	  scheduledEnd: string;
   299	}): Promise<RescheduleWorkOrderResult> {
   300	  const parsed = RescheduleWorkOrderInput.safeParse(params);
   301	  if (!parsed.success) return { ok: false, error: 'invalid_input', issues: parsed.error.issues };
   302	  const input = parsed.data;
   303	
   304	  if (Date.parse(input.scheduledEnd) <= Date.parse(input.scheduledStart)) {
   305	    return { ok: false, error: 'invalid_range' };
   306	  }
   307	
   308	  try {
   309	    return await withOrgContext(async (ctx: OrgActionContext): Promise<RescheduleWorkOrderResult> => {
   310	      if (!(await hasPermission(ctx, PLANNING_WO_WRITE_PERMISSION))) {
   311	        return { ok: false, error: 'forbidden' };
   312	      }
   313	
   314	      const currentResult = await ctx.client.query<{
   315	        status: string;
   316	        scheduled_start_time: Date | string | null;
   317	        scheduled_end_time: Date | string | null;
   318	        production_line_id: string | null;
   319	        site_id: string | null;
   320	      }>(
   321	        `select status, scheduled_start_time, scheduled_end_time, production_line_id, site_id
   322	           from public.work_orders
   323	          where org_id = app.current_org_id()
   324	            and id = $1::uuid
   325	          limit 1
   326	          for update`,
   327	        [input.woId],
   328	      );
   329	      const current = currentResult.rows[0];
   330	      if (!current) return { ok: false, error: 'not_found' };
   331	      if (!(RESCHEDULE_LEGAL_STATUSES as readonly string[]).includes(current.status)) {
   332	        return { ok: false, error: 'invalid_state' };
   333	      }
   334	
   335	      if (input.lineId) {
   336	        const lineResult = await ctx.client.query<{ id: string; site_id: string | null }>(
   337	          `select id, site_id::text as site_id
   338	             from public.production_lines
   339	            where org_id = app.current_org_id()
   340	              and id = $1::uuid
   341	              and status = 'active'
   342	            limit 1`,
   343	          [input.lineId],
   344	        );
   345	        const line = lineResult.rows[0];
   346	        if (!line) return { ok: false, error: 'invalid_line' };
   347	        if (
   348	          current.site_id != null &&
   349	          line.site_id != null &&
   350	          current.site_id !== line.site_id
   351	        ) {
   352	          return { ok: false, error: 'line_site_mismatch' };
   353	        }
   354	      }
   355	
   356	      // V-PLAN-WO-CYCLE defensive guard — refuse to move a WO sitting on an
   357	      // already-cyclic dependency graph (see module header).
   358	      const edgesResult = await ctx.client.query<{ parent_wo_id: string; child_wo_id: string }>(
   359	        `select parent_wo_id, child_wo_id
   360	           from public.wo_dependencies
   361	          where org_id = app.current_org_id()`,
   362	      );
   363	      const edges: WoDependencyEdge[] = edgesResult.rows.map((row) => ({
   364	        parentWoId: row.parent_wo_id,
   365	        childWoId: row.child_wo_id,
   366	      }));
   367	      const cycle = findCycleInvolving(edges, input.woId);
   368	      if (cycle) return { ok: false, error: 'dependency_cycle', cycle };
   369	
   370	      // Status re-checked in the WHERE clause — a concurrent release/start
   371	      // between the read above and this write degrades to invalid_state.
   372	      const updated = await ctx.client.query<WoRow>(
   373	        `update public.work_orders wo
   374	            set scheduled_start_time = $2::timestamptz,
   375	                scheduled_end_time = $3::timestamptz,
   376	                production_line_id = coalesce($4::uuid, wo.production_line_id),
   377	                updated_by = $5::uuid,
   378	                updated_at = now()
   379	          where wo.org_id = app.current_org_id()
   380	            and wo.id = $1::uuid
   381	            and wo.status = $7
   382	            and wo.status = any($6::text[])
   383	      returning wo.id, wo.wo_number, wo.status, wo.priority, wo.production_line_id,
   384	                wo.scheduled_start_time, wo.scheduled_end_time,
   385	                wo.planned_quantity::text as planned_quantity, wo.uom,
   386	                null::text as item_code, null::text as item_name`,
   387	        [
   388	          input.woId,
   389	          input.scheduledStart,
   390	          input.scheduledEnd,
   391	          input.lineId ?? null,
   392	          ctx.userId,
   393	          [...RESCHEDULE_LEGAL_STATUSES],
   394	          current.status,
   395	        ],
   396	      );
   397	      const workOrder = updated.rows[0];
   398	      if (!workOrder) return { ok: false, error: 'invalid_state' };
   399	
   400	      // Audit row like the neighbours (createWorkOrder/releaseWorkOrder write
   401	      // wo_status_history). Status is unchanged — action 'reschedule' carries
   402	      // the before/after schedule in context_jsonb.
   403	      await ctx.client.query(
   404	        `insert into public.wo_status_history
   405	           (org_id, wo_id, from_status, to_status, action, user_id, context_jsonb)
   406	         values
   407	           (app.current_org_id(), $1::uuid, $2, $2, 'reschedule', $3::uuid, $4::jsonb)`,
   408	        [
   409	          input.woId,
   410	          current.status,
   411	          ctx.userId,
   412	          JSON.stringify({
   413	            app_version: APP_VERSION,
   414	            previous: {
   415	              scheduled_start_time: current.scheduled_start_time
   416	                ? toIso(current.scheduled_start_time)
   417	                : null,
   418	              scheduled_end_time: current.scheduled_end_time
   419	                ? toIso(current.scheduled_end_time)
   420	                : null,
     1	-- Migration 179: 04-Planning-Basic — rough-cut capacity planning schema.
     2	-- PRD: docs/prd/04-PLANNING-BASIC-PRD.md §11 (Finite-Capacity Scheduling Stub / rough-cut tally).
     3	--
     4	-- The capacity side of MRP: a capacity plan projects required load (planned + in-flight
     5	-- WO hours) against available capacity per resource per time bucket, flagging
     6	-- over-loaded buckets. This is the ROUGH-CUT horizon owned by 04-planning-basic; the
     7	-- FINITE solver (scheduler_runs / scheduler_assignments / changeover_matrix) is owned by
     8	-- 07-planning-ext and the parallel scheduling agent — NOT created here.
     9	--
    10	-- Wave0 lock: org_id is the business scope (NOT tenant_id); RLS via app.current_org_id().
    11	-- NUMERIC-exact for every hours column. site_id is the day-1 nullable column (no FK).
    12	-- resource_id is a SOFT reference (production_lines / machines live in 03-technical
    13	-- infra-master) and mrp_run_id is a SOFT reference (decouples capacity from the MRP
    14	-- package). Idempotent: safe to re-apply.
    15	
    16	-- ============================================================================
    17	-- 1. capacity_plans — one row per rough-cut capacity projection run
    18	-- ============================================================================
    19	create table if not exists public.capacity_plans (
    20	  id             uuid primary key default gen_random_uuid(),
    21	  org_id         uuid not null references public.organizations(id) on delete cascade,
    22	  site_id        uuid,
    23	  plan_number    text not null,
    24	  status         text not null default 'draft',
    25	  horizon_start  date not null default current_date,
    26	  horizon_end    date not null,
    27	  bucket_kind    text not null default 'day',
    28	  mrp_run_id     uuid, -- soft FK to mrp_runs; service-layer-validated (decoupled package)
    29	  created_by     uuid references public.users(id) on delete restrict,
    30	  created_at     timestamptz not null default pg_catalog.now(),
    31	  updated_at     timestamptz not null default pg_catalog.now(),
    32	
    33	  constraint capacity_plans_org_plan_number_unique unique (org_id, plan_number),
    34	  constraint capacity_plans_status_check check (
    35	    status in ('draft', 'published', 'archived')
    36	  ),
    37	  constraint capacity_plans_bucket_kind_check check (
    38	    bucket_kind in ('day', 'week', 'shift')
    39	  ),
    40	  constraint capacity_plans_horizon_range_check check (horizon_end >= horizon_start)
    41	);
    42	
    43	create index if not exists idx_capacity_plans_org_status on public.capacity_plans (org_id, status);
    44	create index if not exists idx_capacity_plans_org_site   on public.capacity_plans (org_id, site_id);
    45	create index if not exists idx_capacity_plans_mrp_run    on public.capacity_plans (mrp_run_id)
    46	  where mrp_run_id is not null;
    47	create index if not exists idx_capacity_plans_created_by on public.capacity_plans (created_by)
    48	  where created_by is not null;
    49	
    50	-- ============================================================================
    51	-- 2. capacity_plan_lines — load vs available capacity per resource per bucket
    52	-- ============================================================================
    53	create table if not exists public.capacity_plan_lines (
    54	  id              uuid primary key default gen_random_uuid(),
    55	  org_id          uuid not null references public.organizations(id) on delete cascade,
    56	  site_id         uuid,
    57	  plan_id         uuid not null references public.capacity_plans(id) on delete cascade,
    58	  resource_id     uuid, -- soft FK to production_lines / machines (03-technical); service-layer-validated
    59	  resource_kind   text not null default 'line',
    60	  bucket_date     date not null,
    61	  available_hours numeric(12, 4) not null default 0,
    62	  required_hours  numeric(12, 4) not null default 0,
    63	  created_at      timestamptz not null default pg_catalog.now(),
    64	  updated_at      timestamptz not null default pg_catalog.now(),
    65	
    66	  constraint capacity_plan_lines_plan_resource_bucket_unique unique (plan_id, resource_id, bucket_date),
    67	  constraint capacity_plan_lines_resource_kind_check check (
    68	    resource_kind in ('line', 'machine', 'labour')
    69	  ),
    70	  constraint capacity_plan_lines_available_nonnegative_check check (available_hours >= 0),
    71	  constraint capacity_plan_lines_required_nonnegative_check check (required_hours >= 0)
    72	);
    73	
    74	create index if not exists idx_capacity_plan_lines_plan on public.capacity_plan_lines (plan_id);
    75	create index if not exists idx_capacity_plan_lines_org_resource_bucket
    76	  on public.capacity_plan_lines (org_id, resource_id, bucket_date);
    77	
    78	-- ============================================================================
    79	-- 3. RLS enable + force (org-only predicate; site_id day-1 nullable)
    80	-- ============================================================================
    81	alter table public.capacity_plans      enable row level security;
    82	alter table public.capacity_plans      force  row level security;
    83	alter table public.capacity_plan_lines enable row level security;
    84	alter table public.capacity_plan_lines force  row level security;
    85	
    86	-- ============================================================================
    87	-- 4. Policies — one org-isolation policy per table, via app.current_org_id()
    88	-- ============================================================================
    89	drop policy if exists capacity_plans_org_isolation on public.capacity_plans;
    90	create policy capacity_plans_org_isolation on public.capacity_plans
    91	  for all to app_user
    92	  using (org_id = app.current_org_id())
    93	  with check (org_id = app.current_org_id());
    94	
    95	drop policy if exists capacity_plan_lines_org_isolation on public.capacity_plan_lines;
    96	create policy capacity_plan_lines_org_isolation on public.capacity_plan_lines
    97	  for all to app_user
    98	  using (org_id = app.current_org_id())
    99	  with check (org_id = app.current_org_id());
   100	
   101	-- ============================================================================
   102	-- 5. Grants — fail-closed default; DML only to app_user
   103	-- ============================================================================
   104	revoke all on public.capacity_plans      from public;
   105	revoke all on public.capacity_plan_lines from public;
   106	revoke all on public.capacity_plans      from app_user;
   107	revoke all on public.capacity_plan_lines from app_user;
   108	grant select, insert, update, delete on public.capacity_plans      to app_user;
   109	grant select, insert, update, delete on public.capacity_plan_lines to app_user;
   110	
   111	-- ============================================================================
   112	-- 6. updated_at triggers
   113	-- ============================================================================
   114	create or replace function public.planning_capacity_set_updated_at()
   115	returns trigger
   116	language plpgsql
   117	as $$
   118	begin
   119	  new.updated_at := pg_catalog.now();
   120	  return new;
   121	end;
   122	$$;
   123	
   124	drop trigger if exists capacity_plans_set_updated_at on public.capacity_plans;
   125	create trigger capacity_plans_set_updated_at
   126	  before update on public.capacity_plans
   127	  for each row execute function public.planning_capacity_set_updated_at();
   128	
   129	drop trigger if exists capacity_plan_lines_set_updated_at on public.capacity_plan_lines;
   130	create trigger capacity_plan_lines_set_updated_at
   131	  before update on public.capacity_plan_lines
   132	  for each row execute function public.planning_capacity_set_updated_at();

