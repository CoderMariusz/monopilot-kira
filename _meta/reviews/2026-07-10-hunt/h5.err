   263	async function loadOpenWorkOrders(
   264	  ctx: OrgActionContext,
   265	  lineId: string | null,
   266	  horizonDays: number,
   267	): Promise<WorkOrderForScheduling[]> {
   268	  const horizonEnd = new Date(Date.now() + horizonDays * DAY_MS).toISOString();
   269	  const { rows } = await ctx.client.query<WorkOrderForScheduling>(
   270	    `select
   271	       wo.id::text,
   272	       wo.org_id::text,
   273	       wo.site_id::text,
   274	       wo.wo_number,
   275	       wo.product_id::text,
   276	       i.item_code,
   277	       i.name as item_name,
   278	       wo.status,
   279	       wo.planned_quantity::text,
   280	       wo.uom,
   281	       wo.production_line_id::text,
   282	       wo.planned_start_date,
   283	       wo.planned_end_date,
   284	       wo.scheduled_start_time,
   285	       wo.scheduled_end_time,
   286	       coalesce(wo.planned_end_date, wo.scheduled_end_time, wo.planned_start_date, wo.created_at) as due_date,
   287	       coalesce(ap.allergen_ids, '{}'::text[]) as allergen_ids,
   288	       coalesce(routing_dur.routing_duration_ms, 0)::text as routing_duration_ms,
   289	       coalesce(process_dur.process_duration_ms, 0)::text as process_duration_ms
   290	     from public.work_orders wo
   291	     left join public.items i
   292	       on i.org_id = wo.org_id
   293	      and i.id = wo.product_id
   294	     left join lateral (
   295	       select array_agg(distinct iap.allergen_code order by iap.allergen_code) as allergen_ids
   296	         from public.item_allergen_profiles iap
   297	        where iap.org_id = wo.org_id
   298	          and iap.item_id = wo.product_id
   299	     ) ap on true
   300	     left join lateral (
   301	       select
   302	         round(
   303	           (
   304	             coalesce(sum(ro.setup_time_min), 0) * 60000
   305	             + coalesce(
   306	                 sum(ro.run_time_per_unit_sec::numeric * wo.planned_quantity::numeric) * 1000,
   307	                 0
   308	               )
   309	           )
   310	         )::bigint as routing_duration_ms
   311	         from public.routings r
   312	         join public.routing_operations ro
   313	           on ro.routing_id = r.id
   314	          and ro.org_id = r.org_id
   315	        where r.org_id = wo.org_id
   316	          and r.item_id = wo.product_id
   317	          and r.status in ('active', 'approved')
   318	          and (
   319	            wo.production_line_id is null
   320	            or ro.line_id = wo.production_line_id
   321	          )
   322	     ) routing_dur on true
   323	     left join lateral (
   324	       select
   325	         round(
   326	           coalesce(
   327	             nullif(max(p.duration_hours::numeric), 0) * 3600000,
   328	             case
   329	               when max(p.throughput_per_hour::numeric) > 0
   330	                 then (wo.planned_quantity::numeric / max(p.throughput_per_hour::numeric)) * 3600000
   331	               else null
   332	             end
   333	           )
   334	         )::bigint as process_duration_ms
   335	         from public.npd_wip_processes p
   336	         join public.prod_detail pd
   337	           on pd.id = p.prod_detail_id
   338	          and pd.org_id = p.org_id
   339	        where p.org_id = wo.org_id
   340	          and pd.item_id = wo.product_id
   341	     ) process_dur on true
   342	    where wo.org_id = app.current_org_id()
   343	      and wo.status = any($1::varchar[])
   344	      and coalesce(wo.planned_start_date, wo.scheduled_start_time, wo.created_at) < $2::timestamptz
   345	      and ($3::uuid is null or wo.production_line_id = $3::uuid)
   346	    order by due_date asc, wo.id asc`,
   347	    [[...OPEN_WO_STATUSES], horizonEnd, lineId],
   348	  );
   349	  return rows;
   350	}
