   352	async function insertSchedulerRun(
   353	  ctx: OrgActionContext,
   354	  params: {
   355	    lineId: string | null;
   356	    horizonDays: number;
   357	    workOrderCount: number;
   358	    assignmentCount: number;
   359	    totalChangeoverCost: number;
   360	    solveDurationMs: number;
   361	  },
   362	): Promise<SchedulerRunRow> {
   363	  const { rows } = await ctx.client.query<SchedulerRunRow>(
   364	    `insert into public.scheduler_runs
   365	       (org_id, requested_by, status, horizon_days, line_ids, optimizer_version, run_type,
   366	        input_snapshot, output_summary, solve_duration_ms, started_at, completed_at)
   367	     values
   368	       (app.current_org_id(), $1::uuid, 'completed', $2::integer, $3::text[], $4::text, 'schedule',
   369	        $5::jsonb, $6::jsonb, $7::integer, now(), now())
   370	     returning ${RUN_SELECT}`,
   371	    [
   372	      ctx.userId,
   373	      params.horizonDays,
   374	      params.lineId ? [params.lineId] : null,
   375	      OPTIMIZER_VERSION,
   376	      JSON.stringify({
   377	        line_id: params.lineId,
   378	        horizon_days: params.horizonDays,
   379	        open_work_order_count: params.workOrderCount,
   380	      }),
   381	      JSON.stringify({
   382	        assignment_count: params.assignmentCount,
   383	        total_changeover_cost: params.totalChangeoverCost,
   384	      }),
   385	      params.solveDurationMs,
   386	    ],
   387	  );
   388	  return rows[0];
   389	}
