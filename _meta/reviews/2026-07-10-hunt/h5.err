  1105	/**
  1106	 * CANCEL while in transit — reverse the ship for rows that have not been
  1107	 * received yet: restore each source LP's quantity (un-deplete 'shipped' →
  1108	 * 'available') and drop the un-received linkage rows. Received destination LPs
  1109	 * must be handled by reverseToReceiveLine before the final cancel path is used.
  1110	 */
  1111	async function cancelInTransitTransferOrder(
  1112	  ctx: OrgActionContext,
  1113	  to: ToHeaderForUpdate,
  1114	): Promise<{ ok: true }> {
  1115	  const pending = await ctx.client.query<{ id: string; source_lp_id: string; qty: string; lp_quantity: string; lp_status: string }>(
  1116	    `select tll.id, tll.source_lp_id, tll.qty::text as qty,
  1117	            lp.quantity::text as lp_quantity, lp.status as lp_status
  1118	       from public.transfer_order_line_lps tll
  1119	       join public.license_plates lp
  1120	         on lp.org_id = app.current_org_id()
  1121	        and lp.id = tll.source_lp_id
  1122	      where tll.org_id = app.current_org_id()
  1123	        and tll.to_id = $1::uuid
  1124	        and tll.dest_lp_id is null
  1125	      order by tll.created_at asc, tll.id asc
  1126	      for update`,
  1127	    [to.id],
  1128	  );
  1129	
  1130	  for (const row of pending.rows) {
  1131	    const restored = microToText6(toMicro6(row.lp_quantity) + toMicro6(row.qty));
  1132	    const unDeplete = row.lp_status === 'shipped';
  1133	    await ctx.client.query(
  1134	      `update public.license_plates
  1135	          set quantity = $2::numeric,
  1136	              status = case when $3::boolean then 'available' else status end,
  1137	              updated_by = $4::uuid,
  1138	              updated_at = now()
  1139	        where org_id = app.current_org_id()
  1140	          and id = $1::uuid`,
  1141	      [row.source_lp_id, restored, unDeplete, ctx.userId],
  1142	    );
  1143	    if (unDeplete) {
  1144	      await ctx.client.query(
  1145	        `insert into public.lp_state_history
  1146	           (org_id, lp_id, from_state, to_state, reason_code, reason_text, transaction_id, ext_jsonb, created_by)
  1147	         values (app.current_org_id(), $1::uuid, 'shipped', 'available', 'transfer_cancel',
  1148	                 $2, $3::uuid, jsonb_build_object('to_id', $4::uuid), $5::uuid)
  1149	         on conflict (org_id, transaction_id) do nothing`,
  1150	        [row.source_lp_id, `TO cancel ${to.to_number}`, randomUUID(), to.id, ctx.userId],
  1151	      );
  1152	    }
  1153	    await ctx.client.query(
  1154	      `delete from public.transfer_order_line_lps
  1155	        where org_id = app.current_org_id()
  1156	          and id = $1::uuid`,
  1157	      [row.id],
  1158	    );
  1159	  }
  1160	  return { ok: true };
  1161	}
