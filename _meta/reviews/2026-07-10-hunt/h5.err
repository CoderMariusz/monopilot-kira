  1163	export async function transitionTransferOrderStatus(id: string, status: string): Promise<TransferOrderResult<TransferOrder>> {
  1164	  const parsed = TransferOrderStatusSchema.safeParse(status);
  1165	  if (!parsed.success) return { ok: false, error: 'invalid_input' };
  1166	
  1167	  try {
  1168	    return await withOrgContext(async ({ userId, orgId, client }): Promise<TransferOrderResult<TransferOrder>> => {
  1169	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
  1170	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
  1171	
  1172	      // FOR UPDATE: serialize concurrent transitions of the same TO — the loser
  1173	      // re-reads a terminal/changed status and fails the state-machine guard
  1174	      // instead of double-shipping / double-receiving.
  1175	      const before = await ctx.client.query<ToHeaderForUpdate>(
  1176	        `select id, to_number, status, from_warehouse_id, to_warehouse_id
  1177	           from public.transfer_orders
  1178	          where org_id = app.current_org_id()
  1179	            and id = $1::uuid
  1180	          limit 1
  1181	          for update`,
  1182	        [id],
  1183	      );
  1184	      const previous = before.rows[0];
  1185	      if (!previous) return { ok: false, error: 'not_found' };
  1186	
  1187	      // Guard the transition server-side against the legal state machine.
  1188	      const allowed = TO_TRANSITIONS[previous.status] ?? [];
  1189	      if (!allowed.includes(parsed.data)) return { ok: false, error: 'invalid_state' };
  1190	
  1191	      // W9-K-II (F-C05): status flips carry REAL stock movements now.
  1192	      let stockEffect: Record<string, unknown> = {};
  1193	      if (previous.status === 'draft' && parsed.data === 'in_transit') {
  1194	        const shipped = await shipTransferOrder(ctx, previous);
  1195	        if (!shipped.ok) return shipped;
  1196	        stockEffect = { picks: shipped.pickCount };
  1197	      } else if (previous.status === 'in_transit' && parsed.data === 'received') {
  1198	        const received = await receiveTransferOrder(ctx, previous);
  1199	        if (!received.ok) return received;
  1200	        stockEffect = { destLps: received.lpCount };
  1201	      } else if (['in_transit', 'partially_received'].includes(previous.status) && parsed.data === 'cancelled') {
  1202	        // F3 / Wave R4: a TO with already-received destination LPs must NOT be cancelled
  1203	        // directly — the received stock has to be reversed first via reverseToReceiveLine
  1204	        // (the "Reverse receipt" action on TO detail). Cancelling directly would orphan
  1205	        // already-received goods from a cancelled document. Only un-received lines may be
  1206	        // unwound here (source stock restored).
  1207	        const receivedCheck = await ctx.client.query<{ received_count: string }>(
  1208	          `select count(*)::text as received_count
  1209	             from public.transfer_order_line_lps
  1210	            where org_id = app.current_org_id()
  1211	              and to_id = $1::uuid
  1212	              and dest_lp_id is not null`,
  1213	          [previous.id],
  1214	        );
  1215	        if (Number(receivedCheck.rows[0]?.received_count ?? '0') > 0) {
  1216	          return {
  1217	            ok: false,
  1218	            error: 'partially_received',
  1219	            message:
  1220	              'Transfer order has already-received destination stock; cancel is not allowed. Receive the remainder or reverse the received LPs first.',
  1221	          };
  1222	        }
  1223	        await cancelInTransitTransferOrder(ctx, previous);
  1224	        stockEffect = { restored: true };
  1225	      } else if (previous.status === 'partially_received' && parsed.data === 'received') {
  1226	        const received = await receiveTransferOrder(ctx, previous);
  1227	        if (!received.ok) return received;
  1228	        stockEffect = { destLps: received.lpCount };
  1229	      }
  1230	
  1231	      const { rows } = await ctx.client.query<TransferOrderRow>(
  1232	        `update public.transfer_orders
  1233	            set status = $2,
  1234	                updated_by = $3::uuid
  1235	          where org_id = app.current_org_id()
  1236	            and id = $1::uuid
  1237	        returning id, to_number, from_warehouse_id, to_warehouse_id, status,
  1238	                  scheduled_date::text as scheduled_date, notes, created_at, updated_at`,
  1239	        [id, parsed.data, userId],
  1240	      );
  1241	      const row = rows[0];
  1242	      if (!row) return { ok: false, error: 'not_found' };
  1243	      await writeProcurementAudit(ctx, {
  1244	        action: 'planning.transfer_order.status_changed',
  1245	        resourceType: 'transfer_order',
  1246	        resourceId: row.id,
  1247	        beforeState: { status: previous.status },
  1248	        afterState: { status: row.status, ...stockEffect },
  1249	      });
  1250	      revalidateTransferOrderPaths(row.id);
  1251	      return { ok: true, data: mapTransferOrder(row) };
  1252	    });
  1253	  } catch (err) {
  1254	    console.error('[planning/transfer-orders] transitionTransferOrderStatus failed', err);
  1255	    return { ok: false, error: 'persistence_failed' };
  1256	  }
  1257	}
