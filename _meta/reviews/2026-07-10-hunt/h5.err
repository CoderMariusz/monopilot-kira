   140	  it('beats naive due-date ordering when the changeover matrix makes reordering cheaper', () => {
   141	    const a = wo({ id: 'aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa', due: '2026-06-01T08:00:00.000Z', allergens: ['milk'] });
   142	    const b = wo({ id: 'bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb', due: '2026-06-02T08:00:00.000Z', allergens: ['nuts'] });
