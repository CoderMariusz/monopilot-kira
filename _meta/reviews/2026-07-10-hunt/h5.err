    93	
    94	with demo_warehouses as (
    95	  -- NOTE: Postgres has no max()/min() aggregate for uuid — the original
    96	  -- aggregate form failed on live apply. Ordered array_agg instead.
    97	  select
    98	    (array_agg(id order by created_at, id) filter (where is_default))[1] as default_warehouse_id,
    99	    (array_agg(id order by created_at, id))[1] as first_warehouse_id,
   100	    (array_agg(id order by created_at desc, id desc))[1] as last_warehouse_id
   101	  from public.warehouses
   102	  where org_id = '00000000-0000-0000-0000-000000000002'::uuid
   103	),
   104	seeded_tos as (
   105	  insert into public.transfer_orders
   106	    (org_id, to_number, from_warehouse_id, to_warehouse_id, status, scheduled_date, notes)
   107	  select
   108	    '00000000-0000-0000-0000-000000000002'::uuid,
   109	    'TO-DEMO-0001',
   110	    coalesce(default_warehouse_id, first_warehouse_id),
   111	    case
   112	      when last_warehouse_id is distinct from coalesce(default_warehouse_id, first_warehouse_id)
   113	        then last_warehouse_id
   114	      else null
   115	    end,
   116	    'draft',
   117	    date '2026-06-19',
   118	    'Draft internal transfer for planning procurement demo.'
   119	  from demo_warehouses
   120	  on conflict (org_id, to_number) do update
   121	    set from_warehouse_id = excluded.from_warehouse_id,
   122	        to_warehouse_id   = excluded.to_warehouse_id,
   123	        status            = excluded.status,
   124	        scheduled_date    = excluded.scheduled_date,
   125	        notes             = excluded.notes,
   126	        updated_at        = pg_catalog.now()
   127	  returning id, org_id, to_number
   128	)
   129	insert into public.transfer_order_lines
   130	  (org_id, to_id, item_id, qty, uom, line_no)
   131	select
   132	  tos.org_id,
   133	  tos.id,
   134	  i.id,
   135	  v.qty,
   136	  i.uom_base,
   137	  v.line_no
   138	from (values
   139	  (1, 'RM-BEEF-50', 150.000::numeric),
   140	  (2, 'PKG-BOX-CARTON', 300.000::numeric)
   141	) as v(line_no, item_code, qty)
   142	join seeded_tos tos on tos.to_number = 'TO-DEMO-0001'
   143	join public.items i
   144	  on i.org_id = tos.org_id
   145	 and i.item_code = v.item_code
   146	on conflict (org_id, to_id, line_no) do update
   147	  set item_id    = excluded.item_id,
   148	      qty        = excluded.qty,
   149	      uom        = excluded.uom,
   150	      updated_at = pg_catalog.now();

