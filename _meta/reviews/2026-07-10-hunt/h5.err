    88	
    89	class WorkOrderChainError extends Error {
    90	  constructor(readonly code: ChainErrorCode, readonly planningError?: string) {
    91	    super(planningError ? `${code}:${planningError}` : code);
    92	  }
    93	}
    94	
    95	function mapCoreErrorToChainCode(coreError: string | undefined): ChainErrorCode {
    96	  return coreError === 'no_active_site'
    97	    || coreError === 'document_mask_missing'
    98	    || coreError === 'not_released_to_factory'
    99	    ? coreError
   100	    : 'wo_create_failed';
   101	}
   102	
   103	// W1 error-surface contract: specific core failures must reach the caller as
   104	// themselves, never collapsed into a generic wo_create_failed.
   105	function chainCoreFailure(coreError: string | undefined): ChainResult {
   106	  const specific = mapCoreErrorToChainCode(coreError);
   107	  return { ok: false, error: specific, planningError: coreError, message: coreError };
   108	}
   109	
   110	/** After the first chain write, failures must throw so withOrgContext rolls back. */
   111	function throwChainCoreFailure(coreError: string | undefined): never {
   112	  const code = mapCoreErrorToChainCode(coreError);
   113	  throw new WorkOrderChainError(code, coreError);
   114	}
   115	
   116	export async function createWorkOrderChain(raw: unknown, options?: ChainOptions): Promise<ChainResult> {
   117	  const parsed = Input.safeParse(raw);
   118	  if (!parsed.success) {
   119	    return { ok: false, error: 'invalid_input', message: parsed.error.message };
   120	  }
   121	
   122	  try {
   123	    return await withOrgContext(async (ctx): Promise<ChainResult> => {
   124	      if (!(await hasPermission(ctx, PLANNING_WO_WRITE_PERMISSION))) {
   125	        return { ok: false, error: 'forbidden' };
   126	      }
   127	      return createWorkOrderChainInContext(ctx, parsed.data, options);
   128	    });
   129	  } catch (error) {
   130	    if (error instanceof WorkOrderChainError) {
   131	      return { ok: false, error: error.code, planningError: error.planningError, message: error.planningError };
   132	    }
   133	    console.error('[createWorkOrderChain] failed:', error);
   134	    return { ok: false, error: 'persistence_failed' };
   135	  }
   136	}
   137	
   138	export async function createWorkOrderChainForContext(
   139	  ctx: OrgActionContext,
   140	  raw: unknown,
   141	  options?: ChainOptions,
   142	): Promise<ChainResult> {
   143	  const parsed = Input.safeParse(raw);
   144	  if (!parsed.success) {
   145	    return { ok: false, error: 'invalid_input', message: parsed.error.message };
   146	  }
   147	  if (!(await hasPermission(ctx, PLANNING_WO_WRITE_PERMISSION))) {
   148	    return { ok: false, error: 'forbidden' };
   149	  }
   150	  return createWorkOrderChainInContext(ctx, parsed.data, options);
   151	}
   152	
   153	async function createWorkOrderChainInContext(
   154	  ctx: OrgActionContext,
   155	  input: z.infer<typeof Input>,
   156	  options?: ChainOptions,
   157	): Promise<ChainResult> {
   158	  const fgItem = await loadItem(ctx, input.productId);
   159	  if (!fgItem) return { ok: false, error: 'not_found' };
   160	  const itemCode = input.itemCode ?? fgItem.item_code;
   161	
   162	  const existingFg = await loadWorkOrderByNumber(ctx, input.documentNumber);
   163	  if (existingFg) {
   164	    const existing = await loadExistingChain(ctx, existingFg.id);
   165	    const fgArtifacts = await loadFgWoArtifacts(ctx, existingFg.id);
   166	    return {
   167	      ok: true,
   168	      fgWorkOrder: existingFg,
   169	      wipWorkOrders: existing.wipWorkOrders,
   170	      dependencies: existing.dependencies,
   171	      created: false,
   172	      fgMaterials: fgArtifacts.materials,
   173	      fgPrimarySchedule: fgArtifacts.primarySchedule,
   174	    };
   175	  }
   176	
   177	  const bom = await loadActiveBom(ctx, fgItem.id, itemCode);
   178	  if (!bom) return { ok: false, error: 'no_active_bom' };
   179	
   180	  let materialScalar: number;
   181	  try {
   182	    materialScalar = computeWoMaterialScalar({
   183	      plannedBaseQty: Number(input.plannedQuantity),
   184	      lineBasis: bom.line_basis,
   185	      eachPerBox: fgItem.each_per_box == null ? null : Number(fgItem.each_per_box),
   186	      netQtyPerEach: fgItem.net_qty_per_each == null ? null : Number(fgItem.net_qty_per_each),
   187	    });
   188	  } catch (error) {
   189	    if (error instanceof WoMaterialScalarError) return { ok: false, error: 'pack_hierarchy_incomplete' };
   190	    throw error;
   191	  }
   192	
   193	  if (!options?.skipFactoryReleaseGate) {
   194	    const releaseGate = await assertFgReleasedToFactoryForWo(ctx.client, fgItem.id);
   195	    if (releaseGate === 'not_released_to_factory') {
   196	      return { ok: false, error: 'not_released_to_factory' };
   197	    }
   198	  }
   199	
   200	  const wipLines = await loadWipBomLines(ctx, bom.id);
   201	  const stageLineIds = await loadStageProductionLineIds(
   202	    ctx,
   203	    fgItem.id,
   204	    [
   205	      ...wipLines.map((line) => ({ itemId: line.item_id, isFg: false })),
   206	      { itemId: fgItem.id, isFg: true },
   207	    ],
   208	  );
   209	  const wipWorkOrders: WOHeader[] = [];
   210	  let hasWritten = false;
   211	  for (let index = 0; index < wipLines.length; index++) {
   212	    const line = wipLines[index]!;
   213	    const requiredQty = computeRequiredMaterialQty(line, materialScalar);
   214	    const existingWip = await loadWorkOrderByNumber(ctx, `${input.documentNumber}-W${index + 1}`);
   215	    if (existingWip) {
   216	      wipWorkOrders.push(existingWip);
   217	      continue;
   218	    }
   219	    const created = await createWorkOrderCore(ctx, {
   220	      productId: line.item_id,
   221	      itemCode: line.component_code,
   222	      itemTypeAtCreation: 'intermediate',
   223	      documentNumber: `${input.documentNumber}-W${index + 1}`,
   224	      siteId: input.siteId,
   225	      plannedQuantity: requiredQty,
   226	      scheduledStartTime: input.scheduledStartTime,
   227	      productionLineId: stageLineIds.get(line.item_id) ?? undefined,
   228	      notes: `Upstream WIP for ${input.documentNumber}`,
   229	    });
   230	    if (!created.ok) {
   231	      if (hasWritten) throwChainCoreFailure(created.error);
   232	      return chainCoreFailure(created.error);
   233	    }
   234	    hasWritten = true;
   235	    wipWorkOrders.push(created.workOrder);
   236	  }
   237	
   238	  const fgCreated = await createWorkOrderCore(
   239	    ctx,
   240	    {
   241	      productId: fgItem.id,
   242	      itemCode,
   243	      documentNumber: input.documentNumber,
   244	      siteId: input.siteId,
   245	      plannedQuantity: input.plannedQuantity,
   246	      scheduledStartTime: input.scheduledStartTime,
   247	      productionLineId: stageLineIds.get(fgItem.id) ?? input.productionLineId,
   248	      notes: input.notes,
   249	    },
   250	    options?.skipFactoryReleaseGate ? { skipFactoryReleaseGate: true } : undefined,
   251	  );
   252	  if (!fgCreated.ok) {
   253	    if (hasWritten) throwChainCoreFailure(fgCreated.error);
   254	    return chainCoreFailure(fgCreated.error);
   255	  }
   256	
   257	  const dependencies = await linkDependencies(ctx, fgCreated.workOrder, fgCreated.materials, wipWorkOrders);
   258	  return {
   259	    ok: true,
   260	    fgWorkOrder: fgCreated.workOrder,
   261	    wipWorkOrders,
   262	    dependencies,
   263	    created: true,
   264	    fgMaterials: fgCreated.materials,
   265	    fgPrimarySchedule: fgCreated.primarySchedule,
   266	  };
   267	}
   268	
   269	async function loadFgWoArtifacts(
   270	  ctx: OrgActionContext,
   271	  fgWoId: string,
   272	): Promise<{ materials: WOMaterial[]; primarySchedule: ScheduleOutput }> {
   273	  const materialsResult = await ctx.client.query<{
   274	    id: string;
   275	    wo_id: string;
   276	    product_id: string | null;
   277	    material_name: string;
   278	    required_qty: string;
   279	    consumed_qty: string;
   280	    reserved_qty: string;
   281	    uom: string;
   282	    sequence: number;
   283	    material_source: string;
   284	    bom_item_id: string | null;
   285	    bom_version: number | null;
   286	    notes: string | null;
   287	  }>(
   288	    `select id::text as id, wo_id::text as wo_id, product_id::text as product_id,
   289	            material_name, required_qty::text as required_qty,
   290	            consumed_qty::text as consumed_qty, reserved_qty::text as reserved_qty,
   291	            uom, sequence, material_source, bom_item_id::text as bom_item_id,
   292	            bom_version, notes
   293	       from public.wo_materials
   294	      where org_id = app.current_org_id()
   295	        and wo_id = $1::uuid
   296	      order by sequence`,
   297	    [fgWoId],
   298	  );
   299	  const scheduleResult = await ctx.client.query<{
   300	    id: string;
   301	    planned_wo_id: string;
   302	    product_id: string;
   303	    output_role: string;
   304	    expected_qty: string;
   305	    uom: string;
   306	    allocation_pct: string;
   307	    disposition: string;
   308	    downstream_wo_id: string | null;
   309	    notes: string | null;
   310	  }>(
   311	    `select id::text as id, planned_wo_id::text as planned_wo_id, product_id::text as product_id,
   312	            output_role, expected_qty::text as expected_qty, uom,
   313	            allocation_pct::text as allocation_pct, disposition,
   314	            downstream_wo_id::text as downstream_wo_id, notes
   315	       from public.schedule_outputs
   316	      where org_id = app.current_org_id()
   317	        and planned_wo_id = $1::uuid
   318	        and output_role = 'primary'
   319	      limit 1`,
   320	    [fgWoId],
   321	  );
   322	  const scheduleRow = scheduleResult.rows[0];
   323	  if (!scheduleRow) {
   324	    throw new WorkOrderChainError('persistence_failed', 'fg_primary_schedule_missing');
   325	  }
   326	  return {
   327	    materials: materialsResult.rows.map((row) => ({
   328	      id: row.id,
   329	      woId: row.wo_id,
   330	      productId: row.product_id,
   331	      materialName: row.material_name,
   332	      requiredQty: row.required_qty,
   333	      consumedQty: row.consumed_qty,
   334	      reservedQty: row.reserved_qty,
   335	      uom: row.uom,
   336	      sequence: row.sequence,
   337	      materialSource: row.material_source,
   338	      bomItemId: row.bom_item_id,
   339	      bomVersion: row.bom_version,
   340	      notes: row.notes,
   341	    })),
   342	    primarySchedule: {
   343	      id: scheduleRow.id,
   344	      plannedWoId: scheduleRow.planned_wo_id,
   345	      productId: scheduleRow.product_id,
   346	      outputRole: scheduleRow.output_role,
   347	      expectedQty: scheduleRow.expected_qty,
   348	      uom: scheduleRow.uom,
   349	      allocationPct: scheduleRow.allocation_pct,
   350	      disposition: scheduleRow.disposition,
   351	      downstreamWoId: scheduleRow.downstream_wo_id,
   352	      notes: scheduleRow.notes,
   353	    },
   354	  };
   355	}
   356	
   357	async function loadItem(ctx: OrgActionContext, itemId: string): Promise<ItemRow | null> {
   358	  const { rows } = await ctx.client.query<ItemRow>(
   359	    `select id::text as id, item_code, output_uom, uom_base,
   360	            net_qty_per_each::text as net_qty_per_each,
   361	            each_per_box::text as each_per_box,
   362	            boxes_per_pallet::text as boxes_per_pallet,
   363	            weight_mode
   364	       from public.items
   365	      where org_id = app.current_org_id()
   366	        and id = $1::uuid
   367	      limit 1`,
   368	    [itemId],
   369	  );
   370	  return rows[0] ?? null;
   371	}
   372	
   373	export async function loadActiveBom(ctx: OrgActionContext, itemId: string, itemCode: string): Promise<BomHeaderRow | null> {
   374	  const { rows } = await ctx.client.query<BomHeaderRow>(
   375	    `select id::text as id, version, line_basis
   376	       from public.bom_headers
   377	      where org_id = app.current_org_id()
   378	        and status = 'active'
   379	        and (item_id = $1::uuid or product_id = $2)
   380	      order by version desc, created_at desc
   381	      limit 1`,
   382	    [itemId, itemCode],
   383	  );
   384	  return rows[0] ?? null;
   385	}
   386	
   387	/** True when the latest active BOM (same selection as preview/chain) has WIP lines. */
   388	export async function latestActiveBomHasWipLines(
   389	  ctx: OrgActionContext,
   390	  itemId: string,
   391	  itemCode: string,
   392	): Promise<boolean> {
   393	  const bom = await loadActiveBom(ctx, itemId, itemCode);
   394	  if (!bom) return false;
   395	  const wipLines = await loadWipBomLines(ctx, bom.id);
   396	  return wipLines.length > 0;
   397	}
   398	
   399	async function loadWipBomLines(ctx: OrgActionContext, bomHeaderId: string): Promise<WipBomLineRow[]> {
   400	  const { rows } = await ctx.client.query<WipBomLineRow>(
   401	    `select bl.id::text as id,
   402	            bl.line_no,
   403	            bl.item_id::text as item_id,
   404	            bl.component_code,
   405	            bl.quantity::text as quantity,
   406	            bl.scrap_pct::text as scrap_pct
   407	       from public.bom_lines bl
   408	      where bl.org_id = app.current_org_id()
   409	        and bl.bom_header_id = $1::uuid
   410	        and bl.component_type = 'WIP'
   411	        and bl.item_id is not null
   412	      order by bl.line_no`,
   413	    [bomHeaderId],
   414	  );
   415	  return rows;
   416	}
   417	
   418	function computeRequiredMaterialQty(line: WipBomLineRow, materialScalar: number): string {
   419	  const quantity = Number(line.quantity);
   420	  const scrapPct = Number(line.scrap_pct ?? 0);
   421	  const denominator = Math.max(1 - scrapPct / 100, 0.01);
   422	  return (Math.round((quantity * materialScalar / denominator) * 10000) / 10000).toFixed(4);
   423	}
   424	
   425	async function loadWorkOrderByNumber(ctx: OrgActionContext, woNumber: string): Promise<WOHeader | null> {
   426	  const { rows } = await ctx.client.query<{
   427	    id: string;
   428	    wo_number: string;
   429	    product_id: string;
   430	    item_code: string | null;
   431	    item_type_at_creation: string;
   432	    planned_quantity: string;
   433	    produced_quantity: string | null;
   434	    uom: string;
   435	    status: string;
   436	    scheduled_start_time: string | null;
   437	    scheduled_end_time: string | null;
   438	    production_line_id: string | null;
   439	    priority: string;
   440	    source_of_demand: string;
   441	    source_reference: string | null;
   442	    notes: string | null;
   443	    created_at: string;
   444	    updated_at: string;
   445	  }>(
   446	    `select wo.id::text as id,
   447	            wo.wo_number,
   448	            wo.product_id::text as product_id,
   449	            i.item_code,
   450	            wo.item_type_at_creation,
   451	            wo.planned_quantity::text as planned_quantity,
   452	            wo.produced_quantity::text as produced_quantity,
   453	            wo.uom,
   454	            wo.status,
   455	            wo.scheduled_start_time::text as scheduled_start_time,
   456	            wo.scheduled_end_time::text as scheduled_end_time,
   457	            wo.production_line_id::text as production_line_id,
   458	            wo.priority,
   459	            wo.source_of_demand,
   460	            wo.source_reference,
   461	            wo.ext_jsonb->>'notes' as notes,
   462	            wo.created_at::text as created_at,
   463	            wo.updated_at::text as updated_at
   464	       from public.work_orders wo
   465	       left join public.items i
   466	         on i.org_id = wo.org_id
   467	        and i.id = wo.product_id
   468	      where wo.org_id = app.current_org_id()
   469	        and wo.wo_number = $1
   470	      limit 1`,
   471	    [woNumber],
   472	  );
   473	  const row = rows[0];
   474	  if (!row) return null;
   475	  return {
   476	    id: row.id,
   477	    woNumber: row.wo_number,
   478	    productId: row.product_id,
   479	    itemCode: row.item_code,
   480	    itemTypeAtCreation: row.item_type_at_creation,
   481	    plannedQuantity: row.planned_quantity,
   482	    producedQuantity: row.produced_quantity,
   483	    uom: row.uom,
   484	    status: row.status,
   485	    scheduledStartTime: row.scheduled_start_time,
   486	    scheduledEndTime: row.scheduled_end_time,
   487	    productionLineId: row.production_line_id,
   488	    priority: row.priority,
   489	    sourceOfDemand: row.source_of_demand,
   490	    sourceReference: row.source_reference,
   491	    notes: row.notes,
   492	    createdAt: row.created_at,
   493	    updatedAt: row.updated_at,
   494	  };
   495	}
   496	
   497	async function linkDependencies(
   498	  ctx: OrgActionContext,
   499	  fgWorkOrder: WOHeader,
   500	  fgMaterials: WOMaterial[],
   501	  wipWorkOrders: WOHeader[],
   502	): Promise<Array<{ parentWoId: string; childWoId: string; materialLink: string | null; requiredQty: string | null }>> {
   503	  const dependencies: Array<{ parentWoId: string; childWoId: string; materialLink: string | null; requiredQty: string | null }> = [];
   504	  for (const wipWorkOrder of wipWorkOrders) {
   505	    const material = fgMaterials.find((row) => row.productId === wipWorkOrder.productId) ?? null;
   506	    const { rows } = await ctx.client.query<{ parent_wo_id: string; child_wo_id: string; material_link: string | null; required_qty: string | null }>(
   507	      `insert into public.wo_dependencies
   508	         (org_id, parent_wo_id, child_wo_id, material_link, required_qty)
   509	       values
   510	         (app.current_org_id(), $1::uuid, $2::uuid, $3::uuid, $4::numeric)
   511	       on conflict (org_id, parent_wo_id, child_wo_id) do update
   512	         set material_link = coalesce(excluded.material_link, public.wo_dependencies.material_link),
   513	             required_qty = coalesce(excluded.required_qty, public.wo_dependencies.required_qty)
   514	       returning parent_wo_id::text as parent_wo_id,
   515	                 child_wo_id::text as child_wo_id,
   516	                 material_link::text as material_link,
   517	                 required_qty::text as required_qty`,
   518	      [
   519	        fgWorkOrder.id,
   520	        wipWorkOrder.id,
   521	        material?.id ?? null,
   522	        material?.requiredQty ?? null,
   523	      ],
   524	    );
   525	    const row = rows[0];
   526	    if (row) {
   527	      dependencies.push({
   528	        parentWoId: row.parent_wo_id,
   529	        childWoId: row.child_wo_id,
   530	        materialLink: row.material_link,
   531	        requiredQty: row.required_qty,
   532	      });
   533	    }
   534	  }
   535	  return dependencies;
   536	}
   537	
   538	async function loadExistingChain(
   539	  ctx: OrgActionContext,
   540	  fgWoId: string,
   541	): Promise<{
   542	  wipWorkOrders: WOHeader[];
   543	  dependencies: Array<{ parentWoId: string; childWoId: string; materialLink: string | null; requiredQty: string | null }>;
   544	}> {
   545	  const { rows } = await ctx.client.query<{ child_wo_number: string; parent_wo_id: string; child_wo_id: string; material_link: string | null; required_qty: string | null }>(
   546	    `select child.wo_number as child_wo_number,
   547	            dep.parent_wo_id::text as parent_wo_id,
   548	            dep.child_wo_id::text as child_wo_id,
   549	            dep.material_link::text as material_link,
   550	            dep.required_qty::text as required_qty
   551	       from public.wo_dependencies dep
   552	       join public.work_orders child
   553	         on child.org_id = dep.org_id
   554	        and child.id = dep.child_wo_id
   555	      where dep.org_id = app.current_org_id()
   556	        and dep.parent_wo_id = $1::uuid
   557	      order by child.wo_number`,
   558	    [fgWoId],
   559	  );
   560	  const wipWorkOrders: WOHeader[] = [];
   561	  const dependencies: Array<{ parentWoId: string; childWoId: string; materialLink: string | null; requiredQty: string | null }> = [];
   562	  for (const row of rows) {
   563	    const child = await loadWorkOrderByNumber(ctx, row.child_wo_number);
   564	    if (child) wipWorkOrders.push(child);
   565	    dependencies.push({
   566	      parentWoId: row.parent_wo_id,
   567	      childWoId: row.child_wo_id,
   568	      materialLink: row.material_link,
   569	      requiredQty: row.required_qty,
   570	    });
   571	  }
   572	  return { wipWorkOrders, dependencies };
   573	}
FILE apps/web/app/[locale]/(app)/(modules)/planning/work-orders/_actions/chain-preview.ts
     1	'use server';
     2	
     3	/**
     4	 * P2-PLANNING — read-only surface for the multi-stage production chain.
     5	 *
     6	 * Two reads, both org-scoped inside withOrgContext (RLS: org_id =
     7	 * app.current_org_id()); neither writes:
     8	 *
     9	 *   1. previewWorkOrderChain — a DRY RUN of create-work-order-chain. Given the FG
    10	 *      product + planned qty it recomputes (never persists) the child WIP stages
    11	 *      that would be created, so the create flow can show a tree BEFORE the write.
    12	 *      It mirrors create-work-order-chain's reads (loadItem / loadActiveBom /
    13	 *      computeWoMaterialScalar / WIP bom lines) so the preview matches what the
    14	 *      action actually creates. Each stage is enriched with its production line(s)
    15	 *      (routing_operations → production_lines), its process throughput per
    16	 *      product×process (npd_wip_processes via prod_detail.item_id) and the WIP it
    17	 *      consumes / outputs.
    18	 *
    19	 *   2. getStationQueue — the per-station lane. Given a production line it returns
    20	 *      ONLY that line's WOs across every chain, each with demand qty, the upstream
    21	 *      WIP it needs + how much is already produced (real produced_quantity on the
    22	 *      upstream WO), the output target, and the line's throughput_per_hour for that
    23	 *      product×process so the station knows its rate.
    24	 *
    25	 * Honest data policy: throughput/line come from the real masters; when a product has
    26	 * no routing or no npd_wip_processes row the stage simply carries an empty list (the
    27	 * UI renders an em dash), never a fabricated rate. Raw-material stock-on-hand is NOT
    28	 * surfaced here — see the station view's note; the only availability signal is the
    29	 * upstream WIP WO's produced_quantity, which is real.
    30	 */
    31	
    32	import { z } from 'zod';
    33	
    34	import { computeWoMaterialScalar, WoMaterialScalarError } from '../../../../../../../lib/production/wo-material-scalar';
    35	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
    36	import type { QueryClient } from './shared';
    37	
    38	export type ChainStageProcess = {
    39	  name: string;
    40	  throughputPerHour: number | null;
    41	  throughputUom: string | null;
    42	  durationHours: number | null;
    43	};
    44	
    45	export type ChainStageLine = { code: string; name: string };
    46	
    47	export type ChainStageMaterial = { itemCode: string; requiredQty: string; uom: string };
    48	
    49	export type ChainStage = {
    50	  /** Stable key for React lists (item id + suffix). */
    51	  key: string;
    52	  /** "FG" for the root, or the WIP stage label (W1, W2 …). */
    53	  stageLabel: string;
    54	  itemId: string;
    55	  itemCode: string;
    56	  itemName: string;
    57	  /** Qty this stage must output, in `uom`. */
    58	  requiredQty: string;
    59	  uom: string;
    60	  lines: ChainStageLine[];
    61	  processes: ChainStageProcess[];
    62	  /** WIP items this stage consumes from upstream stages (empty for leaf stages). */
    63	  consumes: ChainStageMaterial[];
    64	  children: ChainStage[];
    65	};
    66	
    67	export type PreviewWorkOrderChainResult =
    68	  | { ok: true; spansMultipleStages: boolean; stageCount: number; root: ChainStage }
    69	  | { ok: false; error: 'invalid_input' | 'not_found' | 'no_active_bom' | 'pack_hierarchy_incomplete' | 'persistence_failed' };
    70	
    71	const PreviewInput = z.object({
    72	  productId: z.string().uuid(),
    73	  plannedQuantity: z
    74	    .string()
    75	    .trim()
    76	    .regex(/^\d+(?:\.\d{1,4})?$/)
    77	    .refine((value) => Number(value) > 0),
    78	});
    79	
    80	type ItemRow = {
    81	  id: string;
    82	  item_code: string;
    83	  name: string | null;
    84	  uom_base: string;
    85	  net_qty_per_each: string | null;
    86	  each_per_box: string | null;
    87	};
    88	
    89	type BomHeaderRow = { id: string; line_basis: string };
    90	
    91	type WipBomLineRow = {
    92	  item_id: string;
    93	  component_code: string;
    94	  name: string | null;
    95	  uom_base: string;
    96	  quantity: string;
    97	  scrap_pct: string | null;
    98	};
    99	
   100	type LineRow = { item_id: string; code: string; name: string };
   101	type ProcessRow = {
   102	  item_id: string;
   103	  process_name: string;
   104	  throughput_per_hour: string | null;
   105	  throughput_uom: string | null;
   106	  duration_hours: string | null;
   107	};
   108	
   109	function computeRequiredMaterialQty(quantity: string, scrapPct: string | null, materialScalar: number): string {
   110	  const denominator = Math.max(1 - Number(scrapPct ?? 0) / 100, 0.01);
   111	  return (Math.round((Number(quantity) * materialScalar / denominator) * 10000) / 10000).toFixed(4);
   112	}
   113	
   114	async function loadLinesByItem(client: QueryClient, itemIds: string[]): Promise<Map<string, ChainStageLine[]>> {
   115	  const byItem = new Map<string, ChainStageLine[]>();
   116	  if (itemIds.length === 0) return byItem;
   117	  const { rows } = await client.query<LineRow>(
   118	    `select distinct on (r.item_id, pl.id)
   119	            r.item_id::text as item_id, pl.code, pl.name
   120	       from public.routings r
   121	       join public.routing_operations ro on ro.routing_id = r.id and ro.org_id = r.org_id
   122	       join public.production_lines pl on pl.id = ro.line_id and pl.org_id = ro.org_id
   123	      where r.org_id = app.current_org_id()
   124	        and r.item_id = any($1::uuid[])
   125	        and r.status in ('active', 'approved')
   126	      order by r.item_id, pl.id, ro.op_no`,
   127	    [itemIds],
   128	  );
   129	  for (const row of rows) {
   130	    const list = byItem.get(row.item_id) ?? [];
   131	    list.push({ code: row.code, name: row.name });
   132	    byItem.set(row.item_id, list);
   133	  }
   134	  return byItem;
   135	}
   136	
   137	async function loadProcessesByItem(client: QueryClient, itemIds: string[]): Promise<Map<string, ChainStageProcess[]>> {
   138	  const byItem = new Map<string, ChainStageProcess[]>();
   139	  if (itemIds.length === 0) return byItem;
   140	  const { rows } = await client.query<ProcessRow>(
   141	    `select pd.item_id::text as item_id, p.process_name,
   142	            p.throughput_per_hour::text as throughput_per_hour,
   143	            p.throughput_uom, p.duration_hours::text as duration_hours
   144	       from public.npd_wip_processes p
   145	       join public.prod_detail pd on pd.id = p.prod_detail_id and pd.org_id = p.org_id
   146	      where p.org_id = app.current_org_id()
   147	        and pd.item_id = any($1::uuid[])
   148	      order by pd.item_id, p.display_order`,
   149	    [itemIds],
   150	  );
   151	  for (const row of rows) {
   152	    const list = byItem.get(row.item_id) ?? [];
   153	    list.push({
   154	      name: row.process_name,
   155	      throughputPerHour: row.throughput_per_hour === null ? null : Number(row.throughput_per_hour),
   156	      throughputUom: row.throughput_uom,
   157	      durationHours: row.duration_hours === null ? null : Number(row.duration_hours),
   158	    });
   159	    byItem.set(row.item_id, list);
   160	  }
   161	  return byItem;
   162	}
   163	
   164	export async function previewWorkOrderChain(raw: unknown): Promise<PreviewWorkOrderChainResult> {
   165	  const parsed = PreviewInput.safeParse(raw);
   166	  if (!parsed.success) return { ok: false, error: 'invalid_input' };
   167	
   168	  try {
   169	    return await withOrgContext(async ({ client }): Promise<PreviewWorkOrderChainResult> => {
   170	      const q = client as unknown as QueryClient;
   171	      const fg = (
   172	        await q.query<ItemRow>(
   173	          `select id::text as id, item_code, name, uom_base,
   174	                  net_qty_per_each::text as net_qty_per_each, each_per_box::text as each_per_box
   175	             from public.items
   176	            where org_id = app.current_org_id() and id = $1::uuid
   177	            limit 1`,
   178	          [parsed.data.productId],
   179	        )
   180	      ).rows[0];
   181	      if (!fg) return { ok: false, error: 'not_found' };
   182	
   183	      const bom = (
   184	        await q.query<BomHeaderRow>(
   185	          `select id::text as id, line_basis
   186	             from public.bom_headers
   187	            where org_id = app.current_org_id() and status = 'active'
   188	              and (item_id = $1::uuid or product_id = $2)
   189	            order by version desc, created_at desc
   190	            limit 1`,
   191	          [fg.id, fg.item_code],
   192	        )
   193	      ).rows[0];
   194	      if (!bom) return { ok: false, error: 'no_active_bom' };
   195	
   196	      let materialScalar: number;
   197	      try {
   198	        materialScalar = computeWoMaterialScalar({
   199	          plannedBaseQty: Number(parsed.data.plannedQuantity),
   200	          lineBasis: bom.line_basis,
   201	          eachPerBox: fg.each_per_box == null ? null : Number(fg.each_per_box),
   202	          netQtyPerEach: fg.net_qty_per_each == null ? null : Number(fg.net_qty_per_each),
   203	        });
   204	      } catch (error) {
   205	        if (error instanceof WoMaterialScalarError) return { ok: false, error: 'pack_hierarchy_incomplete' };
   206	        throw error;
   207	      }
   208	
   209	      const wipLines = (
   210	        await q.query<WipBomLineRow>(
   211	          `select bl.item_id::text as item_id, bl.component_code, i.name, i.uom_base,
   212	                  bl.quantity::text as quantity, bl.scrap_pct::text as scrap_pct
   213	             from public.bom_lines bl
   214	             left join public.items i on i.id = bl.item_id and i.org_id = bl.org_id
   215	            where bl.org_id = app.current_org_id()
   216	              and bl.bom_header_id = $1::uuid
   217	              and bl.component_type = 'WIP'
   218	              and bl.item_id is not null
   219	            order by bl.line_no`,
   220	          [bom.id],
   221	        )
   222	      ).rows;
   223	
   224	      const itemIds = [fg.id, ...wipLines.map((l) => l.item_id)];
   225	      const [linesByItem, processesByItem] = await Promise.all([
   226	        loadLinesByItem(q, itemIds),
   227	        loadProcessesByItem(q, itemIds),
   228	      ]);
   229	
   230	      const childStages: ChainStage[] = wipLines.map((line, index) => {
   231	        const requiredQty = computeRequiredMaterialQty(line.quantity, line.scrap_pct, materialScalar);
   232	        return {
   233	          key: `${line.item_id}-W${index + 1}`,
   234	          stageLabel: `W${index + 1}`,
   235	          itemId: line.item_id,
   236	          itemCode: line.component_code,
   237	          itemName: line.name ?? line.component_code,
   238	          requiredQty,
   239	          uom: line.uom_base,
   240	          lines: linesByItem.get(line.item_id) ?? [],
   241	          processes: processesByItem.get(line.item_id) ?? [],
   242	          consumes: [],
   243	          children: [],
   244	        };
   245	      });
   246	
   247	      const root: ChainStage = {
   248	        key: `${fg.id}-FG`,
   249	        stageLabel: 'FG',
   250	        itemId: fg.id,
   251	        itemCode: fg.item_code,
   252	        itemName: fg.name ?? fg.item_code,
   253	        requiredQty: parsed.data.plannedQuantity,
   254	        uom: fg.uom_base,
   255	        lines: linesByItem.get(fg.id) ?? [],
   256	        processes: processesByItem.get(fg.id) ?? [],
   257	        consumes: childStages.map((c) => ({ itemCode: c.itemCode, requiredQty: c.requiredQty, uom: c.uom })),
   258	        children: childStages,
   259	      };
   260	
   261	      return {
   262	        ok: true,
   263	        spansMultipleStages: childStages.length > 0,
   264	        stageCount: childStages.length + 1,
   265	        root,
   266	      };
   267	    });
   268	  } catch (error) {
   269	    console.error('[previewWorkOrderChain] persistence_failed', error);
   270	    return { ok: false, error: 'persistence_failed' };
   271	  }
   272	}
   273	
   274	// ---------------------------------------------------------------------------
   275	// Per-station queue
   276	// ---------------------------------------------------------------------------
   277	
   278	export type StationInput = { itemCode: string; requiredQty: string | null; producedQty: string | null; upstreamWoNumber: string; upstreamStatus: string; uom: string };
   279	
   280	export type StationWorkOrder = {
   281	  id: string;
   282	  woNumber: string;
   283	  status: string;
   284	  itemCode: string | null;
   285	  itemName: string | null;
   286	  demandQty: string;
   287	  producedQty: string | null;
   288	  uom: string;
   289	  scheduledStartTime: string | null;
   290	  processes: ChainStageProcess[];
   291	  inputs: StationInput[];
   292	};
   293	
   294	export type GetStationQueueResult =
   295	  | { ok: true; lineCode: string; lineName: string; workOrders: StationWorkOrder[] }
   296	  | { ok: false; error: 'invalid_input' | 'not_found' | 'persistence_failed' };
   297	
   298	const StationInputSchema = z.object({ lineId: z.string().uuid() });
   299	
   300	type StationWoRow = {
   301	  id: string;
   302	  wo_number: string;
   303	  status: string;
   304	  product_id: string;
   305	  item_code: string | null;
   306	  name: string | null;
   307	  planned_quantity: string;
   308	  produced_quantity: string | null;
   309	  uom: string;
   310	  scheduled_start_time: string | null;
   311	};
   312	
   313	type StationDepRow = {
   314	  parent_wo_id: string;
   315	  child_wo_number: string;
   316	  child_status: string;
   317	  child_item_code: string | null;
   318	  child_uom: string;
   319	  produced_quantity: string | null;
   320	  required_qty: string | null;
   321	};
   322	
   323	export async function getStationQueue(raw: unknown): Promise<GetStationQueueResult> {
   324	  const parsed = StationInputSchema.safeParse(raw);
   325	  if (!parsed.success) return { ok: false, error: 'invalid_input' };
   326	
   327	  try {
   328	    return await withOrgContext(async ({ client }): Promise<GetStationQueueResult> => {
   329	      const q = client as unknown as QueryClient;
   330	      const line = (
   331	        await q.query<{ code: string; name: string }>(
   332	          `select code, name from public.production_lines
   333	            where org_id = app.current_org_id() and id = $1::uuid limit 1`,
   334	          [parsed.data.lineId],
   335	        )
   336	      ).rows[0];
   337	      if (!line) return { ok: false, error: 'not_found' };
   338	
   339	      const woRows = (
   340	        await q.query<StationWoRow>(
   341	          `select wo.id::text as id, wo.wo_number, wo.status, wo.product_id::text as product_id,
   342	                  i.item_code, i.name,
   343	                  wo.planned_quantity::text as planned_quantity,
   344	                  wo.produced_quantity::text as produced_quantity, wo.uom,
   345	                  wo.scheduled_start_time::text as scheduled_start_time
   346	             from public.work_orders wo
   347	             left join public.items i on i.id = wo.product_id and i.org_id = wo.org_id
   348	            where wo.org_id = app.current_org_id()
   349	              and wo.production_line_id = $1::uuid
   350	              and wo.status not in ('CLOSED', 'CANCELLED')
   351	            order by coalesce(wo.scheduled_start_time, wo.created_at), wo.wo_number`,
   352	          [parsed.data.lineId],
   353	        )
   354	      ).rows;
   355	
   356	      if (woRows.length === 0) {
   357	        return { ok: true, lineCode: line.code, lineName: line.name, workOrders: [] };
   358	      }
   359	
   360	      const woIds = woRows.map((w) => w.id);
   361	      const productIds = [...new Set(woRows.map((w) => w.product_id))];
   362	      const [depRows, processesByItem] = await Promise.all([
   363	        q.query<StationDepRow>(
   364	          `select dep.parent_wo_id::text as parent_wo_id, child.wo_number as child_wo_number,
   365	                  child.status as child_status, ci.item_code as child_item_code, child.uom as child_uom,
   366	                  child.produced_quantity::text as produced_quantity, dep.required_qty::text as required_qty
   367	             from public.wo_dependencies dep
   368	             join public.work_orders child on child.id = dep.child_wo_id and child.org_id = dep.org_id
   369	             left join public.items ci on ci.id = child.product_id and ci.org_id = child.org_id
   370	            where dep.org_id = app.current_org_id()
   371	              and dep.parent_wo_id = any($1::uuid[])
   372	            order by child.wo_number`,
   373	          [woIds],
   374	        ),
   375	        loadProcessesByItem(q, productIds),
   376	      ]);
