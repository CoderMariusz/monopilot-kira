    94	
    95	// cm-qualified variant of MATRIX_SELECT for loadChangeoverMatrixForRun, which joins
    96	// changeover_matrix (cm) ⋈ changeover_matrix_versions (cmv). id/org_id/site_id (and
    97	// created_at/updated_at) exist in BOTH tables, so the bare MATRIX_SELECT is ambiguous
    98	// (Postgres 42702 "column reference id is ambiguous") — qualify every column with cm.
    99	const MATRIX_SELECT_CM = `
   100	  cm.id::text,
   101	  cm.org_id::text,
   102	  cm.site_id::text,
   103	  cm.version_id::text,
   104	  cm.line_id,
   105	  cm.allergen_from,
   106	  cm.allergen_to,
   107	  cm.changeover_minutes::text,
