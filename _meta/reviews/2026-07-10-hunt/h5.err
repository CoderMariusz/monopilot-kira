    33	
    34	/** Server-only options — never accepted from client-parsed input. */
    35	type ChainOptions = {
    36	  skipFactoryReleaseGate?: boolean;
    37	};
    38	
    39	type ChainErrorCode =
    40	  | 'invalid_input'
    41	  | 'forbidden'
    42	  | 'not_found'
    43	  | 'no_active_bom'
    44	  | 'pack_hierarchy_incomplete'
