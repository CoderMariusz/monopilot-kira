   256	async function fetchDraftTransferOrderForUpdate(client: QueryClient, toId: string): Promise<TransferOrderRow | null> {
   257	  const { rows } = await client.query<TransferOrderRow>(
   258	    `select id, to_number, from_warehouse_id, to_warehouse_id, status,
   259	            scheduled_date::text as scheduled_date, notes, created_at, updated_at
   260	       from public.transfer_orders
   261	      where org_id = app.current_org_id()
   262	        and id = $1::uuid
   263	      limit 1
   264	      for update`,
   265	    [toId],
   266	  );
   267	  return rows[0] ?? null;
   268	}
