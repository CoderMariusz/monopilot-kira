   114	
   115	function isUuid(value: string | null | undefined): value is string {
   116	  return !!value && /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i.test(value);
   117	}
   118	
   119	function isObjectJson(value: JsonValue | null): value is { [key: string]: JsonValue } {
   120	  return typeof value === 'object' && value !== null && !Array.isArray(value);
   121	}
   122	
   123	function wasApplied(run: SchedulerRunRow): boolean {
   124	  return isObjectJson(run.output_summary) && typeof run.output_summary.applied_at === 'string';
   125	}
   126	
   127	function totalChangeover(assignments: Array<{ cumulative_changeover_cost: number }>): number {
   128	  return assignments.at(-1)?.cumulative_changeover_cost ?? 0;
   129	}
   130	
   131	function numericWeight(value: string | number | null | undefined, fallback: number): number {
   132	  const parsed = Number(value ?? fallback);
   133	  return Number.isFinite(parsed) ? parsed : fallback;
   134	}
   135	
   136	function cloneDefaultSolverConfig(): SequenceSolverConfig {
   137	  return { ...DEFAULT_SEQUENCE_SOLVER_CONFIG, pmWindows: [] };
   138	}
   139	
   140	function solverConfigFromRow(row: SchedulerConfigRow | null): SequenceSolverConfig {
   141	  if (!row) return cloneDefaultSolverConfig();
   142	  const capacity = row.capacity_hours_per_day === null ? null : numericWeight(row.capacity_hours_per_day, 0);
   143	  return {
   144	    sequencingStrategy: row.sequencing_strategy,
   145	    changeoverWeight: numericWeight(row.changeover_weight, 1),
   146	    duedateWeight: numericWeight(row.duedate_weight, 1),
   147	    utilizationWeight: numericWeight(row.utilization_weight, 1),
   148	    capacityHoursPerDay: capacity,
   149	    respectPmWindows: row.respect_pm_windows,
   150	    pmWindows: [],
   151	  };
   152	}
   153	
   154	function capacityHoursByLineFromConfigs(rows: SchedulerConfigRow[]): Record<string, number | null> {
   155	  const byLine: Record<string, number | null> = {};
   156	  for (const row of rows) {
   157	    if (row.line_id === null) continue;
   158	    byLine[row.line_id] =
   159	      row.capacity_hours_per_day === null ? null : numericWeight(row.capacity_hours_per_day, 0);
   160	  }
   161	  return byLine;
   162	}
