   473	async function markRunApplied(
   474	  ctx: OrgActionContext,
   475	  runId: string,
   476	  assignmentCount: number,
   477	): Promise<SchedulerRunRow> {
   478	  const { rows } = await ctx.client.query<SchedulerRunRow>(
   479	    `update public.scheduler_runs
   480	        set output_summary = coalesce(output_summary, '{}'::jsonb)
   481	             || jsonb_build_object(
   482	                  'applied_at', to_char(now() at time zone 'UTC', 'YYYY-MM-DD"T"HH24:MI:SS.MS"Z"'),
   483	                  'applied_by', $2::text,
   484	                  'applied_assignment_count', $3::integer
   485	                ),
   486	            updated_at = now()
   487	      where org_id = app.current_org_id()
   488	        and run_id = $1::uuid
   489	      returning ${RUN_SELECT}`,
   490	    [runId, ctx.userId, assignmentCount],
   491	  );
   492	  return rows[0];
   493	}
