   538	async function loadExistingChain(
   539	  ctx: OrgActionContext,
   540	  fgWoId: string,
   541	): Promise<{
   542	  wipWorkOrders: WOHeader[];
   543	  dependencies: Array<{ parentWoId: string; childWoId: string; materialLink: string | null; requiredQty: string | null }>;
   544	}> {
   545	  const { rows } = await ctx.client.query<{ child_wo_number: string; parent_wo_id: string; child_wo_id: string; material_link: string | null; required_qty: string | null }>(
   546	    `select child.wo_number as child_wo_number,
   547	            dep.parent_wo_id::text as parent_wo_id,
   548	            dep.child_wo_id::text as child_wo_id,
   549	            dep.material_link::text as material_link,
   550	            dep.required_qty::text as required_qty
   551	       from public.wo_dependencies dep
   552	       join public.work_orders child
   553	         on child.org_id = dep.org_id
   554	        and child.id = dep.child_wo_id
   555	      where dep.org_id = app.current_org_id()
   556	        and dep.parent_wo_id = $1::uuid
   557	      order by child.wo_number`,
   558	    [fgWoId],
   559	  );
   560	  const wipWorkOrders: WOHeader[] = [];
   561	  const dependencies: Array<{ parentWoId: string; childWoId: string; materialLink: string | null; requiredQty: string | null }> = [];
   562	  for (const row of rows) {
   563	    const child = await loadWorkOrderByNumber(ctx, row.child_wo_number);
   564	    if (child) wipWorkOrders.push(child);
   565	    dependencies.push({
   566	      parentWoId: row.parent_wo_id,
   567	      childWoId: row.child_wo_id,
   568	      materialLink: row.material_link,
   569	      requiredQty: row.required_qty,
   570	    });
   571	  }
   572	  return { wipWorkOrders, dependencies };
   573	}
