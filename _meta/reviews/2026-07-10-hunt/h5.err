   322	export async function listTransferOrders(params: unknown = {}): Promise<TransferOrderListResult> {
   323	  const input = (params ?? {}) as {
   324	    status?: unknown;
   325	    q?: unknown;
   326	    page?: unknown;
   327	    offset?: unknown;
   328	    limit?: unknown;
   329	    archived?: unknown;
   330	  };
   331	  const status = typeof input.status === 'string' ? TransferOrderStatusSchema.safeParse(input.status) : null;
   332	  if (status && !status.success) return { ok: false, error: 'invalid_input' };
   333	  const q = typeof input.q === 'string' && input.q.trim() ? input.q.trim() : null;
   334	  const archived = input.archived === true;
   335	  const page = normalizePage({
   336	    page: typeof input.page === 'number' ? input.page : undefined,
   337	    offset: typeof input.offset === 'number' ? input.offset : undefined,
   338	    limit: typeof input.limit === 'number' ? input.limit : undefined,
   339	    defaultLimit: DEFAULT_TO_LIST_PAGE_SIZE,
   340	    maxLimit: 200,
   341	  });
   342	
   343	  try {
   344	    return await withOrgContext(async ({ client }): Promise<TransferOrderListResult> => {
   345	      const baseParams = [status?.success ? status.data : null, q, archived] as const;
   346	      const [countResult, dataResult] = await Promise.all([
   347	        (client as QueryClient).query<{ total: number }>(
   348	          `select count(*)::int as total
   349	             ${TO_LIST_FROM}
   350	            where transfer_orders.org_id = app.current_org_id()
   351	              and ($1::text is null or transfer_orders.status = $1)
   352	              and ($2::text is null or transfer_orders.to_number ilike '%' || $2 || '%')
   353	              and coalesce(
   354	                (
   355	                  transfer_orders.status in ('received', 'cancelled')
   356	                  and ods.archive_after_days is not null
   357	                  and transfer_orders.updated_at < now() - make_interval(days => ods.archive_after_days)
   358	                ),
   359	                false
   360	              ) = $3::boolean`,
   361	          [...baseParams],
   362	        ),
   363	        (client as QueryClient).query<TransferOrderRow>(
   364	          `select transfer_orders.id, transfer_orders.to_number, transfer_orders.from_warehouse_id,
   365	                  transfer_orders.to_warehouse_id, transfer_orders.status,
   366	                  transfer_orders.scheduled_date::text as scheduled_date, transfer_orders.notes,
   367	                  transfer_orders.created_at, transfer_orders.updated_at
   368	             ${TO_LIST_FROM}
   369	            where transfer_orders.org_id = app.current_org_id()
   370	              and ($1::text is null or transfer_orders.status = $1)
   371	              and ($2::text is null or transfer_orders.to_number ilike '%' || $2 || '%')
   372	              and coalesce(
   373	                (
   374	                  transfer_orders.status in ('received', 'cancelled')
   375	                  and ods.archive_after_days is not null
   376	                  and transfer_orders.updated_at < now() - make_interval(days => ods.archive_after_days)
   377	                ),
   378	                false
   379	              ) = $3::boolean
   380	            order by transfer_orders.scheduled_date asc nulls last, transfer_orders.to_number asc, transfer_orders.id asc
   381	            limit $4::integer offset $5::integer`,
   382	          [...baseParams, page.limit, page.offset],
   383	        ),
   384	      ]);
   385	      const count = await (client as QueryClient).query<{ archived_count: string | number }>(
   386	        `select count(*) as archived_count
   387	           from public.transfer_orders transfer_orders
   388	           left join public.org_document_settings ods
   389	             on ods.org_id = transfer_orders.org_id
   390	            and ods.doc_type = 'to'
   391	          where transfer_orders.org_id = app.current_org_id()
   392	            and ($1::text is null or transfer_orders.status = $1)
   393	            and ($2::text is null or transfer_orders.to_number ilike '%' || $2 || '%')
   394	            and transfer_orders.status in ('received', 'cancelled')
   395	            and ods.archive_after_days is not null
   396	            and transfer_orders.updated_at < now() - make_interval(days => ods.archive_after_days)`,
   397	        [status?.success ? status.data : null, q],
   398	      );
   399	      const rows = dataResult.rows.map(mapTransferOrder);
   400	      const pagination = toPaginatedResult(rows, Number(countResult.rows[0]?.total ?? 0), page);
   401	      return { ok: true, data: pagination.items, pagination, archivedCount: Number(count.rows[0]?.archived_count ?? 0) };
   402	    });
   403	  } catch (err) {
   404	    console.error('[planning/transfer-orders] listTransferOrders failed', err);
   405	    return { ok: false, error: 'persistence_failed' };
   406	  }
   407	}
   408	
   409	export async function getTransferOrder(id: string): Promise<TransferOrderResult<TransferOrderDetail>> {
   410	  try {
   411	    return await withOrgContext(async ({ client }): Promise<TransferOrderResult<TransferOrderDetail>> => {
   412	      const c = client as QueryClient;
   413	      const { rows } = await c.query<TransferOrderRow>(
   414	        `select id, to_number, from_warehouse_id, to_warehouse_id, status,
   415	                scheduled_date::text as scheduled_date, notes, created_at, updated_at
   416	           from public.transfer_orders
   417	          where org_id = app.current_org_id()
   418	            and id = $1::uuid
   419	          limit 1`,
   420	        [id],
   421	      );
   422	      const row = rows[0];
   423	      if (!row) return { ok: false, error: 'not_found' };
   424	      return { ok: true, data: { ...mapTransferOrder(row), lines: await fetchLines(c, id) } };
   425	    });
   426	  } catch (err) {
   427	    console.error('[planning/transfer-orders] getTransferOrder failed', err);
   428	    return { ok: false, error: 'persistence_failed' };
   429	  }
   430	}
   431	
   432	export async function createTransferOrder(rawInput: unknown): Promise<TransferOrderResult<TransferOrderDetail>> {
   433	  const parsed = TransferOrderCreateInput.safeParse(rawInput);
   434	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   435	  const input = parsed.data;
   436	
   437	  try {
   438	    return await withOrgContext(async ({ userId, orgId, client }): Promise<TransferOrderResult<TransferOrderDetail>> => {
   439	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   440	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   441	
   442	      async function insertHeader(toNumber: string) {
   443	        return ctx.client.query<TransferOrderRow>(
   444	          `insert into public.transfer_orders
   445	             (org_id, to_number, from_warehouse_id, to_warehouse_id, status, scheduled_date, notes, created_by, updated_by)
   446	           values
   447	             (app.current_org_id(), $1, $2::uuid, $3::uuid, $4, $5::date, $6, $7::uuid, $7::uuid)
   448	           returning id, to_number, from_warehouse_id, to_warehouse_id, status,
   449	                     scheduled_date::text as scheduled_date, notes, created_at, updated_at`,
   450	          [
   451	            toNumber,
   452	            input.fromWarehouseId ?? null,
   453	            input.toWarehouseId ?? null,
   454	            input.status,
   455	            input.scheduledDate ?? null,
   456	            input.notes ?? null,
   457	            userId,
   458	          ],
   459	        );
   460	      }
   461	
   462	      const initialToNumber = input.toNumber ?? (await nextDocumentNumber(ctx.client, orgId, 'to', new Date()));
   463	      let insertResult: Awaited<ReturnType<typeof insertHeader>>;
   464	      try {
   465	        insertResult = await insertHeader(initialToNumber);
   466	      } catch (error) {
   467	        if (input.toNumber || !isPgError(error) || error.code !== '23505') throw error;
   468	        insertResult = await insertHeader(await nextDocumentNumber(ctx.client, orgId, 'to', new Date()));
   469	      }
   470	
   471	      const { rows } = insertResult;
   472	      const header = rows[0];
   473	      if (!header) return { ok: false, error: 'persistence_failed' };
   474	
   475	      for (const line of input.lines) {
   476	        await ctx.client.query(
   477	          `insert into public.transfer_order_lines
   478	             (org_id, to_id, item_id, qty, uom, line_no, created_by, updated_by)
   479	           values
   480	             (app.current_org_id(), $1::uuid, $2::uuid, $3::numeric, $4, $5::integer, $6::uuid, $6::uuid)`,
   481	          [header.id, line.itemId, line.qty, line.uom, line.lineNo, userId],
   482	        );
   483	      }
   484	
   485	      await writeProcurementAudit(ctx, {
   486	        action: 'planning.transfer_order.created',
   487	        resourceType: 'transfer_order',
   488	        resourceId: header.id,
   489	        afterState: { toNumber: header.to_number, status: header.status, lineCount: input.lines.length },
   490	      });
   491	      revalidateTransferOrderPaths(header.id);
   492	      return { ok: true, data: { ...mapTransferOrder(header), lines: await fetchLines(ctx.client, header.id) } };
   493	    });
   494	  } catch (err) {
   495	    const error = pgErrorToResult(err);
   496	    if (error !== 'persistence_failed') return { ok: false, error };
   497	    console.error('[planning/transfer-orders] createTransferOrder failed', err);
   498	    return { ok: false, error };
   499	  }
   500	}
   501	
   502	export async function updateTransferOrder(rawInput: unknown): Promise<TransferOrderResult<TransferOrder>> {
   503	  const parsed = UpdateTransferOrderInput.safeParse(rawInput);
   504	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   505	  const input = parsed.data;
   506	
   507	  try {
   508	    return await withOrgContext(async ({ userId, orgId, client }): Promise<TransferOrderResult<TransferOrder>> => {
   509	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   510	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   511	
   512	      const previous = await fetchDraftTransferOrderForUpdate(ctx.client, input.id);
   513	      if (!previous) return { ok: false, error: 'not_found' };
   514	      if (previous.status !== 'draft') return { ok: false, error: 'invalid_state' };
   515	
   516	      const nextFromWarehouseId = input.fromWarehouseId ?? previous.from_warehouse_id;
   517	      const nextToWarehouseId = input.toWarehouseId ?? previous.to_warehouse_id;
   518	      if (input.fromWarehouseId && !(await ensureWarehouseInOrg(ctx.client, input.fromWarehouseId))) {
   519	        return { ok: false, error: 'forbidden' };
   520	      }
   521	      if (input.toWarehouseId && !(await ensureWarehouseInOrg(ctx.client, input.toWarehouseId))) {
   522	        return { ok: false, error: 'forbidden' };
   523	      }
   524	      if (nextFromWarehouseId && nextToWarehouseId && nextFromWarehouseId === nextToWarehouseId) {
   525	        return { ok: false, error: 'invalid_input' };
   526	      }
   527	
   528	      const updated = await ctx.client.query<TransferOrderRow>(
   529	        `update public.transfer_orders
   530	            set from_warehouse_id = $2::uuid,
   531	                to_warehouse_id = $3::uuid,
   532	                scheduled_date = $4::date,
   533	                notes = case when $7::boolean then nullif($5, '') else notes end,
   534	                updated_by = $6::uuid,
   535	                updated_at = now()
   536	          where org_id = app.current_org_id()
   537	            and id = $1::uuid
   538	            and status = 'draft'
   539	        returning id, to_number, from_warehouse_id, to_warehouse_id, status,
   540	                  scheduled_date::text as scheduled_date, notes, created_at, updated_at`,
   541	        [
   542	          input.id,
   543	          nextFromWarehouseId,
   544	          nextToWarehouseId,
   545	          input.expectedDate ?? previous.scheduled_date,
   546	          input.notes ?? null,
   547	          userId,
   548	          input.notes !== undefined,
   549	        ],
   550	      );
   551	      const row = updated.rows[0];
   552	      if (!row) return { ok: false, error: 'invalid_state' };
   553	
   554	      await writeProcurementAudit(ctx, {
   555	        action: 'planning.transfer_order.updated',
   556	        resourceType: 'transfer_order',
   557	        resourceId: row.id,
   558	        beforeState: {
   559	          fromWarehouseId: previous.from_warehouse_id,
   560	          toWarehouseId: previous.to_warehouse_id,
   561	          scheduledDate: previous.scheduled_date,
   562	          notes: previous.notes,
   563	        },
   564	        afterState: {
   565	          fromWarehouseId: row.from_warehouse_id,
   566	          toWarehouseId: row.to_warehouse_id,
   567	          scheduledDate: row.scheduled_date,
   568	          notes: row.notes,
   569	        },
   570	      });
   571	      revalidateTransferOrderPaths(row.id);
   572	      return { ok: true, data: mapTransferOrder(row) };
   573	    });
   574	  } catch (err) {
   575	    const error = pgErrorToResult(err);
   576	    if (error !== 'persistence_failed') return { ok: false, error };
   577	    console.error('[planning/transfer-orders] updateTransferOrder failed', err);
   578	    return { ok: false, error };
   579	  }
   580	}
   581	
   582	export async function addTransferOrderLine(id: string, rawInput: unknown): Promise<TransferOrderResult<TransferOrderDetail>> {
   583	  const parsed = AddTransferOrderLineInput.safeParse({ ...(rawInput as Record<string, unknown>), toId: id });
   584	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   585	  const input = parsed.data;
   586	
   587	  try {
   588	    return await withOrgContext(async ({ userId, orgId, client }): Promise<TransferOrderResult<TransferOrderDetail>> => {
   589	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   590	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   591	
   592	      const header = await fetchDraftTransferOrderForUpdate(ctx.client, input.toId);
   593	      if (!header) return { ok: false, error: 'not_found' };
   594	      if (header.status !== 'draft') return { ok: false, error: 'invalid_state' };
   595	      if (!(await ensureItemInOrg(ctx.client, input.itemId))) return { ok: false, error: 'forbidden' };
   596	
   597	      await denseRenumberTransferOrderLines(ctx.client, input.toId);
   598	      async function insertLine() {
   599	        const next = await ctx.client.query<{ line_no: number }>(
   600	          `select coalesce(max(line_no), 0) + 1 as line_no
   601	             from public.transfer_order_lines
   602	            where org_id = app.current_org_id()
   603	              and to_id = $1::uuid`,
   604	          [input.toId],
   605	        );
   606	        return ctx.client.query(
   607	          `insert into public.transfer_order_lines
   608	             (org_id, to_id, item_id, qty, uom, line_no, created_by, updated_by)
   609	           values
   610	             (app.current_org_id(), $1::uuid, $2::uuid, $3::numeric, $4, $5::integer, $6::uuid, $6::uuid)`,
   611	          [input.toId, input.itemId, input.quantity, input.uom, next.rows[0]?.line_no ?? 1, userId],
   612	        );
   613	      }
   614	      try {
   615	        await insertLine();
   616	      } catch (error) {
   617	        if (!isPgError(error) || error.code !== '23505') throw error;
   618	        await denseRenumberTransferOrderLines(ctx.client, input.toId);
   619	        await insertLine();
   620	      }
   621	
   622	      await writeProcurementAudit(ctx, {
   623	        action: 'planning.transfer_order.line_added',
   624	        resourceType: 'transfer_order',
   625	        resourceId: input.toId,
   626	        afterState: { itemId: input.itemId, quantity: input.quantity, uom: input.uom, notes: input.notes ?? null },
   627	      });
   628	      revalidateTransferOrderPaths(input.toId);
   629	      return { ok: true, data: { ...mapTransferOrder(header), lines: await fetchLines(ctx.client, input.toId) } };
   630	    });
   631	  } catch (err) {
   632	    const error = pgErrorToResult(err);
   633	    if (error !== 'persistence_failed') return { ok: false, error };
   634	    console.error('[planning/transfer-orders] addTransferOrderLine failed', err);
   635	    return { ok: false, error };
   636	  }
   637	}
   638	
   639	export async function updateTransferOrderLine(
   640	  id: string,
   641	  lineId: string,
   642	  rawInput: unknown,
   643	): Promise<TransferOrderResult<TransferOrderDetail>> {
   644	  const parsed = UpdateTransferOrderLineInput.safeParse({ ...(rawInput as Record<string, unknown>), toId: id, lineId });
   645	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   646	  const input = parsed.data;
   647	
   648	  try {
   649	    return await withOrgContext(async ({ userId, orgId, client }): Promise<TransferOrderResult<TransferOrderDetail>> => {
   650	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   651	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   652	
   653	      const header = await fetchDraftTransferOrderForUpdate(ctx.client, input.toId);
   654	      if (!header) return { ok: false, error: 'not_found' };
   655	      if (header.status !== 'draft') return { ok: false, error: 'invalid_state' };
   656	
   657	      const current = await ctx.client.query<{ id: string; qty: string; uom: string }>(
   658	        `select id, qty::text as qty, uom
   659	           from public.transfer_order_lines
   660	          where org_id = app.current_org_id()
   661	            and to_id = $1::uuid
   662	            and id = $2::uuid
   663	          limit 1
   664	          for update`,
   665	        [input.toId, input.lineId],
   666	      );
   667	      const previous = current.rows[0];
   668	      if (!previous) return { ok: false, error: 'not_found' };
   669	
   670	      const updated = await ctx.client.query(
   671	        `update public.transfer_order_lines l
   672	            set qty = $3::numeric,
   673	                uom = $4,
   674	                updated_by = $5::uuid,
   675	                updated_at = now()
   676	           from public.transfer_orders t
   677	          where l.org_id = app.current_org_id()
   678	            and t.org_id = app.current_org_id()
   679	            and t.id = l.to_id
   680	            and t.id = $1::uuid
   681	            and t.status = 'draft'
   682	            and l.id = $2::uuid`,
   683	        [input.toId, input.lineId, input.quantity ?? previous.qty, input.uom ?? previous.uom, userId],
   684	      );
   685	      if ((updated.rowCount ?? 0) === 0) return { ok: false, error: 'invalid_state' };
   686	
   687	      await writeProcurementAudit(ctx, {
   688	        action: 'planning.transfer_order.line_updated',
   689	        resourceType: 'transfer_order',
   690	        resourceId: input.toId,
   691	        beforeState: { lineId: input.lineId, quantity: previous.qty, uom: previous.uom },
   692	        afterState: {
   693	          lineId: input.lineId,
   694	          quantity: input.quantity ?? previous.qty,
   695	          uom: input.uom ?? previous.uom,
   696	          notes: input.notes ?? null,
   697	        },
   698	      });
   699	      revalidateTransferOrderPaths(input.toId);
   700	      return { ok: true, data: { ...mapTransferOrder(header), lines: await fetchLines(ctx.client, input.toId) } };
   701	    });
   702	  } catch (err) {
   703	    const error = pgErrorToResult(err);
   704	    if (error !== 'persistence_failed') return { ok: false, error };
   705	    console.error('[planning/transfer-orders] updateTransferOrderLine failed', err);
   706	    return { ok: false, error };
   707	  }
   708	}
   709	
   710	export async function deleteTransferOrderLine(id: string, lineId: string): Promise<TransferOrderResult<TransferOrderDetail>> {
   711	  const parsed = DeleteTransferOrderLineInput.safeParse({ toId: id, lineId });
   712	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   713	  const input = parsed.data;
   714	
   715	  try {
   716	    return await withOrgContext(async ({ userId, orgId, client }): Promise<TransferOrderResult<TransferOrderDetail>> => {
   717	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   718	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   719	
   720	      const header = await fetchDraftTransferOrderForUpdate(ctx.client, input.toId);
   721	      if (!header) return { ok: false, error: 'not_found' };
   722	      if (header.status !== 'draft') return { ok: false, error: 'invalid_state' };
   723	
   724	      const lines = await ctx.client.query<{ id: string }>(
   725	        `select id
   726	           from public.transfer_order_lines
   727	          where org_id = app.current_org_id()
   728	            and to_id = $1::uuid
   729	          order by line_no asc, id asc
   730	          for update`,
   731	        [input.toId],
   732	      );
   733	      if (!lines.rows.some((line) => line.id === input.lineId)) return { ok: false, error: 'not_found' };
   734	      if (lines.rows.length <= 1) return { ok: false, error: 'last_line', code: 'last_line' };
   735	
   736	      const deleted = await ctx.client.query(
   737	        `delete from public.transfer_order_lines l
   738	          using public.transfer_orders t
   739	          where l.org_id = app.current_org_id()
   740	            and t.org_id = app.current_org_id()
   741	            and t.id = l.to_id
   742	            and t.id = $1::uuid
   743	            and t.status = 'draft'
   744	            and l.id = $2::uuid`,
   745	        [input.toId, input.lineId],
   746	      );
   747	      if ((deleted.rowCount ?? 0) === 0) return { ok: false, error: 'invalid_state' };
   748	      await denseRenumberTransferOrderLines(ctx.client, input.toId);
   749	
   750	      await writeProcurementAudit(ctx, {
   751	        action: 'planning.transfer_order.line_deleted',
   752	        resourceType: 'transfer_order',
   753	        resourceId: input.toId,
   754	        beforeState: { lineId: input.lineId },
   755	      });
   756	      revalidateTransferOrderPaths(input.toId);
   757	      return { ok: true, data: { ...mapTransferOrder(header), lines: await fetchLines(ctx.client, input.toId) } };
   758	    });
   759	  } catch (err) {
   760	    const error = pgErrorToResult(err);
   761	    if (error !== 'persistence_failed') return { ok: false, error };
   762	    console.error('[planning/transfer-orders] deleteTransferOrderLine failed', err);
   763	    return { ok: false, error };
   764	  }
   765	}
   766	
   767	// Server-side state machine for TO status. Terminal states (received, cancelled)
   768	// have no legal successors. Re-validated server-side so a forged/stale request
   769	// can never apply an illegal jump.
   770	const TO_TRANSITIONS: Record<string, readonly string[]> = {
   771	  draft: ['in_transit', 'cancelled'],
   772	  in_transit: ['received', 'cancelled'],
   773	  partially_received: ['received', 'cancelled'],
   774	  received: [],
   775	  cancelled: [],
   776	};
   777	
   778	// ─── NUMERIC-exact decimal helpers (scale 6 — license_plates quantity) ─────────
   779	// LP quantities never round-trip through a JS float: text in, bigint micro-units
   780	// for arithmetic, text out.
   781	const QTY_SCALE = 1_000_000n;
   782	
   783	function toMicro6(decimal: string): bigint {
   784	  const neg = decimal.startsWith('-');
   785	  const body = neg ? decimal.slice(1) : decimal;
   786	  const [intPart, fracRaw = ''] = body.split('.');
   787	  const frac = (fracRaw + '000000').slice(0, 6);
   788	  const micro = BigInt(intPart || '0') * QTY_SCALE + BigInt(frac || '0');
   789	  return neg ? -micro : micro;
   790	}
   791	
   792	function microToText6(micro: bigint): string {
   793	  const neg = micro < 0n;
   794	  const abs = neg ? -micro : micro;
   795	  const frac = (abs % QTY_SCALE).toString().padStart(6, '0').replace(/0+$/, '');
   796	  const out = frac ? `${abs / QTY_SCALE}.${frac}` : `${abs / QTY_SCALE}`;
   797	  return neg && abs !== 0n ? `-${out}` : out;
   798	}
   799	
   800	type ToHeaderForUpdate = {
   801	  id: string;
   802	  to_number: string;
   803	  status: string;
   804	  from_warehouse_id: string | null;
   805	  to_warehouse_id: string | null;
   806	};
   807	
   808	type SourceLpRow = {
   809	  id: string;
   810	  lp_number: string;
   811	  quantity: string;
   812	  reserved_qty: string;
   813	  location_id: string | null;
   814	};
   815	
   816	type SkippedHeldLp = { lpId: string; lpCode: string; qty: string; uom: string };
   817	
   818	type PlannedPick = {
   819	  lineId: string;
   820	  lineNo: number;
   821	  lpId: string;
   822	  lpLocationId: string | null;
   823	  takeMicro: bigint;
   824	  newQtyMicro: bigint;
   825	  uom: string;
   826	};
   827	
   828	/**
   829	 * SHIP (draft → in_transit) — W9-K-II / F-C05. Real stock leaves the source:
   830	 *   1. Validate FIRST, write after — sum of pickable stock (status 'available',
   831	 *      qa_status 'released', matching uom, available = quantity - reserved_qty)
   832	 *      at from_warehouse must cover every line, else 'insufficient_stock' and
   833	 *      NOTHING is written (withOrgContext commits even on ok:false returns).
   834	 *   2. Pick FEFO (expiry asc NULLS LAST, lp_number asc) with row locks.
   835	 *   3. Decrement each picked LP; full depletion → status 'shipped' (+ ledger row).
   836	 *   4. Record every pick in transfer_order_line_lps (source_lp_id + qty) — the
   837	 *      in-transit truth that receive() materializes at the destination.
   838	 *   5. stock_moves row per pick (move_type 'transfer', from = LP's location).
   839	 */
   840	async function shipTransferOrder(
   841	  ctx: OrgActionContext,
   842	  to: ToHeaderForUpdate,
   843	): Promise<{ ok: true; pickCount: number; skippedHeldLps: SkippedHeldLp[] } | { ok: false; error: ProcurementError; message?: string; heldQty?: string }> {
   844	  if (!to.from_warehouse_id) {
   845	    return { ok: false, error: 'invalid_state', message: 'from_warehouse_required' };
   846	  }
   847	
   848	  const lines = await ctx.client.query<{ id: string; item_id: string; qty: string; uom: string; line_no: number }>(
   849	    `select id, item_id, qty::text as qty, uom, line_no
   850	       from public.transfer_order_lines
   851	      where org_id = app.current_org_id()
   852	        and to_id = $1::uuid
   853	      order by line_no asc
   854	      for update`,
   855	    [to.id],
   856	  );
   857	  if (lines.rows.length === 0) {
   858	    return { ok: false, error: 'invalid_state', message: 'no_lines' };
   859	  }
   860	
   861	  // Phase 1 — plan all picks (locks the candidate LPs), no writes yet.
   862	  const picks: PlannedPick[] = [];
   863	  const skippedHeldLps: SkippedHeldLp[] = [];
   864	  for (const line of lines.rows) {
   865	    const lps = await ctx.client.query<SourceLpRow>(
   866	      `select lp.id, lp.lp_number, lp.quantity::text as quantity, lp.reserved_qty::text as reserved_qty, lp.location_id
   867	         from public.license_plates lp
   868	        where lp.org_id = app.current_org_id()
   869	          and lp.warehouse_id = $1::uuid
   870	          and lp.product_id = $2::uuid
   871	          and lp.uom = $3
   872	          and lp.status = 'available'
   873	          and lp.qa_status = 'released'
   874	          and (lp.quantity - lp.reserved_qty) > 0
   875	        order by lp.expiry_date asc nulls last, lp.lp_number asc
   876	        for update`,
   877	      [to.from_warehouse_id, line.item_id, line.uom],
   878	    );
   879	
   880	    let remaining = toMicro6(line.qty);
   881	    for (const lp of lps.rows) {
   882	      if (remaining <= 0n) break;
   883	      try {
   884	        await assertNoActiveHoldForLp(lp.id, ctx.client);
   885	      } catch (error) {
   886	        if (typeof error === 'object' && error !== null && (error as { code?: string }).code === 'QA_HOLD_ACTIVE') {
   887	          const availableHeld = toMicro6(lp.quantity) - toMicro6(lp.reserved_qty);
   888	          skippedHeldLps.push({ lpId: lp.id, lpCode: lp.lp_number, qty: microToText6(availableHeld), uom: line.uom });
   889	          continue;
   890	        }
   891	        throw error;
   892	      }
   893	      const availableMicro = toMicro6(lp.quantity) - toMicro6(lp.reserved_qty);
   894	      if (availableMicro <= 0n) continue;
   895	      const take = availableMicro < remaining ? availableMicro : remaining;
   896	      picks.push({
   897	        lineId: line.id,
   898	        lineNo: line.line_no,
   899	        lpId: lp.id,
   900	        lpLocationId: lp.location_id,
   901	        takeMicro: take,
   902	        newQtyMicro: toMicro6(lp.quantity) - take,
   903	        uom: line.uom,
   904	      });
   905	      remaining -= take;
   906	    }
   907	    if (remaining > 0n) {
   908	      return {
   909	        ok: false,
   910	        error: skippedHeldLps.length > 0 ? 'insufficient_stock_holds' : 'insufficient_stock',
   911	        message: `line ${line.line_no}: short by ${microToText6(remaining)} ${line.uom} at source warehouse`,
   912	        heldQty: skippedHeldLps.length > 0 ? microToText6(skippedHeldLps.reduce((acc, s) => acc + toMicro6(s.qty), 0n)) : undefined,
   913	      };
   914	    }
   915	  }
   916	
   917	  // Phase 2 — apply the plan (all-or-nothing inside the withOrgContext txn).
   918	  for (const pick of picks) {
   919	    const fullyDepleted = pick.newQtyMicro === 0n;
   920	    await ctx.client.query(
   921	      `update public.license_plates
   922	          set quantity = $2::numeric,
   923	              status = case when $3::boolean then 'shipped' else status end,
   924	              updated_by = $4::uuid,
   925	              updated_at = now()
   926	        where org_id = app.current_org_id()
   927	          and id = $1::uuid`,
   928	      [pick.lpId, microToText6(pick.newQtyMicro), fullyDepleted, ctx.userId],
   929	    );
   930	    if (fullyDepleted) {
   931	      await ctx.client.query(
   932	        `insert into public.lp_state_history
   933	           (org_id, lp_id, from_state, to_state, reason_code, reason_text, transaction_id, ext_jsonb, created_by)
   934	         values (app.current_org_id(), $1::uuid, 'available', 'shipped', 'transfer_ship',
   935	                 $2, $3::uuid, jsonb_build_object('to_id', $4::uuid), $5::uuid)
   936	         on conflict (org_id, transaction_id) do nothing`,
   937	        [pick.lpId, `TO ship ${to.to_number}`, randomUUID(), to.id, ctx.userId],
   938	      );
   939	    }
   940	    const moveTxn = randomUUID();
   941	    await ctx.client.query(
   942	      `insert into public.stock_moves
   943	         (org_id, move_number, lp_id, move_type, from_location_id, to_location_id,
   944	          quantity, uom, reason_text, transaction_id, created_by, updated_by)
   945	       values (app.current_org_id(), $1, $2::uuid, 'transfer', $3::uuid, null,
   946	               $4::numeric, $5, $6, $7::uuid, $8::uuid, $8::uuid)
   947	       on conflict (org_id, transaction_id) do nothing`,
   948	      [
   949	        makeStockMoveNumber(moveTxn),
   950	        pick.lpId,
   951	        pick.lpLocationId,
   952	        microToText6(pick.takeMicro),
   953	        pick.uom,
   954	        `TO ship ${to.to_number}`,
   955	        moveTxn,
   956	        ctx.userId,
   957	      ],
   958	    );
   959	    await ctx.client.query(
   960	      `insert into public.transfer_order_line_lps
   961	         (org_id, to_id, to_line_id, source_lp_id, qty, uom, created_by, updated_by)
   962	       values (app.current_org_id(), $1::uuid, $2::uuid, $3::uuid, $4::numeric, $5, $6::uuid, $6::uuid)`,
   963	      [to.id, pick.lineId, pick.lpId, microToText6(pick.takeMicro), pick.uom, ctx.userId],
   964	    );
   965	  }
   966	
   967	  return { ok: true, pickCount: picks.length, skippedHeldLps };
   968	}
   969	
   970	/**
   971	 * RECEIVE (in_transit → received) — W9-K-II / F-C05. Stock appears at the
   972	 * destination for real: every transfer_order_line_lps row (dest_lp_id null)
   973	 * materializes as a NEW destination LP at to_warehouse:
   974	 *   - origin 'transfer', parent_lp_id = source LP (genealogy chain across sites);
   975	 *   - batch/expiry/shelf-life snapshot carried over from the source LP;
   976	 *   - status 'available' + qa_status carried from the source: ship only picks
   977	 *     qa 'released' stock, and an internal transfer is not a new QA event, so
   978	 *     the goods stay released and pickable (NOT re-quarantined) — deliberate
   979	 *     contrast with GRN/production LPs which are born received/pending;
   980	 *   - location = destination warehouse's default (first by level, code);
   981	 *   - stock_moves 'transfer' row into that location + genesis ledger row.
   982	 */
   983	async function receiveTransferOrder(
   984	  ctx: OrgActionContext,
   985	  to: ToHeaderForUpdate,
   986	): Promise<{ ok: true; lpCount: number } | { ok: false; error: ProcurementError; message?: string }> {
   987	  if (!to.to_warehouse_id) {
   988	    return { ok: false, error: 'invalid_state', message: 'to_warehouse_required' };
   989	  }
   990	  const destLocationId = await resolveDefaultLocation(ctx.client, to.to_warehouse_id);
   991	  const destWarehouse = await ctx.client.query<{ site_id: string | null }>(
   992	    `select w.site_id::text as site_id
   993	       from public.warehouses w
   994	      where w.org_id = app.current_org_id()
   995	        and w.id = $1::uuid
   996	      limit 1`,
   997	    [to.to_warehouse_id],
   998	  );
   999	  const destSiteId = destWarehouse.rows[0]?.site_id ?? null;
  1000	
  1001	  const pending = await ctx.client.query<{
  1002	    id: string;
  1003	    source_lp_id: string;
  1004	    qty: string;
  1005	    uom: string;
  1006	    product_id: string;
  1007	    batch_number: string | null;
  1008	    supplier_batch_number: string | null;
  1009	    expiry_date: string | null;
  1010	    best_before_date: string | null;
  1011	    shelf_life_mode_snapshot: string | null;
  1012	    qa_status: string;
  1013	  }>(
  1014	    `select tll.id, tll.source_lp_id, tll.qty::text as qty, tll.uom,
  1015	            lp.product_id, lp.batch_number, lp.supplier_batch_number,
  1016	            lp.expiry_date, lp.best_before_date, lp.shelf_life_mode_snapshot, lp.qa_status
  1017	       from public.transfer_order_line_lps tll
  1018	       join public.license_plates lp
  1019	         on lp.org_id = app.current_org_id()
  1020	        and lp.id = tll.source_lp_id
  1021	      where tll.org_id = app.current_org_id()
  1022	        and tll.to_id = $1::uuid
  1023	        and tll.dest_lp_id is null
  1024	      order by tll.created_at asc, tll.id asc
  1025	      for update of tll`,
  1026	    [to.id],
  1027	  );
  1028	
  1029	  for (const row of pending.rows) {
  1030	    const lpNumber = makeLpNumber();
  1031	    const inserted = await ctx.client.query<{ id: string }>(
  1032	      `insert into public.license_plates (
  1033	         org_id, site_id, warehouse_id, location_id, lp_number, product_id, quantity, uom,
  1034	         status, qa_status, batch_number, supplier_batch_number,
  1035	         expiry_date, best_before_date, shelf_life_mode_snapshot,
  1036	         origin, parent_lp_id, ext_jsonb, created_by, updated_by
  1037	       )
  1038	       values (
  1039	         app.current_org_id(), $1::uuid, $2::uuid, $3::uuid, $4, $5::uuid, $6::numeric, $7,
  1040	         'available', $8, $9, $10,
  1041	         $11::timestamptz, $12::timestamptz, $13,
  1042	         'transfer', $14::uuid, jsonb_build_object('transfer_order_id', $15::uuid), $16::uuid, $16::uuid
  1043	       )
  1044	       returning id`,
  1045	      [
  1046	        destSiteId,
  1047	        to.to_warehouse_id,
  1048	        destLocationId,
  1049	        lpNumber,
  1050	        row.product_id,
  1051	        row.qty,
  1052	        row.uom,
  1053	        row.qa_status,
  1054	        row.batch_number,
  1055	        row.supplier_batch_number,
  1056	        row.expiry_date,
  1057	        row.best_before_date,
  1058	        row.shelf_life_mode_snapshot,
  1059	        row.source_lp_id,
  1060	        to.id,
  1061	        ctx.userId,
  1062	      ],
  1063	    );
  1064	    const destLp = inserted.rows[0];
  1065	    if (!destLp) return { ok: false, error: 'persistence_failed' };
  1066	
  1067	    await ctx.client.query(
  1068	      `insert into public.lp_genealogy (org_id, child_lp_id, parent_lp_id, relation_type, qty, uom)
  1069	       values (app.current_org_id(), $1::uuid, $2::uuid, 'derived', $3::numeric, $4)
  1070	       on conflict (org_id, child_lp_id, parent_lp_id, relation_type) do nothing`,
  1071	      [destLp.id, row.source_lp_id, row.qty, row.uom],
  1072	    );
  1073	
  1074	    await ctx.client.query(
  1075	      `insert into public.lp_state_history
  1076	         (org_id, lp_id, from_state, to_state, reason_code, reason_text, transaction_id, ext_jsonb, created_by)
  1077	       values (app.current_org_id(), $1::uuid, null, 'available', 'transfer_receive',
  1078	               $2, $3::uuid, jsonb_build_object('to_id', $4::uuid, 'source_lp_id', $5::uuid), $6::uuid)
  1079	       on conflict (org_id, transaction_id) do nothing`,
  1080	      [destLp.id, `TO receive ${to.to_number}`, randomUUID(), to.id, row.source_lp_id, ctx.userId],
  1081	    );
  1082	    const moveTxn = randomUUID();
  1083	    await ctx.client.query(
  1084	      `insert into public.stock_moves
  1085	         (org_id, move_number, lp_id, move_type, from_location_id, to_location_id,
  1086	          quantity, uom, reason_text, transaction_id, created_by, updated_by)
  1087	       values (app.current_org_id(), $1, $2::uuid, 'transfer', null, $3::uuid,
  1088	               $4::numeric, $5, $6, $7::uuid, $8::uuid, $8::uuid)
  1089	       on conflict (org_id, transaction_id) do nothing`,
  1090	      [makeStockMoveNumber(moveTxn), destLp.id, destLocationId, row.qty, row.uom, `TO receive ${to.to_number}`, moveTxn, ctx.userId],
  1091	    );
  1092	    await ctx.client.query(
  1093	      `update public.transfer_order_line_lps
  1094	          set dest_lp_id = $2::uuid,
  1095	              updated_by = $3::uuid
  1096	        where org_id = app.current_org_id()
  1097	          and id = $1::uuid`,
  1098	      [row.id, destLp.id, ctx.userId],
  1099	    );
  1100	  }
  1101	
  1102	  return { ok: true, lpCount: pending.rows.length };
  1103	}
  1104	
  1105	/**
  1106	 * CANCEL while in transit — reverse the ship for rows that have not been
  1107	 * received yet: restore each source LP's quantity (un-deplete 'shipped' →
  1108	 * 'available') and drop the un-received linkage rows. Received destination LPs
  1109	 * must be handled by reverseToReceiveLine before the final cancel path is used.
  1110	 */
  1111	async function cancelInTransitTransferOrder(
  1112	  ctx: OrgActionContext,
  1113	  to: ToHeaderForUpdate,
  1114	): Promise<{ ok: true }> {
  1115	  const pending = await ctx.client.query<{ id: string; source_lp_id: string; qty: string; lp_quantity: string; lp_status: string }>(
  1116	    `select tll.id, tll.source_lp_id, tll.qty::text as qty,
  1117	            lp.quantity::text as lp_quantity, lp.status as lp_status
  1118	       from public.transfer_order_line_lps tll
  1119	       join public.license_plates lp
  1120	         on lp.org_id = app.current_org_id()
  1121	        and lp.id = tll.source_lp_id
  1122	      where tll.org_id = app.current_org_id()
  1123	        and tll.to_id = $1::uuid
  1124	        and tll.dest_lp_id is null
  1125	      order by tll.created_at asc, tll.id asc
  1126	      for update`,
  1127	    [to.id],
  1128	  );
  1129	
  1130	  for (const row of pending.rows) {
  1131	    const restored = microToText6(toMicro6(row.lp_quantity) + toMicro6(row.qty));
  1132	    const unDeplete = row.lp_status === 'shipped';
  1133	    await ctx.client.query(
  1134	      `update public.license_plates
  1135	          set quantity = $2::numeric,
  1136	              status = case when $3::boolean then 'available' else status end,
  1137	              updated_by = $4::uuid,
  1138	              updated_at = now()
