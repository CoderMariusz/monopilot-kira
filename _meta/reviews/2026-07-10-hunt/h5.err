   105	-- (B) scheduler_assignments (T-002, §9.3) — draft/approved/rejected/overridden WO assignments.
   106	--     run_id FK ON DELETE CASCADE; wo_id HARD FK to 04-planning work_orders.
   107	-- ===========================================================================
   108	create table if not exists public.scheduler_assignments (
   109	  id                          uuid primary key default gen_random_uuid(),
   110	  org_id                      uuid not null references public.organizations(id) on delete cascade,
   111	  site_id                     uuid,                                  -- site_id day-1
   112	
   113	  run_id                      uuid not null references public.scheduler_runs(run_id) on delete cascade,
   114	  wo_id                       uuid not null references public.work_orders(id) on delete cascade,
   115	  line_id                     text,                                  -- soft FK to 02-settings production_lines
   116	
   117	  status                      text not null default 'draft',
   118	  sequence_index              numeric(10, 2),
   119	  planned_start_at            timestamptz,
   120	  planned_end_at              timestamptz,
   121	  changeover_minutes          numeric(10, 2),
   122	  optimizer_score             numeric(10, 2),
   123	
   124	  override_original_line_id   text,
   125	  override_original_start_at  timestamptz,
   126	  override_reason_code        text,
   127	  override_by                 uuid references public.users(id) on delete set null,
   128	  override_at                 timestamptz,
   129	
   130	  approved_by                 uuid references public.users(id) on delete set null,
   131	  approved_at                 timestamptz,
   132	
   133	  ext                         jsonb not null default '{}'::jsonb,
   134	
   135	  created_at                  timestamptz not null default pg_catalog.now(),
   136	  updated_at                  timestamptz not null default pg_catalog.now(),
   137	
   138	  constraint scheduler_assignments_status_check check (
   139	    status in ('draft', 'approved', 'rejected', 'overridden')
   140	  ),
   141	  constraint scheduler_assignments_changeover_nonneg_check check (
   142	    changeover_minutes is null or changeover_minutes >= 0
   143	  ),
   144	  constraint scheduler_assignments_time_order_check check (
   145	    planned_end_at is null or planned_start_at is null or planned_start_at <= planned_end_at
   146	  )
   147	);
   148	
   149	create index if not exists idx_scheduler_assignments_run    on public.scheduler_assignments (run_id);
   150	create index if not exists idx_scheduler_assignments_wo     on public.scheduler_assignments (wo_id);
   151	create index if not exists idx_scheduler_assignments_status on public.scheduler_assignments (org_id, status);
   152	create index if not exists idx_scheduler_assignments_time   on public.scheduler_assignments (org_id, planned_start_at);
   153	create index if not exists idx_scheduler_assignments_override_by
   154	  on public.scheduler_assignments (override_by) where override_by is not null;
   155	create index if not exists idx_scheduler_assignments_approved_by
   156	  on public.scheduler_assignments (approved_by) where approved_by is not null;
   157	
   158	alter table public.scheduler_assignments enable row level security;
   159	alter table public.scheduler_assignments force row level security;
   160	drop policy if exists scheduler_assignments_org_context on public.scheduler_assignments;
   161	create policy scheduler_assignments_org_context on public.scheduler_assignments
   162	  for all to app_user
   163	  using (org_id = app.current_org_id())
   164	  with check (org_id = app.current_org_id());
   165	revoke all on public.scheduler_assignments from public;
   166	revoke all on public.scheduler_assignments from app_user;
   167	grant select, insert, update, delete on public.scheduler_assignments to app_user;
   168	
   169	drop trigger if exists scheduler_assignments_set_updated_at on public.scheduler_assignments;
   170	create trigger scheduler_assignments_set_updated_at
   171	  before update on public.scheduler_assignments
   172	  for each row execute function public.planning_ext_set_updated_at();
   173	
   174	-- ===========================================================================
   175	-- (C) changeover_matrix_versions + changeover_matrix (T-003, §9.4, §6 D5).
   176	--     The EXTERNAL changeover contract 08-production consumes (planned lookup), distinct from
   177	--     08's runtime changeover_events (recorded window, mig 184).
   178	-- ===========================================================================
   179	create table if not exists public.changeover_matrix_versions (
   180	  id             uuid primary key default gen_random_uuid(),
   181	  org_id         uuid not null references public.organizations(id) on delete cascade,
   182	  site_id        uuid,                                               -- site_id day-1
   183	
   184	  version_number integer not null,
   185	  label          text,
   186	  is_active      boolean not null default false,
   187	  status         text not null default 'draft',
   188	
   189	  published_by   uuid references public.users(id) on delete set null,
   190	  published_at   timestamptz,
   191	
   192	  created_by     uuid references public.users(id) on delete set null,
   193	  created_at     timestamptz not null default pg_catalog.now(),
   194	  updated_at     timestamptz not null default pg_catalog.now(),
   195	
   196	  constraint changeover_matrix_versions_org_version_unique unique (org_id, version_number),
   197	  constraint changeover_matrix_versions_status_check check (
   198	    status in ('draft', 'pending_review', 'active', 'archived')
   199	  ),
   200	  constraint changeover_matrix_versions_version_positive_check check (version_number >= 1)
   201	);
   202	
   203	-- D5: only ONE active version per org (partial unique on is_active=true).
   204	create unique index if not exists idx_changeover_active_per_org
   205	  on public.changeover_matrix_versions (org_id) where is_active = true;
   206	create index if not exists idx_changeover_matrix_versions_org
   207	  on public.changeover_matrix_versions (org_id);
   208	
   209	alter table public.changeover_matrix_versions enable row level security;
   210	alter table public.changeover_matrix_versions force row level security;
   211	drop policy if exists changeover_matrix_versions_org_context on public.changeover_matrix_versions;
   212	create policy changeover_matrix_versions_org_context on public.changeover_matrix_versions
   213	  for all to app_user
   214	  using (org_id = app.current_org_id())
   215	  with check (org_id = app.current_org_id());
   216	revoke all on public.changeover_matrix_versions from public;
   217	revoke all on public.changeover_matrix_versions from app_user;
   218	grant select, insert, update, delete on public.changeover_matrix_versions to app_user;
   219	
   220	drop trigger if exists changeover_matrix_versions_set_updated_at on public.changeover_matrix_versions;
   221	create trigger changeover_matrix_versions_set_updated_at
   222	  before update on public.changeover_matrix_versions
   223	  for each row execute function public.planning_ext_set_updated_at();
   224	
   225	create table if not exists public.changeover_matrix (
   226	  id                 uuid primary key default gen_random_uuid(),
   227	  org_id             uuid not null references public.organizations(id) on delete cascade,
   228	  site_id            uuid,                                           -- site_id day-1
   229	
   230	  version_id         uuid not null references public.changeover_matrix_versions(id) on delete cascade,
   231	  line_id            text,                                           -- D5: NULL = org default; non-NULL = per-line override
   232	  allergen_from      text not null,
   233	  allergen_to        text not null,
   234	  changeover_minutes numeric(10, 2) not null,
   235	  requires_cleaning  boolean not null default false,
   236	  requires_atp       boolean not null default false,
   237	  risk_level         text not null default 'low',
   238	  notes              text,
   239	
   240	  created_at         timestamptz not null default pg_catalog.now(),
   241	  updated_at         timestamptz not null default pg_catalog.now(),
   242	
   243	  -- NULL line_id (default) + a specific line_id (override) coexist for the same pair+version
   244	  -- because NULLs are distinct in a UNIQUE constraint.
   245	  constraint changeover_matrix_pair_unique unique (org_id, version_id, line_id, allergen_from, allergen_to),
   246	  constraint changeover_matrix_risk_level_check check (
   247	    risk_level in ('low', 'medium', 'high', 'segregated')
   248	  ),
   249	  constraint changeover_matrix_changeover_nonneg_check check (changeover_minutes >= 0)
   250	);

