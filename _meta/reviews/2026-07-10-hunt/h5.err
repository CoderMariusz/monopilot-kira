   692	export async function runScheduler(input?: { lineId?: string; horizonDays?: number }): Promise<SchedulerRunResult> {
   693	  const lineId = input?.lineId?.trim() || null;
   694	  if (lineId !== null && !isUuid(lineId)) return { ok: false, error: 'invalid_input' };
   695	
   696	  try {
   697	    return await withOrgContext(async (ctx: OrgActionContext): Promise<SchedulerRunResult> => {
   698	      if (!(await hasPermission(ctx, SCHEDULER_RUN_DISPATCH_PERMISSION))) {
   699	        return { ok: false, error: 'forbidden' };
   700	      }
   701	
   702	      const schedulerConfigs =
   703	        lineId === null ? await loadAllSchedulerConfigs(ctx) : [await loadSchedulerConfig(ctx, lineId)];
   704	      const schedulerConfig =
   705	        lineId === null
   706	          ? (schedulerConfigs.find((row) => row?.line_id === null) ?? null)
   707	          : (schedulerConfigs[0] ?? null);
   708	      const horizonDays = Math.trunc(
   709	        input?.horizonDays ?? schedulerConfig?.default_horizon_days ?? 7,
   710	      );
   711	      if (horizonDays < 1 || horizonDays > 30) return { ok: false, error: 'invalid_input' };
   712	
   713	      const started = Date.now();
   714	      const [workOrders, matrix] = await Promise.all([
   715	        loadOpenWorkOrders(ctx, lineId, horizonDays),
   716	        loadChangeoverMatrixForRun(ctx, lineId),
   717	      ]);
   718	      const baseSolverConfig = solverConfigFromRow(schedulerConfig);
   719	      const solverConfig: SequenceSolverConfig =
   720	        schedulerConfig?.respect_pm_windows === true
   721	          ? {
   722	              ...baseSolverConfig,
   723	              pmWindows: await loadPmWindows(
   724	                ctx,
   725	                lineId,
   726	                horizonDays,
   727	                pmBlockHoursFromConfigParams(schedulerConfig.params),
   728	              ),
   729	            }
   730	          : baseSolverConfig;
   731	      if (lineId === null && schedulerConfigs.length > 0) {
   732	        solverConfig.capacityHoursPerDayByLine = capacityHoursByLineFromConfigs(
   733	          schedulerConfigs.filter((row): row is SchedulerConfigRow => row !== null),
   734	        );
   735	      }
   736	      const sequenced = sequenceWorkOrders(workOrders, matrix, solverConfig);
   737	      const solveDurationMs = Date.now() - started;
   738	      const run = await insertSchedulerRun(ctx, {
   739	        lineId,
   740	        horizonDays,
   741	        workOrderCount: workOrders.length,
   742	        assignmentCount: sequenced.length,
   743	        totalChangeoverCost: totalChangeover(sequenced),
   744	        solveDurationMs,
   745	      });
   746	      const assignments = await insertSchedulerAssignments(ctx, run.run_id, lineId, sequenced);
   747	      await emitSchedulerRunCompletedEvent(ctx, run.run_id, {
   748	        work_orders: workOrders.length,
   749	        assignments: assignments.length,
   750	        total_changeover_cost: totalChangeover(sequenced),
   751	      });
   752	      return { ok: true, run, assignments };
   753	    });
   754	  } catch (error) {
   755	    console.error('[scheduler/runScheduler] persistence_failed', error);
   756	    return { ok: false, error: 'persistence_failed' };
   757	  }
   758	}
   759	
   760	export async function applySchedule(runId: string): Promise<ApplyScheduleResult> {
   761	  if (!isUuid(runId)) return { ok: false, error: 'invalid_input' };
   762	
   763	  try {
   764	    return await withOrgContext(async (ctx: OrgActionContext): Promise<ApplyScheduleResult> => {
   765	      if (!(await hasPermission(ctx, SCHEDULER_ASSIGNMENT_APPROVE_PERMISSION))) {
   766	        return { ok: false, error: 'forbidden' };
   767	      }
   768	
   769	      const run = await loadRun(ctx, runId, true);
   770	      if (!run) return { ok: false, error: 'not_found' };
   771	
   772	      if (run.requested_by && run.requested_by === ctx.userId) {
   773	        return { ok: false, error: 'sod_violation' };
   774	      }
   775	
   776	      const assignments = await loadAssignments(ctx, runId);
   777	      if (wasApplied(run)) return { ok: true, run, assignments, applied: false, stale: [] };
   778	      const appliedAssignments: SchedulerAssignment[] = [];
   779	      const staleAssignments: SchedulerAssignment[] = [];
   780	      for (const assignment of assignments) {
   781	        const applied = await applyAssignmentToWorkOrder(ctx, runId, assignment);
   782	        if (!applied) {
   783	          staleAssignments.push(assignment);
   784	          continue;
   785	        }
   786	        const approved = await approveSchedulerAssignment(ctx, assignment);
   787	        if (!approved) {
   788	          throw new Error(`scheduler assignment ${assignment.id} could not be approved after WO apply`);
   789	        }
   790	        appliedAssignments.push(approved);
   791	      }
   792	
   793	      const appliedRun = await markRunApplied(ctx, runId, appliedAssignments.length);
   794	      await emitSchedulePublishedEvent(ctx, runId, {
   795	        applied: appliedAssignments.length,
   796	        stale: staleAssignments.length,
   797	      });
   798	      return {
   799	        ok: true,
   800	        run: appliedRun,
   801	        assignments: [...appliedAssignments, ...staleAssignments],
   802	        applied: appliedAssignments,
   803	        stale: staleAssignments,
   804	      };
   805	    });
   806	  } catch (error) {
   807	    console.error('[scheduler/applySchedule] persistence_failed', error);
   808	    return { ok: false, error: 'persistence_failed' };
   809	  }
   810	}
