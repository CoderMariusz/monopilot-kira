   528	async function approveSchedulerAssignment(
   529	  ctx: OrgActionContext,
   530	  assignment: SchedulerAssignment,
   531	): Promise<SchedulerAssignment | null> {
   532	  const { rows } = await ctx.client.query<SchedulerAssignment>(
   533	    `update public.scheduler_assignments
   534	        set approved_by = $2::uuid,
   535	            approved_at = now(),
   536	            status = 'approved',
   537	            updated_at = now()
   538	      where org_id = app.current_org_id()
   539	        and id = $1::uuid
   540	        and status not in ('rejected', 'cancelled')
   541	      returning ${ASSIGNMENT_SELECT}`,
   542	    [assignment.id, ctx.userId],
   543	  );
   544	  return rows[0] ?? null;
   545	}
