   181	  );
   182	  const spec = approvedSpec.rows[0];
   183	
   184	  async function insertWorkOrderHeader(documentNumber: string) {
   185	    return ctx.client.query<WorkOrderRow>(
   186	      `insert into public.work_orders
   187	         (id, org_id, wo_number, product_id, item_type_at_creation, active_bom_header_id,
   188	          active_factory_spec_id,
   189	          planned_quantity, uom, status, scheduled_start_time, production_line_id,
