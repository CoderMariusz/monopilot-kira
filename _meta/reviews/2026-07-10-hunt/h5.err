   522	          correction_reason_code: input.reasonCode,
   523	        },
   524	      });
   525	
   526	      await ctx.client.query(
   527	        `update public.license_plates
   528	            set quantity = quantity + $2::numeric,
   529	                status = CASE WHEN status = 'shipped' THEN 'available' ELSE status END,
   530	                updated_by = $3::uuid,
   531	                updated_at = now()
   532	          where org_id = app.current_org_id()
   533	            and id = $1::uuid`,
   534	        [link.source_lp_id, reversedQty, userId],
   535	      );
   536	
   537	      if (link.source_status === 'shipped') {
   538	        await writeLpHistory(ctx, {
   539	          siteId: link.source_site_id,
   540	          lpId: link.source_lp_id,
   541	          fromState: 'shipped',
   542	          toState: 'available',
   543	          reasonText,
   544	          transactionId: sourceHistoryTxn,
   545	          ext: {
   546	            transfer_order_id: link.to_id,
   547	            transfer_order_line_id: link.line_id,
   548	            transfer_order_line_lp_id: link.link_id,
   549	            dest_lp_id: link.dest_lp_id,
   550	            reversed_qty: reversedQty,
   551	            correction_reason_code: input.reasonCode,
   552	          },
   553	        });
   554	      }
   555	
   556	      await writeStockMove(ctx, {
   557	        siteId: link.dest_site_id,
   558	        lpId: link.dest_lp_id,
   559	        fromLocationId: link.dest_location_id,
   560	        toLocationId: null,
   561	        quantity: microToDecimal(-reversedMicro),
   562	        uom: link.line_uom,
   563	        reasonText,
   564	        transactionId: destMoveTxn,
   565	        ext: {
   566	          correction_action: 'transfer_receive_reversed',
   567	          transfer_order_id: link.to_id,
   568	          transfer_order_line_lp_id: link.link_id,
   569	          direction: 'dest_lp_void',
   570	        },
   571	      });
   572	
   573	      await writeStockMove(ctx, {
   574	        siteId: link.source_site_id,
   575	        lpId: link.source_lp_id,
   576	        fromLocationId: null,
   577	        toLocationId: link.source_location_id,
   578	        quantity: reversedQty,
   579	        uom: link.line_uom,
   580	        reasonText,
   581	        transactionId: sourceMoveTxn,
   582	        ext: {
   583	          correction_action: 'transfer_receive_reversed',
   584	          transfer_order_id: link.to_id,
   585	          transfer_order_line_lp_id: link.link_id,
   586	          direction: 'source_lp_credit',
   587	        },
   588	      });
   589	
   590	      await ctx.client.query(
   591	        `update public.transfer_order_line_lps
   592	            set dest_lp_id = null,
   593	                updated_by = $2::uuid
   594	          where org_id = app.current_org_id()
   595	            and id = $1::uuid`,
   596	        [link.link_id, userId],
   597	      );
   598	
   599	      const nextStatus = await rerollTransferOrderStatus(ctx, link.to_id);
   600	      await writeReversalAudit(ctx, {
   601	        link,
   602	        reasonCode: input.reasonCode,
   603	        note,
   604	        reversedQty,
   605	        nextStatus,
   606	      });
   607	      await emitReversalEvent(ctx, { link, reasonCode: input.reasonCode, reversedQty });
   608	
   609	      return {
   610	        ok: true,
   611	        data: {
   612	          transferOrderId: link.to_id,
   613	          lineId: link.line_id,
   614	          sourceLpId: link.source_lp_id,
   615	          destinationLpId: link.dest_lp_id,
   616	          reversedQty,
   617	          status: nextStatus,
   618	        },
   619	      };
   620	    });
   621	
   622	    if (result.ok) {
   623	      revalidateLocalized('/planning/transfer-orders');
   624	      revalidateLocalized(`/planning/transfer-orders/${result.data.transferOrderId}`);
   625	      revalidateLocalized('/warehouse/license-plates');
   626	    }
   627	
   628	    return result;
   629	  } catch (error) {
   630	    const code = (error as { code?: string }).code;
   631	    if (code === '23514' || code === '23503' || code === '22P02') return { ok: false, error: 'invalid_input' };
   632	    console.error('[planning/transfer-orders] reverseToReceiveLine failed', error);
   633	    return { ok: false, error: 'persistence_failed' };
   634	  }
