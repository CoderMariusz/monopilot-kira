     3	import { DEFAULT_SEQUENCE_SOLVER_CONFIG, sequenceWorkOrders } from '../sequence-solver';
     4	import { ATP_STEP_MINUTES, CLEANING_STEP_MINUTES } from '../changeover-matrix-lookup';
     5	import type { ChangeoverMatrixEntry, WorkOrderForScheduling } from '../scheduler-types';
     6	
     7	const ORG_ID = '11111111-1111-4111-8111-111111111111';
     8	const LINE_ID = '22222222-2222-4222-8222-222222222222';
     9	
    10	function wo(input: {
    11	  id: string;
    12	  due: string;
    13	  allergens: string[];
    14	  scheduledStart?: string;
    15	  scheduledEnd?: string;
    16	  lineId?: string;
    17	  routingDurationMs?: number | string | null;
    18	  processDurationMs?: number | string | null;
    19	}): WorkOrderForScheduling {
    20	  return {
    21	    id: input.id,
    22	    org_id: ORG_ID,
    23	    site_id: null,
    24	    wo_number: `WO-${input.id.slice(0, 4)}`,
    25	    product_id: '33333333-3333-4333-8333-333333333333',
    26	    item_code: 'FG-001',
    27	    item_name: 'Finished Good',
    28	    status: 'DRAFT',
    29	    planned_quantity: '100.000',
    30	    uom: 'kg',
    31	    production_line_id: input.lineId ?? LINE_ID,
    32	    planned_start_date: input.scheduledStart ?? null,
    33	    planned_end_date: input.scheduledEnd ?? input.due,
    34	    scheduled_start_time: input.scheduledStart ?? null,
    35	    scheduled_end_time: input.scheduledEnd ?? null,
    36	    due_date: input.due,
    37	    allergen_ids: input.allergens,
    38	    routing_duration_ms: input.routingDurationMs ?? null,
    39	    process_duration_ms: input.processDurationMs ?? null,
    40	  };
    41	}
    42	
    43	function matrix(
    44	  from: string,
    45	  to: string,
    46	  minutes: number,
    47	  over: Partial<ChangeoverMatrixEntry> = {},
    48	): ChangeoverMatrixEntry {
    49	  return {
    50	    id: `${from || 'none'}-${to || 'none'}`,
    51	    org_id: ORG_ID,
    52	    site_id: null,
    53	    version_id: '44444444-4444-4444-8444-444444444444',
    54	    line_id: null,
    55	    allergen_from: from,
    56	    allergen_to: to,
    57	    changeover_minutes: minutes,
    58	    requires_cleaning: minutes > 0,
    59	    requires_atp: false,
    60	    risk_level: 'low',
    61	    notes: null,
    62	    created_at: '2026-06-01T00:00:00.000Z',
    63	    updated_at: '2026-06-01T00:00:00.000Z',
    64	    ...over,
    65	  };
    66	}
    67	
    68	function naiveDueDateTotal(wos: WorkOrderForScheduling[], entries: ChangeoverMatrixEntry[]): number {
    69	  const ordered = [...wos].sort((a, b) => new Date(a.due_date).getTime() - new Date(b.due_date).getTime());
    70	  let total = 0;
    71	  for (let index = 1; index < ordered.length; index += 1) {
    72	    const from = [...ordered[index - 1].allergen_ids].sort();
    73	    const to = [...ordered[index].allergen_ids].sort();
    74	    let step = 0;
    75	    for (const fromCode of from) {
    76	      for (const toCode of to) {
    77	        const hit = entries.find((entry) => entry.allergen_from === fromCode && entry.allergen_to === toCode);
    78	        if (hit) step = Math.max(step, Number(hit.changeover_minutes));
    79	      }
    80	    }
    81	    total += step;
    82	  }
    83	  return total;
    84	}
