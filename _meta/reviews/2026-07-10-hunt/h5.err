   377	export async function consumeTransferReceiveReversalEvent(
   378	  event: TransferReceiveReversalEvent,
   379	): Promise<{ ok: true; handled: boolean }> {
   380	  if (
   381	    event.eventType !== TRANSFER_RECEIVE_REVERSED_EVENT ||
   382	    event.aggregateType !== 'license_plate' ||
   383	    event.payload.correction_action !== 'transfer_receive_reversed'
   384	  ) {
   385	    return { ok: true, handled: false };
   386	  }
   387	
   388	  return { ok: true, handled: true };
   389	}
   390	
   391	/**
   392	 * R4-CL1 — Server-side probe for the TO-detail UI: does the caller hold the
   393	 * `warehouse.transfer.correct` permission? Used to gate the "Reverse receipt"
   394	 * affordance. RBAC stays server-authored — the client never trusts its own check.
   395	 */
   396	export async function canReverseTransferReceipt(): Promise<boolean> {
   397	  try {
   398	    return await withOrgContext(async ({ userId, orgId, client }) => {
   399	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   400	      return hasPermission(ctx, TRANSFER_RECEIVE_REVERSE_PERMISSION);
   401	    });
   402	  } catch (error) {
   403	    console.error('[planning/transfer-orders] canReverseTransferReceipt failed', error);
   404	    return false;
   405	  }
   406	}
