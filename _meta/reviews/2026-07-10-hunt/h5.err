   710	export async function deleteTransferOrderLine(id: string, lineId: string): Promise<TransferOrderResult<TransferOrderDetail>> {
   711	  const parsed = DeleteTransferOrderLineInput.safeParse({ toId: id, lineId });
   712	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   713	  const input = parsed.data;
   714	
   715	  try {
   716	    return await withOrgContext(async ({ userId, orgId, client }): Promise<TransferOrderResult<TransferOrderDetail>> => {
   717	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   718	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   719	
   720	      const header = await fetchDraftTransferOrderForUpdate(ctx.client, input.toId);
   721	      if (!header) return { ok: false, error: 'not_found' };
   722	      if (header.status !== 'draft') return { ok: false, error: 'invalid_state' };
   723	
   724	      const lines = await ctx.client.query<{ id: string }>(
   725	        `select id
   726	           from public.transfer_order_lines
   727	          where org_id = app.current_org_id()
   728	            and to_id = $1::uuid
   729	          order by line_no asc, id asc
   730	          for update`,
   731	        [input.toId],
   732	      );
   733	      if (!lines.rows.some((line) => line.id === input.lineId)) return { ok: false, error: 'not_found' };
   734	      if (lines.rows.length <= 1) return { ok: false, error: 'last_line', code: 'last_line' };
   735	
   736	      const deleted = await ctx.client.query(
   737	        `delete from public.transfer_order_lines l
   738	          using public.transfer_orders t
   739	          where l.org_id = app.current_org_id()
   740	            and t.org_id = app.current_org_id()
   741	            and t.id = l.to_id
   742	            and t.id = $1::uuid
   743	            and t.status = 'draft'
   744	            and l.id = $2::uuid`,
   745	        [input.toId, input.lineId],
   746	      );
   747	      if ((deleted.rowCount ?? 0) === 0) return { ok: false, error: 'invalid_state' };
   748	      await denseRenumberTransferOrderLines(ctx.client, input.toId);
   749	
   750	      await writeProcurementAudit(ctx, {
   751	        action: 'planning.transfer_order.line_deleted',
   752	        resourceType: 'transfer_order',
   753	        resourceId: input.toId,
   754	        beforeState: { lineId: input.lineId },
   755	      });
   756	      revalidateTransferOrderPaths(input.toId);
   757	      return { ok: true, data: { ...mapTransferOrder(header), lines: await fetchLines(ctx.client, input.toId) } };
   758	    });
   759	  } catch (err) {
   760	    const error = pgErrorToResult(err);
   761	    if (error !== 'persistence_failed') return { ok: false, error };
   762	    console.error('[planning/transfer-orders] deleteTransferOrderLine failed', err);
   763	    return { ok: false, error };
   764	  }
   765	}
   766	
   767	// Server-side state machine for TO status. Terminal states (received, cancelled)
   768	// have no legal successors. Re-validated server-side so a forged/stale request
   769	// can never apply an illegal jump.
   770	const TO_TRANSITIONS: Record<string, readonly string[]> = {
   771	  draft: ['in_transit', 'cancelled'],
   772	  in_transit: ['received', 'cancelled'],
   773	  partially_received: ['received', 'cancelled'],
   774	  received: [],
   775	  cancelled: [],
   776	};
   777	
   778	// ─── NUMERIC-exact decimal helpers (scale 6 — license_plates quantity) ─────────
   779	// LP quantities never round-trip through a JS float: text in, bigint micro-units
   780	// for arithmetic, text out.
   781	const QTY_SCALE = 1_000_000n;
   782	
   783	function toMicro6(decimal: string): bigint {
   784	  const neg = decimal.startsWith('-');
   785	  const body = neg ? decimal.slice(1) : decimal;
   786	  const [intPart, fracRaw = ''] = body.split('.');
   787	  const frac = (fracRaw + '000000').slice(0, 6);
   788	  const micro = BigInt(intPart || '0') * QTY_SCALE + BigInt(frac || '0');
   789	  return neg ? -micro : micro;
   790	}
   791	
   792	function microToText6(micro: bigint): string {
   793	  const neg = micro < 0n;
   794	  const abs = neg ? -micro : micro;
   795	  const frac = (abs % QTY_SCALE).toString().padStart(6, '0').replace(/0+$/, '');
   796	  const out = frac ? `${abs / QTY_SCALE}.${frac}` : `${abs / QTY_SCALE}`;
   797	  return neg && abs !== 0n ? `-${out}` : out;
   798	}
   799	
   800	type ToHeaderForUpdate = {
   801	  id: string;
   802	  to_number: string;
   803	  status: string;
   804	  from_warehouse_id: string | null;
   805	  to_warehouse_id: string | null;
   806	};
   807	
   808	type SourceLpRow = {
   809	  id: string;
   810	  lp_number: string;
   811	  quantity: string;
   812	  reserved_qty: string;
   813	  location_id: string | null;
   814	};
   815	
   816	type SkippedHeldLp = { lpId: string; lpCode: string; qty: string; uom: string };
   817	
   818	type PlannedPick = {
   819	  lineId: string;
   820	  lineNo: number;
   821	  lpId: string;
   822	  lpLocationId: string | null;
   823	  takeMicro: bigint;
   824	  newQtyMicro: bigint;
   825	  uom: string;
   826	};
   827	
   828	/**
   829	 * SHIP (draft → in_transit) — W9-K-II / F-C05. Real stock leaves the source:
   830	 *   1. Validate FIRST, write after — sum of pickable stock (status 'available',
   831	 *      qa_status 'released', matching uom, available = quantity - reserved_qty)
   832	 *      at from_warehouse must cover every line, else 'insufficient_stock' and
   833	 *      NOTHING is written (withOrgContext commits even on ok:false returns).
   834	 *   2. Pick FEFO (expiry asc NULLS LAST, lp_number asc) with row locks.
   835	 *   3. Decrement each picked LP; full depletion → status 'shipped' (+ ledger row).
   836	 *   4. Record every pick in transfer_order_line_lps (source_lp_id + qty) — the
   837	 *      in-transit truth that receive() materializes at the destination.
   838	 *   5. stock_moves row per pick (move_type 'transfer', from = LP's location).
   839	 */
   840	async function shipTransferOrder(
   841	  ctx: OrgActionContext,
   842	  to: ToHeaderForUpdate,
   843	): Promise<{ ok: true; pickCount: number; skippedHeldLps: SkippedHeldLp[] } | { ok: false; error: ProcurementError; message?: string; heldQty?: string }> {
   844	  if (!to.from_warehouse_id) {
   845	    return { ok: false, error: 'invalid_state', message: 'from_warehouse_required' };
   846	  }
   847	
   848	  const lines = await ctx.client.query<{ id: string; item_id: string; qty: string; uom: string; line_no: number }>(
   849	    `select id, item_id, qty::text as qty, uom, line_no
   850	       from public.transfer_order_lines
   851	      where org_id = app.current_org_id()
   852	        and to_id = $1::uuid
   853	      order by line_no asc
   854	      for update`,
   855	    [to.id],
   856	  );
   857	  if (lines.rows.length === 0) {
   858	    return { ok: false, error: 'invalid_state', message: 'no_lines' };
   859	  }
   860	
   861	  // Phase 1 — plan all picks (locks the candidate LPs), no writes yet.
   862	  const picks: PlannedPick[] = [];
   863	  const skippedHeldLps: SkippedHeldLp[] = [];
   864	  for (const line of lines.rows) {
   865	    const lps = await ctx.client.query<SourceLpRow>(
   866	      `select lp.id, lp.lp_number, lp.quantity::text as quantity, lp.reserved_qty::text as reserved_qty, lp.location_id
   867	         from public.license_plates lp
   868	        where lp.org_id = app.current_org_id()
   869	          and lp.warehouse_id = $1::uuid
   870	          and lp.product_id = $2::uuid
   871	          and lp.uom = $3
   872	          and lp.status = 'available'
   873	          and lp.qa_status = 'released'
   874	          and (lp.quantity - lp.reserved_qty) > 0
   875	        order by lp.expiry_date asc nulls last, lp.lp_number asc
   876	        for update`,
   877	      [to.from_warehouse_id, line.item_id, line.uom],
   878	    );
   879	
   880	    let remaining = toMicro6(line.qty);
   881	    for (const lp of lps.rows) {
   882	      if (remaining <= 0n) break;
   883	      try {
   884	        await assertNoActiveHoldForLp(lp.id, ctx.client);
   885	      } catch (error) {
   886	        if (typeof error === 'object' && error !== null && (error as { code?: string }).code === 'QA_HOLD_ACTIVE') {
   887	          const availableHeld = toMicro6(lp.quantity) - toMicro6(lp.reserved_qty);
   888	          skippedHeldLps.push({ lpId: lp.id, lpCode: lp.lp_number, qty: microToText6(availableHeld), uom: line.uom });
   889	          continue;
   890	        }
   891	        throw error;
   892	      }
   893	      const availableMicro = toMicro6(lp.quantity) - toMicro6(lp.reserved_qty);
   894	      if (availableMicro <= 0n) continue;
   895	      const take = availableMicro < remaining ? availableMicro : remaining;
   896	      picks.push({
   897	        lineId: line.id,
   898	        lineNo: line.line_no,
   899	        lpId: lp.id,
   900	        lpLocationId: lp.location_id,
   901	        takeMicro: take,
   902	        newQtyMicro: toMicro6(lp.quantity) - take,
   903	        uom: line.uom,
   904	      });
   905	      remaining -= take;
   906	    }
   907	    if (remaining > 0n) {
   908	      return {
   909	        ok: false,
   910	        error: skippedHeldLps.length > 0 ? 'insufficient_stock_holds' : 'insufficient_stock',
   911	        message: `line ${line.line_no}: short by ${microToText6(remaining)} ${line.uom} at source warehouse`,
   912	        heldQty: skippedHeldLps.length > 0 ? microToText6(skippedHeldLps.reduce((acc, s) => acc + toMicro6(s.qty), 0n)) : undefined,
   913	      };
   914	    }
   915	  }
   916	
   917	  // Phase 2 — apply the plan (all-or-nothing inside the withOrgContext txn).
   918	  for (const pick of picks) {
   919	    const fullyDepleted = pick.newQtyMicro === 0n;
   920	    await ctx.client.query(
   921	      `update public.license_plates
   922	          set quantity = $2::numeric,
   923	              status = case when $3::boolean then 'shipped' else status end,
   924	              updated_by = $4::uuid,
   925	              updated_at = now()
   926	        where org_id = app.current_org_id()
   927	          and id = $1::uuid`,
   928	      [pick.lpId, microToText6(pick.newQtyMicro), fullyDepleted, ctx.userId],
   929	    );
   930	    if (fullyDepleted) {
   931	      await ctx.client.query(
   932	        `insert into public.lp_state_history
   933	           (org_id, lp_id, from_state, to_state, reason_code, reason_text, transaction_id, ext_jsonb, created_by)
   934	         values (app.current_org_id(), $1::uuid, 'available', 'shipped', 'transfer_ship',
   935	                 $2, $3::uuid, jsonb_build_object('to_id', $4::uuid), $5::uuid)
   936	         on conflict (org_id, transaction_id) do nothing`,
   937	        [pick.lpId, `TO ship ${to.to_number}`, randomUUID(), to.id, ctx.userId],
   938	      );
   939	    }
   940	    const moveTxn = randomUUID();
   941	    await ctx.client.query(
   942	      `insert into public.stock_moves
   943	         (org_id, move_number, lp_id, move_type, from_location_id, to_location_id,
   944	          quantity, uom, reason_text, transaction_id, created_by, updated_by)
   945	       values (app.current_org_id(), $1, $2::uuid, 'transfer', $3::uuid, null,
   946	               $4::numeric, $5, $6, $7::uuid, $8::uuid, $8::uuid)
   947	       on conflict (org_id, transaction_id) do nothing`,
   948	      [
   949	        makeStockMoveNumber(moveTxn),
   950	        pick.lpId,
   951	        pick.lpLocationId,
   952	        microToText6(pick.takeMicro),
   953	        pick.uom,
   954	        `TO ship ${to.to_number}`,
   955	        moveTxn,
   956	        ctx.userId,
   957	      ],
   958	    );
   959	    await ctx.client.query(
   960	      `insert into public.transfer_order_line_lps
   961	         (org_id, to_id, to_line_id, source_lp_id, qty, uom, created_by, updated_by)
   962	       values (app.current_org_id(), $1::uuid, $2::uuid, $3::uuid, $4::numeric, $5, $6::uuid, $6::uuid)`,
   963	      [to.id, pick.lineId, pick.lpId, microToText6(pick.takeMicro), pick.uom, ctx.userId],
   964	    );
   965	  }
   966	
   967	  return { ok: true, pickCount: picks.length, skippedHeldLps };
   968	}
   969	
   970	/**
   971	 * RECEIVE (in_transit → received) — W9-K-II / F-C05. Stock appears at the
   972	 * destination for real: every transfer_order_line_lps row (dest_lp_id null)
   973	 * materializes as a NEW destination LP at to_warehouse:
   974	 *   - origin 'transfer', parent_lp_id = source LP (genealogy chain across sites);
   975	 *   - batch/expiry/shelf-life snapshot carried over from the source LP;
   976	 *   - status 'available' + qa_status carried from the source: ship only picks
   977	 *     qa 'released' stock, and an internal transfer is not a new QA event, so
   978	 *     the goods stay released and pickable (NOT re-quarantined) — deliberate
   979	 *     contrast with GRN/production LPs which are born received/pending;
   980	 *   - location = destination warehouse's default (first by level, code);
   981	 *   - stock_moves 'transfer' row into that location + genesis ledger row.
   982	 */
   983	async function receiveTransferOrder(
   984	  ctx: OrgActionContext,
   985	  to: ToHeaderForUpdate,
   986	): Promise<{ ok: true; lpCount: number } | { ok: false; error: ProcurementError; message?: string }> {
   987	  if (!to.to_warehouse_id) {
   988	    return { ok: false, error: 'invalid_state', message: 'to_warehouse_required' };
   989	  }
   990	  const destLocationId = await resolveDefaultLocation(ctx.client, to.to_warehouse_id);
   991	  const destWarehouse = await ctx.client.query<{ site_id: string | null }>(
   992	    `select w.site_id::text as site_id
   993	       from public.warehouses w
   994	      where w.org_id = app.current_org_id()
   995	        and w.id = $1::uuid
   996	      limit 1`,
   997	    [to.to_warehouse_id],
   998	  );
   999	  const destSiteId = destWarehouse.rows[0]?.site_id ?? null;
  1000	
  1001	  const pending = await ctx.client.query<{
  1002	    id: string;
  1003	    source_lp_id: string;
  1004	    qty: string;
  1005	    uom: string;
  1006	    product_id: string;
  1007	    batch_number: string | null;
  1008	    supplier_batch_number: string | null;
  1009	    expiry_date: string | null;
  1010	    best_before_date: string | null;
  1011	    shelf_life_mode_snapshot: string | null;
  1012	    qa_status: string;
  1013	  }>(
  1014	    `select tll.id, tll.source_lp_id, tll.qty::text as qty, tll.uom,
  1015	            lp.product_id, lp.batch_number, lp.supplier_batch_number,
  1016	            lp.expiry_date, lp.best_before_date, lp.shelf_life_mode_snapshot, lp.qa_status
  1017	       from public.transfer_order_line_lps tll
  1018	       join public.license_plates lp
  1019	         on lp.org_id = app.current_org_id()
  1020	        and lp.id = tll.source_lp_id
  1021	      where tll.org_id = app.current_org_id()
  1022	        and tll.to_id = $1::uuid
  1023	        and tll.dest_lp_id is null
  1024	      order by tll.created_at asc, tll.id asc
  1025	      for update of tll`,
  1026	    [to.id],
  1027	  );
  1028	
  1029	  for (const row of pending.rows) {
  1030	    const lpNumber = makeLpNumber();
  1031	    const inserted = await ctx.client.query<{ id: string }>(
  1032	      `insert into public.license_plates (
  1033	         org_id, site_id, warehouse_id, location_id, lp_number, product_id, quantity, uom,
  1034	         status, qa_status, batch_number, supplier_batch_number,
  1035	         expiry_date, best_before_date, shelf_life_mode_snapshot,
  1036	         origin, parent_lp_id, ext_jsonb, created_by, updated_by
  1037	       )
  1038	       values (
  1039	         app.current_org_id(), $1::uuid, $2::uuid, $3::uuid, $4, $5::uuid, $6::numeric, $7,
  1040	         'available', $8, $9, $10,
  1041	         $11::timestamptz, $12::timestamptz, $13,
  1042	         'transfer', $14::uuid, jsonb_build_object('transfer_order_id', $15::uuid), $16::uuid, $16::uuid
  1043	       )
  1044	       returning id`,
  1045	      [
  1046	        destSiteId,
  1047	        to.to_warehouse_id,
  1048	        destLocationId,
  1049	        lpNumber,
  1050	        row.product_id,
  1051	        row.qty,
  1052	        row.uom,
  1053	        row.qa_status,
  1054	        row.batch_number,
  1055	        row.supplier_batch_number,
  1056	        row.expiry_date,
  1057	        row.best_before_date,
  1058	        row.shelf_life_mode_snapshot,
  1059	        row.source_lp_id,
  1060	        to.id,
  1061	        ctx.userId,
  1062	      ],
  1063	    );
  1064	    const destLp = inserted.rows[0];
  1065	    if (!destLp) return { ok: false, error: 'persistence_failed' };
  1066	
  1067	    await ctx.client.query(
  1068	      `insert into public.lp_genealogy (org_id, child_lp_id, parent_lp_id, relation_type, qty, uom)
  1069	       values (app.current_org_id(), $1::uuid, $2::uuid, 'derived', $3::numeric, $4)
  1070	       on conflict (org_id, child_lp_id, parent_lp_id, relation_type) do nothing`,
  1071	      [destLp.id, row.source_lp_id, row.qty, row.uom],
  1072	    );
  1073	
  1074	    await ctx.client.query(
  1075	      `insert into public.lp_state_history
  1076	         (org_id, lp_id, from_state, to_state, reason_code, reason_text, transaction_id, ext_jsonb, created_by)
  1077	       values (app.current_org_id(), $1::uuid, null, 'available', 'transfer_receive',
  1078	               $2, $3::uuid, jsonb_build_object('to_id', $4::uuid, 'source_lp_id', $5::uuid), $6::uuid)
  1079	       on conflict (org_id, transaction_id) do nothing`,
  1080	      [destLp.id, `TO receive ${to.to_number}`, randomUUID(), to.id, row.source_lp_id, ctx.userId],
  1081	    );
  1082	    const moveTxn = randomUUID();
  1083	    await ctx.client.query(
  1084	      `insert into public.stock_moves
  1085	         (org_id, move_number, lp_id, move_type, from_location_id, to_location_id,
  1086	          quantity, uom, reason_text, transaction_id, created_by, updated_by)
  1087	       values (app.current_org_id(), $1, $2::uuid, 'transfer', null, $3::uuid,
  1088	               $4::numeric, $5, $6, $7::uuid, $8::uuid, $8::uuid)
  1089	       on conflict (org_id, transaction_id) do nothing`,
  1090	      [makeStockMoveNumber(moveTxn), destLp.id, destLocationId, row.qty, row.uom, `TO receive ${to.to_number}`, moveTxn, ctx.userId],
  1091	    );
  1092	    await ctx.client.query(
  1093	      `update public.transfer_order_line_lps
  1094	          set dest_lp_id = $2::uuid,
  1095	              updated_by = $3::uuid
  1096	        where org_id = app.current_org_id()
  1097	          and id = $1::uuid`,
  1098	      [row.id, destLp.id, ctx.userId],
  1099	    );
  1100	  }
     1	-- Migration 283: transfer_order_line_lps — TO ship/receive LP linkage (W9-K-II, F-C05).
     2	--
     3	-- Before this migration, TO "receive" was a bare status flip (audit F-C05 HIGH):
     4	-- no stock left the source warehouse and none appeared at the destination —
     5	-- phantom stock from clicking. The smallest honest model the schema supports:
     6	--   * SHIP  (draft → in_transit): FEFO-pick available source LPs per line,
     7	--     decrement them (full depletion → status 'shipped'), and record WHAT was
     8	--     taken from WHICH LP here (source_lp_id + qty). Availability is validated
     9	--     server-side (reject qty > available at source).
    10	--   * RECEIVE (in_transit → received): for every row here, create a destination
    11	--     LP at to_warehouse (origin 'transfer', parent_lp_id = source LP for
    12	--     genealogy, batch/expiry carried over) and back-link dest_lp_id.
    13	--   * CANCEL (in_transit → cancelled): restore source LP quantities and delete
    14	--     the rows (no stranded in-transit stock).
    15	-- transfer_order_lines stays item+qty (no lp_id column) — one TO line can ship
    16	-- from MANY LPs, so the linkage is a junction, not a line column.
    17	--
    18	-- Wave0 lock: org_id is the business scope; RLS via app.current_org_id()
    19	-- (NEVER raw current_setting). FKs: transfer order tables (263) and
    20	-- license_plates (191) already exist — hard FKs are safe here.
    21	
    22	create table if not exists public.transfer_order_line_lps (
    23	  id            uuid primary key default gen_random_uuid(),
    24	  org_id        uuid not null references public.organizations(id) on delete cascade,
    25	  to_id         uuid not null references public.transfer_orders(id) on delete cascade,
    26	  to_line_id    uuid not null references public.transfer_order_lines(id) on delete cascade,
    27	
    28	  -- Source LP the shipped quantity was taken from (set at ship time).
    29	  source_lp_id  uuid not null references public.license_plates(id) on delete cascade,
    30	  -- Destination LP created at receive time (null while in transit).
    31	  dest_lp_id    uuid references public.license_plates(id) on delete set null,
    32	
    33	  qty           numeric(18, 6) not null,
    34	  uom           text not null,
    35	
    36	  created_by    uuid references public.users(id) on delete set null,
    37	  updated_by    uuid references public.users(id) on delete set null,
    38	  created_at    timestamptz not null default pg_catalog.now(),
    39	  updated_at    timestamptz not null default pg_catalog.now(),
    40	
    41	  -- One pick per (line, source LP): ship happens exactly once per TO (state
    42	  -- machine: draft → in_transit is the only entry), so this doubles as the
    43	  -- idempotency guard against double-allocation.
    44	  constraint transfer_order_line_lps_line_source_unique unique (org_id, to_line_id, source_lp_id),
    45	  constraint transfer_order_line_lps_qty_positive_check check (qty > 0)
    46	);
    47	
    48	create index if not exists transfer_order_line_lps_org_to_idx
    49	  on public.transfer_order_line_lps (org_id, to_id);
    50	create index if not exists transfer_order_line_lps_line_idx
    51	  on public.transfer_order_line_lps (org_id, to_line_id);
    52	create index if not exists transfer_order_line_lps_source_lp_idx
    53	  on public.transfer_order_line_lps (source_lp_id);
    54	create index if not exists transfer_order_line_lps_dest_lp_idx
    55	  on public.transfer_order_line_lps (dest_lp_id) where dest_lp_id is not null;
    56	
    57	alter table public.transfer_order_line_lps enable row level security;
    58	alter table public.transfer_order_line_lps force row level security;
    59	
    60	drop policy if exists transfer_order_line_lps_org_context on public.transfer_order_line_lps;
    61	create policy transfer_order_line_lps_org_context
    62	  on public.transfer_order_line_lps
    63	  for all
    64	  to app_user
    65	  using (org_id = app.current_org_id())
    66	  with check (org_id = app.current_org_id());
    67	
    68	revoke all on public.transfer_order_line_lps from public;
    69	revoke all on public.transfer_order_line_lps from app_user;
    70	grant select, insert, update, delete on public.transfer_order_line_lps to app_user;
    71	
    72	drop trigger if exists transfer_order_line_lps_set_updated_at on public.transfer_order_line_lps;
    73	create trigger transfer_order_line_lps_set_updated_at
    74	  before update on public.transfer_order_line_lps
    75	  for each row execute function public.planning_procurement_set_updated_at();
    76	
    77	comment on table public.transfer_order_line_lps is
    78	  'TO ship/receive LP linkage (W9-K-II, F-C05): which source LPs a TO line shipped from '
    79	  '(qty decremented at ship) and which destination LP was created at receive. '
    80	  'dest_lp_id null = in transit.';
     1	-- Migration 263: Planning procurement backbone — transfer orders.
     2	--
     3	-- Wave0 lock: org_id is the business scope; RLS uses app.current_org_id().
     4	-- Warehouse references are intentionally soft UUIDs: public.warehouses exists
     5	-- from migration 042, but planning keeps transfer suggestions loosely coupled to
     6	-- site/warehouse rollout ordering.
     7	
     8	create table if not exists public.transfer_orders (
     9	  id                uuid primary key default gen_random_uuid(),
    10	  org_id            uuid not null references public.organizations(id) on delete cascade,
    11	  to_number         text not null,
    12	  from_warehouse_id uuid,
    13	  to_warehouse_id   uuid,
    14	  status            text not null default 'draft',
    15	  scheduled_date    date,
    16	  notes             text,
    17	  created_by        uuid references public.users(id) on delete set null,
    18	  updated_by        uuid references public.users(id) on delete set null,
    19	  created_at        timestamptz not null default pg_catalog.now(),
    20	  updated_at        timestamptz not null default pg_catalog.now(),
    21	
    22	  constraint transfer_orders_org_to_number_unique unique (org_id, to_number),
    23	  constraint transfer_orders_status_check check (
