   502	): Promise<Array<{ parentWoId: string; childWoId: string; materialLink: string | null; requiredQty: string | null }>> {
   503	  const dependencies: Array<{ parentWoId: string; childWoId: string; materialLink: string | null; requiredQty: string | null }> = [];
   504	  for (const wipWorkOrder of wipWorkOrders) {
   505	    const material = fgMaterials.find((row) => row.productId === wipWorkOrder.productId) ?? null;
   506	    const { rows } = await ctx.client.query<{ parent_wo_id: string; child_wo_id: string; material_link: string | null; required_qty: string | null }>(
   507	      `insert into public.wo_dependencies
   508	         (org_id, parent_wo_id, child_wo_id, material_link, required_qty)
   509	       values
   510	         (app.current_org_id(), $1::uuid, $2::uuid, $3::uuid, $4::numeric)
   511	       on conflict (org_id, parent_wo_id, child_wo_id) do update
   512	         set material_link = coalesce(excluded.material_link, public.wo_dependencies.material_link),
   513	             required_qty = coalesce(excluded.required_qty, public.wo_dependencies.required_qty)
   514	       returning parent_wo_id::text as parent_wo_id,
   515	                 child_wo_id::text as child_wo_id,
   516	                 material_link::text as material_link,
   517	                 required_qty::text as required_qty`,
   518	      [
   519	        fgWorkOrder.id,
   520	        wipWorkOrder.id,
   521	        material?.id ?? null,
   522	        material?.requiredQty ?? null,
   523	      ],
   524	    );
   525	    const row = rows[0];
   526	    if (row) {
   527	      dependencies.push({
   528	        parentWoId: row.parent_wo_id,
   529	        childWoId: row.child_wo_id,
   530	        materialLink: row.material_link,
   531	        requiredQty: row.required_qty,
   532	      });
   533	    }
   534	  }
   535	  return dependencies;
   536	}
