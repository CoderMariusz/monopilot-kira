   391	async function insertSchedulerAssignments(
   392	  ctx: OrgActionContext,
   393	  runId: string,
   394	  lineId: string | null,
   395	  assignments: ReturnType<typeof sequenceWorkOrders>,
   396	): Promise<SchedulerAssignment[]> {
   397	  if (assignments.length === 0) return [];
   398	
   399	  const payload = assignments.map((assignment) => ({
   400	    site_id: assignment.work_order.site_id,
   401	    wo_id: assignment.wo_id,
   402	    line_id: lineId ?? assignment.line_id,
   403	    sequence_index: assignment.sequence_index,
   404	    planned_start_at: assignment.planned_start_at,
   405	    planned_end_at: assignment.planned_end_at,
   406	    changeover_minutes: assignment.changeover_cost,
   407	    optimizer_score: assignment.cumulative_changeover_cost,
   408	    ext: {
   409	      allergen_profile_key: assignment.allergen_profile_key,
   410	      cumulative_changeover_cost: assignment.cumulative_changeover_cost,
   411	    },
   412	  }));
   413	
   414	  const { rows } = await ctx.client.query<SchedulerAssignment>(
   415	    `insert into public.scheduler_assignments
   416	       (org_id, site_id, run_id, wo_id, line_id, status, sequence_index, planned_start_at,
   417	        planned_end_at, changeover_minutes, optimizer_score, ext)
   418	     select app.current_org_id(),
   419	            x.site_id::uuid,
   420	            $1::uuid,
   421	            x.wo_id::uuid,
   422	            x.line_id::text,
   423	            'draft',
   424	            x.sequence_index::numeric,
   425	            x.planned_start_at::timestamptz,
   426	            x.planned_end_at::timestamptz,
   427	            x.changeover_minutes::numeric,
   428	            x.optimizer_score::numeric,
   429	            x.ext::jsonb
   430	       from jsonb_to_recordset($2::jsonb) as x(
   431	            site_id text,
   432	            wo_id text,
   433	            line_id text,
   434	            sequence_index numeric,
   435	            planned_start_at text,
   436	            planned_end_at text,
   437	            changeover_minutes numeric,
   438	            optimizer_score numeric,
   439	            ext jsonb
   440	       )
   441	     returning ${ASSIGNMENT_SELECT}`,
   442	    [runId, JSON.stringify(payload)],
   443	  );
   444	  return rows;
   445	}
