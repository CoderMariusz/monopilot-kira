   378	      const inputsByWo = new Map<string, StationInput[]>();
   379	      for (const dep of depRows.rows) {
   380	        const list = inputsByWo.get(dep.parent_wo_id) ?? [];
   381	        list.push({
   382	          itemCode: dep.child_item_code ?? '—',
   383	          requiredQty: dep.required_qty,
   384	          producedQty: dep.produced_quantity,
   385	          upstreamWoNumber: dep.child_wo_number,
   386	          upstreamStatus: dep.child_status,
   387	          uom: dep.child_uom,
   388	        });
   389	        inputsByWo.set(dep.parent_wo_id, list);
   390	      }
   391	
   392	      const workOrders: StationWorkOrder[] = woRows.map((w) => ({
   393	        id: w.id,
   394	        woNumber: w.wo_number,
   395	        status: w.status,
   396	        itemCode: w.item_code,
   397	        itemName: w.name,
   398	        demandQty: w.planned_quantity,
   399	        producedQty: w.produced_quantity,
   400	        uom: w.uom,
   401	        scheduledStartTime: w.scheduled_start_time,
   402	        processes: processesByItem.get(w.product_id) ?? [],
   403	        inputs: inputsByWo.get(w.id) ?? [],
   404	      }));
   405	
   406	      return { ok: true, lineCode: line.code, lineName: line.name, workOrders };
   407	    });
   408	  } catch (error) {
   409	    console.error('[getStationQueue] persistence_failed', error);
   410	    return { ok: false, error: 'persistence_failed' };
   411	  }
   412	}
FILE apps/web/app/[locale]/(app)/(modules)/planning/work-orders/_actions/resolve-stage-production-line.ts
     1	import type { OrgActionContext } from './shared';
     2	
     3	type StageLineRow = {
     4	  item_id: string;
     5	  production_line_id: string | null;
     6	};
     7	
     8	/**
     9	 * Resolve production_line_id per chain stage item.
    10	 *
    11	 * Priority per item:
    12	 * 1. routing_operations.line_id — first op for WIP stages, last op for the FG root
    13	 * 2. npd_wip_processes.line_id via wip_item_id (ensureWipItem path) or wip_definitions.item_id
    14	 * 3. FG root only: npd_wip_processes.line_id via prod_detail.item_id (last op)
    15	 * 4. npd_projects.production_line_id for the FG product's project
    16	 */
    17	export async function loadStageProductionLineIds(
    18	  ctx: OrgActionContext,
    19	  fgItemId: string,
    20	  stageItemIds: Array<{ itemId: string; isFg: boolean }>,
    21	): Promise<Map<string, string | null>> {
    22	  const byItem = new Map<string, string | null>();
    23	  if (stageItemIds.length === 0) return byItem;
    24	
    25	  const itemIds = stageItemIds.map((stage) => stage.itemId);
    26	  const { rows } = await ctx.client.query<StageLineRow>(
    27	    `with stages as (
    28	       select s.item_id,
    29	              s.is_fg
    30	         from unnest($1::uuid[], $2::boolean[]) as s(item_id, is_fg)
    31	     )
    32	     select s.item_id::text as item_id,
    33	            coalesce(
    34	              routing_line.line_id,
    35	              wip_item_line.line_id,
    36	              wip_def_line.line_id,
    37	              fg_process_line.line_id,
    38	              project_line.production_line_id
    39	            )::text as production_line_id
    40	       from stages s
    41	       left join lateral (
    42	         select ro.line_id
    43	           from public.routings r
    44	           join public.routing_operations ro
    45	             on ro.routing_id = r.id
    46	            and ro.org_id = r.org_id
    47	          where r.org_id = app.current_org_id()
    48	            and r.item_id = s.item_id
    49	            and r.status in ('active', 'draft', 'approved')
    50	          order by case r.status when 'active' then 0 when 'approved' then 1 else 2 end,
    51	                   r.version desc,
    52	                   ro.op_no * case when s.is_fg then -1 else 1 end
    53	          limit 1
    54	       ) routing_line on true
    55	       left join lateral (
    56	         select wp.line_id
    57	           from public.npd_wip_processes wp
    58	          where wp.org_id = app.current_org_id()
    59	            and not s.is_fg
    60	            and wp.wip_item_id = s.item_id
    61	          order by wp.display_order asc, wp.created_at asc, wp.id asc
    62	          limit 1
    63	       ) wip_item_line on true
    64	       left join lateral (
    65	         select wp.line_id
    66	           from public.wip_definitions wd
    67	           join public.npd_wip_processes wp
    68	             on wp.org_id = wd.org_id
    69	            and wp.wip_definition_id = wd.id
    70	          where wd.org_id = app.current_org_id()
    71	            and not s.is_fg
    72	            and wd.item_id = s.item_id
    73	          order by wp.display_order asc, wp.created_at asc, wp.id asc
    74	          limit 1
    75	       ) wip_def_line on true
    76	       left join lateral (
    77	         select wp.line_id
    78	           from public.prod_detail pd
    79	           join public.npd_wip_processes wp
    80	             on wp.org_id = pd.org_id
    81	            and wp.prod_detail_id = pd.id
    82	          where pd.org_id = app.current_org_id()
    83	            and s.is_fg
    84	            and pd.item_id = s.item_id
    85	          order by wp.display_order desc, wp.created_at desc, wp.id desc
    86	          limit 1
    87	       ) fg_process_line on true
    88	       left join lateral (
    89	         select p.production_line_id
    90	           from public.items fg
    91	           join public.npd_projects p
    92	             on p.org_id = fg.org_id
    93	            and p.product_code = fg.item_code
    94	          where fg.org_id = app.current_org_id()
    95	            and fg.id = $3::uuid
    96	          limit 1
    97	       ) project_line on true`,
    98	    [itemIds, stageItemIds.map((stage) => stage.isFg), fgItemId],
    99	  );
   100	
   101	  for (const row of rows) {
   102	    byItem.set(row.item_id, row.production_line_id);
   103	  }
   104	  return byItem;
   105	}
FILE apps/web/app/[locale]/(app)/(modules)/planning/work-orders/_actions/create-work-order-core.ts
     1	import { randomUUID } from 'crypto';
     2	
     3	import { nextDocumentNumber } from '../../../../../../../lib/documents/numbering';
     4	import { assertFgReleasedToFactoryForWo } from '../../../../../../../lib/planning/factory-release-wo-gate';
     5	import { computeWoMaterialScalar, WoMaterialScalarError } from '../../../../../../../lib/production/wo-material-scalar';
     6	import { resolveWriteSiteId } from '../../../../../../../lib/site/site-context';
     7	import { snapshotFromItemRow, toBaseQty, TypedError } from '../../../../../../../lib/uom/convert';
     8	import {
     9	  APP_VERSION,
    10	  CreateWorkOrderInput,
    11	  PLANNING_WO_WRITE_PERMISSION,
    12	  hasPermission,
    13	  mapMaterial,
    14	  mapSchedule,
    15	  mapWoHeader,
    16	  isPgError,
    17	  type CreateWorkOrderResult,
    18	  type OrgActionContext,
    19	  type ScheduleOutputRow,
    20	  type UomConversionResult,
    21	  type WOMaterialRow,
    22	  type WorkOrderRow,
    23	} from './shared';
    24	
    25	type ItemUomRow = {
    26	  output_uom: string;
    27	  uom_base: string;
    28	  net_qty_per_each: string | null;
    29	  each_per_box: string | null;
    30	  boxes_per_pallet: string | null;
    31	  weight_mode: 'fixed' | 'catch';
    32	};
    33	
    34	export type CreateWorkOrderCoreParams = {
    35	  productId: string;
    36	  itemCode: string;
    37	  itemTypeAtCreation?: 'rm' | 'ingredient' | 'intermediate' | 'fg' | 'co_product' | 'byproduct';
    38	  documentNumber?: string;
    39	  siteId?: string;
    40	  plannedQuantity: string;
    41	  quantityEntered?: string;
    42	  quantityEnteredUom?: 'base' | 'each' | 'box';
    43	  scheduledStartTime?: string;
    44	  productionLineId?: string;
    45	  notes?: string;
    46	};
    47	
    48	/** Server-only options — never accepted from client-parsed input. */
    49	export type CreateWorkOrderCoreOptions = {
    50	  /** NPD pilot WO path — skip the factory-release owner gate (pre-handoff). */
    51	  skipFactoryReleaseGate?: boolean;
    52	};
    53	
    54	export async function createWorkOrderCore(
    55	  ctx: OrgActionContext,
    56	  params: CreateWorkOrderCoreParams,
    57	  options?: CreateWorkOrderCoreOptions,
    58	): Promise<CreateWorkOrderResult> {
    59	  const parsed = CreateWorkOrderInput.safeParse(params);
    60	  if (!parsed.success) return { ok: false, error: 'invalid_input', issues: parsed.error.issues };
    61	
    62	  if (!(await hasPermission(ctx, PLANNING_WO_WRITE_PERMISSION))) return { ok: false, error: 'forbidden' };
    63	
    64	  const input = parsed.data;
    65	  let siteId: string;
    66	  if (input.siteId) {
    67	    const explicitSite = await ctx.client.query<{ id: string }>(
    68	      `select id::text as id
    69	         from public.sites
    70	        where org_id = app.current_org_id()
    71	          and id = $1::uuid
    72	          and is_active = true
    73	        limit 1`,
    74	      [input.siteId],
    75	    );
    76	    if (!explicitSite.rows[0]) return { ok: false, error: 'no_active_site' };
    77	    siteId = explicitSite.rows[0].id;
    78	  } else {
    79	    const siteResolution = await resolveWriteSiteId(ctx.client);
    80	    if (!siteResolution.ok) return { ok: false, error: siteResolution.reason };
    81	    siteId = siteResolution.siteId;
    82	  }
    83	  const woId = randomUUID();
    84	  let woNumber: string;
    85	  try {
    86	    woNumber = input.documentNumber ?? await nextDocumentNumber(ctx.client, ctx.orgId, 'wo', new Date());
    87	  } catch (error) {
    88	    if (error instanceof Error && error.message.startsWith('document_number_settings_missing:')) {
    89	      return { ok: false, error: 'document_mask_missing' };
    90	    }
    91	    throw error;
    92	  }
    93	
    94	  const itemUomResult = await ctx.client.query<ItemUomRow>(
    95	    `select output_uom, uom_base, net_qty_per_each::text as net_qty_per_each,
    96	            each_per_box::text as each_per_box, boxes_per_pallet::text as boxes_per_pallet,
    97	            weight_mode
    98	       from public.items
    99	      where org_id = app.current_org_id()
   100	        and id = $1::uuid
   101	      limit 1`,
   102	    [input.productId],
   103	  );
   104	  const itemUom = itemUomResult.rows[0];
   105	  if (!itemUom) return { ok: false, error: 'invalid_input' };
   106	
   107	  const skipReleaseGate =
   108	    options?.skipFactoryReleaseGate === true || input.itemTypeAtCreation === 'intermediate';
   109	  if (!skipReleaseGate) {
   110	    const releaseGate = await assertFgReleasedToFactoryForWo(ctx.client, input.productId);
   111	    if (releaseGate === 'not_released_to_factory') {
   112	      return { ok: false, error: 'not_released_to_factory' };
   113	    }
   114	  }
   115	
   116	  const uomSnapshot = snapshotFromItemRow(itemUom);
   117	  const dbUomSnapshot = {
   118	    output_uom: itemUom.output_uom,
   119	    uom_base: itemUom.uom_base,
   120	    net_qty_per_each: itemUom.net_qty_per_each,
   121	    each_per_box: itemUom.each_per_box,
   122	    boxes_per_pallet: itemUom.boxes_per_pallet,
   123	    weight_mode: itemUom.weight_mode,
   124	  };
   125	  let plannedBaseQty = input.plannedQuantity;
   126	  let conversion: UomConversionResult | undefined;
   127	  if (input.quantityEntered) {
   128	    try {
   129	      plannedBaseQty = toBaseQty(uomSnapshot, Number(input.quantityEntered), input.quantityEnteredUom ?? 'base').toFixed(3);
   130	    } catch (error) {
   131	      if (error instanceof TypedError && error.code === 'uom_conversion_unavailable') {
   132	        return { ok: false, error: 'uom_conversion_unavailable' };
   133	      }
   134	      throw error;
   135	    }
   136	    conversion = {
   137	      qtyEntered: input.quantityEntered,
   138	      qtyEnteredUom: input.quantityEnteredUom ?? 'base',
   139	      baseQty: plannedBaseQty,
   140	    } as typeof conversion;
   141	  }
   142	
   143	  const activeBom = await ctx.client.query<{ id: string; version: number; line_basis: string }>(
   144	    `select id, version, line_basis
   145	       from public.bom_headers
   146	      where org_id = app.current_org_id()
   147	        and product_id = $1
   148	        and status = 'active'
   149	      order by version desc
   150	      limit 1`,
   151	    [input.itemCode],
   152	  );
   153	  const bom = activeBom.rows[0];
   154	
   155	  let materialScalar = 0;
   156	  if (bom) {
