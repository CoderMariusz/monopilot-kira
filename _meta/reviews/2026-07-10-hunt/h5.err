   447	async function loadRun(ctx: OrgActionContext, runId: string, lockForUpdate = false): Promise<SchedulerRunRow | null> {
   448	  const { rows } = await ctx.client.query<SchedulerRunRow>(
   449	    `select ${RUN_SELECT}
   450	       from public.scheduler_runs
   451	      where org_id = app.current_org_id()
   452	        and run_id = $1::uuid
   453	      limit 1
   454	      ${lockForUpdate ? 'for update' : ''}`,
   455	    [runId],
   456	  );
   457	  return rows[0] ?? null;
   458	}
   459	
   460	async function loadAssignments(ctx: OrgActionContext, runId: string): Promise<SchedulerAssignment[]> {
   461	  const { rows } = await ctx.client.query<SchedulerAssignment>(
   462	    `select ${ASSIGNMENT_SELECT}
   463	       from public.scheduler_assignments
   464	      where org_id = app.current_org_id()
   465	        and run_id = $1::uuid
   466	        and status not in ('rejected', 'cancelled')
   467	      order by sequence_index asc nulls last, created_at asc`,
   468	    [runId],
   469	  );
   470	  return rows;
   471	}
