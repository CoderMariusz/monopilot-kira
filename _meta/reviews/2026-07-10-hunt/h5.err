   303	
   304	async function denseRenumberTransferOrderLines(client: QueryClient, toId: string): Promise<void> {
   305	  await client.query(
   306	    `with numbered as (
   307	       select id, row_number() over (order by line_no asc, created_at asc, id asc)::integer as next_line_no
   308	         from public.transfer_order_lines
   309	        where org_id = app.current_org_id()
   310	          and to_id = $1::uuid
   311	     )
   312	     update public.transfer_order_lines l
   313	        set line_no = numbered.next_line_no
   314	       from numbered
   315	      where l.org_id = app.current_org_id()
   316	        and l.id = numbered.id
   317	        and l.line_no is distinct from numbered.next_line_no`,
   318	    [toId],
   319	  );
   320	}
