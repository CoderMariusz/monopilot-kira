   408	export async function reverseToReceiveLine(rawInput: unknown): Promise<ReverseToReceiveLineResult> {
   409	  const parsed = ReverseToReceiveLineInput.safeParse(rawInput);
   410	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   411	  const input = parsed.data;
   412	  const note = normalizeNote(input.note);
   413	  const reversedMicro = toMicro(input.quantity);
   414	
   415	  try {
   416	    const result = await withOrgContext(async ({ userId, orgId, client }): Promise<ReverseToReceiveLineResult> => {
   417	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   418	      if (!(await hasPermission(ctx, TRANSFER_RECEIVE_REVERSE_PERMISSION))) {
   419	        return { ok: false, error: 'forbidden' };
   420	      }
   421	
   422	      const link = await loadReceivedLinkForUpdate(ctx.client, input);
   423	      if (!link) return { ok: false, error: 'not_found' };
   424	      if (!['received', 'partially_received', 'in_transit'].includes(link.to_status)) {
   425	        return {
   426	          ok: false,
   427	          error: 'invalid_state',
   428	          message: `transfer_order is ${link.to_status}; expected received/partially_received/in_transit`,
   429	        };
   430	      }
   431	
   432	      if (toMicro(link.link_qty) !== reversedMicro || toMicro(link.dest_quantity) !== reversedMicro) {
   433	        return {
   434	          ok: false,
   435	          error: 'invalid_quantity',
   436	          message: 'Reverse quantity must equal the received destination LP quantity.',
   437	        };
   438	      }
   439	
   440	      if (toMicro(link.dest_reserved_qty) !== 0n) {
   441	        return { ok: false, error: 'lp_active', message: 'Destination LP has reserved quantity and cannot be reversed.' };
   442	      }
   443	
   444	      const blockers = await getDestinationLpBlockers(ctx, link.dest_lp_id);
   445	      if (blockers.length > 0) {
   446	        return {
   447	          ok: false,
   448	          error: 'lp_active',
   449	          message: `Destination LP cannot be reversed because it has ${blockers.join(', ')}.`,
   450	        };
   451	      }
   452	
   453	      if (SOURCE_REVERSE_BLOCKED_STATUSES.has(link.source_status)) {
   454	        return {
   455	          ok: false,
   456	          error: 'invalid_state',
   457	          message: `Source LP is ${link.source_status}; receive reversal would create phantom stock.`,
   458	        };
   459	      }
   460	
   461	      try {
   462	        await assertCorrectionAllowed(
   463	          { userId, orgId, client: client as unknown as ProductionQueryClient } satisfies ProductionContext,
   464	          {
   465	            permission: TRANSFER_RECEIVE_REVERSE_PERMISSION,
   466	            requireEsign: true,
   467	            signature: {
   468	              pin: input.signature.password,
   469	              intent: input.signature.intent ?? TRANSFER_RECEIVE_REVERSE_INTENT,
   470	              reason: input.reasonCode,
   471	              nonce: input.signature.nonce,
   472	              signerUserId: input.signature.signerUserId,
   473	              subject: {
   474	                transfer_order_id: link.to_id,
   475	                transfer_order_line_id: link.line_id,
   476	                transfer_order_line_lp_id: link.link_id,
   477	                source_lp_id: link.source_lp_id,
   478	                dest_lp_id: link.dest_lp_id,
   479	                reversed_qty: input.quantity,
   480	              },
   481	            },
   482	          },
   483	        );
   484	      } catch (error) {
   485	        if (error instanceof CorrectionForbiddenError) return { ok: false, error: 'forbidden' };
   486	        if (error instanceof CorrectionInvalidInputError) return { ok: false, error: 'invalid_input' };
   487	        return { ok: false, error: 'esign_failed' };
   488	      }
   489	
   490	      const destHistoryTxn = randomUUID();
   491	      const sourceHistoryTxn = randomUUID();
   492	      const destMoveTxn = randomUUID();
   493	      const sourceMoveTxn = randomUUID();
   494	      const reversedQty = microToDecimal(reversedMicro);
   495	      const reasonText = note ?? `TO receive reversal ${link.to_number}`;
   496	
   497	      await ctx.client.query(
   498	        `update public.license_plates
   499	            set status = $2,
   500	                quantity = 0,
   501	                reserved_qty = 0,
   502	                updated_by = $3::uuid,
   503	                updated_at = now()
   504	          where org_id = app.current_org_id()
   505	            and id = $1::uuid`,
   506	        [link.dest_lp_id, RETURNED_LP_STATUS, userId],
   507	      );
   508	
   509	      await writeLpHistory(ctx, {
   510	        siteId: link.dest_site_id,
   511	        lpId: link.dest_lp_id,
   512	        fromState: link.dest_status,
   513	        toState: RETURNED_LP_STATUS,
   514	        reasonText,
