   585	async function updateMatrixById(
   586	  ctx: OrgActionContext,
   587	  entry: Partial<ChangeoverMatrixEntry> & { id: string },
   588	): Promise<ChangeoverMatrixEntry | null> {
   589	  const { rows } = await ctx.client.query<ChangeoverMatrixEntry>(
   590	    `update public.changeover_matrix cm
   591	        set site_id = case when $2::boolean then $3::uuid else cm.site_id end,
   592	            version_id = coalesce($4::uuid, cm.version_id),
   593	            line_id = case when $5::boolean then $6::text else cm.line_id end,
   594	            allergen_from = coalesce(nullif($7::text, ''), cm.allergen_from),
   595	            allergen_to = coalesce(nullif($8::text, ''), cm.allergen_to),
   596	            changeover_minutes = coalesce($9::numeric, cm.changeover_minutes),
   597	            requires_cleaning = coalesce($10::boolean, cm.requires_cleaning),
   598	            requires_atp = coalesce($11::boolean, cm.requires_atp),
   599	            risk_level = coalesce($12::text, cm.risk_level),
   600	            notes = case when $13::boolean then $14::text else cm.notes end,
   601	            updated_at = now()
   602	      where cm.org_id = app.current_org_id()
   603	        and cm.id = $1::uuid
   604	      returning ${MATRIX_SELECT}`,
   605	    [
   606	      entry.id,
   607	      entry.site_id !== undefined,
   608	      entry.site_id ?? null,
   609	      entry.version_id ?? null,
   610	      entry.line_id !== undefined,
   611	      entry.line_id ?? null,
   612	      entry.allergen_from ?? '',
   613	      entry.allergen_to ?? '',
   614	      entry.changeover_minutes ?? null,
   615	      entry.requires_cleaning ?? null,
   616	      entry.requires_atp ?? null,
   617	      entry.risk_level ?? null,
   618	      entry.notes !== undefined,
   619	      entry.notes ?? null,
   620	    ],
   621	  );
   622	  return rows[0] ?? null;
   623	}
   624	
   625	async function upsertMatrixByPair(
   626	  ctx: OrgActionContext,
   627	  entry: Partial<ChangeoverMatrixEntry>,
   628	): Promise<ChangeoverMatrixEntry | null> {
   629	  const versionId = entry.version_id ?? (await loadActiveVersionId(ctx));
   630	  const allergenFrom = entry.allergen_from?.trim();
   631	  const allergenTo = entry.allergen_to?.trim();
   632	  const changeoverMinutes = Number(entry.changeover_minutes);
   633	  if (!versionId || !allergenFrom || !allergenTo || !Number.isFinite(changeoverMinutes) || changeoverMinutes < 0) {
   634	    return null;
   635	  }
   636	
   637	  const lineId = entry.line_id ?? null;
   638	  const update = await ctx.client.query<ChangeoverMatrixEntry>(
   639	    `update public.changeover_matrix cm
   640	        set site_id = $5::uuid,
   641	            changeover_minutes = $6::numeric,
   642	            requires_cleaning = $7::boolean,
   643	            requires_atp = $8::boolean,
   644	            risk_level = $9::text,
   645	            notes = $10::text,
   646	            updated_at = now()
   647	      where cm.org_id = app.current_org_id()
   648	        and cm.version_id = $1::uuid
   649	        and cm.line_id is not distinct from $2::text
   650	        and cm.allergen_from = $3::text
   651	        and cm.allergen_to = $4::text
   652	      returning ${MATRIX_SELECT}`,
   653	    [
   654	      versionId,
   655	      lineId,
   656	      allergenFrom,
   657	      allergenTo,
   658	      entry.site_id ?? null,
   659	      changeoverMinutes,
   660	      entry.requires_cleaning ?? false,
   661	      entry.requires_atp ?? false,
   662	      entry.risk_level ?? 'low',
   663	      entry.notes ?? null,
   664	    ],
   665	  );
   666	  if (update.rows[0]) return update.rows[0];
   667	
   668	  const insert = await ctx.client.query<ChangeoverMatrixEntry>(
   669	    `insert into public.changeover_matrix
   670	       (org_id, site_id, version_id, line_id, allergen_from, allergen_to,
   671	        changeover_minutes, requires_cleaning, requires_atp, risk_level, notes)
   672	     values
   673	       (app.current_org_id(), $1::uuid, $2::uuid, $3::text, $4::text, $5::text,
   674	        $6::numeric, $7::boolean, $8::boolean, $9::text, $10::text)
   675	     returning ${MATRIX_SELECT}`,
   676	    [
   677	      entry.site_id ?? null,
   678	      versionId,
   679	      lineId,
   680	      allergenFrom,
   681	      allergenTo,
   682	      changeoverMinutes,
   683	      entry.requires_cleaning ?? false,
   684	      entry.requires_atp ?? false,
   685	      entry.risk_level ?? 'low',
   686	      entry.notes ?? null,
   687	    ],
   688	  );
   689	  return insert.rows[0] ?? null;
   690	}
