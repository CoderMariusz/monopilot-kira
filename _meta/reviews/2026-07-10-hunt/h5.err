   294	function revalidateTransferOrderPaths(toId: string): void {
   295	  try {
   296	    revalidateLocalized('/planning/transfer-orders');
   297	    revalidateLocalized(`/planning/transfer-orders/${toId}`);
   298	  } catch (err) {
