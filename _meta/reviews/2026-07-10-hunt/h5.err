   126	async function loadReceivedLinkForUpdate(
   127	  client: QueryClient,
   128	  input: z.infer<typeof ReverseToReceiveLineInput>,
   129	): Promise<ReceivedLinkRow | null> {
   130	  const { rows } = await client.query<ReceivedLinkRow>(
   131	    `select t.id::text as to_id,
   132	            t.to_number,
   133	            t.status as to_status,
   134	            l.id::text as line_id,
   135	            l.uom as line_uom,
   136	            tll.id::text as link_id,
   137	            tll.qty::text as link_qty,
   138	            src.id::text as source_lp_id,
   139	            src.status as source_status,
   140	            src.quantity::text as source_quantity,
   141	            src.location_id::text as source_location_id,
   142	            src.site_id::text as source_site_id,
   143	            dst.id::text as dest_lp_id,
   144	            dst.status as dest_status,
   145	            dst.quantity::text as dest_quantity,
   146	            dst.reserved_qty::text as dest_reserved_qty,
   147	            dst.location_id::text as dest_location_id,
   148	            dst.site_id::text as dest_site_id
   149	       from public.transfer_orders t
   150	       join public.transfer_order_lines l
   151	         on l.org_id = app.current_org_id()
   152	        and l.to_id = t.id
   153	       join public.transfer_order_line_lps tll
   154	         on tll.org_id = app.current_org_id()
   155	        and tll.to_id = t.id
   156	        and tll.to_line_id = l.id
   157	       join public.license_plates src
   158	         on src.org_id = app.current_org_id()
   159	        and src.id = tll.source_lp_id
   160	       join public.license_plates dst
   161	         on dst.org_id = app.current_org_id()
   162	        and dst.id = tll.dest_lp_id
   163	      where t.org_id = app.current_org_id()
   164	        and t.id = $1::uuid
   165	        and l.id = $2::uuid
   166	        and tll.dest_lp_id = $3::uuid
   167	      limit 1
   168	      for update of t, l, tll, src, dst`,
   169	    [input.toId, input.lineId, input.destLpId],
   170	  );
   171	  return rows[0] ?? null;
   172	}
