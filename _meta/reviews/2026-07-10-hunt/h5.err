   172	
   173	async function fetchLines(client: QueryClient, toId: string): Promise<TransferOrderLine[]> {
   174	  // The transfer_order_line_lps link carries the received destination LP per line
   175	  // (one received LP per line in the current receive flow — the same row
   176	  // reverseToReceiveLine loads). LEFT JOIN keeps not-yet-received lines visible
   177	  // with null LP fields. dst.quantity is the received qty the reversal action
   178	  // validates against (it must equal the link qty).
   179	  const { rows } = await client.query<TransferOrderLineRow>(
   180	    `select l.id, l.to_id, l.item_id, i.item_code, i.name as item_name,
   181	            l.qty::text as qty, l.uom, l.line_no,
   182	            tll.dest_lp_id::text as received_dest_lp_id,
   183	            dst.lp_number as received_dest_lp_number,
   184	            dst.quantity::text as received_qty,
   185	            coalesce((
   186	              t.status in ('received', 'partially_received', 'in_transit')
   187	              and tll.dest_lp_id is not null
   188	              and src.id is not null
   189	              and dst.id is not null
   190	              and tll.qty = dst.quantity
   191	              and dst.reserved_qty = 0::numeric
   192	              and cardinality(coalesce(lp_blockers.blockers, array[]::text[])) = 0
   193	            ), false) as can_reverse,
   194	            case
   195	              when tll.dest_lp_id is null then null
   196	              when t.status not in ('received', 'partially_received', 'in_transit')
   197	                then 'Transfer order status does not allow reversal.'
   198	              when src.id is null or dst.id is null
   199	                then 'Received pallet link is no longer reversible.'
   200	              when tll.qty <> dst.quantity
   201	                then 'Reverse quantity must equal the received destination pallet quantity.'
   202	              when dst.reserved_qty <> 0::numeric
   203	                then 'Destination pallet has reserved quantity and cannot be reversed.'
   204	              when cardinality(coalesce(lp_blockers.blockers, array[]::text[])) > 0
   205	                then 'Destination pallet cannot be reversed because it has ' || array_to_string(lp_blockers.blockers, ', ') || '.'
   206	              else null
   207	            end as reverse_block_reason
   208	       from public.transfer_order_lines l
   209	       join public.transfer_orders t
   210	         on t.org_id = app.current_org_id()
   211	        and t.id = l.to_id
   212	       left join public.items i on i.org_id = app.current_org_id() and i.id = l.item_id
   213	       left join public.transfer_order_line_lps tll
   214	         on tll.org_id = app.current_org_id()
   215	        and tll.to_id = l.to_id
   216	        and tll.to_line_id = l.id
   217	        and tll.dest_lp_id is not null
   218	       left join public.license_plates src
   219	         on src.org_id = app.current_org_id()
   220	        and src.id = tll.source_lp_id
   221	       left join public.license_plates dst
   222	         on dst.org_id = app.current_org_id()
   223	        and dst.id = tll.dest_lp_id
   224	       left join lateral (
   225	         select array_remove(array[
   226	           case when exists (
   227	             select 1
   228	               from public.inventory_allocations ia
   229	              where ia.org_id = app.current_org_id()
   230	                and ia.license_plate_id = tll.dest_lp_id
   231	           ) then 'allocations'::text end,
   232	           case when exists (
   233	             select 1
   234	               from public.shipment_box_contents sbc
   235	              where sbc.org_id = app.current_org_id()
   236	                and sbc.license_plate_id = tll.dest_lp_id
   237	           ) or (dst.status = 'shipped' or dst.source_so_id is not null)
   238	           then 'outbound_shipments'::text end,
   239	           case when exists (
   240	             select 1
   241	               from public.wo_material_consumption wmc
   242	              where wmc.org_id = app.current_org_id()
   243	                and wmc.lp_id = tll.dest_lp_id
   244	                and wmc.correction_of_id is null
   245	           ) then 'consumed_wo_inputs'::text end
   246	         ], null) as blockers
   247	       ) lp_blockers on tll.dest_lp_id is not null
   248	      where l.org_id = app.current_org_id()
   249	        and l.to_id = $1::uuid
   250	      order by l.line_no asc`,
   251	    [toId],
   252	  );
   253	  return rows.map(mapLine);
   254	}
