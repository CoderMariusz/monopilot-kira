    52	  blockType: string;
    53	};
    54	
    55	export type ScheduleLineDayUtilization = {
    56	  lineId: string;
    57	  dayKey: string; // YYYY-MM-DD (UTC)
    58	  scheduledHours: number;
    59	  capacityHours: number | null;
    60	  /** null when capacityHours is null or zero. */
    61	  utilizationPct: number | null;
    62	};
    63	
    64	export type ScheduleBoardData = {
    65	  windowStart: string; // ISO, UTC midnight today
    66	  windowEnd: string; // ISO, windowStart + 7d
    67	  lines: ScheduleBoardLine[];
    68	  scheduled: ScheduleBoardWo[];
    69	  unscheduled: ScheduleBoardWo[];
    70	  unscheduledPagination: PaginatedResult<ScheduleBoardWo>;
    71	  capacityBlocks: ScheduleCapacityBlock[];
    72	  /** Per-line/day finite-capacity utilisation from scheduler_config + scheduled WOs. */
    73	  lineDayUtilization: ScheduleLineDayUtilization[];
    74	};
    75	
    76	export type BarInterval = {
    77	  id: string;
    78	  lineId: string | null;
    79	  startMs: number;
    80	  endMs: number;
    81	};
    82	
    83	/**
    84	 * IDs of bars that overlap another bar on the SAME line (open interval
    85	 * comparison — touching end==start is NOT a conflict). Bars without a line
    86	 * never conflict (they render in the "no line" lane purely informationally).
    87	 */
    88	export function computeConflictIds(bars: readonly BarInterval[]): Set<string> {
    89	  const conflictIds = new Set<string>();
    90	  const byLine = new Map<string, BarInterval[]>();
    91	  for (const bar of bars) {
    92	    if (bar.lineId === null) continue;
    93	    const lane = byLine.get(bar.lineId);
    94	    if (lane) lane.push(bar);
    95	    else byLine.set(bar.lineId, [bar]);
    96	  }
    97	  for (const lane of byLine.values()) {
    98	    const sorted = [...lane].sort((a, b) => a.startMs - b.startMs);
    99	    for (let i = 0; i < sorted.length; i += 1) {
   100	      for (let j = i + 1; j < sorted.length; j += 1) {
   101	        const a = sorted[i] as BarInterval;
   102	        const b = sorted[j] as BarInterval;
   103	        if (b.startMs >= a.endMs) break; // sorted — no later bar can overlap a
   104	        conflictIds.add(a.id);
   105	        conflictIds.add(b.id);
   106	      }
   107	    }
   108	  }
   109	  return conflictIds;
   110	}
   111	
   112	/** Interval for a WO bar, applying the open-end fallback. */
   113	export function barInterval(wo: ScheduleBoardWo): BarInterval | null {
   114	  if (!wo.scheduledStart) return null;
   115	  const startMs = Date.parse(wo.scheduledStart);
   116	  if (Number.isNaN(startMs)) return null;
   117	  const endParsed = wo.scheduledEnd ? Date.parse(wo.scheduledEnd) : Number.NaN;
   118	  const endMs = Number.isNaN(endParsed) ? startMs + OPEN_END_FALLBACK_MS : endParsed;
   119	  return { id: wo.id, lineId: wo.productionLineId, startMs, endMs: Math.max(endMs, startMs) };
   120	}
   121	
   122	export function capacityBlockInterval(block: ScheduleCapacityBlock): BarInterval | null {
   123	  const startMs = Date.parse(`${block.blockDate}T${block.startTime}Z`);
   124	  const endMs = Date.parse(`${block.blockDate}T${block.endTime}Z`);
   125	  if (Number.isNaN(startMs) || Number.isNaN(endMs)) return null;
   126	  return { id: block.id, lineId: block.lineId, startMs, endMs: Math.max(endMs, startMs) };
   127	}
   128	
   129	/**
   130	 * Percentage geometry of a bar inside the board window, clamped to [0,100].
   131	 * Returns null when the bar lies fully outside the window. Minimum width
   132	 * 0.75% keeps zero/short bars clickable.
   133	 */
   134	export function barGeometry(
   135	  startMs: number,
   136	  endMs: number,
   137	  windowStartMs: number,
   138	  windowEndMs: number,
   139	): { leftPct: number; widthPct: number } | null {
   140	  const span = windowEndMs - windowStartMs;
   141	  if (span <= 0) return null;
   142	  if (endMs <= windowStartMs || startMs >= windowEndMs) return null;
   143	  const clampedStart = Math.max(startMs, windowStartMs);
   144	  const clampedEnd = Math.min(endMs, windowEndMs);
   145	  const leftPct = ((clampedStart - windowStartMs) / span) * 100;
   146	  const widthPct = Math.max(((clampedEnd - clampedStart) / span) * 100, 0.75);
   147	  return { leftPct, widthPct: Math.min(widthPct, 100 - leftPct) };
   148	}
   149	
   150	/** The 7 day-key strings (YYYY-MM-DD, UTC) of the window for headers. */
   151	export function windowDayKeys(windowStartIso: string, days: number = BOARD_WINDOW_DAYS): string[] {
   152	  const startMs = Date.parse(windowStartIso);
   153	  return Array.from({ length: days }, (_, i) =>
   154	    new Date(startMs + i * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
   155	  );
   156	}
   157	
   158	const DAY_MS = 24 * 60 * 60 * 1000;
   159	
   160	/** Milliseconds of [startMs, endMs) overlapping a UTC day bucket. */
   161	export function overlapMsWithUtcDay(startMs: number, endMs: number, dayStartMs: number): number {
   162	  const dayEndMs = dayStartMs + DAY_MS;
   163	  const overlapStart = Math.max(startMs, dayStartMs);
   164	  const overlapEnd = Math.min(endMs, dayEndMs);
   165	  return Math.max(0, overlapEnd - overlapStart);
   166	}
   167	
   168	function numericCapacity(value: string | number | null | undefined): number | null {
   169	  if (value === null || value === undefined) return null;
   170	  const parsed = Number(value);
   171	  return Number.isFinite(parsed) && parsed > 0 ? parsed : null;
   172	}
   173	
   174	function resolveLineCapacityHours(
   175	  lineId: string,
   176	  perLine: Map<string, number | null>,
   177	  orgDefault: number | null,
   178	): number | null {
   179	  if (perLine.has(lineId)) return perLine.get(lineId) ?? null;
   180	  return orgDefault;
   181	}
   182	
   183	/**
   184	 * Aggregate scheduled WO hours per line/day and compare to scheduler_config capacity.
   185	 * `capacityRows` uses null line_id for the org-wide default.
   186	 */
   187	export function computeLineDayUtilization(input: {
   188	  lines: readonly ScheduleBoardLine[];
   189	  scheduled: readonly ScheduleBoardWo[];
   190	  capacityRows: ReadonlyArray<{ line_id: string | null; capacity_hours_per_day: string | number | null }>;
   191	  windowStartIso: string;
   192	  days?: number;
   193	}): ScheduleLineDayUtilization[] {
   194	  const days = input.days ?? BOARD_WINDOW_DAYS;
   195	  const windowStartMs = Date.parse(input.windowStartIso);
   196	  const dayKeys = windowDayKeys(input.windowStartIso, days);
   197	
   198	  const perLine = new Map<string, number | null>();
   199	  let orgDefault: number | null = null;
   200	  for (const row of input.capacityRows) {
   201	    const hours = numericCapacity(row.capacity_hours_per_day);
   202	    if (row.line_id === null) orgDefault = hours;
   203	    else perLine.set(row.line_id, hours);
   204	  }
   205	
   206	  const scheduledHours = new Map<string, number>();
   207	  for (const wo of input.scheduled) {
   208	    const interval = barInterval(wo);
   209	    if (!interval?.lineId) continue;
   210	    for (let index = 0; index < days; index += 1) {
   211	      const dayStartMs = windowStartMs + index * DAY_MS;
   212	      const overlapMs = overlapMsWithUtcDay(interval.startMs, interval.endMs, dayStartMs);
   213	      if (overlapMs <= 0) continue;
   214	      const key = `${interval.lineId}|${dayKeys[index]}`;
   215	      scheduledHours.set(key, (scheduledHours.get(key) ?? 0) + overlapMs / (60 * 60 * 1000));
   216	    }
   217	  }
   218	
   219	  const results: ScheduleLineDayUtilization[] = [];
   220	  for (const line of input.lines) {
   221	    const capacityHours = resolveLineCapacityHours(line.id, perLine, orgDefault);
   222	    for (const dayKey of dayKeys) {
   223	      const key = `${line.id}|${dayKey}`;
   224	      const hours = scheduledHours.get(key) ?? 0;
   225	      if (hours <= 0 && capacityHours === null) continue;
   226	      const utilizationPct =
   227	        capacityHours !== null && capacityHours > 0 ? (hours / capacityHours) * 100 : null;
   228	      results.push({
   229	        lineId: line.id,
   230	        dayKey,
   231	        scheduledHours: Math.round(hours * 100) / 100,
   232	        capacityHours,
   233	        utilizationPct: utilizationPct === null ? null : Math.round(utilizationPct * 10) / 10,
   234	      });
   235	    }
   236	  }
   237	  return results;
   238	}
     1	import type { OrgActionContext } from './shared';
     2	
     3	type StageLineRow = {
     4	  item_id: string;
     5	  production_line_id: string | null;
     6	};
     7	
     8	/**
     9	 * Resolve production_line_id per chain stage item.
    10	 *
    11	 * Priority per item:
    12	 * 1. routing_operations.line_id — first op for WIP stages, last op for the FG root
    13	 * 2. npd_wip_processes.line_id via wip_item_id (ensureWipItem path) or wip_definitions.item_id
    14	 * 3. FG root only: npd_wip_processes.line_id via prod_detail.item_id (last op)
    15	 * 4. npd_projects.production_line_id for the FG product's project
    16	 */
    17	export async function loadStageProductionLineIds(
    18	  ctx: OrgActionContext,
    19	  fgItemId: string,
    20	  stageItemIds: Array<{ itemId: string; isFg: boolean }>,
    21	): Promise<Map<string, string | null>> {
    22	  const byItem = new Map<string, string | null>();
    23	  if (stageItemIds.length === 0) return byItem;
    24	
    25	  const itemIds = stageItemIds.map((stage) => stage.itemId);
    26	  const { rows } = await ctx.client.query<StageLineRow>(
    27	    `with stages as (
    28	       select s.item_id,
    29	              s.is_fg
    30	         from unnest($1::uuid[], $2::boolean[]) as s(item_id, is_fg)
    31	     )
    32	     select s.item_id::text as item_id,
    33	            coalesce(
    34	              routing_line.line_id,
    35	              wip_item_line.line_id,
    36	              wip_def_line.line_id,
    37	              fg_process_line.line_id,
    38	              project_line.production_line_id
    39	            )::text as production_line_id
    40	       from stages s
    41	       left join lateral (
    42	         select ro.line_id
    43	           from public.routings r
    44	           join public.routing_operations ro
    45	             on ro.routing_id = r.id
    46	            and ro.org_id = r.org_id
    47	          where r.org_id = app.current_org_id()
    48	            and r.item_id = s.item_id
    49	            and r.status in ('active', 'draft', 'approved')
    50	          order by case r.status when 'active' then 0 when 'approved' then 1 else 2 end,
    51	                   r.version desc,
    52	                   ro.op_no * case when s.is_fg then -1 else 1 end
    53	          limit 1
    54	       ) routing_line on true
    55	       left join lateral (
    56	         select wp.line_id
    57	           from public.npd_wip_processes wp
    58	          where wp.org_id = app.current_org_id()
    59	            and not s.is_fg
    60	            and wp.wip_item_id = s.item_id
    61	          order by wp.display_order asc, wp.created_at asc, wp.id asc
    62	          limit 1
    63	       ) wip_item_line on true
    64	       left join lateral (
    65	         select wp.line_id
    66	           from public.wip_definitions wd
    67	           join public.npd_wip_processes wp
    68	             on wp.org_id = wd.org_id
    69	            and wp.wip_definition_id = wd.id
    70	          where wd.org_id = app.current_org_id()
    71	            and not s.is_fg
    72	            and wd.item_id = s.item_id
    73	          order by wp.display_order asc, wp.created_at asc, wp.id asc
    74	          limit 1
    75	       ) wip_def_line on true
    76	       left join lateral (
    77	         select wp.line_id
    78	           from public.prod_detail pd
    79	           join public.npd_wip_processes wp
    80	             on wp.org_id = pd.org_id
    81	            and wp.prod_detail_id = pd.id
    82	          where pd.org_id = app.current_org_id()
    83	            and s.is_fg
    84	            and pd.item_id = s.item_id
    85	          order by wp.display_order desc, wp.created_at desc, wp.id desc
    86	          limit 1
    87	       ) fg_process_line on true
    88	       left join lateral (
    89	         select p.production_line_id
    90	           from public.items fg
    91	           join public.npd_projects p
    92	             on p.org_id = fg.org_id
    93	            and p.product_code = fg.item_code
    94	          where fg.org_id = app.current_org_id()
    95	            and fg.id = $3::uuid
    96	          limit 1
    97	       ) project_line on true`,
    98	    [itemIds, stageItemIds.map((stage) => stage.isFg), fgItemId],
    99	  );
   100	
   101	  for (const row of rows) {
   102	    byItem.set(row.item_id, row.production_line_id);
   103	  }
   104	  return byItem;
   105	}
     1	'use server';
     2	
     3	/**
     4	 * P2-PLANNING — read-only surface for the multi-stage production chain.
     5	 *
     6	 * Two reads, both org-scoped inside withOrgContext (RLS: org_id =
     7	 * app.current_org_id()); neither writes:
     8	 *
     9	 *   1. previewWorkOrderChain — a DRY RUN of create-work-order-chain. Given the FG
    10	 *      product + planned qty it recomputes (never persists) the child WIP stages
    11	 *      that would be created, so the create flow can show a tree BEFORE the write.
    12	 *      It mirrors create-work-order-chain's reads (loadItem / loadActiveBom /
    13	 *      computeWoMaterialScalar / WIP bom lines) so the preview matches what the
    14	 *      action actually creates. Each stage is enriched with its production line(s)
    15	 *      (routing_operations → production_lines), its process throughput per
    16	 *      product×process (npd_wip_processes via prod_detail.item_id) and the WIP it
    17	 *      consumes / outputs.
    18	 *
    19	 *   2. getStationQueue — the per-station lane. Given a production line it returns
    20	 *      ONLY that line's WOs across every chain, each with demand qty, the upstream
    21	 *      WIP it needs + how much is already produced (real produced_quantity on the
    22	 *      upstream WO), the output target, and the line's throughput_per_hour for that
    23	 *      product×process so the station knows its rate.
    24	 *
    25	 * Honest data policy: throughput/line come from the real masters; when a product has
    26	 * no routing or no npd_wip_processes row the stage simply carries an empty list (the
    27	 * UI renders an em dash), never a fabricated rate. Raw-material stock-on-hand is NOT
    28	 * surfaced here — see the station view's note; the only availability signal is the
    29	 * upstream WIP WO's produced_quantity, which is real.
    30	 */
    31	
    32	import { z } from 'zod';
    33	
    34	import { computeWoMaterialScalar, WoMaterialScalarError } from '../../../../../../../lib/production/wo-material-scalar';
    35	import { withOrgContext } from '../../../../../../../lib/auth/with-org-context';
    36	import type { QueryClient } from './shared';
    37	
    38	export type ChainStageProcess = {
    39	  name: string;
    40	  throughputPerHour: number | null;
    41	  throughputUom: string | null;
    42	  durationHours: number | null;
    43	};
    44	
    45	export type ChainStageLine = { code: string; name: string };
    46	
    47	export type ChainStageMaterial = { itemCode: string; requiredQty: string; uom: string };
    48	
    49	export type ChainStage = {
    50	  /** Stable key for React lists (item id + suffix). */
    51	  key: string;
    52	  /** "FG" for the root, or the WIP stage label (W1, W2 …). */
    53	  stageLabel: string;
    54	  itemId: string;
    55	  itemCode: string;
    56	  itemName: string;
    57	  /** Qty this stage must output, in `uom`. */
    58	  requiredQty: string;
    59	  uom: string;
    60	  lines: ChainStageLine[];
    61	  processes: ChainStageProcess[];
    62	  /** WIP items this stage consumes from upstream stages (empty for leaf stages). */
    63	  consumes: ChainStageMaterial[];
    64	  children: ChainStage[];
    65	};
    66	
    67	export type PreviewWorkOrderChainResult =
    68	  | { ok: true; spansMultipleStages: boolean; stageCount: number; root: ChainStage }
    69	  | { ok: false; error: 'invalid_input' | 'not_found' | 'no_active_bom' | 'pack_hierarchy_incomplete' | 'persistence_failed' };
    70	
    71	const PreviewInput = z.object({
    72	  productId: z.string().uuid(),
    73	  plannedQuantity: z
    74	    .string()
    75	    .trim()
    76	    .regex(/^\d+(?:\.\d{1,4})?$/)
    77	    .refine((value) => Number(value) > 0),
    78	});
    79	
    80	type ItemRow = {
    81	  id: string;
    82	  item_code: string;
    83	  name: string | null;
    84	  uom_base: string;
    85	  net_qty_per_each: string | null;
    86	  each_per_box: string | null;
    87	};
    88	
    89	type BomHeaderRow = { id: string; line_basis: string };
    90	
    91	type WipBomLineRow = {
    92	  item_id: string;
    93	  component_code: string;
    94	  name: string | null;
    95	  uom_base: string;
    96	  quantity: string;
    97	  scrap_pct: string | null;
    98	};
    99	
   100	type LineRow = { item_id: string; code: string; name: string };
   101	type ProcessRow = {
   102	  item_id: string;
   103	  process_name: string;
   104	  throughput_per_hour: string | null;
   105	  throughput_uom: string | null;
   106	  duration_hours: string | null;
   107	};
   108	
   109	function computeRequiredMaterialQty(quantity: string, scrapPct: string | null, materialScalar: number): string {
   110	  const denominator = Math.max(1 - Number(scrapPct ?? 0) / 100, 0.01);
   111	  return (Math.round((Number(quantity) * materialScalar / denominator) * 10000) / 10000).toFixed(4);
   112	}
   113	
   114	async function loadLinesByItem(client: QueryClient, itemIds: string[]): Promise<Map<string, ChainStageLine[]>> {
   115	  const byItem = new Map<string, ChainStageLine[]>();
   116	  if (itemIds.length === 0) return byItem;
   117	  const { rows } = await client.query<LineRow>(
   118	    `select distinct on (r.item_id, pl.id)
   119	            r.item_id::text as item_id, pl.code, pl.name
   120	       from public.routings r
   121	       join public.routing_operations ro on ro.routing_id = r.id and ro.org_id = r.org_id
   122	       join public.production_lines pl on pl.id = ro.line_id and pl.org_id = ro.org_id
   123	      where r.org_id = app.current_org_id()
   124	        and r.item_id = any($1::uuid[])
   125	        and r.status in ('active', 'approved')
   126	      order by r.item_id, pl.id, ro.op_no`,
   127	    [itemIds],
   128	  );
   129	  for (const row of rows) {
   130	    const list = byItem.get(row.item_id) ?? [];
   131	    list.push({ code: row.code, name: row.name });
   132	    byItem.set(row.item_id, list);
   133	  }
   134	  return byItem;
   135	}
   136	
   137	async function loadProcessesByItem(client: QueryClient, itemIds: string[]): Promise<Map<string, ChainStageProcess[]>> {
   138	  const byItem = new Map<string, ChainStageProcess[]>();
   139	  if (itemIds.length === 0) return byItem;
   140	  const { rows } = await client.query<ProcessRow>(
   141	    `select pd.item_id::text as item_id, p.process_name,
   142	            p.throughput_per_hour::text as throughput_per_hour,
   143	            p.throughput_uom, p.duration_hours::text as duration_hours
   144	       from public.npd_wip_processes p
   145	       join public.prod_detail pd on pd.id = p.prod_detail_id and pd.org_id = p.org_id
   146	      where p.org_id = app.current_org_id()
   147	        and pd.item_id = any($1::uuid[])
   148	      order by pd.item_id, p.display_order`,
   149	    [itemIds],
   150	  );
   151	  for (const row of rows) {
   152	    const list = byItem.get(row.item_id) ?? [];
   153	    list.push({
   154	      name: row.process_name,
   155	      throughputPerHour: row.throughput_per_hour === null ? null : Number(row.throughput_per_hour),
   156	      throughputUom: row.throughput_uom,
   157	      durationHours: row.duration_hours === null ? null : Number(row.duration_hours),
   158	    });
   159	    byItem.set(row.item_id, list);
   160	  }
   161	  return byItem;
   162	}
   163	
   164	export async function previewWorkOrderChain(raw: unknown): Promise<PreviewWorkOrderChainResult> {
   165	  const parsed = PreviewInput.safeParse(raw);
   166	  if (!parsed.success) return { ok: false, error: 'invalid_input' };
   167	
   168	  try {
   169	    return await withOrgContext(async ({ client }): Promise<PreviewWorkOrderChainResult> => {
   170	      const q = client as unknown as QueryClient;
   171	      const fg = (
   172	        await q.query<ItemRow>(
   173	          `select id::text as id, item_code, name, uom_base,
   174	                  net_qty_per_each::text as net_qty_per_each, each_per_box::text as each_per_box
   175	             from public.items
   176	            where org_id = app.current_org_id() and id = $1::uuid
   177	            limit 1`,
   178	          [parsed.data.productId],
   179	        )
   180	      ).rows[0];
   181	      if (!fg) return { ok: false, error: 'not_found' };
   182	
   183	      const bom = (
   184	        await q.query<BomHeaderRow>(
   185	          `select id::text as id, line_basis
   186	             from public.bom_headers
   187	            where org_id = app.current_org_id() and status = 'active'
   188	              and (item_id = $1::uuid or product_id = $2)
   189	            order by version desc, created_at desc
   190	            limit 1`,
   191	          [fg.id, fg.item_code],
   192	        )
   193	      ).rows[0];
   194	      if (!bom) return { ok: false, error: 'no_active_bom' };
   195	
   196	      let materialScalar: number;
   197	      try {
   198	        materialScalar = computeWoMaterialScalar({
   199	          plannedBaseQty: Number(parsed.data.plannedQuantity),
   200	          lineBasis: bom.line_basis,
   201	          eachPerBox: fg.each_per_box == null ? null : Number(fg.each_per_box),
   202	          netQtyPerEach: fg.net_qty_per_each == null ? null : Number(fg.net_qty_per_each),
   203	        });
   204	      } catch (error) {
   205	        if (error instanceof WoMaterialScalarError) return { ok: false, error: 'pack_hierarchy_incomplete' };
   206	        throw error;
   207	      }
   208	
   209	      const wipLines = (
   210	        await q.query<WipBomLineRow>(
   211	          `select bl.item_id::text as item_id, bl.component_code, i.name, i.uom_base,
   212	                  bl.quantity::text as quantity, bl.scrap_pct::text as scrap_pct
   213	             from public.bom_lines bl
   214	             left join public.items i on i.id = bl.item_id and i.org_id = bl.org_id
   215	            where bl.org_id = app.current_org_id()
   216	              and bl.bom_header_id = $1::uuid
   217	              and bl.component_type = 'WIP'
   218	              and bl.item_id is not null
   219	            order by bl.line_no`,
   220	          [bom.id],
   221	        )
   222	      ).rows;
   223	
   224	      const itemIds = [fg.id, ...wipLines.map((l) => l.item_id)];
   225	      const [linesByItem, processesByItem] = await Promise.all([
   226	        loadLinesByItem(q, itemIds),
   227	        loadProcessesByItem(q, itemIds),
   228	      ]);
   229	
   230	      const childStages: ChainStage[] = wipLines.map((line, index) => {
   231	        const requiredQty = computeRequiredMaterialQty(line.quantity, line.scrap_pct, materialScalar);
   232	        return {
   233	          key: `${line.item_id}-W${index + 1}`,
   234	          stageLabel: `W${index + 1}`,
   235	          itemId: line.item_id,
   236	          itemCode: line.component_code,
   237	          itemName: line.name ?? line.component_code,
   238	          requiredQty,
   239	          uom: line.uom_base,
   240	          lines: linesByItem.get(line.item_id) ?? [],
   241	          processes: processesByItem.get(line.item_id) ?? [],
   242	          consumes: [],
   243	          children: [],
   244	        };
   245	      });
   246	
   247	      const root: ChainStage = {
   248	        key: `${fg.id}-FG`,
   249	        stageLabel: 'FG',
   250	        itemId: fg.id,
   251	        itemCode: fg.item_code,
   252	        itemName: fg.name ?? fg.item_code,
   253	        requiredQty: parsed.data.plannedQuantity,
   254	        uom: fg.uom_base,
   255	        lines: linesByItem.get(fg.id) ?? [],
   256	        processes: processesByItem.get(fg.id) ?? [],
   257	        consumes: childStages.map((c) => ({ itemCode: c.itemCode, requiredQty: c.requiredQty, uom: c.uom })),
   258	        children: childStages,
   259	      };
   260	
   261	      return {
   262	        ok: true,
   263	        spansMultipleStages: childStages.length > 0,
   264	        stageCount: childStages.length + 1,
   265	        root,
   266	      };
   267	    });
   268	  } catch (error) {
   269	    console.error('[previewWorkOrderChain] persistence_failed', error);
   270	    return { ok: false, error: 'persistence_failed' };
   271	  }
   272	}
