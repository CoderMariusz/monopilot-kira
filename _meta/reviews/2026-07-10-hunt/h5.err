   495	async function applyAssignmentToWorkOrder(
   496	  ctx: OrgActionContext,
   497	  runId: string,
   498	  assignment: SchedulerAssignment,
   499	): Promise<boolean> {
   500	  const result = await ctx.client.query(
   501	    `update public.work_orders wo
   502	        set scheduled_start_time = $2::timestamptz,
   503	            scheduled_end_time = $3::timestamptz,
   504	            production_line_id = coalesce($4::uuid, wo.production_line_id),
   505	            ext_jsonb = coalesce(wo.ext_jsonb, '{}'::jsonb)
   506	              || jsonb_build_object(
   507	                   'scheduler_run_id', $5::text,
   508	                   'scheduler_sequence_index', $6::numeric
   509	                 ),
   510	            updated_by = $7::uuid,
   511	            updated_at = now()
   512	      where wo.org_id = app.current_org_id()
   513	        and wo.id = $1::uuid
   514	        and wo.status in ('DRAFT', 'RELEASED')`,
   515	    [
   516	      assignment.wo_id,
   517	      assignment.planned_start_at,
   518	      assignment.planned_end_at,
   519	      isUuid(assignment.line_id) ? assignment.line_id : null,
   520	      runId,
   521	      assignment.sequence_index,
   522	      ctx.userId,
   523	    ],
   524	  );
   525	  return Number(result.rowCount ?? 0) > 0;
   526	}
