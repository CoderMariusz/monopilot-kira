   224	function validateRow(
   225	  row: PoImportRow,
   226	  suppliers: Map<string, SupplierLookupRow>,
   227	  items: Map<string, ItemLookupRow>,
   228	  units: Set<string>,
   229	): PoImportError | null {
   230	  const externalRef = normalizeText(row.external_ref);
   231	  if (!externalRef) return { column: 'external_ref', message: 'External reference is required.' };
   232	
   233	  const supplierCode = normalizeText(row.supplier_code);
   234	  if (!supplierCode) return { column: 'supplier_code', message: 'Supplier code is required.' };
   235	  if (!suppliers.has(supplierCode)) {
   236	    return { column: 'supplier_code', message: `Supplier code "${supplierCode}" was not found for this org.` };
   237	  }
   238	
   239	  const itemCode = normalizeText(row.item_code);
   240	  if (!itemCode) return { column: 'item_code', message: 'Item code is required.' };
   241	  const item = items.get(itemCode);
   242	  if (!item) return { column: 'item_code', message: `Item code "${itemCode}" is not an active item for this org.` };
   243	
   244	  const uom = normalizeText(row.uom);
   245	  if (!uom) return { column: 'uom', message: 'UoM is required.' };
   246	  if (!isValidUomForItem(uom, item, units)) {
   247	    return { column: 'uom', message: `UoM "${uom}" is not valid for item code "${itemCode}".` };
   248	  }
   249	
   250	  if (!Number.isFinite(row.qty) || row.qty <= 0) {
   251	    return { column: 'qty', message: `Quantity "${String(row.qty)}" must be greater than 0.` };
   252	  }
   253	  if (decimalPlaces(row.qty) > 3) {
   254	    return { column: 'qty', message: `Quantity "${numberToPlainString(row.qty)}" must have at most 3 decimal places.` };
   255	  }
   256	
   257	  if (row.price !== undefined) {
   258	    if (!Number.isFinite(row.price) || row.price < 0) {
   259	      return { column: 'price', message: `Price "${String(row.price)}" must be greater than or equal to 0.` };
   260	    }
   261	    if (decimalPlaces(row.price) > 4) {
   262	      return { column: 'price', message: `Price "${numberToPlainString(row.price)}" must have at most 4 decimal places.` };
   263	    }
   264	  }
   265	
   266	  const expectedDelivery = normalizeText(row.expected_delivery);
   267	  if (expectedDelivery) {
   268	    if (!isValidIsoDate(expectedDelivery)) {
   269	      return { column: 'expected_delivery', message: `Expected delivery "${expectedDelivery}" must be a YYYY-MM-DD date.` };
   270	    }
   271	    if (expectedDelivery < todayUtcDate()) {
   272	      return { column: 'expected_delivery', message: `Expected delivery "${expectedDelivery}" must not be in the past.` };
   273	    }
   274	  }
   275	
   276	  return null;
   277	}
