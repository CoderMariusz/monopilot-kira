   476	export async function updatePurchaseOrder(rawInput: unknown): Promise<PurchaseOrderResult<PurchaseOrderDetail>> {
   477	  const parsed = UpdatePurchaseOrderInput.safeParse(rawInput);
   478	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   479	  const input = parsed.data;
   480	
   481	  try {
   482	    return await withOrgContext(async ({ userId, orgId, client }): Promise<PurchaseOrderResult<PurchaseOrderDetail>> => {
   483	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   484	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   485	
   486	      const before = await fetchDraftPurchaseOrderForUpdate(ctx.client, input.id);
   487	      if (!before) return { ok: false, error: 'not_found' };
   488	      if (before.status !== 'draft') return { ok: false, error: 'invalid_state', code: 'invalid_state' };
   489	
   490	      if (input.supplierId) {
   491	        const supplierCheck = await ensureSupplierInOrg(ctx.client, input.supplierId);
   492	        if (supplierCheck === 'not_found') return { ok: false, error: 'not_found' };
   493	        if (supplierCheck === 'supplier_blocked' && input.supplierId !== before.supplier_id) {
   494	          return { ok: false, error: 'supplier_blocked', code: 'supplier_blocked', message: 'Supplier is blocked' };
   495	        }
   496	      }
   497	
   498	      const { rows } = await ctx.client.query<PurchaseOrderRow>(
   499	        `update public.purchase_orders
   500	            set supplier_id = coalesce($2::uuid, supplier_id),
   501	                expected_delivery = case when $7::boolean then nullif($3, '')::date else expected_delivery end,
   502	                currency = coalesce($4, currency),
   503	                notes = case when $8::boolean then nullif($5, '') else notes end,
   504	                updated_by = $6::uuid
   505	          where org_id = app.current_org_id()
   506	            and id = $1::uuid
   507	            and status = 'draft'
   508	        returning id, po_number, supplier_id, null::text as supplier_code, null::text as supplier_name,
   509	                  status, expected_delivery::text as expected_delivery, currency, notes, created_at, updated_at`,
   510	        [
   511	          input.id,
   512	          input.supplierId ?? null,
   513	          input.expectedDelivery ?? null,
   514	          input.currency ?? null,
   515	          input.notes ?? null,
   516	          userId,
   517	          input.expectedDelivery !== undefined,
   518	          input.notes !== undefined,
   519	        ],
   520	      );
   521	      const row = rows[0];
   522	      if (!row) return { ok: false, error: 'invalid_state', code: 'invalid_state' };
   523	
   524	      await writeProcurementAudit(ctx, {
   525	        action: 'planning.purchase_order.updated',
   526	        resourceType: 'purchase_order',
   527	        resourceId: row.id,
   528	        beforeState: {
   529	          supplierId: before.supplier_id,
   530	          expectedDelivery: before.expected_delivery,
   531	          currency: before.currency,
   532	          notes: before.notes,
   533	        },
   534	        afterState: {
   535	          supplierId: row.supplier_id,
   536	          expectedDelivery: row.expected_delivery,
   537	          currency: row.currency,
   538	          notes: row.notes,
   539	        },
   540	      });
   541	      revalidatePurchaseOrderPaths(row.id);
   542	      return { ok: true, data: { ...mapPurchaseOrder(row), lines: await fetchLines(ctx.client, row.id) } };
   543	    });
   544	  } catch (err) {
   545	    const error = pgErrorToResult(err);
   780	    return { ok: false, error };
   781	  }
   782	}
   783	
   784	// Server-side state machine for PO status. Terminal states (received, cancelled)
   785	// have no legal successors. The client surfaces only legal transitions, but we
   786	// re-validate here so a forged/stale request can never apply an illegal jump.
   787	const PO_TRANSITIONS: Record<string, readonly string[]> = {
   788	  draft: ['sent', 'cancelled'],
   789	  sent: ['draft', 'confirmed', 'cancelled'],
   790	  confirmed: ['cancelled'],
   791	  partially_received: ['cancelled'],
   792	  received: [],
   793	  cancelled: [],
   794	};
   795	
   796	export async function reopenPurchaseOrder(poId: string): Promise<PurchaseOrderResult<PurchaseOrder>> {
   797	  const parsed = uuidSchema.safeParse(poId);
   798	  if (!parsed.success) return { ok: false, error: 'invalid_input' };
   799	
   800	  try {
   801	    return await withOrgContext(async ({ userId, orgId, client }): Promise<PurchaseOrderResult<PurchaseOrder>> => {
   802	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   803	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   804	
   805	      const before = await fetchDraftPurchaseOrderForUpdate(ctx.client, parsed.data);
   806	      if (!before) return { ok: false, error: 'not_found' };
   807	      // Reopen un-sends a SENT po OR un-cancels a CANCELLED po, both back to
   808	      // draft (the detail UI shows "Przywróć do wersji roboczej" for cancelled).
   809	      // PO_TRANSITIONS treats cancelled as terminal, so this is the dedicated
   810	      // reopen path; the po_has_receipts guard below still blocks reopening a po
   811	      // that has receipts.
   812	      if (before.status !== 'sent' && before.status !== 'cancelled') {
   813	        return { ok: false, error: 'invalid_state', code: 'invalid_state' };
   814	      }
   815	
   816	      const receiptState = await getPurchaseOrderReceiptState(ctx.client, parsed.data);
   817	      if (receiptState.activeReceivedCount > 0 || receiptState.grnLineCount > 0) {
   818	        return { ok: false, error: 'po_has_receipts', code: 'po_has_receipts' };
   819	      }
   820	
   821	      const { rows } = await ctx.client.query<PurchaseOrderRow>(
   822	        `update public.purchase_orders
   823	            set status = 'draft',
   824	                updated_by = $2::uuid
   825	          where org_id = app.current_org_id()
   826	            and id = $1::uuid
   827	            and status in ('sent', 'cancelled')
   828	            and not exists (
   829	              select 1
   830	                from public.grn_items gi
   831	                left join public.grns g
   832	                  on g.org_id = app.current_org_id()
   833	                 and g.id = gi.grn_id
   834	               where gi.org_id = app.current_org_id()
   835	                 and gi.cancelled_at is null
   836	                 and coalesce(g.status, 'draft') <> 'cancelled'
   837	                 and (
   838	                   gi.po_line_id in (
   839	                     select pol.id
   840	                       from public.purchase_order_lines pol
   841	                      where pol.org_id = app.current_org_id()
   842	                        and pol.po_id = $1::uuid
   843	                   )
   844	                   or g.po_id = $1::uuid
   845	                 )
   846	            )
   847	        returning id, po_number, supplier_id, null::text as supplier_code, null::text as supplier_name,
   848	                  status, expected_delivery::text as expected_delivery, currency, notes, created_at, updated_at`,
   849	        [parsed.data, userId],
   850	      );
   851	      const row = rows[0];
   852	      if (!row) {
   853	        const currentReceiptState = await getPurchaseOrderReceiptState(ctx.client, parsed.data);
   854	        if (currentReceiptState.activeReceivedCount > 0 || currentReceiptState.grnLineCount > 0) {
   855	          return { ok: false, error: 'po_has_receipts', code: 'po_has_receipts' };
   856	        }
   857	        return { ok: false, error: 'invalid_state', code: 'invalid_state' };
   858	      }
   859	
   860	      await writeProcurementAudit(ctx, {
   861	        action: 'planning.purchase_order.status_changed',
   862	        resourceType: 'purchase_order',
   863	        resourceId: row.id,
   864	        beforeState: { status: before.status },
   865	        afterState: { status: row.status },
   866	      });
   867	      revalidatePurchaseOrderPaths(row.id);
   868	      return { ok: true, data: mapPurchaseOrder(row) };
   869	    });
   870	  } catch (err) {
   871	    console.error('[planning/purchase-orders] reopenPurchaseOrder failed', err);
   872	    return { ok: false, error: 'persistence_failed' };
   873	  }
   874	}
   875	
   876	export async function transitionPurchaseOrderStatus(id: string, status: string): Promise<PurchaseOrderResult<PurchaseOrder>> {
   877	  const parsed = PurchaseOrderStatusSchema.safeParse(status);
   878	  if (!parsed.success) return { ok: false, error: 'invalid_input' };
   879	
   880	  try {
   881	    return await withOrgContext(async ({ userId, orgId, client }): Promise<PurchaseOrderResult<PurchaseOrder>> => {
   882	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   883	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   884	
   885	      const before = await ctx.client.query<{ status: string }>(
   886	        `select status
   887	           from public.purchase_orders
   888	          where org_id = app.current_org_id()
   889	            and id = $1::uuid
   890	          limit 1
   891	          for update`,
   892	        [id],
   893	      );
   894	      const previous = before.rows[0];
   895	      if (!previous) return { ok: false, error: 'not_found' };
   896	
   897	      if (parsed.data === 'received' || parsed.data === 'partially_received') {
   898	        const receiptState = await getPurchaseOrderReceiptState(ctx.client, id);
   899	        if (parsed.data === 'partially_received' && receiptState.activeReceivedCount === 0) {
   900	          return { ok: false, error: 'po_open_quantity', code: 'po_open_quantity' };
   901	        }
   902	        if (parsed.data === 'received' && !(await isPurchaseOrderFullyReceived(ctx.client, id))) {
   903	          return { ok: false, error: 'po_open_quantity', code: 'po_open_quantity' };
   904	        }
   905	      }
   906	
   907	      // Guard the transition server-side against the legal state machine.
   908	      const allowed = PO_TRANSITIONS[previous.status] ?? [];
   909	      if (!allowed.includes(parsed.data)) return { ok: false, error: 'invalid_state' };
   910	      if (parsed.data === 'cancelled') {
   911	        const receiptState = await getPurchaseOrderReceiptState(ctx.client, id);
   912	        if (receiptState.activeReceivedCount > 0) return { ok: false, error: 'po_has_receipts', code: 'po_has_receipts' };
   913	      }
   914	
   915	      const { rows } = await ctx.client.query<PurchaseOrderRow>(
   916	        `update public.purchase_orders
   917	            set status = $2,
   918	                updated_by = $3::uuid
   919	          where org_id = app.current_org_id()
   920	            and id = $1::uuid
   921	        returning id, po_number, supplier_id, null::text as supplier_code, null::text as supplier_name,
   922	                  status, expected_delivery::text as expected_delivery, currency, notes, created_at, updated_at`,
   923	        [id, parsed.data, userId],
   924	      );
   925	      const row = rows[0];
   926	      if (!row) return { ok: false, error: 'not_found' };
   927	      await writeProcurementAudit(ctx, {
   928	        action: 'planning.purchase_order.status_changed',
   929	        resourceType: 'purchase_order',
   930	        resourceId: row.id,
   931	        beforeState: { status: previous.status },
   932	        afterState: { status: row.status },
   933	      });
   934	      revalidatePurchaseOrderPaths(row.id);
   935	      return { ok: true, data: mapPurchaseOrder(row) };
   936	    });
   937	  } catch (err) {
   938	    console.error('[planning/purchase-orders] transitionPurchaseOrderStatus failed', err);
   939	    return { ok: false, error: 'persistence_failed' };
   940	  }
   941	}
   180	
   181	export async function updateSupplier(rawInput: unknown): Promise<SupplierResult<Supplier>> {
   182	  const parsed = SupplierUpdateInput.safeParse(rawInput);
   183	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
   184	  const input = parsed.data;
   185	
   186	  try {
   187	    return await withOrgContext(async ({ userId, orgId, client }): Promise<SupplierResult<Supplier>> => {
   188	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   189	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   190	
   191	      const before = await ctx.client.query<SupplierRow>(
   192	        `select id, code, name, contact_jsonb, currency, lead_time_days, status, notes, created_at, updated_at
   193	           from public.suppliers
   194	          where org_id = app.current_org_id()
   195	            and id = $1::uuid
   196	          limit 1
   197	          for update`,
   198	        [input.id],
   199	      );
   200	      const previous = before.rows[0];
   201	      if (!previous) return { ok: false, error: 'not_found' };
   202	
   203	      const { rows, rowCount } = await ctx.client.query<SupplierRow>(
   204	        // `code` is the supplier natural key and is referenced by loose text
   205	        // soft-refs (supplier_specs.supplier_code, npd_packaging_components.supplier_code)
   206	        // that have NO FK cascade — editing it would silently desync them, so it is
   207	        // intentionally immutable here (renames would be a separate, cascade-aware op).
   208	        `update public.suppliers
   209	            set name = $2,
   210	                contact_jsonb = $3::jsonb,
   211	                currency = $4,
   212	                lead_time_days = $5::integer,
   213	                status = $6,
   214	                notes = $7,
   215	                updated_by = $8::uuid
   216	          where org_id = app.current_org_id()
   217	            and id = $1::uuid
   218	        returning id, code, name, contact_jsonb, currency, lead_time_days, status, notes, created_at, updated_at`,
   219	        [
   220	          input.id,
   221	          input.name,
   222	          JSON.stringify(input.contact ?? {}),
   223	          input.currency,
   224	          input.leadTimeDays,
   225	          input.status,
   226	          input.notes ?? null,
   227	          userId,
   228	        ],
   229	      );
   230	      const row = rows[0];
   231	      if (rowCount === 0 || !row) return { ok: false, error: 'not_found' };
   232	
   233	      await writeProcurementAudit(ctx, {
   234	        action: 'planning.supplier.updated',
   235	        resourceType: 'supplier',
   236	        resourceId: row.id,
   237	        beforeState: {
   238	          code: previous.code,
   239	          name: previous.name,
   240	          contact: previous.contact_jsonb,
   241	          currency: previous.currency,
   242	          leadTimeDays: Number(previous.lead_time_days),
   243	          status: previous.status,
   244	          notes: previous.notes,
   245	        },
   246	        afterState: {
   247	          code: row.code,
   248	          name: row.name,
   249	          contact: row.contact_jsonb,
   250	          currency: row.currency,
   251	          leadTimeDays: Number(row.lead_time_days),
   252	          status: row.status,
   253	          notes: row.notes,
   254	        },
   255	      });
   256	      revalidateSupplierPaths(row.id);
   257	      return { ok: true, data: mapSupplier(row) };
   258	    });
   259	  } catch (err) {
   260	    const error = pgErrorToResult(err);
   261	    if (error !== 'persistence_failed') return { ok: false, error };
   262	    console.error('[planning/suppliers] updateSupplier failed', err);
   263	    return { ok: false, error };
   264	  }
   265	}
   266	
   267	export async function transitionSupplierStatus(id: string, status: string): Promise<SupplierResult<Supplier>> {
   268	  const parsed = SupplierStatusSchema.safeParse(status);
   269	  if (!parsed.success) return { ok: false, error: 'invalid_input' };
   270	
   271	  try {
   272	    return await withOrgContext(async ({ userId, orgId, client }): Promise<SupplierResult<Supplier>> => {
   273	      const ctx: OrgActionContext = { userId, orgId, client: client as QueryClient };
   274	      if (!(await hasPlanningWritePermission(ctx))) return { ok: false, error: 'forbidden' };
   275	
   276	      const before = await ctx.client.query<{ status: string }>(
   277	        `select status from public.suppliers where org_id = app.current_org_id() and id = $1::uuid limit 1`,
   278	        [id],
   279	      );
   280	      const previous = before.rows[0];
   281	      if (!previous) return { ok: false, error: 'not_found' };
   282	
   283	      const { rows } = await ctx.client.query<SupplierRow>(
   284	        `update public.suppliers
   285	            set status = $2,
   286	                updated_by = $3::uuid
   287	          where org_id = app.current_org_id()
   288	            and id = $1::uuid
   289	        returning id, code, name, contact_jsonb, currency, lead_time_days, status, notes, created_at, updated_at`,
   290	        [id, parsed.data, userId],
   291	      );
   292	      const row = rows[0];
   293	      if (!row) return { ok: false, error: 'not_found' };
   294	      await writeProcurementAudit(ctx, {
   295	        action: 'planning.supplier.status_changed',
   296	        resourceType: 'supplier',
   297	        resourceId: row.id,
   298	        beforeState: { status: previous.status },
   299	        afterState: { status: row.status },
   300	      });
   301	      revalidateSupplierPaths(row.id);
   302	      return { ok: true, data: mapSupplier(row) };
   303	    });
   304	  } catch (err) {
   305	    console.error('[planning/suppliers] transitionSupplierStatus failed', err);
   306	    return { ok: false, error: 'persistence_failed' };
   307	  }
   308	}
