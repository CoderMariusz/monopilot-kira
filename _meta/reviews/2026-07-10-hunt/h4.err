   404	
   405	function isValidUomForItem(uom: string, item: ItemLookupRow, units: Set<string>): boolean {
   406	  const normalizedUom = normalizePieceUom(uom) ?? uom;
   407	  const itemUoms = new Set(
   408	    [normalizeText(item.uom_base), normalizeText(item.uom_secondary)]
   409	      .filter((value) => value.length > 0)
   410	      .map((value) => normalizePieceUom(value) ?? value),
   411	  );
   412	  const orgUnits = new Set([...units].map((code) => normalizePieceUom(code) ?? code));
   413	  return itemUoms.has(normalizedUom) || orgUnits.has(normalizedUom);
   414	}
   415	
   416	function normalizeText(value: string | undefined | null): string {
   417	  return typeof value === 'string' ? value.trim() : '';
   418	}
   419	
   420	function uniqueNormalized(values: string[]): string[] {
   421	  return Array.from(new Set(values.map(normalizeText).filter((value) => value.length > 0)));
   422	}
   423	
   424	function isValidIsoDate(value: string): boolean {
   425	  if (!/^\d{4}-\d{2}-\d{2}$/.test(value)) return false;
   426	  const date = new Date(`${value}T00:00:00.000Z`);
   427	  return Number.isFinite(date.getTime()) && date.toISOString().slice(0, 10) === value;
   428	}
   429	
   430	function todayUtcDate(): string {
   431	  const now = new Date();
   432	  return new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate())).toISOString().slice(0, 10);
   433	}
   434	
   435	function decimalPlaces(value: number): number {
   436	  const plain = numberToPlainString(value);
   437	  const [, fraction = ''] = plain.split('.');
   438	  return fraction.replace(/0+$/, '').length;
   439	}
   440	
   441	function numberToPlainString(value: number): string {
   442	  if (!Number.isFinite(value)) return String(value);
   443	  const raw = String(value);
   444	  if (!/[eE]/.test(raw)) return raw;
   445	  return value.toLocaleString('en-US', {
   446	    useGrouping: false,
   447	    maximumFractionDigits: 20,
   448	  });
   449	}
