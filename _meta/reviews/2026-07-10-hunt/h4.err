   322	
   323	async function findExistingTransferOrderRefs(client: QueryClient, rawRefs: string[]): Promise<Set<string>> {
   324	  const refs = uniqueNormalized(rawRefs);
   325	  if (refs.length === 0) return new Set();
   326	  const { rows } = await client.query<ExistingTransferOrderRow>(
   327	    `select to_number
   328	       from public.transfer_orders
   329	      where org_id = app.current_org_id()
   330	        and to_number = any($1::text[])`,
   331	    [refs],
   332	  );
   333	  return new Set(rows.map((row) => row.to_number));
   334	}
   335	
   336	async function insertImportJob(
   337	  client: QueryClient,
   338	  input: {
   339	    userId: string;
   340	    total: number;
   341	    createdCount: number;
   342	    skippedCount: number;
   343	    failedCount: number;
   344	    createdExternalRefs: string[];
   345	  },
   346	): Promise<void> {
   347	  await client.query(
   348	    `insert into public.import_export_jobs
   349	       (org_id, kind, target, status, progress_processed, progress_total, download_url, created_by, completed_at, metadata)
   350	     values
   351	       (app.current_org_id(), 'import', 'transfer_orders', 'completed', $1::integer, $1::integer, null, $2::uuid, pg_catalog.now(), $3::jsonb)`,
   352	    [
   353	      input.total,
   354	      input.userId,
   355	      JSON.stringify({
   356	        total: input.total,
   357	        created_count: input.createdCount,
   358	        skipped_count: input.skippedCount,
   359	        failed_count: input.failedCount,
   360	        created_external_refs: input.createdExternalRefs,
   361	      }),
   362	    ],
   363	  );
   364	}
   365	
   366	function groupRows(rows: ValidImportRow[]): ImportGroup[] {
   367	  const groups = new Map<string, ImportGroup>();
   368	  for (const row of rows) {
   369	    const key = `${row.fromWarehouseCode}\u0000${row.toWarehouseCode}\u0000${row.externalRef}`;
   370	    const group = groups.get(key);
   371	    if (group) {
   372	      group.rows.push(row);
   373	    } else {
   374	      groups.set(key, {
   375	        fromWarehouseCode: row.fromWarehouseCode,
   376	        toWarehouseCode: row.toWarehouseCode,
   377	        externalRef: row.externalRef,
   378	        rows: [row],
   379	      });
   380	    }
   381	  }
   382	  return Array.from(groups.values());
   383	}
