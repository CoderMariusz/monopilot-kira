    98	        externalRef: normalizeText(row.external_ref),
    99	        fromWarehouseCode: normalizeText(row.from_warehouse_code),
   100	        toWarehouseCode: normalizeText(row.to_warehouse_code),
   101	        itemCode: normalizeText(row.item_code),
   102	        uom: normalizeText(row.uom),
   103	      };
   104	    })
   105	    .filter((row): row is ValidImportRow => row !== null);
   106	
   107	  return withOrgContext(async ({ userId, orgId, client }): Promise<ToImportResult> => {
   108	    const ctx: OrgActionContext = { userId, orgId, client: client as unknown as QueryClient };
   109	    await requirePlanningWritePermission(ctx);
   110	
   111	    const created: ToImportResult['created'] = [];
   112	    const skipped: ToImportResult['skipped'] = [];
   113	    const skippedRefs = new Set<string>();
   114	    const runtimeFailed: ToImportResult['failed'] = [...failed];
   115	
   116	    const existingRefs = await findExistingTransferOrderRefs(ctx.client, validRows.map((row) => row.externalRef));
   117	    const rowsToCreate = validRows.filter((row) => {
   118	      if (!existingRefs.has(row.externalRef)) return true;
   119	      if (!skippedRefs.has(row.externalRef)) {
   120	        skipped.push({ external_ref: row.externalRef, reason: `Transfer order already exists for external_ref "${row.externalRef}".` });
   121	        skippedRefs.add(row.externalRef);
   122	      }
   123	      return false;
   124	    });
   125	
   126	    const [warehouses, items] = await Promise.all([
   127	      loadWarehouses(ctx.client, rowsToCreate.flatMap((row) => [row.fromWarehouseCode, row.toWarehouseCode])),
   128	      loadActiveItems(ctx.client, rowsToCreate.map((row) => row.itemCode)),
   129	    ]);
   130	
   131	    for (const group of groupRows(rowsToCreate)) {
   132	      const fromWarehouse = warehouses.get(group.fromWarehouseCode);
   133	      const toWarehouse = warehouses.get(group.toWarehouseCode);
   134	      if (!fromWarehouse) {
   135	        failGroup(runtimeFailed, group, 'from_warehouse_code', `Warehouse code "${group.fromWarehouseCode}" was not found for this org.`);
   136	        continue;
   137	      }
   138	      if (!toWarehouse) {
   139	        failGroup(runtimeFailed, group, 'to_warehouse_code', `Warehouse code "${group.toWarehouseCode}" was not found for this org.`);
   140	        continue;
   141	      }
   142	      if (fromWarehouse.id === toWarehouse.id) {
   143	        failGroup(runtimeFailed, group, 'to_warehouse_code', 'Transfer source and destination warehouses must differ.');
   144	        continue;
   145	      }
   146	
   147	      const lineInputs: CreateTransferOrderLinePayload[] = [];
   148	      let groupHasLookupFailure = false;
   149	      for (const entry of group.rows) {
   150	        const item = items.get(entry.itemCode);
   151	        if (!item) {
   152	          runtimeFailed.push({
   153	            rowNumber: entry.rowNumber,
   154	            errors: [{ column: 'item_code', message: `Item code "${entry.itemCode}" is not an active item for this org.` }],
   155	          });
   156	          groupHasLookupFailure = true;
   157	          continue;
   158	        }
   159	        lineInputs.push({
   160	          itemId: item.id,
   161	          qty: numberToPlainString(entry.row.qty),
   162	          uom: entry.uom,
   163	          lineNo: lineInputs.length + 1,
   164	        });
   165	      }
   166	      if (groupHasLookupFailure) continue;
   167	
   168	      const result = await createTransferOrder({
   169	        toNumber: group.externalRef,
   170	        fromWarehouseId: fromWarehouse.id,
   171	        toWarehouseId: toWarehouse.id,
   172	        status: 'draft',
   173	        scheduledDate: firstText(group.rows, (entry) => entry.row.date),
   174	        lines: lineInputs,
   175	      });
   176	
   177	      if (result.ok) {
   178	        created.push({ to_number: result.data.toNumber, external_ref: group.externalRef });
   179	        continue;
   180	      }
   181	
   182	      failGroup(
   183	        runtimeFailed,
   184	        group,
   185	        'external_ref',
   186	        `Could not create transfer order for external_ref "${group.externalRef}": ${result.message ?? result.error}.`,
   187	      );
   188	    }
   189	
   190	    await insertImportJob(ctx.client, {
   191	      userId,
   192	      total: validation.summary.total,
   193	      createdCount: created.length,
   194	      skippedCount: skipped.length,
   195	      failedCount: runtimeFailed.length,
   196	      createdExternalRefs: created.map((row) => row.external_ref),
   197	    });
   198	
   199	    return { created, skipped, failed: runtimeFailed };
   200	  });
   201	}
   202	
   203	async function requirePlanningWritePermission(ctx: OrgActionContext): Promise<void> {
   204	  if (!(await hasPlanningWritePermission(ctx))) {
   205	    throw new ToImportForbiddenError();
   206	  }
   207	}
   208	
   209	async function validateRows(client: QueryClient, rows: ToImportRow[]): Promise<ToValidationResult> {
   210	  const [warehouses, items, units] = await Promise.all([
   315	      where org_id = app.current_org_id()
   316	        and deleted_at is null
   317	        and code = any($1::text[])`,
   318	    [codes],
   319	  );
   320	  return new Set(rows.map((row) => row.code));
