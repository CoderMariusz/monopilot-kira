   224	function validateRow(
   225	  row: ToImportRow,
   226	  warehouses: Map<string, WarehouseLookupRow>,
   227	  items: Map<string, ItemLookupRow>,
   228	  units: Set<string>,
   229	): ToImportError[] {
   230	  const errors: ToImportError[] = [];
   231	
   232	  const externalRef = normalizeText(row.external_ref);
   233	  if (!externalRef) errors.push({ column: 'external_ref', message: 'External reference is required.' });
   234	
   235	  const fromWarehouseCode = normalizeText(row.from_warehouse_code);
   236	  const toWarehouseCode = normalizeText(row.to_warehouse_code);
   237	  const fromWarehouse = warehouses.get(fromWarehouseCode);
   238	  const toWarehouse = warehouses.get(toWarehouseCode);
   239	  if (!fromWarehouseCode) {
   240	    errors.push({ column: 'from_warehouse_code', message: 'Source warehouse code is required.' });
   241	  } else if (!fromWarehouse) {
   242	    errors.push({ column: 'from_warehouse_code', message: `Warehouse code "${fromWarehouseCode}" was not found for this org.` });
   243	  }
   244	  if (!toWarehouseCode) {
   245	    errors.push({ column: 'to_warehouse_code', message: 'Destination warehouse code is required.' });
   246	  } else if (!toWarehouse) {
   247	    errors.push({ column: 'to_warehouse_code', message: `Warehouse code "${toWarehouseCode}" was not found for this org.` });
   248	  }
   249	  if (fromWarehouse && toWarehouse && fromWarehouse.id === toWarehouse.id) {
   250	    errors.push({ column: 'to_warehouse_code', message: 'Transfer source and destination warehouses must differ.' });
   251	  }
   252	
   253	  const itemCode = normalizeText(row.item_code);
   254	  const item = items.get(itemCode);
   255	  if (!itemCode) {
   256	    errors.push({ column: 'item_code', message: 'Item code is required.' });
   257	  } else if (!item) {
   258	    errors.push({ column: 'item_code', message: `Item code "${itemCode}" is not an active item for this org.` });
   259	  }
   260	
   261	  const uom = normalizeText(row.uom);
   262	  if (!uom) {
   263	    errors.push({ column: 'uom', message: 'UoM is required.' });
