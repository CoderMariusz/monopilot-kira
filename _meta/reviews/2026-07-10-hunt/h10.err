 succeeded in 0ms:
     1	'use server';
     2	
     3	import { withOrgContext } from '../../lib/auth/with-org-context';
     4	import { isStrongPassword } from './password-policy';
     5	import { SYSTEM_ROLE_CODES_FORBIDDEN_AS_DEFAULT } from './user-role-policy';
     6	import { createSupabaseAuthAdmin } from './supabase-admin';
     7	
     8	/**
     9	 * createUserWithPassword — admin-only "create a user directly with a password,
    10	 * without sending an invite email".
    11	 *
    12	 * This is an ADDITIONAL admin option that lives alongside (and never weakens)
    13	 * the email-invite path in `invite.ts`. Where `inviteUser` mints a Supabase
    14	 * invite magic-link and provisions an INACTIVE `public.users` row carrying an
    15	 * `invite_token`, this action:
    16	 *
    17	 *   1. Verifies the caller holds the SAME admin gate the invite path uses
    18	 *      (`settings.users.invite`) in the caller's current org.
    19	 *   2. Creates the auth user server-side with the SERVICE-ROLE admin client via
    20	 *      `supabase.auth.admin.createUser({ email, password, email_confirm: true })`
    21	 *      — `email_confirm: true` confirms the address WITHOUT sending any email.
    22	 *   3. Provisions the matching ACTIVE `public.users` row (is_active = true, no
    23	 *      invite_token) plus the `public.user_roles` junction row, org-scoped and
    24	 *      RLS-safe, mirroring the invite + assign-role provisioning.
    25	 *
    26	 * SECURITY (critical):
    27	 *   - The service-role key is read ONLY here, server-side; it is never exposed
    28	 *     to the client. The action is a `'use server'` module.
    29	 *   - The admin gate is checked INSIDE the org-context transaction BEFORE any
    30	 *     auth user is created. A non-admin caller never reaches `createUser`.
    31	 *   - The new user is scoped to the CALLER's org (resolved by withOrgContext),
    32	 *     never an org supplied by the client.
    33	 *   - If a Supabase auth user is created but DB provisioning fails, the orphan
    34	 *     auth user is best-effort deleted so a half-provisioned identity cannot
    35	 *     log in with no org row (withOrgContext would then reject it anyway).
    36	 */
    37	
    38	const CREATE_PERMISSION = 'settings.users.invite';
    39	const SUPER_ROLE_CODES = ['owner', 'admin', 'org_admin'] as const;
    40	
    41	export type CreateUserWithPasswordInput = {
    42	  email: string;
    43	  password: string;
    44	  name?: string;
    45	  roleId?: string;
    46	  language?: string;
    47	};
    48	
    49	export type CreateUserWithPasswordResult =
    50	  | { ok: true; data: { email: string; userId: string } }
    51	  | {
    52	      ok: false;
    53	      error:
    54	        | 'invalid_input'
    55	        | 'weak_password'
    56	        | 'forbidden'
    57	        | 'forbidden_role' // role is in SYSTEM_ROLE_CODES_FORBIDDEN_AS_DEFAULT — valid UUID but not self-serveable
    58	        | 'seat_limit_exceeded'
    59	        | 'email_taken'
    60	        | 'service_unavailable'
    61	        | 'create_failed'
    62	        | 'persistence_failed';
    63	    };
    64	
    65	type OrganizationSeatRow = { seat_limit: number | null };
    66	
    67	type RoleRow = {
    68	  id: string;
    69	  org_id: string;
    70	  code: string;
    71	  is_system: boolean;
    72	  display_order: number | null;
    73	};
    74	
    75	type QueryClient = {
    76	  query<T = Record<string, unknown>>(
    77	    sql: string,
    78	    params?: readonly unknown[],
    79	  ): Promise<{ rows: T[]; rowCount?: number | null }>;
    80	};
    81	
    82	function normalizeEmail(value: unknown): string | null {
    83	  if (typeof value !== 'string') return null;
    84	  const email = value.trim().toLowerCase();
    85	  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email) ? email : null;
    86	}
    87	
    88	function normalizeString(value: unknown): string | null {
    89	  if (typeof value !== 'string') return null;
    90	  const trimmed = value.trim();
    91	  return trimmed.length > 0 ? trimmed : null;
    92	}
    93	
    94	/**
    95	 * Service-role Supabase admin client. Mirrors the canonical factory used by
    96	 * `actions/onboarding/complete-onboarding.ts`. Reads the service-role key from
    97	 * the server-only env var and disables session persistence/refresh (this is a
    98	 * one-shot privileged call, not a user session).
    99	 *
   100	 * Throws when the service-role env is absent so the caller can surface
   101	 * `service_unavailable` instead of silently degrading to the anon key (which
   102	 * would make `auth.admin.createUser` fail closed in a confusing way).
   103	 */
   104	// (Factory moved to ./supabase-admin — shared with the invite path since f4.1.)
   105	
   106	async function hasSuperRole(client: QueryClient, userId: string, orgId: string): Promise<boolean> {
   107	  const { rows } = await client.query<{ ok: boolean }>(
   108	    `select true as ok
   109	       from public.user_roles ur
   110	       join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
   111	      where ur.user_id = $1::uuid
   112	        and ur.org_id = $2::uuid
   113	        and (r.code = any($3::text[]) or r.slug = any($3::text[]))
   114	      limit 1`,
   115	    [userId, orgId, SUPER_ROLE_CODES],
   116	  );
   117	  return rows[0]?.ok === true;
   118	}
   119	
   120	async function readCallerPermissions(client: QueryClient, userId: string, orgId: string): Promise<Set<string>> {
   121	  const { rows } = await client.query<{ permission: string }>(
   122	    `select distinct permission
   123	       from (
   124	         select rp.permission
   125	           from public.user_roles ur
   126	           join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
   127	           join public.role_permissions rp on rp.role_id = r.id
   128	          where ur.user_id = $1::uuid
   129	            and ur.org_id = $2::uuid
   130	         union
   131	         select jsonb_array_elements_text(coalesce(r.permissions, '[]'::jsonb)) as permission
   132	           from public.user_roles ur
   133	           join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
   134	          where ur.user_id = $1::uuid
   135	            and ur.org_id = $2::uuid
   136	       ) grants
   137	      where permission is not null`,
   138	    [userId, orgId],
   139	  );
   140	  return new Set(rows.map((row) => row.permission));
   141	}
   142	
   143	async function readRolePermissions(client: QueryClient, roleId: string): Promise<string[]> {
   144	  const { rows } = await client.query<{ permission: string }>(
   145	    `select distinct permission
   146	       from (
   147	         select rp.permission
   148	           from public.role_permissions rp
   149	           join public.roles r on r.id = rp.role_id
   150	          where r.org_id = app.current_org_id()
   151	            and r.id = $1::uuid
   152	         union
   153	         select jsonb_array_elements_text(coalesce(r.permissions, '[]'::jsonb)) as permission
   154	           from public.roles r
   155	          where r.org_id = app.current_org_id()
   156	            and r.id = $1::uuid
   157	       ) grants
   158	      where permission is not null
   159	      order by permission`,
   160	    [roleId],
   161	  );
   162	  return rows.map((row) => row.permission);
   163	}
   164	
   165	export async function createUserWithPassword(
   166	  input: CreateUserWithPasswordInput,
   167	): Promise<CreateUserWithPasswordResult> {
   168	  const email = normalizeEmail(input?.email);
   169	  if (!email) {
   170	    return { ok: false, error: 'invalid_input' };
   171	  }
   172	
   173	  const requestedRoleId = normalizeString(input?.roleId);
   174	  if (!requestedRoleId) {
   175	    return { ok: false, error: 'invalid_input' };
   176	  }
   177	
   178	  if (!isStrongPassword(input?.password)) {
   179	    return { ok: false, error: 'weak_password' };
   180	  }
   181	  const password = input.password;
   182	
   183	  const name = normalizeString(input?.name) ?? email;
   184	  const language = normalizeString(input?.language) ?? 'pl';
   185	
   186	  return withOrgContext(async ({ userId, orgId, client }) => {
   187	    // ── Admin gate (same permission the invite path uses), checked BEFORE any
   188	    //    auth user is created. Fail-closed: an explicit grant of
   189	    //    settings.users.invite via role_permissions, role code/slug, or the
   190	    //    role's jsonb permissions array. ───────────────────────────────────
   191	    const { rows: permRows } = await client.query<{ ok: boolean }>(
   192	      `select true as ok
   193	         from public.user_roles ur
   194	         join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
   195	         left join public.role_permissions rp on rp.role_id = r.id and rp.permission = $3
   196	        where ur.user_id = $1::uuid
   197	          and ur.org_id = $2::uuid
   198	          and (
   199	            rp.permission is not null
   200	            or r.code = $3
   201	            or r.slug = $3
   202	            or coalesce(r.permissions, '[]'::jsonb) ? $3
   203	          )
   204	        limit 1`,
   205	      [userId, orgId, CREATE_PERMISSION],
   206	    );
   207	    if (permRows.length === 0) {
   208	      return { ok: false, error: 'forbidden' };
   209	    }
   210	
   211	    // ── Resolve + validate the requested role belongs to the caller's org and
   212	    //    is not a privileged system role that must not be self-served. ──────
   213	    const { rows: roleRows } = await client.query<RoleRow>(
   214	      `select id, org_id, code, is_system, display_order
   215	         from public.roles
   216	        where id = $1::uuid`,
   217	      [requestedRoleId],
   218	    );
   219	    const role = roleRows[0];
   220	    if (!role || role.org_id !== orgId) {
   221	      return { ok: false, error: 'invalid_input' };
   222	    }
   223	    if (SYSTEM_ROLE_CODES_FORBIDDEN_AS_DEFAULT.has(role.code)) {
   224	      // Dedicated code so the UI can surface "this role cannot be self-served"
   225	      // rather than the opaque invalid_input that gives no field-level guidance.
   226	      return { ok: false, error: 'forbidden_role' };
   227	    }
   228	    const roleId = role.id;
   229	
   230	    // Match the role editor's grantable-subset rule: super roles may assign any
   231	    // non-system business role; other assigners may only assign roles whose
   232	    // permissions are all already present in their own grant set.
   233	    if (!(await hasSuperRole(client, userId, orgId))) {
   234	      const [callerPermissions, targetPermissions] = await Promise.all([
   235	        readCallerPermissions(client, userId, orgId),
   236	        readRolePermissions(client, roleId),
   237	      ]);
   238	      if (targetPermissions.some((permission) => !callerPermissions.has(permission))) {
   239	        return { ok: false, error: 'forbidden_role' };
   240	      }
   241	    }
   242	
   243	    // ── Reject duplicate email within the org before touching Supabase Auth. ─
   244	    const { rows: existingRows } = await client.query<{ id: string }>(
   245	      `select id from public.users where org_id = $1::uuid and email = $2::citext limit 1`,
   246	      [orgId, email],
   247	    );
   248	    if (existingRows.length > 0) {
   249	      return { ok: false, error: 'email_taken' };
   250	    }
   251	
   252	    // ── Seat-limit pre-flight (mirror invite path): count active users. The
   253	    //    new user is created ACTIVE, so it consumes a seat immediately. ──────
   254	    const { rows: seatRows } = await client.query<OrganizationSeatRow>(
   255	      `select seat_limit from public.organizations where id = $1::uuid`,
   256	      [orgId],
   257	    );
   258	    const seatLimit = seatRows[0]?.seat_limit ?? null;
   259	    const { rows: countRows } = await client.query<{ active_user_count: string | number }>(
   260	      `select count(*) as active_user_count
   261	         from public.users
   262	        where org_id = $1::uuid
   263	          and is_active = true`,
   264	      [orgId],
   265	    );
   266	    const activeUserCount = Number(countRows[0]?.active_user_count ?? 0);
   267	    if (seatLimit !== null && activeUserCount >= seatLimit) {
   268	      return { ok: false, error: 'seat_limit_exceeded' };
   269	    }
   270	
   271	    // ── Create the auth user WITHOUT an invite email. email_confirm: true
   272	    //    confirms the address so the account is usable immediately and no
   273	    //    confirmation mail is dispatched. ────────────────────────────────────
   274	    let supabase: Awaited<ReturnType<typeof createSupabaseAuthAdmin>>;
   275	    try {
   276	      supabase = await createSupabaseAuthAdmin();
   277	    } catch {
   278	      return { ok: false, error: 'service_unavailable' };
   279	    }
   280	
   281	    const created = await supabase.auth.admin.createUser({
   282	      email,
   283	      password,
   284	      email_confirm: true,
   285	      user_metadata: { org_id: orgId, created_by: userId, name },
   286	    });
   287	    if (created.error || !created.data?.user?.id) {
   288	      const message = created.error?.message?.toLowerCase() ?? '';
   289	      if (message.includes('already') || message.includes('registered') || message.includes('exists')) {
   290	        return { ok: false, error: 'email_taken' };
   291	      }
   292	      return { ok: false, error: 'create_failed' };
   293	    }
   294	    const authUserId = created.data.user.id;
   295	
   296	    try {
   297	      // id must equal the Supabase auth user UUID so that withOrgContext (which
   298	      // queries `public.users where id = auth_user_id`) can resolve the org for
   299	      // this user when they sign in. Without this, the random gen_random_uuid()
   300	      // default would create a mismatch, causing withOrgContext to throw for
   301	      // every login AND causing reactivateUser's auth-identity guard to return
   302	      // auth_identity_missing (it calls getUserById(public.users.id) which must
   303	      // be the auth UUID to succeed).
   304	      const inserted = await client.query<{ id: string }>(
   305	        `insert into public.users
   306	           (id, org_id, email, name, role_id, language, is_active, invite_token, invite_token_expires_at, updated_at)
   307	         values ($1::uuid, $2::uuid, $3::citext, $4, $5::uuid, $6, true, null, null, now())
   308	         returning id`,
   309	        [authUserId, orgId, email, name, roleId, language],
   310	      );
   311	      const newUserId = inserted.rows[0]?.id;
   312	      if (!newUserId) {
   313	        throw new Error('public.users insert returned no id');
   314	      }
   315	
   316	      await client.query(
   317	        `insert into public.user_roles (user_id, role_id, org_id)
   318	         values ($1::uuid, $2::uuid, $3::uuid)
   319	         on conflict (user_id, role_id) do update set org_id = excluded.org_id`,
   320	        [newUserId, roleId, orgId],
   321	      );
   322	
   323	      await client.query(
   324	        `insert into public.audit_log
   325	           (org_id, actor_user_id, actor_type, action, resource_type, resource_id, before_state, after_state, retention_class)
   326	         values ($1::uuid, $2::uuid, 'user', $3, 'org_security_policies', $4, null, $5::jsonb, 'security')`,
   327	        [
   328	          orgId,
   329	          userId,
   330	          'settings.user.created_with_password',
   331	          newUserId,
   332	          JSON.stringify({
   333	            org_id: orgId,
   334	            email,
   335	            role_id: roleId,
   336	            created_by: userId,
   337	            auth_user_id: authUserId,
   338	            email_confirmed: true,
   339	            invite_email_sent: false,
   340	          }),
   341	        ],
   342	      );
   343	
   344	      await client.query(
   345	        `insert into public.outbox_events
   346	           (org_id, event_type, aggregate_type, aggregate_id, payload, app_version)
   347	         values ($1::uuid, $2, 'user', $3::uuid, $4::jsonb, 'settings-create-user-with-password-v1')`,
   348	        [
   349	          orgId,
   350	          'settings.user.created_with_password',
   351	          newUserId,
   352	          JSON.stringify({
   353	            org_id: orgId,
   354	            email,
   355	            created_by: userId,
   356	            auth_user_id: authUserId,
   357	            invite_email_sent: false,
   358	          }),
   359	        ],
   360	      );
   361	
   362	      return { ok: true, data: { email, userId: newUserId } };
   363	    } catch {
   364	      // DB provisioning failed AFTER the auth user was created. Best-effort
   365	      // delete the orphan so a half-provisioned identity can't authenticate
   366	      // against an org with no public.users row.
   367	      try {
   368	        await supabase.auth.admin.deleteUser(authUserId);
   369	      } catch {
   370	        /* noop — orphan cleanup is best-effort */
   371	      }
   372	      return { ok: false, error: 'persistence_failed' };
   373	    }
   374	  });
   375	}
     1	'use server';
     2	
     3	import { hasAnyPermission } from '../../lib/auth/has-permission';
     4	import { withOrgContext } from '../../lib/auth/with-org-context';
     5	
     6	const FORBIDDEN = 'forbidden' as const;
     7	
     8	const DEACTIVATE_PERMISSIONS = ['org.access.admin', 'settings.users.deactivate'] as const;
     9	
    10	type QueryClient = {
    11	  query<T = unknown>(sql: string, values?: readonly unknown[]): Promise<{ rows: T[]; rowCount?: number | null }>;
    12	};
    13	
    14	export type DeactivateUserInput = {
    15	  targetUserId: string;
    16	};
    17	
    18	export type DeactivateUserResult =
    19	  | { ok: true; data: { targetUserId: string; deactivated: true } }
    20	  | {
    21	      ok: false;
    22	      error: 'invalid_input' | 'forbidden' | 'self_deactivation' | 'not_found' | 'persistence_failed';
    23	    };
    24	
    25	function normalizeId(value: unknown): string | null {
    26	  if (typeof value !== 'string') return null;
    27	  const trimmed = value.trim();
    28	  return trimmed.length > 0 ? trimmed : null;
    29	}
    30	
    31	async function isLastOwnerViolation(
    32	  client: QueryClient,
    33	  targetUserId: string,
    34	  orgId: string,
    35	): Promise<boolean> {
    36	  const { rows } = await client.query<{ last_owner_violation: boolean }>(
    37	    `with locked_active_owners as (
    38	        select distinct u.id as user_id
    39	          from public.user_roles ur
    40	          join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
    41	          join public.users u on u.id = ur.user_id and u.org_id = ur.org_id
    42	         where ur.org_id = $2::uuid
    43	           and u.is_active = true
    44	           and (r.code = 'owner' or r.slug = 'owner')
    45	         for update of u
    46	      ),
    47	      target_is_active_owner as (
    48	        select exists (
    49	          select 1
    50	            from locked_active_owners lao
    51	           where lao.user_id = $1::uuid
    52	        ) as value
    53	      ),
    54	      other_active_owner_count as (
    55	        select count(distinct user_id)::int as value
    56	          from locked_active_owners
    57	         where user_id <> $1::uuid
    58	      )
    59	      select coalesce((select value from target_is_active_owner), false)
    60	           and coalesce((select value from other_active_owner_count), 0) = 0 as last_owner_violation`,
    61	    [targetUserId, orgId],
    62	  );
    63	  return rows[0]?.last_owner_violation === true;
    64	}
    65	
    66	export async function deactivateUser(input: DeactivateUserInput): Promise<DeactivateUserResult> {
    67	  const targetUserId = normalizeId(input?.targetUserId);
    68	  if (!targetUserId) {
    69	    return { ok: false, error: 'invalid_input' };
    70	  }
    71	
    72	  return withOrgContext(async ({ userId, orgId, client }) => {
    73	    try {
    74	      const permCtx = { client, userId, orgId };
    75	      if (!(await hasAnyPermission(permCtx, [...DEACTIVATE_PERMISSIONS]))) {
    76	        return { ok: false, error: 'forbidden' };
    77	      }
    78	
    79	      if (targetUserId === userId) {
    80	        return { ok: false, error: 'self_deactivation' };
    81	      }
    82	
    83	      if (await isLastOwnerViolation(client, targetUserId, orgId)) {
    84	        return { ok: false, error: 'forbidden' };
    85	      }
    86	
    87	      const { rows } = await client.query<{ id: string }>(
    88	        `update public.users
    89	            set is_active = false,
    90	                updated_at = now()
    91	          where id = $1::uuid
    92	            and org_id = $2::uuid
    93	        returning id`,
    94	        [targetUserId, orgId],
    95	      );
    96	      if (rows.length === 0) {
    97	        return { ok: false, error: 'not_found' };
    98	      }
    99	
   100	      await client.query(
   101	        `insert into public.audit_log
   102	           (org_id, actor_user_id, actor_type, action, resource_type, resource_id, before_state, after_state, retention_class)
   103	         values ($1::uuid, $2::uuid, 'user', $3, 'org_security_policies', $4, null, $5::jsonb, 'security')`,
   104	        [
   105	          orgId,
   106	          userId,
   107	          'settings.user.deactivated',
   108	          targetUserId,
   109	          JSON.stringify({ org_id: orgId, target_user_id: targetUserId, actor_user_id: userId, is_active: false }),
   110	        ],
   111	      );
   112	
   113	      await client.query(
   114	        `insert into public.outbox_events
   115	           (org_id, event_type, aggregate_type, aggregate_id, payload, app_version)
   116	         values ($1::uuid, $2, 'user', $3::uuid, $4::jsonb, 'settings-deactivate-user-v1')`,
   117	        [
   118	          orgId,
   119	          'settings.user.deactivated',
   120	          targetUserId,
   121	          JSON.stringify({
   122	            org_id: orgId,
   123	            target_user_id: targetUserId,
   124	            actor_user_id: userId,
   125	          }),
   126	        ],
   127	      );
   128	
   129	      return { ok: true, data: { targetUserId, deactivated: true } };
   130	    } catch (error) {
   131	      if (error === FORBIDDEN) {
   132	        return { ok: false, error: 'forbidden' };
   133	      }
   134	      return { ok: false, error: 'persistence_failed' };
   135	    }
   136	  });
   137	}
     1	'use server';
     2	
     3	import { withOrgContext } from '../../lib/auth/with-org-context';
     4	import { revalidateLocalized } from '../../lib/i18n/revalidate-localized';
     5	import type { ReactivateUserInput, ReactivateUserResult } from './user-lifecycle.types';
     6	
     7	const FORBIDDEN = 'forbidden' as const;
     8	
     9	type QueryClient = {
    10	  query<T = unknown>(sql: string, values?: readonly unknown[]): Promise<{ rows: T[]; rowCount?: number | null }>;
    11	};
    12	
    13	type PermissionContext = {
    14	  client: QueryClient;
    15	  userId: string;
    16	  orgId: string;
    17	};
    18	
    19	function normalizeId(value: unknown): string | null {
    20	  if (typeof value !== 'string') return null;
    21	  const trimmed = value.trim();
    22	  return trimmed.length > 0 ? trimmed : null;
    23	}
    24	
    25	/** Throws FORBIDDEN unless the caller holds at least one of the given permissions. */
    26	async function requireAnyPermission(ctx: PermissionContext, permissions: [string, ...string[]]): Promise<void> {
    27	  for (const permission of permissions) {
    28	    const { rows } = await ctx.client.query<{ ok: boolean }>(
    29	      `select true as ok
    30	         from public.user_roles ur
    31	         join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
    32	         left join public.role_permissions rp on rp.role_id = r.id and rp.permission = $3
    33	        where ur.user_id = $1::uuid
    34	          and ur.org_id = $2::uuid
    35	          and (
    36	            rp.permission is not null
    37	            or r.code = $3
    38	            or r.slug = $3
    39	            or r.permissions ? $3
    40	          )
    41	        limit 1`,
    42	      [ctx.userId, ctx.orgId, permission],
    43	    );
    44	    if (rows.length > 0) return;
    45	  }
    46	  throw FORBIDDEN;
    47	}
    48	
    49	async function createSupabaseAuthAdmin() {
    50	  const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
    51	  const serviceRoleKey = process.env.SUPABASE_SERVICE_ROLE_KEY;
    52	  if (!supabaseUrl || !serviceRoleKey) {
    53	    throw new Error('reactivateUser requires Supabase service-role env (SUPABASE_SERVICE_ROLE_KEY)');
    54	  }
    55	  const { createClient } = await import('@supabase/supabase-js');
    56	  return createClient(supabaseUrl, serviceRoleKey, {
    57	    auth: { autoRefreshToken: false, persistSession: false },
    58	  });
    59	}
    60	
    61	export async function reactivateUser(input: ReactivateUserInput): Promise<ReactivateUserResult> {
    62	  const targetUserId = normalizeId(input?.targetUserId);
    63	  if (!targetUserId) {
    64	    return { ok: false, error: 'invalid_input' };
    65	  }
    66	
    67	  return withOrgContext(async ({ userId, orgId, client }) => {
    68	    try {
    69	      // Same OR-union as deactivateUser (org.access.admin OR settings.users.deactivate).
    70	      await requireAnyPermission({ client, userId, orgId }, ['org.access.admin', 'settings.users.deactivate']);
    71	
    72	      const { rows: targetRows } = await client.query<{
    73	        id: string;
    74	        is_active: boolean;
    75	        invite_token: string | null;
    76	      }>(
    77	        `select id, is_active, invite_token
    78	           from public.users
    79	          where id = $1::uuid
    80	            and org_id = $2::uuid`,
    81	        [targetUserId, orgId],
    82	      );
    83	      const target = targetRows[0];
    84	      if (!target) {
    85	        return { ok: false, error: 'not_found' };
    86	      }
    87	      if (target.is_active) {
    88	        return { ok: false, error: 'not_disabled' };
    89	      }
    90	      if (target.invite_token) {
    91	        return { ok: false, error: 'not_disabled' };
    92	      }
    93	
    94	      // Deactivate only flips public.users.is_active — it does not ban the Supabase
    95	      // auth identity. Guard reactivation when the auth user was hard-deleted.
    96	      try {
    97	        const supabase = await createSupabaseAuthAdmin();
    98	        const authLookup = await supabase.auth.admin.getUserById(targetUserId);
    99	        if (authLookup.error || !authLookup.data.user) {
   100	          return { ok: false, error: 'auth_identity_missing' };
   101	        }
   102	      } catch {
   103	        return { ok: false, error: 'auth_identity_missing' };
   104	      }
   105	
   106	      // FOR UPDATE locks the org row so that concurrent reactivations in the same
   107	      // transaction cannot both read the same count and both conclude there is a
   108	      // free seat.  The count query below is an aggregate over public.users (not
   109	      // directly lockable here), so a brief TOCTOU window remains between the
   110	      // count read and the UPDATE; the seat-limit is an advisory soft-cap and the
   111	      // owner accepted this residual race (advisory F4 — owner-accepted).
   112	      const { rows: seatRows } = await client.query<{ seat_limit: number | null }>(
   113	        `select seat_limit from public.organizations where id = $1::uuid for update`,
   114	        [orgId],
   115	      );
   116	      const seatLimit = seatRows[0]?.seat_limit ?? null;
   117	      if (seatLimit !== null) {
   118	        const { rows: countRows } = await client.query<{ active_user_count: string | number }>(
   119	          `select count(*) as active_user_count
   120	             from public.users
   121	            where org_id = $1::uuid
   122	              and is_active = true`,
   123	          [orgId],
   124	        );
   125	        const activeUserCount = Number(countRows[0]?.active_user_count ?? 0);
   126	        if (activeUserCount >= seatLimit) {
   127	          return { ok: false, error: 'seat_limit_exceeded' };
   128	        }
   129	      }
   130	
   131	      const { rows } = await client.query<{ id: string }>(
   132	        `update public.users
   133	            set is_active = true,
   134	                updated_at = now()
   135	          where id = $1::uuid
   136	            and org_id = $2::uuid
   137	            and is_active = false
   138	            and invite_token is null
   139	        returning id`,
   140	        [targetUserId, orgId],
   141	      );
   142	      if (rows.length === 0) {
   143	        return { ok: false, error: 'not_found' };
   144	      }
   145	
   146	      await client.query(
   147	        `insert into public.audit_log
   148	           (org_id, actor_user_id, actor_type, action, resource_type, resource_id, before_state, after_state, retention_class)
   149	         values ($1::uuid, $2::uuid, 'user', $3, 'org_security_policies', $4, null, $5::jsonb, 'security')`,
   150	        [
   151	          orgId,
   152	          userId,
   153	          'settings.user.reactivated',
   154	          targetUserId,
   155	          JSON.stringify({ org_id: orgId, target_user_id: targetUserId, actor_user_id: userId, is_active: true }),
   156	        ],
   157	      );
   158	
   159	      await client.query(
   160	        `insert into public.outbox_events
   161	           (org_id, event_type, aggregate_type, aggregate_id, payload, app_version)
   162	         values ($1::uuid, $2, 'user', $3::uuid, $4::jsonb, 'settings-reactivate-user-v1')`,
   163	        [
   164	          orgId,
   165	          'settings.user.reactivated',
   166	          targetUserId,
   167	          JSON.stringify({
   168	            org_id: orgId,
   169	            target_user_id: targetUserId,
   170	            actor_user_id: userId,
   171	          }),
   172	        ],
   173	      );
   174	
   175	      revalidateLocalized('/settings/users');
   176	
   177	      return { ok: true, data: { targetUserId, reactivated: true } };
   178	    } catch (error) {
   179	      if (error === FORBIDDEN) {
   180	        return { ok: false, error: 'forbidden' };
   181	      }
   182	      return { ok: false, error: 'persistence_failed' };
   183	    }
   184	  });
   185	}
     1	'use server';
     2	
     3	import { withOrgContext } from '../../lib/auth/with-org-context';
     4	import { revalidateLocalized } from '../../lib/i18n/revalidate-localized';
     5	import type { ResetUserMfaInput, ResetUserMfaResult } from './user-lifecycle.types';
     6	
     7	const FORBIDDEN = 'forbidden' as const;
     8	
     9	type QueryClient = {
    10	  query<T = unknown>(sql: string, values?: readonly unknown[]): Promise<{ rows: T[]; rowCount?: number | null }>;
    11	};
    12	
    13	type PermissionContext = {
    14	  client: QueryClient;
    15	  userId: string;
    16	  orgId: string;
    17	};
    18	
    19	function normalizeId(value: unknown): string | null {
    20	  if (typeof value !== 'string') return null;
    21	  const trimmed = value.trim();
    22	  return trimmed.length > 0 ? trimmed : null;
    23	}
    24	
    25	function normalizeReason(value: unknown): string | null {
    26	  if (typeof value !== 'string') return null;
    27	  const trimmed = value.trim();
    28	  return trimmed.length >= 3 ? trimmed : null;
    29	}
    30	
    31	/** Throws FORBIDDEN unless the caller holds at least one of the given permissions. */
    32	async function requireAnyPermission(ctx: PermissionContext, permissions: [string, ...string[]]): Promise<void> {
    33	  for (const permission of permissions) {
    34	    const { rows } = await ctx.client.query<{ ok: boolean }>(
    35	      `select true as ok
    36	         from public.user_roles ur
    37	         join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
    38	         left join public.role_permissions rp on rp.role_id = r.id and rp.permission = $3
    39	        where ur.user_id = $1::uuid
    40	          and ur.org_id = $2::uuid
    41	          and (
    42	            rp.permission is not null
    43	            or r.code = $3
    44	            or r.slug = $3
    45	            or r.permissions ? $3
    46	          )
    47	        limit 1`,
    48	      [ctx.userId, ctx.orgId, permission],
    49	    );
    50	    if (rows.length > 0) return;
    51	  }
    52	  throw FORBIDDEN;
    53	}
    54	
    55	/**
    56	 * Service-role Supabase admin client — same pattern as create-user-with-password.ts
    57	 * and reset-password.ts (auth.admin.* privileged calls).
    58	 */
    59	async function createSupabaseAuthAdmin() {
    60	  const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
    61	  const serviceRoleKey = process.env.SUPABASE_SERVICE_ROLE_KEY;
    62	  if (!supabaseUrl || !serviceRoleKey) {
    63	    throw new Error('resetUserMfa requires Supabase service-role env (SUPABASE_SERVICE_ROLE_KEY)');
    64	  }
    65	  const { createClient } = await import('@supabase/supabase-js');
    66	  return createClient(supabaseUrl, serviceRoleKey, {
    67	    auth: { autoRefreshToken: false, persistSession: false },
    68	  });
    69	}
    70	
    71	type MfaAdminApi = {
    72	  listFactors?: (params: { userId: string }) => Promise<{
    73	    data: { factors?: Array<{ id: string }> } | null;
    74	    error: { message: string } | null;
    75	  }>;
    76	  deleteFactor?: (params: { id: string; userId: string }) => Promise<{ error: { message: string } | null }>;
    77	};
    78	
    79	async function clearAuthMfaFactors(supabase: Awaited<ReturnType<typeof createSupabaseAuthAdmin>>, userId: string) {
    80	  const mfaAdmin = (supabase.auth.admin as { mfa?: MfaAdminApi }).mfa;
    81	  if (!mfaAdmin?.listFactors || !mfaAdmin.deleteFactor) {
    82	    return 0;
    83	  }
    84	
    85	  const listed = await mfaAdmin.listFactors({ userId });
    86	  if (listed.error) {
    87	    throw listed.error;
    88	  }
    89	
    90	  const factors = listed.data?.factors ?? [];
    91	  for (const factor of factors) {
    92	    const removed = await mfaAdmin.deleteFactor({ id: factor.id, userId });
    93	    if (removed.error) {
    94	      throw removed.error;
    95	    }
    96	  }
    97	  return factors.length;
    98	}
    99	
   100	async function clearAppMfaEnrollment(
   101	  supabase: Awaited<ReturnType<typeof createSupabaseAuthAdmin>>,
   102	  userId: string,
   103	): Promise<boolean> {
   104	  const secrets = await supabase.from('mfa_secrets').delete().eq('user_id', userId);
   105	  if (secrets.error) {
   106	    throw secrets.error;
   107	  }
   108	  const recovery = await supabase.from('recovery_codes').delete().eq('user_id', userId);
   109	  if (recovery.error) {
   110	    throw recovery.error;
   111	  }
   112	  return (secrets.count ?? 0) > 0 || (recovery.count ?? 0) > 0;
   113	}
   114	
   115	export async function resetUserMfa(input: ResetUserMfaInput): Promise<ResetUserMfaResult> {
   116	  const targetUserId = normalizeId(input?.targetUserId);
   117	  const reason = normalizeReason(input?.reason);
   118	  if (!targetUserId || !reason) {
   119	    return { ok: false, error: 'invalid_input' };
   120	  }
   121	
   122	  return withOrgContext(async ({ userId, orgId, client }) => {
   123	    try {
   124	      await requireAnyPermission({ client, userId, orgId }, ['org.access.admin', 'settings.users.deactivate']);
   125	
   126	      const { rows } = await client.query<{ id: string }>(
   127	        `select id
   128	           from public.users
   129	          where id = $1::uuid
   130	            and org_id = $2::uuid`,
   131	        [targetUserId, orgId],
   132	      );
   133	      if (rows.length === 0) {
   134	        return { ok: false, error: 'not_found' };
   135	      }
   136	
   137	      let supabase: Awaited<ReturnType<typeof createSupabaseAuthAdmin>>;
   138	      try {
   139	        supabase = await createSupabaseAuthAdmin();
   140	      } catch {
   141	        return { ok: false, error: 'service_unavailable' };
   142	      }
   143	
   144	      let factorsRemoved = 0;
   145	      let secretsCleared = false;
   146	      try {
   147	        factorsRemoved = await clearAuthMfaFactors(supabase, targetUserId);
   148	        secretsCleared = await clearAppMfaEnrollment(supabase, targetUserId);
   149	      } catch {
   150	        return { ok: false, error: 'reset_failed' };
   151	      }
   152	
   153	      // Revoke active sessions so the user must re-authenticate after MFA reset.
   154	      // The supabase-js SDK v2 auth.admin.signOut takes a JWT, not a userId.  We
   155	      // call the admin REST endpoint directly.  Non-fatal: MFA factors are already
   156	      // cleared; a session without TOTP will hit the MFA gate on next sensitive op.
   157	      try {
   158	        const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
   159	        const serviceRoleKey = process.env.SUPABASE_SERVICE_ROLE_KEY;
   160	        if (supabaseUrl && serviceRoleKey) {
   161	          await fetch(`${supabaseUrl}/auth/v1/admin/users/${targetUserId}/sessions`, {
   162	            method: 'DELETE',
   163	            headers: {
   164	              Authorization: `Bearer ${serviceRoleKey}`,
   165	              apikey: serviceRoleKey,
   166	            },
   167	          });
   168	        }
   169	      } catch {
   170	        // non-fatal — MFA factors are already cleared
   171	      }
   172	
   173	      await client.query(
   174	        `insert into public.audit_log
   175	           (org_id, actor_user_id, actor_type, action, resource_type, resource_id, before_state, after_state, retention_class)
   176	         values ($1::uuid, $2::uuid, 'user', $3, 'org_security_policies', $4, null, $5::jsonb, 'security')`,
   177	        [
   178	          orgId,
   179	          userId,
   180	          'settings.user.mfa_reset',
   181	          targetUserId,
   182	          JSON.stringify({
   183	            org_id: orgId,
   184	            target_user_id: targetUserId,
   185	            actor_user_id: userId,
   186	            reason,
   187	            factors_removed: factorsRemoved,
   188	            secrets_cleared: secretsCleared,
   189	          }),
   190	        ],
   191	      );
   192	
   193	      revalidateLocalized('/settings/users');
   194	
   195	      return {
   196	        ok: true,
   197	        data: { targetUserId, factorsRemoved, secretsCleared },
   198	      };
   199	    } catch (error) {
   200	      if (error === FORBIDDEN) {
   201	        return { ok: false, error: 'forbidden' };
   202	      }
   203	      return { ok: false, error: 'persistence_failed' };
   204	    }
   205	  });
   206	}
     1	'use server';
     2	
     3	import { withOrgContext } from '../../lib/auth/with-org-context';
     4	import { createServerSupabaseClient } from '../../lib/auth/supabase-server';
     5	
     6	const FORBIDDEN = 'forbidden' as const;
     7	
     8	type QueryClient = {
     9	  query<T = unknown>(sql: string, values?: readonly unknown[]): Promise<{ rows: T[]; rowCount?: number | null }>;
    10	};
    11	
    12	type PermissionContext = {
    13	  client: QueryClient;
    14	  userId: string;
    15	  orgId: string;
    16	};
    17	
    18	export type ResetPasswordInput = {
    19	  targetUserId: string;
    20	  redirectTo?: string;
    21	};
    22	
    23	export type ResetPasswordResult =
    24	  | { ok: true; data: { targetUserId: string; revokedCount: number } }
    25	  | { ok: false; error: 'invalid_input' | 'forbidden' | 'not_found' | 'reset_failed' | 'persistence_failed' };
    26	
    27	function normalizeId(value: unknown): string | null {
    28	  if (typeof value !== 'string') return null;
    29	  const trimmed = value.trim();
    30	  return trimmed.length > 0 ? trimmed : null;
    31	}
    32	
    33	function normalizeOptionalString(value: unknown): string | undefined {
    34	  if (typeof value !== 'string') return undefined;
    35	  const trimmed = value.trim();
    36	  return trimmed.length > 0 ? trimmed : undefined;
    37	}
    38	
    39	function requirePermission(permission: string) {
    40	  return async ({ client, userId, orgId }: PermissionContext): Promise<void> => {
    41	    const { rows } = await client.query<{ ok: boolean }>(
    42	      `select true as ok
    43	         from public.user_roles ur
    44	         join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
    45	         left join public.role_permissions rp on rp.role_id = r.id and rp.permission = $3
    46	        where ur.user_id = $1::uuid
    47	          and ur.org_id = $2::uuid
    48	          and (
    49	            rp.permission is not null
    50	            or r.code = $3
    51	            or r.slug = $3
    52	            or r.permissions ? $3
    53	          )
    54	        limit 1`,
    55	      [userId, orgId, permission],
    56	    );
    57	
    58	    if (rows.length === 0) {
    59	      throw FORBIDDEN;
    60	    }
    61	  };
    62	}
    63	
    64	export async function resetPassword(input: ResetPasswordInput): Promise<ResetPasswordResult> {
    65	  const targetUserId = normalizeId(input?.targetUserId);
    66	  const redirectTo = normalizeOptionalString(input?.redirectTo);
    67	  if (!targetUserId) {
    68	    return { ok: false, error: 'invalid_input' };
    69	  }
    70	
    71	  return withOrgContext(async ({ userId, orgId, client }) => {
    72	    try {
    73	      await requirePermission('org.access.admin')({ client, userId, orgId });
    74	
    75	      const { rows } = await client.query<{ email: string }>(
    76	        `select email
    77	           from public.users
    78	          where id = $1::uuid
    79	            and org_id = $2::uuid
    80	            and is_active = true`,
    81	        [targetUserId, orgId],
    82	      );
    83	      const email = rows[0]?.email;
    84	      if (!email) {
    85	        return { ok: false, error: 'not_found' };
    86	      }
    87	
    88	      const supabase = await createServerSupabaseClient();
    89	      const linkResponse = await supabase.auth.admin.generateLink({
    90	        type: 'recovery',
    91	        email,
    92	        options: { redirectTo },
    93	      });
    94	      if (linkResponse.error) {
    95	        return { ok: false, error: 'reset_failed' };
    96	      }
    97	
    98	      // Revoke all active sessions for the target user via the Supabase Auth
    99	      // admin REST endpoint DELETE /auth/v1/admin/users/{id}/sessions.
   100	      // The supabase-js SDK v2 does not expose a userId-based admin signOut method
   101	      // (auth.admin.signOut takes a JWT, not a userId), so we call the endpoint
   102	      // directly.  Failure is non-fatal: the recovery link already supersedes
   103	      // existing tokens on first use; we record revokedCount: 0 on API error.
   104	      let revokedCount = 0;
   105	      try {
   106	        const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
   107	        const serviceRoleKey = process.env.SUPABASE_SERVICE_ROLE_KEY;
   108	        if (supabaseUrl && serviceRoleKey) {
   109	          const signOutResp = await fetch(
   110	            `${supabaseUrl}/auth/v1/admin/users/${targetUserId}/sessions`,
   111	            {
   112	              method: 'DELETE',
   113	              headers: {
   114	                Authorization: `Bearer ${serviceRoleKey}`,
   115	                apikey: serviceRoleKey,
   116	              },
   117	            },
   118	          );
   119	          if (signOutResp.ok) {
   120	            revokedCount = 1;
   121	          }
   122	        }
   123	      } catch {
   124	        // non-fatal — the recovery link supersedes existing sessions on use
   125	      }
   126	
   127	      return {
   128	        ok: true,
   129	        data: { targetUserId, revokedCount },
   130	      };
   131	    } catch (error) {
   132	      if (error === FORBIDDEN) {
   133	        return { ok: false, error: 'forbidden' };
   134	      }
   135	      return { ok: false, error: 'persistence_failed' };
   136	    }
   137	  });
   138	}
     1	/**
     2	 * Service-role Supabase admin client factory — shared by the privileged user
     3	 * actions (create-with-password, invite link generation). Lives OUTSIDE any
     4	 * 'use server' module so it can be a plain export.
     5	 *
     6	 * Reads the service-role key from the server-only env var and disables session
     7	 * persistence/refresh (one-shot privileged calls, not a user session). Throws
     8	 * when the env is absent so callers surface `service_unavailable` instead of
     9	 * silently degrading to the anon key (which makes `auth.admin.*` fail closed
    10	 * in a confusing way — the wave-F4 live invite 403 `not_admin` class).
    11	 */
    12	export async function createSupabaseAuthAdmin() {
    13	  const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL;
    14	  const serviceRoleKey = process.env.SUPABASE_SERVICE_ROLE_KEY;
    15	  if (!supabaseUrl || !serviceRoleKey) {
    16	    throw new Error('privileged user actions require Supabase service-role env (SUPABASE_SERVICE_ROLE_KEY)');
    17	  }
    18	  const { createClient } = await import('@supabase/supabase-js');
    19	  return createClient(supabaseUrl, serviceRoleKey, {
    20	    auth: { autoRefreshToken: false, persistSession: false },
    21	  });
    22	}
     1	'use server';
     2	
     3	import { withOrgContext } from '../../lib/auth/with-org-context';
     4	import { createServerSupabaseClient } from '../../lib/auth/supabase-server';
     5	import { SYSTEM_ROLE_CODES_FORBIDDEN_AS_DEFAULT } from './user-role-policy';
     6	import { createSupabaseAuthAdmin } from './supabase-admin';
     7	
     8	const INVITE_TTL_SECONDS = 604800;
     9	const INVITE_PERMISSION = 'settings.users.invite';
    10	
    11	export type InviteUserInput = {
    12	  email: string;
    13	  name?: string;
    14	  roleId?: string;
    15	  site?: string;
    16	  personalMessage?: string;
    17	  language?: string;
    18	  redirectTo?: string;
    19	};
    20	
    21	export type InviteUserResult =
    22	  | { ok: true; data: { email: string; expiresAt: string } }
    23	  | {
    24	      ok: false;
    25	      error:
    26	        | 'invalid_input'
    27	        | 'forbidden'
    28	        | 'seat_limit_exceeded'
    29	        | 'invite_failed'
    30	        | 'persistence_failed';
    31	    };
    32	
    33	type OrganizationSeatRow = {
    34	  seat_limit: number | null;
    35	};
    36	
    37	type RoleRow = {
    38	  id: string;
    39	  org_id: string;
    40	  code: string;
    41	  is_system: boolean;
    42	  display_order: number | null;
    43	};
    44	
    45	function normalizeEmail(value: unknown): string | null {
    46	  if (typeof value !== 'string') return null;
    47	  const email = value.trim().toLowerCase();
    48	  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email) ? email : null;
    49	}
    50	
    51	function normalizeString(value: unknown): string | null {
    52	  if (typeof value !== 'string') return null;
    53	  const trimmed = value.trim();
    54	  return trimmed.length > 0 ? trimmed : null;
    55	}
    56	
    57	export async function inviteUser(input: InviteUserInput): Promise<InviteUserResult> {
    58	  const email = normalizeEmail(input?.email);
    59	  if (!email) {
    60	    return { ok: false, error: 'invalid_input' };
    61	  }
    62	
    63	  const requestedRoleId = normalizeString(input.roleId);
    64	  if (!requestedRoleId) {
    65	    return { ok: false, error: 'invalid_input' };
    66	  }
    67	
    68	  const name = normalizeString(input.name) ?? email;
    69	  const site = normalizeString(input.site);
    70	  const personalMessage = normalizeString(input.personalMessage);
    71	  const language = normalizeString(input.language) ?? 'pl';
    72	  const redirectTo = normalizeRedirectTo(input.redirectTo);
    73	  if (redirectTo === 'invalid') {
    74	    return { ok: false, error: 'invalid_input' };
    75	  }
    76	  const expiresAt = new Date(Date.now() + INVITE_TTL_SECONDS * 1000);
    77	
    78	  return withOrgContext(async ({ userId, orgId, client }) => {
    79	    // Fail-closed permission-based RBAC: require an explicit grant of
    80	    // settings.users.invite on one of the caller's roles. Role-code fallbacks
    81	    // are honored only when the role exposes the permission via its slug/code
    82	    // or jsonb permissions array — never via hard-coded role-slug allowlists,
    83	    // which drift from the permission registry.
    84	    const { rows: permRows } = await client.query<{ ok: boolean }>(
    85	      `select true as ok
    86	         from public.user_roles ur
    87	         join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
    88	         left join public.role_permissions rp on rp.role_id = r.id and rp.permission = $3
    89	        where ur.user_id = $1::uuid
    90	          and ur.org_id = $2::uuid
    91	          and (
    92	            rp.permission is not null
    93	            or r.code = $3
    94	            or r.slug = $3
    95	            or coalesce(r.permissions, '[]'::jsonb) ? $3
    96	          )
    97	        limit 1`,
    98	      [userId, orgId, INVITE_PERMISSION],
    99	    );
   100	    if (permRows.length === 0) {
   101	      return { ok: false, error: 'forbidden' };
   102	    }
   103	
   104	    const { rows: roleRows } = await client.query<RoleRow>(
   105	      `select id, org_id, code, is_system, display_order
   106	         from public.roles
   107	        where id = $1::uuid`,
   108	      [requestedRoleId],
   109	    );
   110	    const role = roleRows[0];
   111	    if (!role || role.org_id !== orgId) {
   112	      return { ok: false, error: 'invalid_input' };
   113	    }
   114	    if (SYSTEM_ROLE_CODES_FORBIDDEN_AS_DEFAULT.has(role.code)) {
   115	      return { ok: false, error: 'invalid_input' };
   116	    }
   117	    const roleId = role.id;
   118	
   119	    const { rows: seatRows } = await client.query<OrganizationSeatRow>(
   120	      `select seat_limit from public.organizations where id = $1::uuid`,
   121	      [orgId],
   122	    );
   123	    const seatLimit = seatRows[0]?.seat_limit ?? null;
   124	
   125	    const { rows: countRows } = await client.query<{ active_user_count: string | number }>(
   126	      `select count(*) as active_user_count
   127	         from public.users
   128	        where org_id = $1::uuid
   129	          and is_active = true`,
   130	      [orgId],
   131	    );
   132	    const activeUserCount = Number(countRows[0]?.active_user_count ?? 0);
   133	    if (seatLimit !== null && activeUserCount >= seatLimit) {
   134	      return { ok: false, error: 'seat_limit_exceeded' };
   135	    }
   136	
   137	    // f4.1: generateLink is an admin API — the session client gets 403 not_admin.
   138	    const supabase = await createSupabaseAuthAdmin();
   139	    const linkResponse = await supabase.auth.admin.generateLink({
   140	      type: 'invite',
   141	      email,
   142	      options: {
   143	        data: {
   144	          org_id: orgId,
   145	          invited_by: userId,
   146	          expires_in: INVITE_TTL_SECONDS,
   147	          site: site ?? undefined,
   148	          personal_message: personalMessage ?? undefined,
   149	        },
   150	        redirectTo: redirectTo ?? undefined,
   151	      },
   152	    });
   153	    if (linkResponse.error) {
   154	      return { ok: false, error: 'invite_failed' };
   155	    }
   156	
   157	    const inviteToken =
   158	      linkResponse.data?.properties?.hashed_token ??
   159	      linkResponse.data?.properties?.email_otp ??
   160	      linkResponse.data?.user?.id ??
   161	      null;
   162	
   163	    try {
   164	      const invited = await client.query<{ id: string }>(
   165	        `insert into public.users
   166	           (org_id, email, name, role_id, language, is_active, invite_token, invite_token_expires_at, updated_at)
   167	         values ($1::uuid, $2::citext, $3, $4::uuid, $5, false, $6, $7::timestamptz, now())
   168	         on conflict (email) do update set
   169	           name = excluded.name,
   170	           role_id = excluded.role_id,
   171	           language = excluded.language,
   172	           is_active = false,
   173	           invite_token = excluded.invite_token,
   174	           invite_token_expires_at = excluded.invite_token_expires_at,
   175	           updated_at = now()
   176	         where public.users.org_id = excluded.org_id
   177	         returning id`,
   178	        [orgId, email, name, roleId, language, inviteToken, expiresAt.toISOString()],
   179	      );
   180	      if ((invited.rowCount ?? invited.rows.length) < 1) {
   181	        return { ok: false, error: 'invalid_input' };
   182	      }
   183	
   184	      await client.query(
   185	        `insert into public.audit_log
   186	           (org_id, actor_user_id, actor_type, action, resource_type, resource_id, before_state, after_state, retention_class)
   187	         values ($1::uuid, $2::uuid, 'user', $3, 'org_security_policies', $4, null, $5::jsonb, 'security')`,
   188	        [
   189	          orgId,
   190	          userId,
   191	          'settings.user.invited',
   192	          invited.rows[0]?.id ?? email,
   193	          JSON.stringify({
   194	            org_id: orgId,
   195	            email,
   196	            role_id: roleId,
   197	            invited_by: userId,
   198	            expires_at: expiresAt.toISOString(),
   199	            site,
   200	            personal_message_present: Boolean(personalMessage),
   201	          }),
   202	        ],
   203	      );
   204	
   205	      await client.query(
   206	        `insert into public.outbox_events
   207	           (org_id, event_type, aggregate_type, aggregate_id, payload, app_version)
   208	         values ($1::uuid, $2, 'user', $3::uuid, $4::jsonb, 'settings-invite-user-v1')`,
   209	        [
   210	          orgId,
   211	          'settings.user.invited',
   212	          userId,
   213	          JSON.stringify({
   214	            org_id: orgId,
   215	            email,
   216	            invited_by: userId,
   217	            expires_at: expiresAt.toISOString(),
   218	            site,
   219	            personal_message_present: Boolean(personalMessage),
   220	          }),
   221	        ],
   222	      );
   223	    } catch {
   224	      return { ok: false, error: 'persistence_failed' };
   225	    }
   226	
   227	    return { ok: true, data: { email, expiresAt: expiresAt.toISOString() } };
   228	  });
   229	}
   230	
   231	function normalizeRedirectTo(value: unknown): string | null | 'invalid' {
   232	  const redirectTo = normalizeString(value);
   233	  if (!redirectTo) return null;
   234	  const baseUrl = normalizeAppUrl(process.env.NEXT_PUBLIC_APP_URL);
   235	  if (!baseUrl) return 'invalid';
   236	  try {
   237	    const resolved = new URL(redirectTo, baseUrl);
   238	    if (resolved.origin !== baseUrl.origin) return 'invalid';
   239	    return resolved.toString();
   240	  } catch {
   241	    return 'invalid';
   242	  }
   243	}
   244	
   245	function normalizeAppUrl(value: unknown): URL | null {
   246	  if (typeof value !== 'string' || value.trim().length === 0) return null;
   247	  try {
   248	    const url = new URL(value.trim());
   249	    return url.protocol === 'http:' || url.protocol === 'https:' ? url : null;
   250	  } catch {
   251	    return null;
   252	  }
   253	}
     1	'use server';
     2	
     3	import { revalidateLocalized } from '../../lib/i18n/revalidate-localized';
     4	
     5	import { withOrgContext } from '../../lib/auth/with-org-context';
     6	
     7	const FORBIDDEN = 'forbidden' as const;
     8	
     9	type QueryClient = {
    10	  query<T = unknown>(sql: string, values?: readonly unknown[]): Promise<{ rows: T[]; rowCount?: number | null }>;
    11	};
    12	
    13	type PermissionContext = {
    14	  client: QueryClient;
    15	  userId: string;
    16	  orgId: string;
    17	};
    18	
    19	export type AssignRoleInput = {
    20	  targetUserId: string;
    21	  roleId: string;
    22	};
    23	
    24	export type AssignRoleResult =
    25	  | { ok: true; data: { targetUserId: string; roleId: string } }
    26	  | { ok: false; error: 'invalid_input' | 'forbidden' | 'not_found' | 'persistence_failed' };
    27	
    28	type AssignRoleMutationRow = {
    29	  role_found: boolean;
    30	  target_user_found: boolean;
    31	  last_owner_violation: boolean;
    32	  updated_user_id: string | null;
    33	};
    34	
    35	function normalizeId(value: unknown): string | null {
    36	  if (typeof value !== 'string') return null;
    37	  const trimmed = value.trim();
    38	  return trimmed.length > 0 ? trimmed : null;
    39	}
    40	
    41	function requirePermission(permission: string) {
    42	  return async ({ client, userId, orgId }: PermissionContext): Promise<void> => {
    43	    const { rows } = await client.query<{ ok: boolean }>(
    44	      `select true as ok
    45	         from public.user_roles ur
    46	         join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
    47	         left join public.role_permissions rp on rp.role_id = r.id and rp.permission = $3
    48	        where ur.user_id = $1::uuid
    49	          and ur.org_id = $2::uuid
    50	          and (
    51	            rp.permission is not null
    52	            or r.code = $3
    53	            or coalesce(r.permissions, '[]'::jsonb) ? $3
    54	          )
    55	        limit 1`,
    56	      [userId, orgId, permission],
    57	    );
    58	
    59	    if (rows.length === 0) {
    60	      throw FORBIDDEN;
    61	    }
    62	  };
    63	}
    64	
    65	export async function assignRole(input: AssignRoleInput): Promise<AssignRoleResult> {
    66	  const targetUserId = normalizeId(input?.targetUserId);
    67	  const roleId = normalizeId(input?.roleId);
    68	  if (!targetUserId || !roleId) {
    69	    return { ok: false, error: 'invalid_input' };
    70	  }
    71	
    72	  return withOrgContext(async ({ userId, orgId, client }) => {
    73	    try {
    74	      await requirePermission('settings.roles.assign')({ client, userId, orgId });
    75	
    76	      const { rows: mutationRows } = await client.query<AssignRoleMutationRow>(
    77	        `with target_role as (
    78	            select id,
    79	                   (code = 'owner' or slug = 'owner') as is_owner
    80	              from public.roles
    81	             where id = $2::uuid
    82	               and org_id = $3::uuid
    83	          ),
    84	          target_user as (
    85	            select id
    86	              from public.users
    87	             where id = $1::uuid
    88	               and org_id = $3::uuid
    89	          ),
    90	          locked_owner_roles as (
    91	            select ur.user_id
    92	              from public.user_roles ur
    93	              join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
    94	             where ur.org_id = $3::uuid
    95	               and (r.code = 'owner' or r.slug = 'owner')
    96	             for update of ur
    97	          ),
    98	          target_current_owner as (
    99	            select exists (
   100	              select 1
   101	                from locked_owner_roles lor
   102	               where lor.user_id = $1::uuid
   103	            ) as is_owner
   104	          ),
   105	          owner_count as (
   106	            select count(distinct user_id)::int as value
   107	              from locked_owner_roles
   108	          ),
   109	          guard as (
   110	            select exists(select 1 from target_role) as role_found,
   111	                   exists(select 1 from target_user) as target_user_found,
   112	                   coalesce((select is_owner from target_current_owner), false)
   113	                     and not coalesce((select is_owner from target_role), false)
   114	                     and coalesce((select value from owner_count), 0) <= 1 as last_owner_violation
   115	          ),
   116	          updated_user as (
   117	            update public.users
   118	               set role_id = $2::uuid,
   119	                   updated_at = now()
   120	             where id = $1::uuid
   121	               and org_id = $3::uuid
   122	               and (select role_found and target_user_found and not last_owner_violation from guard)
   123	             returning id
   124	          ),
   125	          deleted_roles as (
   126	            delete from public.user_roles
   127	             where user_id = $1::uuid
   128	               and org_id = $3::uuid
   129	               and exists(select 1 from updated_user)
   130	             returning user_id
   131	          ),
   132	          inserted_role as (
   133	            insert into public.user_roles (user_id, role_id, org_id)
   134	            select id, $2::uuid, $3::uuid
   135	              from updated_user
   136	            on conflict (user_id, role_id) do update set org_id = excluded.org_id
   137	            returning user_id
   138	          )
   139	          select guard.role_found,
   140	                 guard.target_user_found,
   141	                 guard.last_owner_violation,
   142	                 (select user_id from inserted_role limit 1) as updated_user_id
   143	            from guard`,
   144	        [targetUserId, roleId, orgId],
   145	      );
   146	      const mutation = mutationRows[0];
   147	      if (!mutation?.role_found || !mutation.target_user_found) {
   148	        return { ok: false, error: 'not_found' };
   149	      }
   150	      if (mutation.last_owner_violation) {
   151	        return { ok: false, error: 'forbidden' };
   152	      }
   153	      if (!mutation.updated_user_id) {
   154	        return { ok: false, error: 'persistence_failed' };
   155	      }
   156	
   157	      await client.query(
