'use server';

import { revalidateLocalized } from '../../lib/i18n/revalidate-localized';

import { withOrgContext } from '../../lib/auth/with-org-context';

const FORBIDDEN = 'forbidden' as const;

// 14-multi-site — per-user site assignment write path (mig 381 user_sites +
// mig 383 app.user_can_see_site RLS floor). The DB table is the assignment
// STORE; THIS action is the operable control surface an admin uses to set it.
//
// Gating: SAME permission as assign-role (settings.roles.assign) — site
// assignment is a roles/visibility-management act, so it reuses the existing
// users-manage grant rather than inventing a new permission. The page already
// derives `canAssignRoles` from this exact permission for the role picker, so
// the new "Assign sites" affordance shares that server-trusted flag.
//
// Semantics: assignments are REPLACED transactionally (delete-then-insert) so
// the submitted set is authoritative. Empty siteIds = unassign all = 0 rows =
// UNRESTRICTED (the enforcement lib degrades to all-org-sites on 0 rows).
const ASSIGN_PERMISSION = 'settings.roles.assign';

type QueryClient = {
  query<T = unknown>(sql: string, values?: readonly unknown[]): Promise<{ rows: T[]; rowCount?: number | null }>;
};

export type AssignUserSitesInput = {
  userId: string;
  siteIds: string[];
};

export type AssignUserSitesResult =
  | { ok: true; data: { userId: string; siteIds: string[] } }
  | { ok: false; error: 'invalid_input' | 'forbidden' | 'not_found' | 'persistence_failed' };

function normalizeId(value: unknown): string | null {
  if (typeof value !== 'string') return null;
  const trimmed = value.trim();
  return trimmed.length > 0 ? trimmed : null;
}

function normalizeSiteIds(value: unknown): string[] | null {
  if (!Array.isArray(value)) return null;
  const ids: string[] = [];
  const seen = new Set<string>();
  for (const raw of value) {
    const id = normalizeId(raw);
    if (!id) return null;
    if (seen.has(id)) continue;
    seen.add(id);
    ids.push(id);
  }
  return ids;
}

async function requirePermission(client: QueryClient, userId: string, orgId: string, permission: string): Promise<void> {
  const { rows } = await client.query<{ ok: boolean }>(
    `select true as ok
       from public.user_roles ur
       join public.roles r on r.id = ur.role_id and r.org_id = ur.org_id
       left join public.role_permissions rp on rp.role_id = r.id and rp.permission = $3
      where ur.user_id = $1::uuid
        and ur.org_id = $2::uuid
        and (
          rp.permission is not null
          or r.code = $3
          or coalesce(r.permissions, '[]'::jsonb) ? $3
        )
      limit 1`,
    [userId, orgId, permission],
  );
  if (rows.length === 0) {
    throw FORBIDDEN;
  }
}

export async function assignUserSites(input: AssignUserSitesInput): Promise<AssignUserSitesResult> {
  const targetUserId = normalizeId(input?.userId);
  const siteIds = normalizeSiteIds(input?.siteIds);
  if (!targetUserId || siteIds === null) {
    return { ok: false, error: 'invalid_input' };
  }

  return withOrgContext(async ({ userId, orgId, client }) => {
    try {
      await requirePermission(client as QueryClient, userId, orgId, ASSIGN_PERMISSION);

      // Validate the target user is in the caller's org and (if any) every
      // requested site is an active org site. A single guard query returns the
      // existence flags so we never half-apply a bad payload.
      const { rows: guardRows } = await (client as QueryClient).query<{
        target_user_found: boolean;
        all_sites_valid: boolean;
      }>(
        `select
            exists(
              select 1 from public.users u
               where u.id = $1::uuid and u.org_id = app.current_org_id()
            ) as target_user_found,
            (
              select count(*) = coalesce(array_length($2::uuid[], 1), 0)
                from public.sites s
               where s.id = any($2::uuid[])
                 and s.org_id = app.current_org_id()
                 and s.is_active = true
            ) as all_sites_valid`,
        [targetUserId, siteIds],
      );
      const guard = guardRows[0];
      if (!guard?.target_user_found) {
        return { ok: false, error: 'not_found' };
      }
      if (!guard.all_sites_valid) {
        return { ok: false, error: 'invalid_input' };
      }

      // Replace transactionally: the submitted set is authoritative. The
      // delete clears prior assignments (org-scoped via app.current_org_id());
      // the insert (unnest) writes one row per site with the actor as
      // assigned_by. Empty siteIds → delete only → 0 rows = unrestricted.
      const { rows: replacedRows } = await (client as QueryClient).query<{ replaced: string | null }>(
        `with deleted as (
            delete from public.user_sites
             where user_id = $1::uuid
               and org_id = app.current_org_id()
            returning site_id
          ),
          inserted as (
            insert into public.user_sites (user_id, site_id, org_id, assigned_by)
            select $1::uuid, s.site_id, app.current_org_id(), $3::uuid
              from unnest($2::uuid[]) as s(site_id)
            returning site_id
          )
          select (select count(*)::text from inserted) as replaced`,
        [targetUserId, siteIds, userId],
      );
      if (!replacedRows[0]) {
        return { ok: false, error: 'persistence_failed' };
      }

      await (client as QueryClient).query(
        `insert into public.audit_log
           (org_id, actor_user_id, actor_type, action, resource_type, resource_id, before_state, after_state, retention_class)
         values ($1::uuid, $2::uuid, 'user', $3, 'org_security_policies', $4, null, $5::jsonb, 'security')`,
        [
          orgId,
          userId,
          'settings.user.sites_assigned',
          targetUserId,
          JSON.stringify({ org_id: orgId, target_user_id: targetUserId, site_ids: siteIds, actor_user_id: userId }),
        ],
      );

      // NOTE: no outbox_events emit — 'settings.user.sites_assigned' is not in the
      // outbox_events_event_type_check CHECK (verified live: 23514), and no consumer
      // needs it. The audit_log entry above is the authoritative record. If a
      // downstream consumer is ever needed, add the event via a dedicated CHECK
      // migration (the ~180-value list must be reproduced carefully).
      try {
        revalidateLocalized('/settings/users');
      } catch {
        // Unit tests and non-Next callers do not provide a static-generation
        // store; persistence has already succeeded so cache invalidation must
        // not mask it.
      }
      return { ok: true, data: { userId: targetUserId, siteIds } };
    } catch (error) {
      if (error === FORBIDDEN) {
        return { ok: false, error: 'forbidden' };
      }
      return { ok: false, error: 'persistence_failed' };
    }
  });
}
     1	-- Migration 381 — user_sites: per-user site assignment (foundation for security-scoped visibility).
     2	--
     3	-- Owner 2026-06-28: each user gets assigned site(s); for security they may only see/select data for their
     4	-- assigned site(s) (today the top-bar active site is chosen freely from ALL org sites). This table is the
     5	-- assignment STORE. It changes NO behaviour on its own — later slices (getUserSites picker filter, hardened
     6	-- setActiveSite, assertUserSiteAccess) read it. Until a user has rows here the enforcement lib degrades to
     7	-- all-org-sites (0 rows = unrestricted), so all existing users are unaffected (opt-in per user).
     8	--
     9	-- Multi-site JOIN table (not a single users.primary_site_id) per owner intent + scout recommendation: a
    10	-- factory operator is usually one site, but planners/QA cover several and admins all — the join table covers
    11	-- all three with no NULL-means-all ambiguity. Mirrors the user_roles pattern (mig 017): bare org_id
    12	-- (denormalised so the org-scoped RLS policy is a direct equality, no join), composite PK, ENABLE+FORCE RLS,
    13	-- app_user DML grant. assigned_at/assigned_by are audit breadcrumbs.
    14	
    15	create table if not exists public.user_sites (
    16	  user_id     uuid        not null references public.users(id) on delete cascade,
    17	  site_id     uuid        not null references public.sites(id) on delete cascade,
    18	  org_id      uuid        not null,
    19	  assigned_at timestamptz not null default now(),
    20	  assigned_by uuid        references public.users(id) on delete set null,
    21	  primary key (user_id, site_id)
    22	);
    23	
    24	create index if not exists user_sites_user_idx on public.user_sites (user_id, org_id);
    25	create index if not exists user_sites_site_idx on public.user_sites (site_id, org_id);
    26	
    27	alter table public.user_sites enable row level security;
    28	alter table public.user_sites force row level security;
    29	
    30	drop policy if exists user_sites_org_context on public.user_sites;
    31	create policy user_sites_org_context
    32	  on public.user_sites
    33	  for all
    34	  to app_user
    35	  using (org_id = app.current_org_id())
    36	  with check (org_id = app.current_org_id());
    37	
    38	grant select, insert, update, delete on public.user_sites to app_user;
     1	-- Migration 383 — P2+P3 of per-user-site RLS: the visibility helper + RESTRICTIVE policies.
     2	--
     3	-- Builds on mig 382 (app.current_user_id). app.user_can_see_site(site_id) is the single security predicate;
     4	-- a RESTRICTIVE policy on each site-scoped table ANDs it with the existing PERMISSIVE org policy (org_id =
     5	-- current_org_id) WITHOUT modifying that policy. Postgres: permissive policies are OR'd, then ALL restrictive
     6	-- policies are AND'd — so effective read = (org match) AND (site visible).
     7	--
     8	-- ROLLOUT IS A NO-OP UNTIL ASSIGNMENTS EXIST: today every user has ZERO public.user_sites rows, so
     9	-- user_can_see_site() returns true for every row via the zero-assignment condition (and also via the
    10	-- null-current_user_id condition during the deploy window before mig-382's with-org-context change lands).
    11	-- Enforcement activates ONLY once a sysadmin assigns sites (the settings assign-UI slice). Writes: the
    12	-- BEFORE INSERT triggers (mig 379/380) populate site_id before WITH CHECK runs, so a restricted user's create
    13	-- (active site = their site) passes and an admin/zero-assignment user always passes.
    14	
    15	-- ── P2: the visibility predicate (SECURITY DEFINER so it reads user_roles/user_sites past their RLS) ──
    16	create or replace function app.user_can_see_site(p_site_id uuid)
    17	returns boolean
    18	language sql
    19	security definer
    20	stable
    21	set search_path = pg_catalog
    22	as $$
    23	  select
    24	    -- (1) no registered user (pre-mig-382 deploy window / test stub) → unrestricted
    25	    app.current_user_id() is null
    26	    -- (2) admin role (canonical admin slug family) → unrestricted
    27	    or exists (
    28	      select 1
    29	        from public.user_roles ur
    30	        join public.roles r on r.id = ur.role_id
    31	       where ur.user_id = app.current_user_id()
    32	         and ur.org_id  = app.current_org_id()
    33	         and r.slug = any(array['org.access.admin','org.platform.admin','owner','admin','org_admin'])
    34	    )
    35	    -- (3) zero site assignments → unrestricted (opt-in; every user today)
    36	    or not exists (
    37	      select 1
    38	        from public.user_sites us
    39	       where us.user_id = app.current_user_id()
    40	         and us.org_id  = app.current_org_id()
    41	    )
    42	    -- (4) row has no site (orphan / pre-backfill) → visible (fail-open, not data loss)
    43	    or p_site_id is null
    44	    -- (5) user is assigned to this row's site
    45	    or exists (
    46	      select 1
    47	        from public.user_sites us
    48	       where us.user_id = app.current_user_id()
    49	         and us.site_id = p_site_id
    50	         and us.org_id  = app.current_org_id()
    51	    )
    52	$$;
    53	
    54	revoke all on function app.user_can_see_site(uuid) from public;
    55	grant execute on function app.user_can_see_site(uuid) to app_user;
    56	
    57	-- Supporting index for condition (2): user_roles PK is (user_id, role_id); add (user_id, org_id) lookup.
    58	create index if not exists user_roles_user_org_idx on public.user_roles (user_id, org_id);
    59	
    60	-- ── P3: RESTRICTIVE site-visibility policy on every site-scoped table ──
    61	-- (each already has exactly one PERMISSIVE org policy + RLS enabled — verified pre-migration)
    62	do $$
    63	declare t text;
    64	begin
    65	  foreach t in array array[
    66	    'work_orders','purchase_orders','grns','stock_moves','lp_state_history',
    67	    'quality_holds','quality_inspections','ncr_reports','shipments','schedule_outputs','license_plates'
    68	  ] loop
    69	    execute format('drop policy if exists %I on public.%I', t || '_site_visibility', t);
    70	    execute format(
    71	      'create policy %I on public.%I as restrictive for all to app_user '
    72	      || 'using (app.user_can_see_site(site_id)) with check (app.user_can_see_site(site_id))',
    73	      t || '_site_visibility', t
    74	    );
    75	  end loop;
    76	end $$;

