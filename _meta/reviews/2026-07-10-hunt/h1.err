   234	
   235	  softMissing.push(...await requiredFieldsMissing(db, projectId, fromStage));
   236	  return softMissing.length > 0
   237	    ? { status: 'SOFT_GATE_BLOCKED', missing: softMissing }
   238	    : { status: 'PASS' };
   239	}
