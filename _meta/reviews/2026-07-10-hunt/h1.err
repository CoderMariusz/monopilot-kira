    37	
    38	type RevertNpdGateResult =
    39	  | { success: true }
    40	  | { success: false; error: string; status: number };
    41	
    42	export async function revertNpdGate(rawInput: unknown): Promise<RevertNpdGateResult> {
    43	  const parsed = inputSchema.safeParse(rawInput);
    44	  if (!parsed.success) return { success: false, error: 'INVALID_INPUT', status: 400 };
    45	
    46	  try {
    47	    return await withOrgContext<RevertNpdGateResult>(async (ctx) => {
    48	      const context = ctx as OrgContextLike;
    49	      await requireActionPermission(context, GATE_ADVANCE_PERMISSION);
    50	
    51	      const project = await loadProjectForRevert(context, parsed.data.projectId);
    52	      if (project.npd_locked_for_release_at) {
    53	        return { success: false, error: 'NPD_RELEASE_LOCKED', status: 409 };
    54	      }
    55	
    56	      const targetGate = previousGate(project.current_gate);
    57	      if (!targetGate) {
    58	        return { success: false, error: 'ALREADY_AT_FIRST_GATE', status: 409 };
    59	      }
    60	
    61	      await signEvent(
    62	        {
    63	          signerUserId: context.userId,
    64	          pin: parsed.data.pin,
    65	          intent: GATE_REVERTED_EVENT,
    66	          subject: {
    67	            projectId: project.id,
    68	            projectCode: project.code,
    69	            fromGate: project.current_gate,
    70	            toGate: targetGate,
    71	          },
    72	          nonce: `${GATE_REVERTED_EVENT}:${project.id}:${project.current_gate}:${targetGate}:${Date.now()}`,
    73	          reason: parsed.data.reason,
    74	        },
    75	        { client: context.client as ESignTxOptions['client'] },
    76	      );
    77	
    78	      await updateProjectGate(context, project.id, targetGate);
    79	      await emitOutbox(context, {
    80	        eventType: GATE_REVERTED_EVENT,
    81	        aggregateType: 'npd_project',
    82	        aggregateId: project.id,
    83	        payload: {
    84	          project_id: project.id,
    85	          from_gate: project.current_gate,
    86	          to_gate: targetGate,
    87	          reason: parsed.data.reason,
    88	          actor_user_id: context.userId,
    89	        },
    90	        dedupKey: `${GATE_REVERTED_EVENT}:${project.id}:${project.current_gate}:${targetGate}:${Date.now()}`,
    91	      });
    92	
    93	      safeRevalidatePath(`/npd/pipeline/${project.id}`);
    94	      return { success: true };
    95	    });
    96	  } catch (error) {
    97	    const serialized = serializeGateError(error);
    98	    if (serialized) return { success: false, error: serialized.error, status: serialized.status };
    99	    if (error instanceof Error && /pin|failed|locked/i.test(error.message)) {
   100	      return { success: false, error: 'ESIGN_FAILED', status: 403 };
   101	    }
   102	    console.error('[revertNpdGate] persistence_failed', {
   103	      appVersion: APP_VERSION,
   104	      error: error instanceof Error ? error.message : String(error),
   105	    });
   106	    return { success: false, error: 'PERSISTENCE_FAILED', status: 500 };
   107	  }
   108	}
   109	
   110	async function loadProjectForRevert(ctx: OrgContextLike, projectId: string): Promise<RevertProjectRow> {
   111	  const { rows } = await ctx.client.query<RevertProjectRow>(
   112	    `select p.id,
   113	            p.code,
   114	            p.current_gate,
   115	            p.current_stage,
   116	            p.product_code,
   117	            product.private_jsonb ->> 'npd_locked_for_release_at' as npd_locked_for_release_at
   118	       from public.npd_projects p
   119	       left join public.product product
   120	         on product.org_id = p.org_id
   121	        and product.product_code = p.product_code
   122	      where p.id = $1::uuid
   123	        and p.org_id = app.current_org_id()
   124	      for update of p`,
   125	    [projectId],
