    66	export async function approveProjectGate(rawInput: unknown): Promise<ApproveProjectGateResult> {
    67	  const parsed = inputSchema.safeParse(rawInput);
    68	  if (!parsed.success) return { ok: false, error: 'INVALID_INPUT', status: 400 };
    69	
    70	  try {
    71	    return await withOrgContext<ApproveProjectGateResult>(async (ctx) => {
    72	      const context = ctx as OrgContextLike;
    73	      await requireActionPermission(context, GATE_APPROVE_PERMISSION);
    74	
    75	      const project = await loadProjectForUpdate(context, parsed.data.projectId);
    76	      // The project's DERIVED gate (from current_stage) must match the gate being
    77	      // approved. G3 → packaging/trial/sensory/pilot; G4 → approval/handoff.
    78	      if (project.current_gate !== parsed.data.gateCode) {
    79	        return { ok: false, error: 'GATE_MISMATCH', status: 409 };
    80	      }
    81	
    82	      // E-sign approval is now a CHECKPOINT RECORD — it no longer auto-advances the
    83	      // project. Advancement is stage-driven via advanceProjectGate; the G4 e-sign
    84	      // recorded here is what assertG4ESignForHandoff verifies for approval→handoff.
    85	      // Blockers are still checked against the current stage's gate checklist.
    86	      const nextStg = nextStage(project.current_stage) as AnyStage | null;
    87	      const blockers =
    88	        parsed.data.decision === 'approved' && nextStg
    89	          ? await getBlockers(context, project, nextStg)
    90	          : [];
    91	      if (blockers.length > 0) return { ok: false, error: 'BLOCKERS_PRESENT', status: 409, blockers };
    92	
    93	      let currentGate: ReturnType<typeof gateForStage> = project.current_gate;
    94	
    95	      // E-signature is collected ONLY on the approve path (G3/G4 require it). A rejection
    96	      // records the reason with no password and no signature (esigned_at/esign_hash null).
    97	      let esignedAt: string | null = null;
    98	      let esignHash: string | null = null;
    99	      let signatureId: string | null = null;
   100	      if (parsed.data.decision === 'approved') {
   101	        const receipt = await signEvent(
   102	          {
   103	            signerUserId: context.userId,
   104	            pin: parsed.data.password,
   105	            intent: `npd.gate.${parsed.data.decision}`,
   106	            subject: {
   107	              projectId: project.id,
   108	              projectCode: project.code,
   109	              gateCode: parsed.data.gateCode,
   110	              decision: parsed.data.decision,
   111	            },
   112	            nonce: `${project.id}:${parsed.data.gateCode}:${parsed.data.decision}:${Date.now()}`,
   113	            reason: parsed.data.notes,
   114	          },
   115	          { client: context.client as ESignTxOptions['client'] },
   116	        );
   117	        esignedAt = new Date(receipt.signedAt).toISOString();
   118	        esignHash = deterministicApprovalHash(context.userId, project.id, parsed.data.gateCode, esignedAt);
   119	        signatureId = receipt.signatureId;
   120	      }
   121	
   122	      const approval = await context.client.query<{ id: string }>(
   123	        `insert into public.gate_approvals
   124	           (org_id, project_id, gate_code, decision, approver_user_id, notes, rejection_reason, esigned_at, esign_hash)
   125	         values
   126	           (app.current_org_id(), $1::uuid, $2, $3, $4::uuid, $5, $6, $7::timestamptz, $8)
   127	         returning id`,
   128	        [
   129	          project.id,
   130	          parsed.data.gateCode,
   131	          parsed.data.decision,
   132	          context.userId,
   133	          parsed.data.notes,
   134	          parsed.data.decision === 'rejected' ? parsed.data.notes : null,
   135	          esignedAt,
   136	          esignHash,
   137	        ],
   138	      );
   139	      const approvalId = approval.rows[0]?.id;
   140	      if (!approvalId) return { ok: false, error: 'PERSISTENCE_FAILED', status: 500 };
   141	
   142	      let currentStage = project.current_stage as AnyStage;
   143	      if (parsed.data.decision === 'approved') {
   144	        const targetStage = approvalTargetStage(project.current_stage, parsed.data.gateCode);
   145	        if (targetStage) {
   146	          if (project.current_stage === 'approval' && targetStage === 'handoff') {
   147	            await seedHandoffChecklist(context, project);
   148	          }
   149	          await updateProjectStage(context, project.id, targetStage);
   150	          currentStage = targetStage;
   151	          currentGate = gateForStage(targetStage);
   152	        }
   153	      }
   154	
   155	      await emitOutbox(context, {
   156	        eventType: GATE_APPROVED_EVENT,
   157	        aggregateType: 'npd_project',
   158	        aggregateId: project.id,
   159	        payload: {
   160	          org_id: context.orgId,
   161	          actor_user_id: context.userId,
   162	          project_id: project.id,
   163	          project_code: project.code,
   164	          gate_code: parsed.data.gateCode,
   165	          decision: parsed.data.decision,
   166	          current_gate: currentGate,
   167	          current_stage: currentStage,
   168	          approval_id: approvalId,
   169	          e_sign_signature_id: signatureId,
   170	          esign_hash: esignHash,
   171	        },
   172	        dedupKey: `${GATE_APPROVED_EVENT}:${approvalId}`,
   173	      });
   174	
   175	      safeRevalidatePath(`/npd/pipeline/${project.id}`);
   176	      return {
   177	        ok: true,
   178	        data: {
   179	          projectId: project.id,
   180	          approvedGate: parsed.data.gateCode,
   181	          decision: parsed.data.decision,
   182	          currentGate,
   183	          currentStage,
   184	          approvalId,
   185	          outboxEventType: GATE_APPROVED_EVENT,
   186	        },
   187	      };
   188	    });
   189	  } catch (error) {
   190	    const serialized = serializeGateError(error);
   230	  if (role.rows.length === 0) throw new GateActionError('FORBIDDEN', 403);
   231	}
   232	
   233	/**
   234	 * G4 e-signature checkpoint guard for the approval → handoff stage transition.
   235	 *
   236	 * Advancing FROM `approval` TO `handoff` is the BRCGS/CFR-21 e-sign checkpoint. The
   237	 * signature itself is collected by the existing approveProjectGate flow (gateCode
   238	 * 'G4', signEvent intent 'npd.gate.approved' → gate_approvals with esigned_at +
   239	 * esign_hash). This guard verifies a valid, immutable G4 e-sign approval exists
   240	 * before allowing the stage to advance — advancing without one throws ESIGN_REQUIRED.
   241	 */
   242	export async function assertG4ESignForHandoff(ctx: OrgContextLike, projectId: string): Promise<void> {
   243	  const { rows } = await ctx.client.query<{ ok: boolean }>(
   244	    `select true as ok
   245	       from public.gate_approvals
   246	      where org_id = app.current_org_id()
   247	        and project_id = $1::uuid
   248	        and gate_code = 'G4'
   249	        and decision = 'approved'
   250	        and esigned_at is not null
   251	        and esign_hash is not null
   252	      limit 1`,
   253	    [projectId],
   254	  );
   255	  if (rows.length === 0) {
   256	    throw new GateActionError('ESIGN_REQUIRED', 403);
   257	  }
   258	}
   259	
   260	/**
   261	 * G3 e-signature guard for the G3 → G4 stage crossing (pilot → approval).
   262	 * Mirrors assertG4ESignForHandoff: a valid, immutable G3 e-sign approval (collected
   263	 * by approveProjectGate, gateCode 'G3') must exist before the project may enter G4.
   264	 * Advancing without one throws ESIGN_REQUIRED. (Owner decision F-1, 2026-06-27.)
   265	 */
   266	export async function assertG3ESignForApproval(ctx: OrgContextLike, projectId: string): Promise<void> {
   267	  const { rows } = await ctx.client.query<{ ok: boolean }>(
   268	    `select true as ok
   269	       from public.gate_approvals
   270	      where org_id = app.current_org_id()
   271	        and project_id = $1::uuid
   272	        and gate_code = 'G3'
   273	        and decision = 'approved'
   274	        and esigned_at is not null
   275	        and esign_hash is not null
   276	      limit 1`,
   277	    [projectId],
   278	  );
   279	  if (rows.length === 0) {
   280	    throw new GateActionError('ESIGN_REQUIRED', 403);
   281	  }
   282	}
