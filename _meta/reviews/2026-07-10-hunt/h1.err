   284	export async function loadProjectForUpdate(ctx: OrgContextLike, projectId: string): Promise<GateProjectRow> {
   285	  const { rows } = await ctx.client.query<GateProjectRow>(
   286	    `select id, code, name, type, current_gate, current_stage, product_code
   287	       from public.npd_projects
   288	      where id = $1::uuid
   289	        and org_id = app.current_org_id()
   290	      for update`,
    20	/**
    21	 * Delete an NPD project. Deleting the row cascades gate_checklist_items (ON DELETE
    22	 * CASCADE, mig 085) and nulls gate_approvals.project_id (ON DELETE SET NULL, kept for
    23	 * audit). A project that already has downstream work (formulation/packaging/trial/…)
    24	 * whose FK restricts deletion returns HAS_DEPENDENTS rather than a hard failure.
    25	 *
    26	 * RBAC: gated on npd.project.create (whoever can create projects can delete them).
    27	 */
    28	export async function deleteProject(rawInput: unknown): Promise<DeleteProjectResult> {
    29	  const projectId = typeof rawInput === 'string' ? rawInput : (rawInput as { projectId?: unknown })?.projectId;
    30	  if (typeof projectId !== 'string' || projectId.trim() === '') {
    31	    return { ok: false, error: 'INVALID_INPUT' };
    32	  }
    33	
    34	  try {
    35	    return await withOrgContext<DeleteProjectResult>(async (rawCtx): Promise<DeleteProjectResult> => {
    36	      const ctx = rawCtx as OrgContextLike;
    37	      if (!(await hasPermission(ctx, PROJECT_CREATE_PERMISSION))) {
    38	        return { ok: false, error: 'FORBIDDEN' };
    39	      }
    40	
    41	      let deleted: { id: string; code: string } | undefined;
    42	      try {
    43	        const { rows } = await ctx.client.query<{ id: string; code: string }>(
    44	          `delete from public.npd_projects
    45	            where id = $1::uuid
    46	              and org_id = app.current_org_id()
    47	          returning id, code`,
    48	          [projectId],
    49	        );
    50	        deleted = rows[0];
    51	      } catch (err) {
    52	        if ((err as { code?: string })?.code === PG_FK_VIOLATION) {
    53	          return { ok: false, error: 'HAS_DEPENDENTS' };
    54	        }
    55	        throw err;
    56	      }
    57	
    58	      if (!deleted) return { ok: false, error: 'NOT_FOUND' };
    59	
    60	      // Emit the deletion event as BEST-EFFORT. The project row is already deleted
    61	      // in this transaction; a failure here must NOT roll back the delete. The
    62	      // event_type 'npd.project.deleted' is not yet in the outbox_events CHECK
    63	      // allow-list, so this INSERT throws — and a failed statement aborts the whole
    64	      // transaction, which is exactly why "Could not delete the project" happened.
    65	      // Isolate it behind a SAVEPOINT so the delete still commits. (Follow-up:
    66	      // allow-list the event_type so deletion events are actually recorded.)
    67	      try {
    68	        await ctx.client.query('savepoint after_project_delete');
    69	        await ctx.client.query(
    70	          `insert into public.outbox_events
    71	             (org_id, event_type, aggregate_type, aggregate_id, payload, app_version, dedup_key)
    72	           values
    73	             (app.current_org_id(), $1, 'npd_project', $2, $3::jsonb, 'npd-project-actions-v1', $4)
    74	           on conflict (org_id, dedup_key) where dedup_key is not null do nothing`,
    75	          [
    76	            PROJECT_DELETED_EVENT,
    77	            deleted.id,
    78	            JSON.stringify({ org_id: ctx.orgId, actor_user_id: ctx.userId, project_id: deleted.id, code: deleted.code }),
    79	            `${PROJECT_DELETED_EVENT}:${deleted.id}`,
    80	          ],
    81	        );
    82	      } catch (evtErr) {
    83	        await ctx.client.query('rollback to savepoint after_project_delete');
    84	        console.error('[deleteProject] deletion event not emitted (delete still committed)', evtErr);
    85	      }
    86	
    87	      try {
    88	        revalidateLocalized('/pipeline');
    89	      } catch {
    90	        // Vitest imports Server Actions outside a Next request store.
    91	      }
    92	      return { ok: true };
    93	    });
    94	  } catch {
    95	    return { ok: false, error: 'PERSISTENCE_FAILED' };
    96	  }
    97	}
