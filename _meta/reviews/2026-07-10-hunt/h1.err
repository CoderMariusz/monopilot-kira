  }
}

function approvalTargetStage(currentStage: string, gateCode: 'G3' | 'G4'): AnyStage | null {
  if (gateCode === 'G3') return 'approval';
  if (gateCode === 'G4' && currentStage === 'approval') return 'handoff';
  return null;
}

