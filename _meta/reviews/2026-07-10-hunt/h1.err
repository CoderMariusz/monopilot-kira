    51	export type ApproveProjectGateResult =
    52	  | {
    53	      ok: true;
    54	      data: {
    55	        projectId: string;
    56	        approvedGate: 'G3' | 'G4';
    57	        decision: 'approved' | 'rejected';
    58	        currentGate: ProjectGate;
    59	        currentStage: AnyStage;
    60	        approvalId: string;
    61	        outboxEventType: typeof GATE_APPROVED_EVENT;
    62	      };
    63	    }
    64	  | { ok: false; error: string; status: number; blockers?: GateBlocker[] };
