    57	
    58	export function computeWoActualCostTotals(input: WoActualCostMathInput): WoActualCostTotals {
    59	  let materialQtyTotal = 0n;
    60	  let materialsTotal = 0n;
    61	
    62	  const materials = input.materials.map((material) => {
    63	    const qty = toMicro(material.qtyKg);
    64	    const costPerKg = toMicro(material.costPerKg ?? '0');
    65	    const cost = mulMicro(qty, costPerKg);
    66	    materialQtyTotal += qty;
    67	    materialsTotal += cost;
    68	
    69	    return {
    70	      itemCode: material.itemCode,
    71	      qtyKg: microToFixed(qty, 3),
    72	      costPerKg: microToFixed(costPerKg, 6),
    73	      cost: microToFixed(cost, 4),
    74	    };
    75	  });
    76	
    77	  const labor =
    78	    input.labor == null
    79	      ? null
    80	      : (() => {
    81	          const runtimeMin = toMicro(input.labor.runtimeMin);
    82	          const staffing = toMicro(input.labor.staffing);
    83	          const ratePerHour = toMicro(input.labor.ratePerHour);
    84	          const runtimeHours = divMicro(runtimeMin, toMicro('60'));
    85	          const staffedHours = mulMicro(runtimeHours, staffing);
    86	          const cost = mulMicro(staffedHours, ratePerHour);
    87	          return {
