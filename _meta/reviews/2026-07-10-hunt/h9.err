    56	export async function listCostHistory(rawInput: unknown): Promise<ListCostHistoryResult> {
    57	  const parsed = ListCostHistoryInput.safeParse(rawInput);
    58	  if (!parsed.success) return { ok: false, error: 'invalid_input', message: parsed.error.message };
    59	  const input = parsed.data;
    60	
    61	  try {
    62	    return await withOrgContext(async ({ userId, orgId, client }): Promise<ListCostHistoryResult> => {
    63	      const qc = client as QueryClient;
    64	      const ctx: OrgActionContext = { userId, orgId, client: qc };
    65	      if (!(await hasPermission(ctx, COST_EDIT_PERMISSION))) return { ok: false, error: 'forbidden' };
    66	
    67	      const { rows } = await qc.query<HistoryDbRow>(
    68	        `select id,
    69	                item_id,
    70	                cost_per_kg::text as cost_per_kg,
    71	                currency,
    72	                effective_from::text as effective_from,
    73	                effective_to::text as effective_to,
    74	                source,
    75	                created_by::text as created_by,
    76	                created_at
    77	           from public.item_cost_history
    78	          where org_id = app.current_org_id()
    79	            and item_id = $1::uuid
    80	          order by effective_from desc, created_at desc`,
    81	        [input.itemId],
    82	      );
    83	
    84	      return { ok: true, data: { rows: rows.map(mapRow) } };
    85	    });
    86	  } catch (error) {
    87	    console.error('[technical/cost] listCostHistory load_failed', {
    88	      err: error instanceof Error ? error.message : String(error),
    89	    });
    90	    return { ok: false, error: 'persistence_failed' };

