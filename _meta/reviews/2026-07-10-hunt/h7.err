     1	import pg from 'pg';
     2	
     3	/**
     4	 * 09-Quality T-064 — canonical consume-gate guard (single source of truth).
     5	 *
     6	 * 08-production's WO-consume Server Action, 05-warehouse's LP-consume Server Action, and
     7	 * 11-shipping's LP qa_status gate MUST call these helpers before recording a consumption /
     8	 * allocation. Direct reads of `quality_holds` from a consume path are a contract violation —
     9	 * import `assertNoActiveHoldForWo` / `assertNoActiveHoldForLp` from THIS module so the active-hold
    10	 * predicate lives in exactly one place (see MON-domain-quality §"CRITICAL: T-064 consume gate").
    11	 *
    12	 * The guards read the `v_active_holds` SECURITY INVOKER view (migration 197), so RLS on
    13	 * `quality_holds` flows from the caller's `app.current_org_id()`. They never bypass RLS and never
    14	 * re-implement the active-hold WHERE clause.
    15	 *
    16	 * NOTE: this is a plain library module (NOT a Next.js `'use server'` file). It deliberately exports
    17	 * the `QaHoldActiveError` class + the `QA_HOLD_ACTIVE` constant alongside the async guards — a
    18	 * `'use server'` module may only export async functions, so consumers that need the error type in a
    19	 * `'use server'` boundary import it from here (the non-`'use server'` source), per the class-2
    20	 * recurring-live-bug rule.
    21	 */
    22	
    23	/** Stable cross-module error code carried in the QaHoldActiveError envelope. */
    24	export const QA_HOLD_ACTIVE = 'QA_HOLD_ACTIVE' as const;
    25	
    26	/** Hold priority levels (mirrors quality_holds_priority_check). */
    27	export type HoldPriority = 'low' | 'medium' | 'high' | 'critical';
    28	
    29	/**
    30	 * Cross-module error envelope thrown when an active hold blocks a consume / allocate operation.
    31	 * The shape `{ code, hold_number, priority, reason_code }` is the pinned cross-module contract —
    32	 * do NOT change it without a coordinated revision in 05-warehouse / 08-production / 11-shipping.
    33	 */
    34	export interface QaHoldActiveEnvelope {
    35	  code: typeof QA_HOLD_ACTIVE;
    36	  hold_number: string;
    37	  priority: HoldPriority;
    38	  reason_code: string | null;
    39	}
    40	
    41	/** HTTP-409 error thrown by the consume gate when an active hold covers the reference. */
    42	export class QaHoldActiveError extends Error {
    43	  readonly status = 409 as const;
    44	  readonly code = QA_HOLD_ACTIVE;
    45	  readonly holdNumber: string;
    46	  readonly priority: HoldPriority;
    47	  readonly reasonCode: string | null;
    48	
    49	  constructor(holdNumber: string, priority: HoldPriority, reasonCode: string | null) {
    50	    super(`Active quality hold ${holdNumber} (priority=${priority}) blocks this operation`);
    51	    this.name = 'QaHoldActiveError';
    52	    this.holdNumber = holdNumber;
    53	    this.priority = priority;
    54	    this.reasonCode = reasonCode;
    55	    // Restore prototype chain for instanceof across transpilation targets.
    56	    Object.setPrototypeOf(this, QaHoldActiveError.prototype);
    57	  }
    58	
    59	  /** Serialise to the pinned cross-module JSON envelope. */
    60	  toEnvelope(): QaHoldActiveEnvelope {
    61	    return {
    62	      code: this.code,
    63	      hold_number: this.holdNumber,
    64	      priority: this.priority,
    65	      reason_code: this.reasonCode,
    66	    };
    67	  }
    68	}
    69	
    70	type ActiveHoldRow = {
    71	  hold_number: string;
    72	  priority: HoldPriority;
    73	};
    74	
    75	/** Minimal query surface satisfied by pg.Pool / pg.PoolClient and the local QueryClient aliases used in each action file. */
    76	export interface HoldQueryClient {
    77	  query<R extends pg.QueryResultRow = ActiveHoldRow>(
    78	    queryText: string,
    79	    values?: unknown[],
    80	  ): Promise<{ rows: R[]; rowCount?: number | null | undefined }>;
    81	}
    82	
    83	/**
    84	 * Core gate: throw QaHoldActiveError if `v_active_holds` contains an active hold whose
    85	 * (reference_type, reference_id) covers the given reference. RLS via SECURITY INVOKER means only
    86	 * the caller's own org's holds are visible — the explicit `org_id` argument is used solely to keep
    87	 * the predicate self-documenting (and to fail closed if a caller forgets to bind org context).
    88	 */
    89	async function assertNoActiveHoldForReference(
    90	  referenceType: 'wo' | 'po' | 'grn',
    91	  referenceId: string,
    92	  db: HoldQueryClient,
    93	): Promise<void> {
    94	  const { rows } = await db.query<ActiveHoldRow>(
    95	    `select hold_number, priority
    96	       from public.v_active_holds
    97	      where org_id = app.current_org_id()
    98	        and reference_type = $1
    99	        and reference_id = $2::uuid
   100	      order by case priority
   101	                 when 'critical' then 0
   102	                 when 'high' then 1
   103	                 when 'medium' then 2
   104	                 when 'low' then 3
   105	                 else 4
   106	               end
   107	      limit 1`,
   108	    [referenceType, referenceId],
   109	  );
   110	
   111	  if (rows.length > 0) {
   112	    const hit = rows[0];
   113	    // reason_code is not projected by v_active_holds (intentionally minimal read model); the
   114	    // envelope carries null until a richer reason projection is added. Consumers surface the
   115	    // hold_number + priority for the operator.
   116	    throw new QaHoldActiveError(hit.hold_number, hit.priority, null);
   117	  }
   118	}
   119	
   120	/**
   121	 * Assert no active quality hold covers the given Work Order. Call from 08-production's WO-consume
   122	 * Server Action before recording consumption.
   123	 */
   124	export async function assertNoActiveHoldForWo(
   125	  woId: string,
   126	  db: HoldQueryClient,
   127	): Promise<void> {
   128	  await assertNoActiveHoldForReference('wo', woId, db);
   129	}
   130	
   131	/**
   132	 * Assert no active quality hold covers the given License Plate. Call from 05-warehouse's LP-consume
   133	 * Server Action (and 11-shipping's LP qa_status gate) before recording consumption / allocation.
   134	 */
   135	export async function assertNoActiveHoldForLp(
   136	  lpId: string,
   137	  db: HoldQueryClient,
   138	): Promise<void> {
   139	  const { rows } = await db.query<ActiveHoldRow>(
   140	    `with target_lp as (
