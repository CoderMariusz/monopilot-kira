   974	          qaStatus,
   975	          signatureHash: receipt.subjectHash,
   976	        },
   977	      };
   978	    });
   979	  } catch (err) {
   980	    return { ok: false, reason: 'error', message: err instanceof Error ? err.message : String(err) };
   981	  }
   982	}
