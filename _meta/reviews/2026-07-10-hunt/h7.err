   337	
   338	async function applyLpDecisionSideEffects(
   339	  ctx: QualityContext,
   340	  params: { referenceType: ReferenceType; referenceId: string; decision: Decision; note: string | null },
   341	): Promise<'released' | 'rejected' | 'on_hold' | null> {
   342	  if (params.referenceType === 'grn') {
   343	    if (params.decision !== 'fail') return null;
   344	    const lpIds = await findReceivedLpIdsForGrn(ctx, params.referenceId);
   345	    if (lpIds.length === 0) throw new Error('grn inspection failed but no received license plates were found');
   346	    await createInspectionHoldIfMissing(ctx, {
   347	      referenceType: 'grn',
   348	      referenceId: params.referenceId,
   349	      lpIds,
   350	      reasonText: params.note ?? 'failed GRN inspection',
   351	      priority: 'high',
   352	    });
   353	    return 'on_hold';
   354	  }
   355	
   356	  if (params.referenceType === 'wo_output') {
   357	    if (params.decision !== 'pass') return null;
   358	    const lpId = await findLpIdForWoOutput(ctx, params.referenceId);
   359	    // Deliberate: the signed inspection decision is the gated act (quality.inspection perms + signEvent); the LP release is its side effect — bypassing quality.batch.release here is an R-G1 SHOULD-3 owner-flagged decision (wave F3).
   360	    const released = await releaseLpQaForContext(
   361	      { userId: ctx.userId, orgId: ctx.orgId, client: ctx.client },
   362	      { lpId, decision: 'released', note: params.note ?? undefined },
   363	      { requirePermission: false },
   364	    );
   365	    if (!released.ok) throw new Error(released.message ?? released.reason);
   366	    return released.data.qaStatus;
   367	  }
   368	
   369	  if (params.referenceType !== 'lp') return null;
   370	
   371	  const qaStatus = params.decision === 'pass' ? 'released' : params.decision === 'fail' ? 'rejected' : 'on_hold';
   372	  if (qaStatus === 'released') {
   373	    try {
   374	      await assertNoActiveHoldForLp(params.referenceId, ctx.client);
   375	    } catch (error) {
   376	      if (typeof error === 'object' && error !== null && (error as { code?: string }).code === 'QA_HOLD_ACTIVE') {
   377	        const current = await ctx.client.query<{ qa_status: 'released' | 'rejected' | 'on_hold' | 'pending' | null }>(
   378	          `select qa_status
   379	             from public.license_plates
   380	            where org_id = app.current_org_id()
   381	              and id = $1::uuid
   382	            limit 1`,
   383	          [params.referenceId],
   384	        );
   385	        const currentStatus = current.rows[0]?.qa_status;
   386	        return currentStatus === 'released' || currentStatus === 'rejected' || currentStatus === 'on_hold' ? currentStatus : null;
   387	      }
   388	      throw error;
   389	    }
   390	  }
   391	
   392	  const updated = await ctx.client.query<{ id: string }>(
   393	    `update public.license_plates
   394	        set qa_status = $2,
   395	            updated_by = $3::uuid
   396	      where org_id = app.current_org_id()
   397	        and id = $1::uuid
   398	        and status <> all($4::text[])
   399	      returning id::text`,
   400	    [params.referenceId, qaStatus, ctx.userId, [...TERMINAL_LP_STATUSES]],
   401	  );
   402	  if (!updated.rows[0]) throw new Error('license plate not found');
   403	  if (params.decision === 'hold') {
   404	    await createInspectionHoldIfMissing(ctx, {
   405	      referenceType: 'lp',
   406	      referenceId: params.referenceId,
   407	      lpIds: [params.referenceId],
   408	      reasonText: params.note ?? 'inspection hold',
   409	      priority: 'high',
   410	    });
   411	  }
   412	  return qaStatus;
   413	}
   414	
   415	async function fetchInspectionDetail(ctx: QualityContext, inspectionId: string): Promise<InspectionDetail | null> {
   416	  const { rows } = await ctx.client.query<Parameters<typeof mapDetailRow>[0]>(
   417	    `select
   418	       qi.id::text,
   419	       qi.inspection_number,
   420	       qi.reference_type,
   421	       qi.reference_id::text,
   422	       coalesce(
   423	         case when qi.reference_type = 'lp' then lp.lp_number end,
   424	         case when qi.reference_type = 'grn' then grn.grn_number end,
   425	         case when qi.reference_type = 'wo_output' then wo.wo_number || coalesce(' / ' || woo.batch_number, '') end,
   426	         qi.reference_id::text
   427	       ) as reference_display,
   428	       coalesce(qi.product_id, lp.product_id, woo.product_id)::text as product_id,
   429	       i.item_code as product_code,
   430	       i.name as product_name,
   431	       qi.status,
   432	       qi.assigned_to::text,
   433	       assigned.email::text as assigned_email,
   434	       assigned.display_name as assigned_name,
   435	       qi.due_date::text,
   436	       qi.created_at,
   437	       qi.parameters,
   438	       qi.result_notes,
   439	       qi.decided_by::text,
   440	       decided.email::text as decided_email,
   441	       decided.display_name as decided_name,
   442	       qi.decided_at,
   443	       qi.signature_hash,
   444	       qi.created_by::text,
   445	       creator.email::text as created_email,
   446	       creator.display_name as created_name,
   447	       qi.updated_at,
   448	       hold.id::text as hold_id
   449	     from public.quality_inspections qi
   450	     left join public.license_plates lp on qi.reference_type = 'lp' and lp.id = qi.reference_id and lp.org_id = qi.org_id
   451	     left join public.grns grn on qi.reference_type = 'grn' and grn.id = qi.reference_id and grn.org_id = qi.org_id
   452	     left join public.wo_outputs woo on qi.reference_type = 'wo_output' and woo.id = qi.reference_id and woo.org_id = qi.org_id
   453	     left join public.work_orders wo on wo.id = woo.wo_id and wo.org_id = qi.org_id
   454	     left join public.items i on i.id = coalesce(qi.product_id, lp.product_id, woo.product_id) and i.org_id = qi.org_id
   455	     left join public.users assigned on assigned.id = qi.assigned_to and assigned.org_id = qi.org_id
   456	     left join public.users decided on decided.id = qi.decided_by and decided.org_id = qi.org_id
   457	     left join public.users creator on creator.id = qi.created_by and creator.org_id = qi.org_id
   458	     -- Latest ACTIVE hold for this inspection's LP. No FK links inspection→hold
   459	     -- (migration 272), and submitInspectionDecision creates the hold via
   460	     -- createLpHold against reference_type='lp' + reference_id, so we deep-link to
   461	     -- the most recent still-active hold for the same LP.
   462	     left join lateral (
   463	       select qh.id
   464	         from public.quality_holds qh
   465	        where qh.org_id = qi.org_id
   466	          and qi.reference_type = 'lp'
   467	          and qh.reference_type = 'lp'
   468	          and qh.reference_id = qi.reference_id
   469	          -- Canonical "active hold" definition (migration 197 v_active_holds):
   470	          -- non-terminal hold_status AND released_at IS NULL (review fix F6).
   471	          and qh.hold_status in ('open', 'investigating', 'escalated', 'quarantined')
   472	          and qh.released_at is null
   473	        order by qh.created_at desc
   474	        limit 1
   475	     ) hold on true
   476	    where qi.org_id = app.current_org_id()
   477	      and qi.id = $1::uuid
   478	    limit 1`,
   479	    [inspectionId],
   480	  );
   481	  return rows[0] ? mapDetailRow(rows[0]) : null;
   482	}
