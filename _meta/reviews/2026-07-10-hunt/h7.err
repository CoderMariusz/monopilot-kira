   527	          and (
   528	            rt.row_key = h.reason_code_id::text
   529	            or rt.row_data->>'id' = h.reason_code_id::text
   530	            or rt.row_data->>'reason_code_id' = h.reason_code_id::text
   531	          )
   532	        where h.org_id = app.current_org_id()
   533	          and h.id = $1::uuid
   534	        limit 1`,
   535	        [parsedHoldId],
   536	      );
   537	      const row = header.rows[0];
   538	      if (!row) return { ok: true, data: null };
   539	
   540	      const [items, ncrs] = await Promise.all([
   541	        ctx.client.query<{
   542	          id: string;
   543	          license_plate_id: string | null;
   544	          lp_number: string | null;
   545	          item_id: string | null;
   546	          item_code: string | null;
   547	          qty_held_kg: string | null;
   548	          qty_released_kg: string | null;
   549	          item_status: string;
   550	        }>(
   551	          `select
   552	             qhi.id::text,
   553	             qhi.license_plate_id::text,
   554	             lp.lp_number,
   555	             lp.product_id::text as item_id,
   556	             i.item_code,
   557	             qhi.qty_held_kg::text,
   558	             qhi.qty_released_kg::text,
   559	             qhi.item_status
   560	           from public.quality_hold_items qhi
   561	           left join public.license_plates lp on lp.id = qhi.license_plate_id and lp.org_id = qhi.org_id
   562	           left join public.items i on i.id = lp.product_id and i.org_id = qhi.org_id
   563	          where qhi.org_id = app.current_org_id()
   564	            and qhi.hold_id = $1::uuid
   565	          order by lp.lp_number nulls last, qhi.created_at`,
   566	          [parsedHoldId],
   567	        ),
   568	        ctx.client.query<{
   569	          id: string;
   570	          ncr_number: string;
   571	          title: string;
   572	          severity: string;
   573	          status: string;
   574	        }>(
   575	          `select id::text, ncr_number, title, severity, status
   576	             from public.ncr_reports
   577	            where org_id = app.current_org_id()
   578	              and linked_hold_id = $1::uuid
   579	            order by created_at desc`,
   580	          [parsedHoldId],
   581	        ),
   582	      ]);
   583	
   584	      return {
   585	        ok: true,
   586	        data: {
   587	          ...mapListRow(row),
   588	          disposition: row.disposition,
   589	          releaseNotes: row.release_notes,
   590	          releaseSignatureHash: row.release_signature_hash,
   591	          releasedBy: row.released_by,
   592	          items: items.rows.map((item) => ({
   593	            id: item.id,
   594	            licensePlateId: item.license_plate_id,
   595	            lpNumber: item.lp_number,
   596	            itemId: item.item_id,
   597	            itemCode: item.item_code,
   598	            qtyHeldKg: item.qty_held_kg,
   599	            qtyReleasedKg: item.qty_released_kg,
   600	            status: item.item_status,
   601	          })),
   602	          ncrs: ncrs.rows.map((ncr) => ({
   603	            id: ncr.id,
   604	            ncrNumber: ncr.ncr_number,
   605	            title: ncr.title,
   606	            severity: ncr.severity,
   607	            status: ncr.status,
   608	          })),
   609	        },
   610	      };
   611	    });
   612	  } catch (err) {
   613	    return { ok: false, reason: 'error', message: err instanceof Error ? err.message : String(err) };
   614	  }
   615	}
   616	
   617	export async function createHold(input: {
   618	  referenceType: ReferenceType;
   619	  referenceId: string;
   620	  reasonCodeId?: string;
   621	  reasonText?: string;
   622	  priority: HoldPriority;
   623	  lpIds?: string[];
   624	  estimatedReleaseAt?: string;
   625	}): Promise<ActionResult<CreatedHold>> {
   626	  try {
   627	    const parsed = createSchema.parse(input);
   628	    return await withOrgContext(async (ctx): Promise<ActionResult<CreatedHold>> => {
   629	      if (!(await hasPermission(ctx, 'quality.hold.create'))) return { ok: false, reason: 'forbidden' };
   630	      return { ok: true, data: await createHoldCore(ctx, parsed) };
   631	    });
   632	  } catch (err) {
   633	    return { ok: false, reason: 'error', message: err instanceof Error ? err.message : String(err) };
   634	  }
   635	}
   636	
   637	type HoldForRelease = {
   638	  id: string;
   639	  hold_number: string;
   640	  reference_type: ReferenceType;
   641	  reference_id: string;
   642	  hold_status: string;
   643	  released_at: Date | string | null;
   644	};
   645	
   646	type ReleaseHoldCoreInput = {
   647	  holdId: string;
   648	  disposition: ReleaseDisposition;
   649	  reasonText: string;
   650	};
   651	
   652	export async function releaseHoldCore(
   653	  ctx: QualityContext,
   654	  input: ReleaseHoldCoreInput,
   655	  options: {
   656	    releaseSource: string;
   657	    expectedReference?: { type: ReferenceType; id: string };
   658	    getSignatureHash: (current: HoldForRelease) => Promise<string>;
   659	  },
   660	): Promise<ActionResult<ReleasedHold>> {
   661	  const hold = await ctx.client.query<HoldForRelease>(
   662	    `select id::text, hold_number, reference_type, reference_id::text, hold_status, released_at
   663	       from public.quality_holds
   664	      where org_id = app.current_org_id()
   665	        and id = $1::uuid
   666	      for update`,
   667	    [input.holdId],
   668	  );
   669	  const current = hold.rows[0];
   670	  if (!current) throw new Error('quality hold not found');
   671	  if (current.hold_status === 'released' || current.released_at !== null) {
   672	    throw new Error('quality hold is already released');
   673	  }
   674	  if (
   675	    options.expectedReference &&
   676	    (current.reference_type !== options.expectedReference.type || current.reference_id !== options.expectedReference.id)
   677	  ) {
   678	    throw new Error('quality hold does not match license plate');
   679	  }
   680	
   681	  const signatureHash = await options.getSignatureHash(current);
   682	
   683	  const dbDisposition =
   684	    input.disposition === 'release'
   685	      ? 'release_as_is'
   686	      : input.disposition === 'scrap'
   687	        ? 'scrap'
   688	        : input.disposition === 'rework'
   689	          ? 'rework'
   690	          : 'other';
   691	  const itemStatus = input.disposition === 'scrap' ? 'scrapped' : input.disposition === 'partial' ? 'partial_released' : 'released';
   692	  const lpQaStatus = input.disposition === 'scrap' ? 'rejected' : 'released';
   693	
   694	  const updated = await ctx.client.query<{ released_at: Date | string }>(
   695	    `update public.quality_holds
   696	        set hold_status = 'released',
   697	            released_by = $2::uuid,
   698	            released_at = pg_catalog.now(),
   699	            disposition = $3,
   700	            release_notes = $4,
   701	            release_signature_hash = $5
   702	      where org_id = app.current_org_id()
   703	        and id = $1::uuid
   704	        and hold_status <> 'released'
   705	        and released_at is null
   706	      returning released_at`,
   707	    [input.holdId, ctx.userId, dbDisposition, input.reasonText, signatureHash],
   708	  );
   709	  const releasedAt = updated.rows[0]?.released_at;
   710	  if (!releasedAt) throw new Error('quality hold release update did not return a row');
   711	
   712	  await ctx.client.query(
   713	    `update public.quality_hold_items
   714	        set item_status = $2,
   715	            qty_released_kg = case when $2 = 'released' then qty_held_kg else qty_released_kg end
   716	      where org_id = app.current_org_id()
   717	        and hold_id = $1::uuid`,
   718	    [input.holdId, itemStatus],
   719	  );
   720	
   721	  const heldLps = await ctx.client.query<{
   722	    id: string;
   723	    status: string;
   724	    qa_status: string;
   725	    site_id: string | null;
   726	    wo_id: string | null;
   727	    grn_id: string | null;
   728	  }>(
   729	    `select lp.id::text, lp.status, lp.qa_status, lp.site_id::text, lp.wo_id::text, lp.grn_id::text
   730	       from public.quality_hold_items qhi
   731	       join public.license_plates lp on lp.id = qhi.license_plate_id and lp.org_id = qhi.org_id
   732	      where qhi.org_id = app.current_org_id()
   733	        and qhi.hold_id = $1::uuid
   734	        and qhi.license_plate_id is not null`,
   735	    [input.holdId],
   736	  );
   737	
   738	  if (heldLps.rows.length > 0) {
   739	    let restoreReleasedLpIds = heldLps.rows.map((lp) => lp.id);
   740	    const blockedByOtherHold = new Set<string>();
   741	    const restoresReleasedQaStatus = lpQaStatus === 'released';
   742	
   743	    if (restoresReleasedQaStatus) {
   744	      for (const lpId of restoreReleasedLpIds) {
   745	        try {
   746	          await assertNoActiveHoldForLp(lpId, ctx.client);
   747	        } catch (error) {
   748	          if (typeof error === 'object' && error !== null && (error as { code?: string }).code === 'QA_HOLD_ACTIVE') {
   749	            blockedByOtherHold.add(lpId);
   750	            continue;
   751	          }
   752	          throw error;
   753	        }
   754	      }
   755	      restoreReleasedLpIds = restoreReleasedLpIds.filter((lpId) => !blockedByOtherHold.has(lpId));
   756	    }
   757	
   758	    const lpUpdateIds = restoresReleasedQaStatus ? restoreReleasedLpIds : heldLps.rows.map((lp) => lp.id);
   759	    if (lpUpdateIds.length > 0) {
   760	      await ctx.client.query(
   761	        `update public.license_plates
   762	            set qa_status = $2,
   763	                status = case
   764	                  when $5::boolean and status = 'blocked' then 'available'
   765	                  else status
   766	                end,
   767	                updated_by = $3::uuid
   768	          where org_id = app.current_org_id()
   769	            and id = any($1::uuid[])
   770	            and status <> all($4::text[])`,
   771	        [
   772	          lpUpdateIds,
   773	          lpQaStatus,
   774	          ctx.userId,
   775	          [...TERMINAL_LP_STATUSES],
   776	          input.disposition === 'release',
   777	        ],
   778	      );
   779	    }
   780	
   781	    for (const lp of heldLps.rows.filter((row) => !TERMINAL_LP_STATUSES.includes(row.status as (typeof TERMINAL_LP_STATUSES)[number]))) {
   782	      const restoresQaStatus = !blockedByOtherHold.has(lp.id);
   783	      const restoresBlockedStatus = input.disposition === 'release' && restoresQaStatus && lp.status === 'blocked';
   784	      const toState = restoresBlockedStatus ? 'available' : lp.status;
   785	      await ctx.client.query(
   786	        `insert into public.lp_state_history (
   787	           org_id,
   788	           site_id,
   789	           lp_id,
   790	           from_state,
   791	           to_state,
   792	           reason_code,
   793	           reason_text,
   794	           wo_id,
   795	           grn_id,
   796	           created_by,
   797	           ext_jsonb
   798	         )
   799	         values (
   800	           app.current_org_id(),
   801	           $2::uuid,
   802	           $1::uuid,
   803	           $3,
   804	           $4,
   805	           $5,
   806	           $6,
   807	           $7::uuid,
   808	           $8::uuid,
   809	           $9::uuid,
   810	           $10::jsonb
   811	         )`,
   812	        [
   813	          lp.id,
   814	          lp.site_id,
   815	          lp.status,
   816	          toState,
   817	          restoresBlockedStatus ? 'status_change' : 'quality_hold_release',
   818	          input.reasonText,
   819	          lp.wo_id,
   820	          lp.grn_id,
   500	          parsed.critical_limit_min ?? null,
   501	          parsed.critical_limit_max ?? null,
   502	          parsed.unit ?? '',
   503	          parsed.monitoring_frequency ?? '',
   504	          parsed.corrective_action ?? '',
   505	          parsed.line_id ?? null,
   506	          parsed.plan_id ?? null,
   507	          parsed.is_active ?? true,
   508	          ctx.userId,
   509	          hasPlanId,
   510	        ],
   511	      );
   512	      const row = rows[0];
   513	      if (!row) throw new Error('CCP upsert did not return a row');
   514	
   515	      return { ok: true, data: mapCcpRow(row) };
   516	    });
   517	  } catch (err) {
   518	    return { ok: false, reason: 'error', message: err instanceof Error ? err.message : String(err) };
   519	  }
   520	}
   521	
   522	export async function deactivateCcp(ccpId: string): Promise<ActionResult<{ id: string; isActive: false }>> {
   523	  try {
   524	    const parsedCcpId = deactivateCcpSchema.parse(ccpId);
   525	    return await withOrgContext(async (ctx): Promise<ActionResult<{ id: string; isActive: false }>> => {
   526	      if (!(await hasPermission(ctx, 'quality.haccp.plan_edit'))) return { ok: false, reason: 'forbidden' };
   527	
   528	      const before = await ctx.client.query<{ id: string; is_active: boolean }>(
   529	        `select id::text, is_active
   530	           from public.haccp_ccps
   531	          where org_id = app.current_org_id()
   532	            and id = $1::uuid
   533	          limit 1`,
   534	        [parsedCcpId],
   535	      );
   536	      const beforeRow = before.rows[0];
   537	      if (!beforeRow) throw new Error('CCP not found');
   538	
   539	      const updated = await ctx.client.query<{ id: string; is_active: false }>(
   540	        `update public.haccp_ccps
   541	            set is_active = false
   542	          where org_id = app.current_org_id()
   543	            and id = $1::uuid
   544	          returning id::text, is_active`,
   545	        [parsedCcpId],
   546	      );
   547	      const row = updated.rows[0];
   548	      if (!row) throw new Error('CCP deactivate did not return a row');
   549	
   550	      await writeAuditEvent(ctx, {
   551	        action: 'haccp.ccp.deactivated',
   552	        resourceType: 'haccp_ccp',
   553	        resourceId: row.id,
   554	        beforeState: { id: beforeRow.id, isActive: beforeRow.is_active },
   555	        afterState: { id: row.id, isActive: row.is_active },
   556	      });
   557	
   558	      return { ok: true, data: { id: row.id, isActive: false } };
   559	    });
   560	  } catch (err) {
   561	    return { ok: false, reason: 'error', message: err instanceof Error ? err.message : String(err) };
   562	  }
   563	}
   564	
   565	export async function listMonitoringLog(input: { ccpId?: string; days?: number } = {}): Promise<ActionResult<MonitoringLogRow[]>> {
   566	  try {
   567	    const parsed = listMonitoringLogSchema.parse(input);
   568	    return await withOrgContext(async (ctx): Promise<ActionResult<MonitoringLogRow[]>> => {
   569	      // READ gate (relaxed P1): plan_edit OR ccp.deviation_override — see canReadCcpBoard.
   570	      if (!(await canReadCcpBoard(ctx))) return { ok: false, reason: 'forbidden' };
   571	
   572	      const { rows } = await ctx.client.query<Parameters<typeof mapMonitoringRow>[0]>(
   573	        `select
   574	           l.id::text,
   575	           l.ccp_id::text,
   576	           c.ccp_code,
   577	           l.measured_value::text,
   578	           l.measured_at,
   579	           l.wo_id::text,
   580	           l.within_limits,
   581	           l.recorded_by::text,
   582	           l.note,
   583	           l.breach_ncr_id::text
   584	         from public.haccp_monitoring_log l
   585	         left join public.haccp_ccps c on c.id = l.ccp_id and c.org_id = l.org_id
   586	        where l.org_id = app.current_org_id()
   587	          and ($1::uuid is null or l.ccp_id = $1::uuid)
   588	          and ($2::int is null or l.measured_at >= pg_catalog.now() - make_interval(days => $2::int))
   589	        order by l.measured_at desc`,
   590	        [parsed.ccpId ?? null, parsed.days ?? null],
   591	      );
   592	
   593	      return { ok: true, data: rows.map(mapMonitoringRow) };
   594	    });
   595	  } catch (err) {
   596	    return { ok: false, reason: 'error', message: err instanceof Error ? err.message : String(err) };
   597	  }
   598	}
   599	
   600	export async function recordMonitoring(data: {
   601	  ccpId: string;
   602	  measuredValue: string;
   603	  woId?: string;
   604	  note?: string;
   605	}): Promise<ActionResult<MonitoringResult>> {
   606	  try {
   607	    const parsed = recordMonitoringSchema.parse(data);
   608	    return await withOrgContext(async (ctx): Promise<ActionResult<MonitoringResult>> => {
   609	      if (!(await hasPermission(ctx, 'quality.ccp.deviation_override'))) return { ok: false, reason: 'forbidden' };
   610	
   611	      const ccpResult = await ctx.client.query<{
   612	        id: string;
   613	        ccp_code: string;
   614	        critical_limit_min: string | null;
   615	        critical_limit_max: string | null;
   616	        unit: string | null;
   617	      }>(
   618	        `select id::text, ccp_code, critical_limit_min::text, critical_limit_max::text, nullif(unit, '') as unit
   619	           from public.haccp_ccps
   620	          where org_id = app.current_org_id()
   621	            and id = $1::uuid
   622	            and is_active
   623	          limit 1
   624	          for update`,
   625	        [parsed.ccpId],
   626	      );
   627	      const ccp = ccpResult.rows[0];
   628	      if (!ccp) throw new Error('CCP not found or inactive');
   629	
   630	      const withinLimits = isWithinLimits(parsed.measuredValue, ccp.critical_limit_min, ccp.critical_limit_max);
   631	
   632	      const insertedLog = await ctx.client.query<{ id: string }>(
   633	        `insert into public.haccp_monitoring_log (
   634	           org_id,
   635	           ccp_id,
   636	           measured_value,
   637	           wo_id,
   638	           within_limits,
   639	           recorded_by,
   640	           note
   641	         )
   642	         values (
   643	           app.current_org_id(),
   644	           $1::uuid,
   645	           $2::numeric(12,4),
   646	           $3::uuid,
   647	           $4::boolean,
   648	           $5::uuid,
   649	           $6
   650	         )
   651	         returning id::text`,
   652	        [parsed.ccpId, parsed.measuredValue, parsed.woId ?? null, withinLimits, ctx.userId, parsed.note ?? null],
   653	      );
   654	      const logId = insertedLog.rows[0]?.id;
   655	      if (!logId) throw new Error('monitoring log insert did not return a row');
   656	
   657	      if (withinLimits) return { ok: true, data: { withinLimits, ncrId: null, outboxEmitted: false } };
   658	
   659	      const existingDeviation = await ctx.client.query<{ id: string; breach_ncr_id: string | null }>(
   660	        `select d.id::text, l.breach_ncr_id::text
   661	           from public.ccp_deviations d
   662	           left join public.haccp_monitoring_log l on l.id = d.monitoring_log_id and l.org_id = d.org_id
   663	          where d.org_id = app.current_org_id()
   664	            and d.monitoring_log_id = $1::uuid
   665	          limit 1
   666	          for update of d`,
   667	        [logId],
   668	      );
   669	      const existing = existingDeviation.rows[0];
   670	      if (existing) {
   671	        return { ok: true, data: { withinLimits, ncrId: existing.breach_ncr_id, outboxEmitted: false } };
   672	      }
   673	
   674	      const sourceSiteId = await resolveWoSiteId(ctx, parsed.woId);
   675	      const ncr = await ctx.client.query<{ id: string }>(
   676	        `insert into public.ncr_reports (
   677	           org_id,
   678	           site_id,
   679	           ncr_type,
   680	           severity,
   681	           status,
   682	           title,
   683	           description,
   684	           reference_type,
   685	           reference_id,
   686	           detected_by
   687	         )
   688	         values (
   689	           app.current_org_id(),
   690	           $5::uuid,
   691	           'quality',
   692	           'critical',
   693	           'open',
   694	           $1,
   695	           $2,
   696	           'ccp_deviation',
   697	           $3::uuid,
   698	           $4::uuid
   699	         )
   700	         returning id::text`,
   701	        [
   702	          `CCP Breach: ${ccp.ccp_code}`,
   703	          `Measured value ${parsed.measuredValue} was outside configured CCP limits.`,
   704	          parsed.ccpId,
   705	          ctx.userId,
   706	          sourceSiteId,
   707	        ],
   708	      );
   709	      const ncrId = ncr.rows[0]?.id;
   710	      if (!ncrId) throw new Error('NCR insert did not return a row');
   711	
   712	      await ctx.client.query(
   713	        `update public.haccp_monitoring_log
   714	            set breach_ncr_id = $2::uuid
   715	          where org_id = app.current_org_id()
   716	            and id = $1::uuid`,
   717	        [logId, ncrId],
   718	      );
   719	
   720	      await writeNcrOpenedOutbox(ctx, {
   721	        ncrId,
   722	        ccpId: parsed.ccpId,
   723	        logId,
   724	        measuredValue: parsed.measuredValue,
   725	      });
   726	
   727	      let outputLps: OutputLp[] = [];
   728	      let woHold: ActiveHold | null = null;
   729	      let firstLpHold: ActiveHold | null = null;
   730	      if (parsed.woId) {
   731	        const windowStart = await findCcpHoldWindowStart(ctx, {
   732	          ccpId: parsed.ccpId,
   733	          woId: parsed.woId,
   734	          logId,
   735	        });
   736	        outputLps = await findOutputLpsInCcpHoldWindow(ctx, { woId: parsed.woId, windowStart });
   737	      }
   738	
   739	      const deviationNote = !parsed.woId
   740	        ? 'Auto-hold not created: no work order target was provided.'
   741	        : outputLps.length === 0
   742	          ? 'Auto-hold created at work-order level only: no output license plates were found in the CCP breach window.'
   743	          : null;
   744	
   745	      const deviation = await ctx.client.query<{ id: string }>(
   746	        `insert into public.ccp_deviations (
   747	           org_id,
   748	           ccp_id,
   749	           monitoring_log_id,
   750	           measured_value,
   751	           uom,
   752	           action_taken,
   753	           status,
   754	           opened_by
   755	         )
   756	         values (
   757	           app.current_org_id(),
   758	           $1::uuid,
   759	           $2::uuid,
   760	           $3::numeric,
   761	           $4,
   762	           $5,
   763	           'open',
   764	           $6::uuid
   765	         )
   766	         returning id::text`,
   767	        [parsed.ccpId, logId, parsed.measuredValue, ccp.unit, deviationNote, ctx.userId],
   768	      );
   769	      const deviationId = deviation.rows[0]?.id;
   770	      if (!deviationId) throw new Error('CCP deviation insert did not return a row');
   771	
   772	      if (parsed.woId) {
   773	        for (const lp of outputLps) {
   774	          const hold = await createCcpDeviationHoldIfMissing(ctx, {
   775	            referenceType: 'lp',
   776	            referenceId: lp.id,
   777	            ccpCode: ccp.ccp_code,
   778	            measuredValue: parsed.measuredValue,
   779	          });
   780	          firstLpHold ??= hold;
   781	        }
   782	
   783	        woHold = await createCcpDeviationHoldIfMissing(ctx, {
   784	          referenceType: 'wo',
   785	          referenceId: parsed.woId,
   786	          lpIds: outputLps.map((lp) => lp.id),
   787	          ccpCode: ccp.ccp_code,
   788	          measuredValue: parsed.measuredValue,
   789	        });
   790	
   791	        const linkedHold = firstLpHold ?? woHold;
   792	        await ctx.client.query(
   793	          `update public.ccp_deviations
   794	              set hold_id = $2::uuid
   795	            where org_id = app.current_org_id()
   796	              and id = $1::uuid`,
   797	          [deviationId, linkedHold.id],
   798	        );
   799	      }
   800	
   801	      return { ok: true, data: { withinLimits, ncrId, outboxEmitted: true } };
   802	    });
   803	  } catch (err) {
   804	    return { ok: false, reason: 'error', message: err instanceof Error ? err.message : String(err) };
   805	  }
   806	}
     1	-- Migration 306: Wave E3 (HACCP full) — haccp_plans + ccp_deviations + link ccps to a plan.
     2	-- haccp_ccps (mig 289) + haccp_monitoring_log already exist; this adds the PLAN layer above CCPs
     3	-- (draft→active→superseded, clone-on-write versioning, e-sign approval) and a deviation register
     4	-- (a critical-limit breach opens a ccp_deviation + can auto-hold the affected LP/WO). plan_id on
     5	-- haccp_ccps is nullable so existing CCPs are not broken.
     6	-- Wave0 lock: org_id; RLS via app.current_org_id(). site_id day-1 nullable.
     7	create table if not exists public.haccp_plans (
     8	  id            uuid primary key default gen_random_uuid(),
     9	  org_id        uuid not null references public.organizations(id) on delete cascade,
    10	  site_id       uuid,
    11	  scope_type    text not null default 'product',
    12	  scope_ref     text,
    13	  name          text not null,
    14	  version       integer not null default 1,
    15	  status        text not null default 'draft',
    16	  approved_by   uuid references public.users(id) on delete set null,
    17	  approved_at   timestamptz,
    18	  created_by    uuid references public.users(id) on delete set null,
    19	  created_at    timestamptz not null default pg_catalog.now(),
    20	  updated_at    timestamptz not null default pg_catalog.now(),
    21	  constraint haccp_plans_scope_check check (scope_type in ('product','category','line')),
    22	  constraint haccp_plans_status_check check (status in ('draft','active','superseded')),
    23	  constraint haccp_plans_org_name_version_unique unique (org_id, name, version)
    24	);
    25	create index if not exists idx_haccp_plans_org on public.haccp_plans (org_id, status);
    26	
    27	alter table public.haccp_ccps add column if not exists plan_id uuid references public.haccp_plans(id) on delete set null;
    28	create index if not exists idx_haccp_ccps_plan on public.haccp_ccps (plan_id) where plan_id is not null;
    29	
    30	create table if not exists public.ccp_deviations (
    31	  id                uuid primary key default gen_random_uuid(),
    32	  org_id            uuid not null references public.organizations(id) on delete cascade,
    33	  site_id           uuid,
    34	  ccp_id            uuid not null references public.haccp_ccps(id) on delete cascade,
    35	  monitoring_log_id uuid,
    36	  measured_value    numeric,
    37	  uom               text,
    38	  action_taken      text,
    39	  disposition       text,
    40	  hold_id           uuid,
    41	  status            text not null default 'open',
    42	  opened_at         timestamptz not null default pg_catalog.now(),
    43	  opened_by         uuid references public.users(id) on delete set null,
    44	  closed_at         timestamptz,
    45	  closed_by         uuid references public.users(id) on delete set null,
    46	  esign_ref         text,
    47	  created_at        timestamptz not null default pg_catalog.now(),
    48	  updated_at        timestamptz not null default pg_catalog.now(),
    49	  constraint ccp_deviations_status_check check (status in ('open','resolved'))
    50	);
    51	create index if not exists idx_ccp_deviations_org on public.ccp_deviations (org_id, status);
    52	create index if not exists idx_ccp_deviations_ccp on public.ccp_deviations (ccp_id);
    53	
    54	alter table public.haccp_plans    enable row level security;
    55	alter table public.haccp_plans    force  row level security;
    56	alter table public.ccp_deviations enable row level security;
    57	alter table public.ccp_deviations force  row level security;
    58	
    59	drop policy if exists haccp_plans_org_isolation on public.haccp_plans;
    60	create policy haccp_plans_org_isolation on public.haccp_plans
    61	  for all to app_user using (org_id = app.current_org_id()) with check (org_id = app.current_org_id());
    62	drop policy if exists ccp_deviations_org_isolation on public.ccp_deviations;
    63	create policy ccp_deviations_org_isolation on public.ccp_deviations
    64	  for all to app_user using (org_id = app.current_org_id()) with check (org_id = app.current_org_id());
    65	
    66	revoke all on public.haccp_plans    from public;
    67	revoke all on public.haccp_plans    from app_user;
    68	revoke all on public.ccp_deviations from public;
    69	revoke all on public.ccp_deviations from app_user;
    70	grant select, insert, update, delete on public.haccp_plans    to app_user;
    71	grant select, insert, update, delete on public.ccp_deviations to app_user;
    72	
    73	drop trigger if exists haccp_plans_set_updated_at on public.haccp_plans;
    74	create trigger haccp_plans_set_updated_at before update on public.haccp_plans
    75	  for each row execute function public.planning_mrp_set_updated_at();
    76	drop trigger if exists ccp_deviations_set_updated_at on public.ccp_deviations;
    77	create trigger ccp_deviations_set_updated_at before update on public.ccp_deviations
    78	  for each row execute function public.planning_mrp_set_updated_at();

