   306	async function findReceivedLpIdsForGrn(ctx: QualityContext, grnId: string): Promise<string[]> {
   307	  const { rows } = await ctx.client.query<{ id: string }>(
   308	    `select lp_id::text as id
   309	       from public.grn_items
   310	      where org_id = app.current_org_id()
   311	        and grn_id = $1::uuid
   312	        and lp_id is not null
