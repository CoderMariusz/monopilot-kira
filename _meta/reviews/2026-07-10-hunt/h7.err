   266	async function findActiveHoldForReference(
   267	  ctx: QualityContext,
   268	  params: { referenceType: 'lp' | 'grn'; referenceId: string },
   269	): Promise<string | null> {
   270	  const { rows } = await ctx.client.query<{ id: string }>(
   271	    `select id::text
   272	       from public.quality_holds
   273	      where org_id = app.current_org_id()
   274	        and reference_type = $1
   275	        and reference_id = $2::uuid
   276	        and hold_status = any($3::text[])
   277	        and released_at is null
   278	      order by created_at desc
   279	      limit 1
   280	      for update`,
   281	    [params.referenceType, params.referenceId, [...ACTIVE_HOLD_STATUSES]],
   282	  );
   283	  return rows[0]?.id ?? null;
   284	}
   285	
   286	async function createInspectionHoldIfMissing(
   287	  ctx: QualityContext,
   288	  params: { referenceType: 'lp' | 'grn'; referenceId: string; lpIds: string[]; reasonText: string; priority: 'high' | 'critical' },
   289	): Promise<void> {
   290	  const existing = await findActiveHoldForReference(ctx, {
   291	    referenceType: params.referenceType,
   292	    referenceId: params.referenceId,
   293	  });
   294	  if (existing) return;
   295	
   296	  const hold = await createHoldForContext(ctx, {
   297	    referenceType: params.referenceType,
   298	    referenceId: params.referenceId,
   299	    reasonText: params.reasonText,
   300	    priority: params.priority,
   301	    lpIds: params.lpIds,
   302	  });
   303	  if (!hold.ok) throw new Error(hold.message ?? 'quality hold could not be created');
   304	}
