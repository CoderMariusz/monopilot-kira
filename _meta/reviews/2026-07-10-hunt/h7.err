   791	// F4 (R3 review) — QA-aware restore target. A consumed LP goes back to
   792	// 'available' (pickable) ONLY when its QA release still stands; QA holds restore
   793	// to 'blocked' only while an active LP hold still exists, and other
   794	// non-released statuses restore to 'received'. qa_status itself is preserved
   795	// as-is. Partially-consumed LPs keep their status.
   796	async function lpRestoreTargetState(ctx: ProductionContext, lp: LicensePlateRow): Promise<string> {
   797	  if (lp.status !== 'consumed') return lp.status;
   798	  if (lp.qa_status === 'on_hold') return (await hasOpenLpQualityHold(ctx, lp.id)) ? 'blocked' : 'received';
   799	  return lp.qa_status === 'released' ? 'available' : 'received';
   800	}
