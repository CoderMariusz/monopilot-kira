   889	export async function submitInspectionDecision(input: {
   890	  inspectionId: string;
   891	  decision: 'pass' | 'fail' | 'hold';
   892	  signature: { password: string };
   893	  note?: string;
   894	}): Promise<ActionResult<SubmittedInspection>> {
   895	  try {
   896	    const parsed = decisionSchema.parse(input);
   897	    // ATOMICITY INVARIANT (review fix F7): withOrgContext (lib/auth/with-org-context.ts)
   898	    // opens an app-role transaction (BEGIN → app.set_org_context → callback →
   899	    // COMMIT, ROLLBACK on throw), so the status update + LP qa_status side
   900	    // effect + hold insert below are all-or-nothing without an explicit
   901	    // transaction here. Do not move these mutations out of this callback.
   902	    return await withOrgContext(async (ctx): Promise<ActionResult<SubmittedInspection>> => {
   903	      if (!(await hasPermission(ctx, 'quality.inspection.execute'))) return { ok: false, reason: 'forbidden' };
   904	
   905	      const currentResult = await ctx.client.query<{
   906	        id: string;
   907	        inspection_number: string;
   908	        reference_type: ReferenceType;
   909	        reference_id: string;
   910	        status: InspectionStatus;
   911	        parameters: unknown;
   912	      }>(
   913	        `select id::text, inspection_number, reference_type, reference_id::text, status, parameters
   914	           from public.quality_inspections
   915	          where org_id = app.current_org_id()
   916	            and id = $1::uuid
   917	          for update`,
   918	        [parsed.inspectionId],
   919	      );
   920	      const current = currentResult.rows[0];
   921	      if (!current) throw new Error('quality inspection not found');
   922	      if (['passed', 'failed', 'on_hold', 'cancelled'].includes(current.status)) {
   923	        throw new Error('quality inspection decision is already final');
   924	      }
   925	      if (parsed.decision === 'pass' && current.status === 'pending' && parseParameters(current.parameters).length === 0) {
   926	        return { ok: false, reason: 'error', message: 'inspection_parameters_required' };
   927	      }
   928	
   929	      const nextStatus = parsed.decision === 'pass' ? 'passed' : parsed.decision === 'fail' ? 'failed' : 'on_hold';
   930	      const receipt = await signEvent(
   931	        {
   932	          signerUserId: ctx.userId,
   933	          pin: parsed.signature.password,
   934	          intent: 'qa.inspection.submit',
   935	          subject: {
   936	            inspectionId: current.id,
   937	            inspectionNumber: current.inspection_number,
   938	            decision: parsed.decision,
   939	          },
   940	          reason: parsed.note ?? `quality inspection ${parsed.decision}`,
   941	        },
   942	        { client: ctx.client as unknown as pg.PoolClient },
   943	      );
   944	
   945	      const updated = await ctx.client.query<{ id: string; inspection_number: string; status: 'passed' | 'failed' | 'on_hold' }>(
   946	        `update public.quality_inspections
   947	            set status = $2,
   948	                result_notes = coalesce($3, result_notes),
   949	                decided_by = $4::uuid,
   950	                decided_at = pg_catalog.now(),
   951	                signature_hash = $5
   952	          where org_id = app.current_org_id()
   953	            and id = $1::uuid
   954	          returning id::text, inspection_number, status`,
   955	        [parsed.inspectionId, nextStatus, parsed.note ?? null, ctx.userId, receipt.subjectHash],
   956	      );
   957	      const row = updated.rows[0];
   958	      if (!row) throw new Error('quality inspection decision update did not return a row');
   959	
   960	      const qaStatus = await applyLpDecisionSideEffects(ctx, {
   961	        referenceType: current.reference_type,
   962	        referenceId: current.reference_id,
   963	        decision: parsed.decision,
   964	        note: parsed.note ?? null,
   965	      });
   966	
   967	      revalidateLocalized('/quality');
   968	      return {
   969	        ok: true,
   970	        data: {
