   923	           from public.license_plates
   924	          where org_id = app.current_org_id()
   925	            and id = $1::uuid
   926	          for update`,
   927	        [parsed.lpId],
   928	      );
   929	      const currentLp = lp.rows[0];
   930	      if (!currentLp) return { ok: false, reason: 'error', message: 'license plate not found' };
   931	      if (currentLp.status !== 'blocked' || currentLp.qa_status !== 'on_hold') {
   932	        return { ok: false, reason: 'error', message: 'invalid_state' };
   933	      }
   934	
   935	      const hold = await ctx.client.query<{ id: string }>(
   936	        `select id::text
   937	           from public.quality_holds
   938	          where org_id = app.current_org_id()
   939	            and reference_type = 'lp'
   940	            and reference_id = $1::uuid
   941	            and hold_status = any($2::text[])
   942	            and released_at is null
   943	          order by created_at desc
   944	          limit 1
   945	          for update`,
   946	        [parsed.lpId, [...ACTIVE_HOLD_STATUSES]],
   947	      );
   948	      const activeHold = hold.rows[0];
   949	      if (!activeHold) return { ok: false, reason: 'error', message: 'no_open_hold' };
   950	
   951	      return releaseHoldCore(ctx, { holdId: activeHold.id, disposition: 'release', reasonText: parsed.reasonText }, {
   952	        releaseSource: 'warehouse_lp_unblock',
   953	        expectedReference: { type: 'lp', id: parsed.lpId },
   954	        getSignatureHash: async () => {
   955	          const receipt = await signEvent(
   956	            {
   957	              signerUserId: ctx.userId,
   958	              pin: parsed.signature.password,
   959	              intent: 'qa.hold.release',
   960	              subject: { holdId: activeHold.id, disposition: 'release' },
   961	              reason: parsed.reasonText,
   962	            },
   963	            { client: ctx.client as unknown as pg.PoolClient },
   964	          );
   965	          return receipt.subjectHash;
   966	        },
   967	      });
   968	    });
   969	  } catch (err) {
   970	    return actionError(err);
   971	  }
   972	}
