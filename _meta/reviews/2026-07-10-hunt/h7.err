  await writeOutbox(ctx, {
    eventType: 'quality.hold.created',
    aggregateId: created.id,
    payload: {
      holdId: created.id,
      holdNumber: created.hold_number,
      referenceType: parsed.referenceType,
      referenceId: parsed.referenceId,
