    17	} from './so-transitions';
    18	import { releaseShipmentLiveAllocationsInContext, voidShipmentBoxesInContext } from './so-shipment-release';
    19	import { readLockedSalesOrderStatus, writeSalesOrderStatusInContext, writeShipmentStatusInContext } from './so-status-write';
    20	import { applyShipmentWacCancelCredits } from '../../../../../../lib/finance/upsert-wac';
    21	
    22	type QueryClient = {
    23	  query<T = Record<string, unknown>>(
    24	    sql: string,
    25	    params?: readonly unknown[],
    26	  ): Promise<{ rows: T[]; rowCount?: number | null }>;
    27	};
    28	
    29	type ShippingContext = { userId: string; orgId: string; client: QueryClient };
    30	
    31	type ShippingReversalError =
    32	  | 'forbidden'
    33	  | 'not_found'
    34	  | 'invalid_input'
    35	  | 'invalid_state'
    36	  | 'illegal_transition'
    37	  | 'downstream_financial_record'
    38	  | 'esign_failed'
    39	  | 'persistence_failed';
    40	
    41	export type ShippingReversalInput = {
    42	  shipmentId: string;
    43	  reasonCode?: string | null;
    44	  note?: string | null;
    45	  signature: {
    46	    password: string;
    47	    nonce?: string | null;
    48	  };
    49	};
    50	
    51	export type ShippingReversalResult =
    52	  | { ok: true }
    53	  | { ok: false; error: ShippingReversalError; message?: string };
    54	
    55	type ShipmentRow = {
    56	  id: string;
    57	  status: string;
    58	  sales_order_id: string | null;
    59	  sales_order_status: string | null;
    60	  shipment_number: string | null;
    61	  delivered_at: string | null;
    62	  bol_signed_pdf_url: string | null;
    63	  ext_data: unknown;
    64	};
    65	
    66	type ShipmentLpRow = {
    67	  lp_id: string;
    68	  site_id: string | null;
    69	  from_status: string;
    70	  shipped_qty: string;
    71	  reserved_qty: string;
    72	  prior_reserved_qty: string;
    73	};
    74	
    75	type AllocationRow = {
    76	  id: string;
    77	  lp_id: string;
    78	  qty: string;
    79	  status: string;
    80	};
    81	
    82	type FinancialTableRow = {
    83	  table_name: string;
    84	  has_shipment_id: boolean;
    85	  has_sales_order_id: boolean;
    86	  has_so_id: boolean;
    87	};
    88	
    89	const SHIP_SO_CANCEL = 'ship.so.cancel';
    90	const SHIP_PACK_CLOSE = 'ship.pack.close';
    91	const SHIP_SHIP_CONFIRM = 'ship.ship.confirm';
    92	const SHIP_BOL_SIGN = 'ship.bol.sign';
    93	
    94	const CANCEL_SHIPMENT_INTENT = 'cancel_shipment';
    95	const UNPACK_SHIPMENT_INTENT = 'unpack_shipment';
    96	const VOID_POD_INTENT = 'void_pod';
    97	
    98	const SHIPPING_SO_CANCELLED_EVENT = 'shipping.so.cancelled';
    99	const SHIPPING_SHIPMENT_PACKED_EVENT = 'shipping.shipment.packed';
   100	const SHIPPING_SHIPMENT_CONFIRMED_EVENT = 'shipping.shipment.confirmed';
   101	const WAREHOUSE_LP_TRANSITIONED_EVENT = 'warehouse.lp.transitioned';
   102	
   103	const CANCEL_BLOCKED_SO_STATUSES = new Set(['delivered', 'partially_delivered', 'cancelled']);
   104	const UNPACK_BLOCKED_SHIPMENT_STATUSES = new Set(['shipped', 'delivered', 'cancelled']);
   105	const PRE_SHIP_CANCEL_STATUSES = new Set<ShipmentStatus>(['pending', 'packing', 'packed', 'manifested']);
   106	
   107	const reversalInputSchema = z.object({
   108	  shipmentId: z.string().uuid(),
   109	  reasonCode: z.string().trim().min(1).max(64).optional().nullable(),
   110	  note: z.string().trim().max(1000).optional().nullable(),
   111	  signature: z.object({
   112	    password: z.string().min(1),
   113	    nonce: z.string().trim().min(1).optional().nullable(),
   114	  }),
   115	});
   116	
   117	class ActionError extends Error {
   118	  constructor(readonly code: ShippingReversalError) {
   119	    super(code);
   120	  }
   121	}
   122	
   123	class CancelShipmentAbort extends Error {
   124	  constructor(readonly result: Extract<ShippingReversalResult, { ok: false }>) {
   125	    super(result.error);
   126	  }
   127	}
   128	
   129	function parseInput(input: ShippingReversalInput): z.infer<typeof reversalInputSchema> | null {
   130	  const parsed = reversalInputSchema.safeParse(input);
   131	  return parsed.success ? parsed.data : null;
   132	}
   133	
   134	function errorCode(error: unknown): ShippingReversalError {
   135	  if (error instanceof CancelShipmentAbort) return error.result.error;
   136	  if (error instanceof ActionError) return error.code;
   137	  const code = (error as { code?: string } | null)?.code;
   138	  if (code === '22P02' || code === '23503' || code === '23514') return 'invalid_input';
   139	  return 'persistence_failed';
   140	}
   141	
   142	async function requireAnyPermission(
   143	  ctx: ShippingContext,
   144	  permissions: readonly string[],
   145	): Promise<ShippingReversalResult | null> {
   146	  for (const permission of permissions) {
   147	    if (await hasPermission(ctx, permission)) return null;
   148	  }
   149	  return { ok: false, error: 'forbidden' };
   150	}
   151	
   152	async function requirePermission(ctx: ShippingContext, permission: string): Promise<ShippingReversalResult | null> {
   153	  return requireAnyPermission(ctx, [permission]);
   154	}
   155	
   156	async function lockShipment(ctx: ShippingContext, shipmentId: string): Promise<ShipmentRow | null> {
   157	  const { rows: previewRows } = await ctx.client.query<{ sales_order_id: string | null }>(
   158	    `select sales_order_id::text
   159	       from public.shipments
   160	      where org_id = app.current_org_id()
   161	        and id = $1::uuid
   162	        and deleted_at is null`,
   163	    [shipmentId],
   164	  );
   165	  const soId = previewRows[0]?.sales_order_id ?? null;
   166	  if (!previewRows[0]) return null;
   167	
   168	  let salesOrderStatus: string | null = null;
   169	  if (soId) {
   170	    const { rows: salesOrderRows } = await ctx.client.query<{ status: string }>(
   171	      `select status
   172	         from public.sales_orders
   173	        where org_id = app.current_org_id()
   174	          and id = $1::uuid
   175	          and deleted_at is null
   176	        for update`,
   177	      [soId],
   178	    );
   179	    salesOrderStatus = salesOrderRows[0]?.status ?? null;
   180	  }
   181	
   182	  const { rows } = await ctx.client.query<ShipmentRow>(
   183	    `select sh.id::text,
   184	            sh.status,
   185	            sh.sales_order_id::text,
   186	            null::text as sales_order_status,
   187	            sh.shipment_number,
   188	            sh.delivered_at::text,
   189	            sh.bol_signed_pdf_url,
   190	            sh.ext_data
   191	       from public.shipments sh
   192	      where sh.org_id = app.current_org_id()
   193	        and sh.id = $1::uuid
   194	        and sh.deleted_at is null
   195	      for update of sh`,
   196	    [shipmentId],
   197	  );
   198	  const shipment = rows[0] ?? null;
   199	  if (!shipment) return null;
   200	  shipment.sales_order_status = salesOrderStatus;
   201	  return shipment;
   202	}
   203	
   204	async function lockShipmentLps(ctx: ShippingContext, shipmentId: string): Promise<ShipmentLpRow[]> {
   205	  const { rows } = await ctx.client.query<ShipmentLpRow>(
   206	    `with shipment_lps as (
   207	       select sbc.license_plate_id,
   208	              sum(sbc.quantity)::numeric as shipped_qty
   209	       from public.shipment_box_contents sbc
   210	       join public.shipment_boxes sb on sb.id = sbc.shipment_box_id
   560	    packingCount: Number(snapshot.packing_count ?? 0),
   561	    packedCount: Number(snapshot.packed_count ?? 0),
   562	    manifestedCount: Number(snapshot.manifested_count ?? 0),
   563	    shippedCount: Number(snapshot.shipped_count ?? 0),
   564	    deliveredCount: Number(snapshot.delivered_count ?? 0),
   565	    liveAllocationCount: Number(snapshot.allocation_count ?? 0),
   566	  };
   567	}
   568	
   569	async function recomputeSalesOrderStatusAfterCancel(ctx: ShippingContext, shipment: ShipmentRow): Promise<SalesOrderStatus | null> {
   570	  if (!shipment.sales_order_id) return null;
   571	  const snapshot = await loadSalesOrderProgressSnapshot(ctx, shipment.sales_order_id, shipment.id);
   572	  return deriveSalesOrderStatusFromProgress(snapshot);
   573	}
   574	
   575	async function recomputeSalesOrderStatusAfterVoidPod(ctx: ShippingContext, soId: string): Promise<SalesOrderStatus> {
   576	  const snapshot = await loadSalesOrderProgressSnapshot(ctx, soId);
   577	  return deriveSalesOrderStatusFromProgress(snapshot);
   578	}
   579	
   580	export async function cancelShipment(input: ShippingReversalInput): Promise<ShippingReversalResult> {
   581	  const parsed = parseInput(input);
   582	  if (!parsed) return { ok: false, error: 'invalid_input' };
   583	
   584	  try {
   585	    return await withOrgContext(async ({ userId, orgId, client }): Promise<ShippingReversalResult> => {
   586	      const ctx: ShippingContext = { userId, orgId, client: client as QueryClient };
   587	      const forbidden = await requirePermission(ctx, SHIP_SO_CANCEL);
   588	      if (forbidden) return forbidden;
   589	
   590	      const shipment = await lockShipment(ctx, parsed.shipmentId);
   591	      if (!shipment) return { ok: false, error: 'not_found' };
   592	      if (shipment.status === 'cancelled') return { ok: true };
   593	      if (
   594	        !isShipmentStatus(shipment.status) ||
   595	        !isLegalShipmentTransition(shipment.status, 'cancelled') ||
   596	        shipment.status === 'delivered' ||
   597	        CANCEL_BLOCKED_SO_STATUSES.has(shipment.sales_order_status ?? '')
   598	      ) {
   599	        return { ok: false, error: 'invalid_state' };
   600	      }
   601	
   602	      const isShippedCancel = shipment.status === 'shipped';
   603	      const isPreShipCancel = PRE_SHIP_CANCEL_STATUSES.has(shipment.status as ShipmentStatus);
   604	
   605	      const lps = isShippedCancel ? await lockShipmentLps(ctx, shipment.id) : [];
   606	      const allocations = isPreShipCancel ? await lockShipmentAllocations(ctx, shipment) : [];
   607	      const signatureId = await signReversal(ctx, parsed, CANCEL_SHIPMENT_INTENT, {
   608	        shipment_id: shipment.id,
   609	        sales_order_id: shipment.sales_order_id,
   610	        shipment_status: shipment.status,
   611	        sales_order_status: shipment.sales_order_status,
   612	        reason_code: parsed.reasonCode ?? null,
   613	      });
   614	
   615	      if (isPreShipCancel && shipment.sales_order_id) {
   616	        await releaseShipmentLiveAllocationsInContext(ctx, shipment.id, shipment.sales_order_id);
   617	      }
   618	
   619	      if (isShippedCancel) {
   620	        for (const lp of lps) {
   621	          const { rowCount } = await ctx.client.query(
   622	            `update public.license_plates
   623	                set quantity = quantity + $2::numeric,
   624	                    status = $3,
   625	                    source_so_id = null,
   626	                    updated_at = now(),
   627	                    updated_by = $4::uuid
   628	              where org_id = app.current_org_id()
   629	                and id = $1::uuid
   630	                and status = 'shipped'`,
   631	            [lp.lp_id, lp.shipped_qty, lp.from_status, userId],
   632	          );
   633	          if (rowCount !== 1) throw new ActionError('persistence_failed');
   634	          await writeLpTransition(ctx, shipment, { ...lp, from_status: 'shipped' }, lp.from_status, parsed.reasonCode ?? null, parsed.note ?? null);
   635	        }
   636	
   637	        const shipmentExtData =
   638	          shipment.ext_data != null && typeof shipment.ext_data === 'object' && !Array.isArray(shipment.ext_data)
   639	            ? (shipment.ext_data as { wac_debits?: unknown })
   640	            : null;
   641	        await applyShipmentWacCancelCredits(ctx.client, {
   642	          orgId,
   643	          siteId: lps[0]?.site_id ?? null,
   644	          wacDebits: shipmentExtData?.wac_debits,
   645	          updatedBy: userId,
   646	        });
   647	      }
   648	
   649	      await voidShipmentBoxesInContext(
   650	        ctx,
   651	        shipment.id,
   652	        JSON.stringify({
   653	          cancellation_signature_id: signatureId,
   654	          cancellation_reason_code: parsed.reasonCode ?? null,
   655	        }),
   656	      );
   657	
   658	      const cancelWrite = await writeShipmentStatusInContext(ctx, shipment.id, 'cancelled', {
   659	        currentStatus: shipment.status as ShipmentStatus,
   660	      });
   661	      if (cancelWrite !== 'ok') throw new ActionError('persistence_failed');
   662	
   663	      await ctx.client.query(
   664	        `update public.shipments
   665	            set ext_data = coalesce(ext_data, '{}'::jsonb) || $2::jsonb,
   666	                updated_at = now(),
   667	                updated_by = $3::uuid
   668	          where org_id = app.current_org_id()
   669	            and id = $1::uuid
   670	            and status = 'cancelled'
   671	            and deleted_at is null`,
   672	        [
   673	          shipment.id,
   674	          JSON.stringify({
   675	            cancelled_at: new Date().toISOString(),
   676	            cancelled_by: userId,
   677	            cancellation_reason_code: parsed.reasonCode ?? null,
   678	            cancellation_note: parsed.note ?? null,
   679	            cancellation_signature_id: signatureId,
   680	          }),
   681	          userId,
   682	        ],
   683	      );
   684	
   685	      const targetSoStatus = await recomputeSalesOrderStatusAfterCancel(ctx, shipment);
   686	      if (shipment.sales_order_id && targetSoStatus) {
   687	        const currentSoStatus = await readLockedSalesOrderStatus(ctx, shipment.sales_order_id);
   688	        if (currentSoStatus === 'not_found') throw new ActionError('persistence_failed');
   689	        const soWrite = await writeSalesOrderStatusInContext(ctx, shipment.sales_order_id, targetSoStatus, {
   690	          currentStatus: currentSoStatus,
   691	          allowShipmentReversal: true,
   692	        });
   693	        if (soWrite === 'illegal_transition') {
   694	          throw new CancelShipmentAbort({ ok: false, error: 'illegal_transition' });
   695	        }
   696	        if (soWrite !== 'ok') throw new ActionError('persistence_failed');
   697	      }
   698	
   699	      const auditId = await writeAuditEvent(ctx, {
   700	        action: 'shipping.shipment.cancelled',
   701	        shipment,
   702	        beforeState: {
   703	          shipment_status: shipment.status,
   704	          sales_order_status: shipment.sales_order_status,
   705	          allocation_ids: allocations.map((allocation) => allocation.id),
   706	          lp_statuses: lps.map((lp) => ({ lp_id: lp.lp_id, status: lp.from_status })),
   707	        },
   708	        afterState: {
   709	          shipment_status: 'cancelled',
   710	          sales_order_status: targetSoStatus,
   711	          allocations_released: allocations.map((allocation) => allocation.id),
   712	          signature_id: signatureId,
   713	          reason_code: parsed.reasonCode ?? null,
   714	          note: parsed.note ?? null,
   715	        },
   716	      });
   717	
   718	      await emitOutboxEvent(ctx, {
   719	        eventType: SHIPPING_SO_CANCELLED_EVENT,
   720	        aggregateType: 'shipment',
   721	        aggregateId: shipment.id,
   722	        payload: {
   723	          shipment_id: shipment.id,
   724	          sales_order_id: shipment.sales_order_id,
   725	          audit_event_id: auditId,
   726	          signature_id: signatureId,
   727	          previous_shipment_status: shipment.status,
   728	          shipment_status: 'cancelled',
   729	          previous_sales_order_status: shipment.sales_order_status,
   730	          sales_order_status: targetSoStatus,
   731	        },
   732	      });
   733	
   734	      return { ok: true };
   735	    });
   736	  } catch (error) {
   737	    if (error instanceof CancelShipmentAbort) return error.result;
   738	    return { ok: false, error: errorCode(error) };
   739	  }
   740	}
   741	
   742	export async function unpackShipment(input: ShippingReversalInput): Promise<ShippingReversalResult> {
   743	  const parsed = parseInput(input);
   744	  if (!parsed) return { ok: false, error: 'invalid_input' };
   745	
   746	  try {
   747	    return await withOrgContext(async ({ userId, orgId, client }): Promise<ShippingReversalResult> => {
   748	      const ctx: ShippingContext = { userId, orgId, client: client as QueryClient };
   749	      const forbidden = await requireAnyPermission(ctx, [SHIP_PACK_CLOSE]);
   750	      if (forbidden) return forbidden;
   751	
   752	      const shipment = await lockShipment(ctx, parsed.shipmentId);
   753	      if (!shipment) return { ok: false, error: 'not_found' };
   754	      if (UNPACK_BLOCKED_SHIPMENT_STATUSES.has(shipment.status)) return { ok: false, error: 'invalid_state' };
   755	      if (!['packed', 'manifested'].includes(shipment.status)) return { ok: false, error: 'invalid_state' };
   756	
   757	      const lps = await lockShipmentLps(ctx, shipment.id);
   758	      const signatureId = await signReversal(ctx, parsed, UNPACK_SHIPMENT_INTENT, {
   759	        shipment_id: shipment.id,
   760	        sales_order_id: shipment.sales_order_id,
   761	        shipment_status: shipment.status,
   762	        sales_order_status: shipment.sales_order_status,
   763	        reason_code: parsed.reasonCode ?? null,
   764	      });
   765	
   766	      await ctx.client.query(
   767	        `update public.shipment_box_contents sbc
   768	            set deleted_at = coalesce(deleted_at, now()),
   769	                updated_at = now(),
   770	                updated_by = $2::uuid,
   771	                ext_data = coalesce(ext_data, '{}'::jsonb) || $3::jsonb
   772	           from public.shipment_boxes sb
   773	          where sb.id = sbc.shipment_box_id
   774	            and sb.org_id = app.current_org_id()
   775	            and sb.shipment_id = $1::uuid
   776	            and sbc.org_id = app.current_org_id()
   777	            and sbc.deleted_at is null`,
   778	        [
   779	          shipment.id,
   780	          userId,
   781	          JSON.stringify({ unpack_signature_id: signatureId, unpack_reason_code: parsed.reasonCode ?? null }),
   782	        ],
   783	      );
   784	
   785	      await ctx.client.query(
   786	        `update public.shipment_boxes
   787	            set deleted_at = coalesce(deleted_at, now()),
   788	                updated_at = now(),
   789	                updated_by = $2::uuid,
   790	                ext_data = coalesce(ext_data, '{}'::jsonb) || $3::jsonb
   791	          where org_id = app.current_org_id()
   792	            and shipment_id = $1::uuid
   793	            and deleted_at is null`,
   794	        [
   795	          shipment.id,
   796	          userId,
   797	          JSON.stringify({ unpack_signature_id: signatureId, unpack_reason_code: parsed.reasonCode ?? null }),
   798	        ],
   799	      );
   800	
   801	      const unpackTransition = await writeShipmentStatusInContext(ctx, shipment.id, 'packing', {
   802	        currentStatus: shipment.status as ShipmentStatus,
   803	      });
   804	      if (unpackTransition !== 'ok') throw new ActionError('persistence_failed');
   805	
   806	      await ctx.client.query(
   807	        `update public.shipments
   808	            set packed_at = null,
   809	                packed_by = null,
   810	                ext_data = coalesce(ext_data, '{}'::jsonb) || $2::jsonb,
   811	                updated_at = now(),
   812	                updated_by = $3::uuid
   813	          where org_id = app.current_org_id()
   814	            and id = $1::uuid
   815	            and status = 'packing'
   816	            and deleted_at is null`,
   817	        [
   818	          shipment.id,
   819	          JSON.stringify({
   820	            unpacked_at: new Date().toISOString(),
   821	            unpacked_by: userId,
   822	            unpack_reason_code: parsed.reasonCode ?? null,
   823	            unpack_note: parsed.note ?? null,
   824	            unpack_signature_id: signatureId,
   825	          }),
   826	          userId,
   827	        ],
   828	      );
   829	
   830	      const auditId = await writeAuditEvent(ctx, {
   615	    });
   616	  } catch (err) {
   617	    return { ok: false, error: errorCode(err) };
   618	  }
   619	}
   620	
   621	export async function recordPod(input: RecordPodInput): Promise<RecordPodResult> {
   622	  const parsed = parseRecordPodInput(input);
   623	  if (!parsed) return { ok: false, error: 'invalid_input' };
   624	
   625	  try {
   626	    return await withOrgContext(async ({ userId, orgId, client }): Promise<RecordPodResult> => {
   627	      const ctx: ShippingContext = { userId, orgId, client: client as QueryClient };
   628	      const forbidden = await requirePermission(ctx, SHIP_BOL_SIGN);
   629	      if (forbidden) return forbidden;
   630	
   631	      const { rows: shipmentRows } = await ctx.client.query<{
   632	        id: string;
   633	        status: string;
   634	        sales_order_id: string | null;
   635	        bol_signed_pdf_url: string | null;
   636	      }>(
   637	        `select id::text,
   638	                status,
   639	                sales_order_id::text,
   640	                bol_signed_pdf_url
   641	           from public.shipments
   642	          where org_id = app.current_org_id()
   643	            and id = $1::uuid
   644	            and deleted_at is null
   645	          limit 1`,
   646	        [parsed.shipmentId],
   647	      );
   648	      const currentShipment = shipmentRows[0];
   649	      if (!currentShipment || currentShipment.status !== 'shipped') {
   650	        return { ok: false, error: 'invalid_state' };
   651	      }
   652	
   653	      const signatureId = await signPodDelivery(ctx, parsed, {
   654	        shipment_id: parsed.shipmentId,
   655	        signed_pdf_url: parsed.signedPdfUrl,
   656	        reason: parsed.reason,
   657	      });
   658	
   659	      const podTransition = await writeShipmentStatusInContext(ctx, parsed.shipmentId, 'delivered', {
   660	        currentStatus: 'shipped',
   661	      });
   662	      if (podTransition !== 'ok') throw new ActionError('persistence_failed');
   663	
   664	      const { rows } = await ctx.client.query<{ id: string; sales_order_id: string | null }>(
   665	        `update public.shipments
   666	            set delivered_at = now(),
   667	                bol_signed_pdf_url = $2::text,
   668	                updated_at = now(),
   669	                updated_by = $3::uuid
   670	          where org_id = app.current_org_id()
   671	            and id = $1::uuid
   672	            and status = 'delivered'
   673	            and deleted_at is null
   674	          returning id::text, sales_order_id::text`,
   675	        [parsed.shipmentId, parsed.signedPdfUrl, userId],
   676	      );
   677	      const shipment = rows[0];
   678	      if (!shipment) throw new ActionError('persistence_failed');
   679	
   680	      let targetSoStatus: SalesOrderStatus | null = null;
   681	      if (shipment.sales_order_id) {
   682	        const soStatus = await readLockedSalesOrderStatus(ctx, shipment.sales_order_id);
   683	        if (soStatus === 'not_found' || soStatus === 'cancelled') {
   684	          throw new ActionError('invalid_state');
   685	        }
   686	
   687	        const { rows: remainingRows } = await ctx.client.query<{ remaining_count: number | string | bigint | null }>(
   688	          `select count(*)::int as remaining_count
   689	             from public.shipments
   690	            where org_id = app.current_org_id()
   691	              and sales_order_id = $1::uuid
   692	              and deleted_at is null
   693	              and status not in ('delivered', 'cancelled')`,
   694	          [shipment.sales_order_id],
   695	        );
   696	
   697	        targetSoStatus = toNumber(remainingRows[0]?.remaining_count) === 0 ? 'delivered' : 'partially_delivered';
   698	        const soWrite = await writeSalesOrderStatusInContext(ctx, shipment.sales_order_id, targetSoStatus, {
   699	          currentStatus: soStatus,
   700	        });
   701	        if (soWrite !== 'ok') throw new ActionError('invalid_state');
   702	      }
   703	
   704	      await writePodAuditEvent(ctx, {
   705	        shipmentId: parsed.shipmentId,
   706	        signatureId,
   707	        beforeState: {
   708	          shipment_status: currentShipment.status,
   709	          sales_order_id: currentShipment.sales_order_id,
   710	          bol_signed_pdf_url: currentShipment.bol_signed_pdf_url,
   711	        },
   712	        afterState: {
   713	          shipment_status: 'delivered',
   714	          sales_order_status: targetSoStatus,
   715	          bol_signed_pdf_url: parsed.signedPdfUrl,
   716	          reason: parsed.reason,
   717	        },
   718	      });
   719	
   720	      return { ok: true };
   721	    });
   722	  } catch (err) {
   723	    return { ok: false, error: errorCode(err) };
   724	  }
   725	}

codex
The first end-to-end pass found a concrete reversal edge: the ship path deliberately leaves a partially consumed LP in its prior status, while shipped-cancel currently requires that same LP to be in `shipped`. I’m validating this against allocation/packing semantics and looking for similarly reproducible SSCC, POD, and hierarchy failures before ranking it.
