   647	export async function allocateSalesOrder(id: string): Promise<AllocateSalesOrderResult> {
   648	  return withOrgContext(async ({ userId, orgId, client }): Promise<AllocateSalesOrderResult> => {
   649	    const ctx: ShippingContext = { userId, orgId, client: client as QueryClient };
   650	    const forbidden = await requirePermission(ctx, SHIP_SO_ALLOCATE);
   651	    if (forbidden) return forbidden;
   652	
   653	    const { rows: statusRows } = await ctx.client.query<{ status: string }>(
   654	      `select status
   655	         from public.sales_orders
   656	        where org_id = app.current_org_id()
   657	          and id = $1::uuid
   658	          and deleted_at is null
   659	        limit 1
   660	        for update`,
   661	      [id],
   662	    );
   663	    const current = statusRows[0]?.status;
   664	    if (!current) return { ok: true, data: null };
   665	    if (!isSalesOrderStatus(current) || !isLegalSoTransition(current, 'allocated')) {
   666	      return { ok: false, error: 'ILLEGAL_TRANSITION', from: current, to: 'allocated' };
   667	    }
   668	
   669	    const { rows: lines } = await ctx.client.query<{
   670	      id: string;
   671	      site_id: string | null;
   672	      product_id: string;
   673	      quantity_ordered: string;
   674	    }>(
   675	      `select id::text, site_id::text, product_id::text, quantity_ordered::text
   676	         from public.sales_order_lines
   677	        where org_id = app.current_org_id()
   678	          and sales_order_id = $1::uuid
   679	          and deleted_at is null
   680	        order by line_number`,
   681	      [id],
   682	    );
   683	
   684	    const warnDays = await readNearExpiryWarnDays(ctx.client);
   685	
   686	    const planned: Array<{
   687	      lineId: string;
   688	      siteId: string | null;
   689	      allocated: string;
   690	      allocations: Array<{ lpId: string; qty: string }>;
   691	    }> = [];
   692	
   693	    // Soft near-expiry tracking across every LP actually allocated to this order.
   694	    let nearExpiryCount = 0;
   695	    let soonestNearExpiry: { date: string; days: number } | null = null;
   696	
   697	    for (const line of lines) {
   698	      let needed = decimalToUnits(line.quantity_ordered);
   699	      let available = 0n;
   700	      const allocations: Array<{ lpId: string; qty: string }> = [];
   701	
   702	      const { rows: candidates } = await ctx.client.query<{
   703	        lp_id: string;
   704	        available_qty: string;
   705	        expiry_date: string | null;
   706	        days_to_expiry: number | string | null;
   707	      }>(
   708	        `select lp.id::text as lp_id,
   709	                (lp.quantity - lp.reserved_qty)::text as available_qty,
   710	                to_char(lp.expiry_date, 'YYYY-MM-DD') as expiry_date,
   711	                (lp.expiry_date - current_date) as days_to_expiry
   712	           from public.license_plates lp
   713	          where lp.org_id = app.current_org_id()
   714	            and lp.product_id = $1::uuid
   715	            and ($2::uuid is null or lp.site_id = $2::uuid)
   716	            and lp.status = 'available'
   717	            and lp.qa_status = 'released'
   718	            -- Food-safety (G-QA-03 / owner per-rule BLOCK): never allocate an
   719	            -- already-expired LP. The order-by still prefers earliest expiry
   720	            -- (FEFO); this only drops LPs that are past their expiry date.
   721	            and (lp.expiry_date is null or lp.expiry_date >= current_date)
   722	            -- Food-safety (G-QA-07 / owner per-rule BLOCK): never allocate an LP
   723	            -- on an active quality hold. status='available' + qa_status='released'
   724	            -- does NOT cover holds — they are a separate polymorphic layer (T-064,
   725	            -- migration 197). Read the canonical SECURITY INVOKER, org-scoped
   726	            -- v_active_holds view (reference_type='lp') — never quality_holds
   727	            -- directly — mirroring shipShipment's egress guard so held stock is
   728	            -- excluded at allocation as well as at ship.
   729	            and not exists (
   730	              select 1
   731	                from public.v_active_holds h
   732	               where h.org_id = app.current_org_id()
   733	                 and h.reference_type = 'lp'
   734	                 and h.reference_id = lp.id
   735	            )
   736	            and (lp.quantity - lp.reserved_qty) > 0
   737	          order by lp.expiry_date asc nulls last, lp.created_at asc
   738	          for update of lp`,
   739	        [line.product_id, line.site_id],
   740	      );
   741	
   742	      for (const lp of candidates) {
   743	        const lpAvailable = decimalToUnits(lp.available_qty);
   744	        available += lpAvailable;
   745	        if (needed <= 0n) continue;
   746	        const take = minUnits(needed, lpAvailable);
   747	        if (take <= 0n) continue;
   748	        allocations.push({ lpId: lp.lp_id, qty: unitsToDecimal(take) });
   749	        needed -= take;
   750	
   751	        // Near-expiry WARN (G-QA-03 sibling): this LP is being ALLOCATED (the
   752	        // expired ones were already filtered out above), but it falls inside the
   753	        // org's near-expiry window. Record the soonest one for the soft warning.
   754	        if (warnDays > 0 && lp.expiry_date != null && lp.days_to_expiry != null) {
   755	          const days = Number(lp.days_to_expiry);
   756	          if (Number.isFinite(days) && days >= 0 && days <= warnDays) {
   757	            nearExpiryCount += 1;
   758	            if (soonestNearExpiry === null || days < soonestNearExpiry.days) {
   759	              soonestNearExpiry = { date: lp.expiry_date, days };
   760	            }
   761	          }
   762	        }
   763	      }
   764	
   765	      if (needed > 0n) {
   766	        return {
   767	          ok: false,
   768	          error: 'INSUFFICIENT_STOCK',
   769	          item_id: line.product_id,
   770	          needed: line.quantity_ordered,
   771	          available: unitsToDecimal(available),
   772	        };
   773	      }
   774	
   775	      let allocated = 0n;
   776	      for (const allocation of allocations) {
   777	        allocated += decimalToUnits(allocation.qty);
   778	      }
   779	      planned.push({ lineId: line.id, siteId: line.site_id, allocated: unitsToDecimal(allocated), allocations });
   780	    }
   781	
   782	    for (const line of planned) {
   783	      for (const allocation of line.allocations) {
   784	        await ctx.client.query(
   785	          `insert into public.inventory_allocations
   786	             (org_id, site_id, sales_order_line_id, license_plate_id, quantity_allocated, status, created_by, updated_by)
   787	           values ($1::uuid, $2::uuid, $3::uuid, $4::uuid, $5::numeric, 'allocated', $6::uuid, $6::uuid)`,
   788	          [orgId, line.siteId, line.lineId, allocation.lpId, allocation.qty, userId],
   789	        );
   790	        await ctx.client.query(
   791	          `update public.license_plates
   792	              set reserved_qty = reserved_qty + $2::numeric,
   793	                  updated_by = $3::uuid
   794	            where org_id = app.current_org_id()
   795	              and id = $1::uuid`,
   796	          [allocation.lpId, allocation.qty, userId],
   797	        );
   798	      }
   799	
   800	      await ctx.client.query(
   801	        `update public.sales_order_lines
   802	            set quantity_allocated = $2::numeric,
   803	                updated_by = $3::uuid
   804	          where org_id = app.current_org_id()
   805	            and id = $1::uuid`,
   806	        [line.lineId, line.allocated, userId],
   807	      );
   808	    }
   809	
   810	    const result = await transitionSalesOrderStatusInContext(ctx, id, 'allocated');
   811	    if (result && 'error' in result) return result;
   812	
   813	    const nearExpiryWarning: NearExpiryAllocationWarning | undefined =
   814	      soonestNearExpiry !== null
   815	        ? {
   816	            nearExpiry: true,
   817	            reasonCode: 'allocated_lp_near_expiry',
   818	            soonestExpiry: soonestNearExpiry.date,
   819	            daysToExpiry: soonestNearExpiry.days,
   820	            warnDays,
   821	            affectedLpCount: nearExpiryCount,
   822	          }
   823	        : undefined;
   824	
   825	    // Soft + additive: only spread the warning when it actually fired.
   826	    return nearExpiryWarning ? { ok: true, data: result, nearExpiryWarning } : { ok: true, data: result };
   827	  });
   828	}
