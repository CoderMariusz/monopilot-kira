   183	
   184	export async function sealShipment(shipmentId: string): Promise<SealShipmentResult> {
   185	  try {
   186	    return await withOrgContext(async ({ userId, orgId, client }): Promise<SealShipmentResult> => {
   187	      const ctx: ShippingContext = { userId, orgId, client: client as QueryClient };
   188	      const forbidden = await requirePermission(ctx, SHIP_PACK_CLOSE);
   189	      if (forbidden) return forbidden;
   190	
   191	      const { rows: shipmentRows } = await ctx.client.query<{
   192	        id: string;
   193	        status: string;
   194	        box_count: number | string | bigint | null;
   195	      }>(
   196	        `select sh.id::text,
   197	                sh.status,
   198	                count(distinct sb.id)::int as box_count
   199	           from public.shipments sh
   200	           left join public.shipment_boxes sb on sb.shipment_id = sh.id
   201	            and sb.org_id = app.current_org_id()
   202	            and sb.deleted_at is null
   203	          where sh.org_id = app.current_org_id()
   204	            and sh.id = $1::uuid
   205	            and sh.deleted_at is null
   206	          group by sh.id, sh.status
   207	          limit 1`,
   208	        [shipmentId],
   209	      );
   210	      const shipment = shipmentRows[0];
   211	      if (!shipment || shipment.status !== 'packing') {
   212	        return { ok: false, error: 'invalid_state' };
   213	      }
   214	      if (toNumber(shipment.box_count) < 1) {
   215	        return { ok: false, error: 'no_boxes' };
   216	      }
   217	
   218	      const sealResult = await writeShipmentStatusInContext(ctx, shipmentId, 'packed', {
   219	        currentStatus: 'packing',
   220	      });
   221	      if (sealResult !== 'ok') throw new ActionError('persistence_failed');
   222	
   223	      await ctx.client.query(
   224	        `update public.shipments
   225	            set packed_at = now(),
   226	                packed_by = $2::uuid,
   227	                updated_at = now(),
   228	                updated_by = $2::uuid
   229	          where org_id = app.current_org_id()
   230	            and id = $1::uuid
   231	            and status = 'packed'
   232	            and deleted_at is null`,
   233	        [shipmentId, userId],
   234	      );
   235	
   236	      return { ok: true };
   237	    });
   238	  } catch (err) {
   239	    return { ok: false, error: errorCode(err) };
   240	  }
   241	}
   242	
   243	export async function shipShipment(shipmentId: string): Promise<ShipShipmentResult> {
   244	  try {
   245	    return await withOrgContext(async ({ userId, orgId, client }): Promise<ShipShipmentResult> => {
   246	      const ctx: ShippingContext = { userId, orgId, client: client as QueryClient };
   247	      const forbidden = await requirePermission(ctx, SHIP_SHIP_CONFIRM);
   248	      if (forbidden) return forbidden;
   249	
   250	      const { rows: shipmentRows } = await ctx.client.query<{
   251	        id: string;
   252	        status: string;
   253	        sales_order_id: string | null;
   254	        box_count: number | string | bigint | null;
   255	      }>(
   256	        `select sh.id::text,
   257	                sh.status,
   258	                sh.sales_order_id::text,
   259	                count(distinct sb.id)::int as box_count
   260	           from public.shipments sh
   261	           left join public.shipment_boxes sb on sb.shipment_id = sh.id
   262	            and sb.org_id = app.current_org_id()
   263	            and sb.deleted_at is null
   264	          where sh.org_id = app.current_org_id()
   265	            and sh.id = $1::uuid
   266	            and sh.deleted_at is null
   267	          group by sh.id, sh.status, sh.sales_order_id
   268	          limit 1`,
   269	        [shipmentId],
   270	      );
   271	      const shipment = shipmentRows[0];
   272	      if (!shipment || shipment.status !== 'packed' || !shipment.sales_order_id || toNumber(shipment.box_count) < 1) {
   273	        return { ok: false, error: 'invalid_state' };
   274	      }
   275	
   276	      const soStatus = await readLockedSalesOrderStatus(ctx, shipment.sales_order_id);
   277	      if (soStatus === 'not_found' || soStatus === 'cancelled') {
   278	        return { ok: false, error: 'invalid_state' };
   279	      }
   280	
   281	      const lpRows = await fetchShipmentLps(ctx, shipmentId);
   282	      const lpIds = lpRows.map((row) => row.lp_id);
   283	      if (lpIds.length === 0) return { ok: false, error: 'invalid_state' };
   284	
   285	      const shipTransition = await writeShipmentStatusInContext(ctx, shipmentId, 'shipped', {
   286	        currentStatus: 'packed',
   287	      });
   288	      if (shipTransition !== 'ok') throw new ActionError('persistence_failed');
   289	
   290	      await ctx.client.query(
   291	        `update public.shipments
   292	            set shipped_at = now(),
   293	                shipped_by = $2::uuid,
   294	                updated_at = now(),
   295	                updated_by = $2::uuid
   296	          where org_id = app.current_org_id()
   297	            and id = $1::uuid
   298	            and status = 'shipped'
   299	            and deleted_at is null`,
   300	        [shipmentId, userId],
   301	      );
   302	
   303	      // Food-safety re-assert (G-QA-01 / G-SHIP-06 / owner per-rule = BLOCK): a
   304	      // quality hold, a QA-status reversion, or an expiry can land AFTER
   305	      // allocation but BEFORE ship. Re-check every LP in the shipment and REFUSE
   306	      // to ship if any is on an active hold (v_active_holds, T-064), not
   307	      // QA-released, or past its expiry date — held/expired goods must not leave
   308	      // the building. Same transaction → throwing here rolls back the
   309	      // packing→packed flip too, so the shipment can be re-shipped after the
   310	      // hold/expiry is resolved.
   311	      const { rows: blockedLps } = await ctx.client.query<{ lp_number: string; reason: string }>(
   312	        `select lp.lp_number,
   313	                case when h.hold_id is not null then 'hold'
   314	                     when lp.qa_status is distinct from 'released' then 'qa'
   315	                     else 'expired' end as reason
   316	           from public.shipment_box_contents sbc
   317	           join public.shipment_boxes sb on sb.id = sbc.shipment_box_id
   318	            and sb.org_id = app.current_org_id() and sb.deleted_at is null
   319	           join public.license_plates lp on lp.id = sbc.license_plate_id
   320	            and lp.org_id = app.current_org_id()
   321	           left join lateral (
   322	             select hold_id from public.v_active_holds h
   323	              where h.org_id = app.current_org_id()
   324	                and h.reference_type = 'lp' and h.reference_id = lp.id
   325	              limit 1
   326	           ) h on true
   327	          where sbc.org_id = app.current_org_id() and sbc.deleted_at is null
   328	            and sb.shipment_id = $1::uuid
   329	            and sbc.quantity is not null and sbc.quantity > 0
   330	            and ( h.hold_id is not null
   331	                  or lp.qa_status is distinct from 'released'
   332	                  or (lp.expiry_date is not null and lp.expiry_date < current_date) )
   333	          limit 5`,
   334	        [shipmentId],
   335	      );
   336	      if (blockedLps.length > 0) throw new ActionError('lp_blocked_for_ship');
   337	
   338	      const { rows: updatedLpRows } = await ctx.client.query<{
   339	        id: string;
   340	        shipped_qty: string;
   341	        prior_status: string;
   342	        prior_reserved_qty: string;
   343	      }>(
   344	        `with shipment_lps as (
   345	           select sbc.license_plate_id as lp_id,
   346	                  sum(sbc.quantity)::numeric as shipped_qty,
   347	                  lp.status as prior_status,
   348	                  lp.reserved_qty as prior_reserved_qty
   349	             from public.shipment_box_contents sbc
   350	             join public.shipment_boxes sb on sb.id = sbc.shipment_box_id
   351	              and sb.org_id = app.current_org_id()
   352	              and sb.deleted_at is null
   353	             join public.license_plates lp on lp.id = sbc.license_plate_id
   354	              and lp.org_id = app.current_org_id()
   355	            where sbc.org_id = app.current_org_id()
   356	              and sbc.deleted_at is null
   357	              and sbc.quantity is not null
   358	              and sbc.quantity > 0
   359	              and sb.shipment_id = $1::uuid
   360	            group by sbc.license_plate_id, lp.status, lp.reserved_qty
   361	         )
   362	         update public.license_plates lp
   363	            set quantity = lp.quantity - shipment_lps.shipped_qty,
   364	                reserved_qty = greatest(0, lp.reserved_qty - shipment_lps.shipped_qty),
   365	                -- Only flip the whole LP to 'shipped' when the shipment consumes
   366	                -- its full quantity. On a partial ship the remainder must stay in
   367	                -- its prior (pickable) status, otherwise it is frozen: a 'shipped'
   368	                -- LP with leftover qty can be neither split nor destroyed → lost stock.
   369	                status = case
   370	                           when lp.quantity = shipment_lps.shipped_qty then 'shipped'
   371	                           else lp.status
   372	                         end,
   373	                updated_at = now(),
   374	                updated_by = $2::uuid
   375	           from shipment_lps
   376	          where lp.org_id = app.current_org_id()
   377	            and lp.id = shipment_lps.lp_id
   378	            and lp.quantity >= shipment_lps.shipped_qty
   379	          returning lp.id::text,
   380	                    shipment_lps.shipped_qty::text,
   381	                    shipment_lps.prior_status,
   382	                    shipment_lps.prior_reserved_qty::text`,
   383	        [shipmentId, userId],
   384	      );
   385	      if (updatedLpRows.length !== lpIds.length) throw new ActionError('persistence_failed');
   386	
   387	      const wacDebits: Array<{
   388	        lp_id: string;
   389	        item_id: string;
   390	        qty_kg?: string;
   391	        wac_value?: string;
   392	        wac_excluded?: string;
   393	      }> = [];
   394	      for (const lp of lpRows) {
   395	        const wacDebit = await debitWac(ctx.client, {
   396	          orgId,
   397	          siteId: null,
   398	          itemId: lp.product_id,
   399	          qty: lp.shipped_qty,
   400	          uom: lp.uom,
   401	          updatedBy: userId,
   402	          sourceRef: {
   403	            aggregateType: 'shipment',
   404	            aggregateId: shipmentId,
   405	            dedupKey: `shipping-ship:${shipmentId}:${lp.lp_id}`,
   406	          },
   407	        });
   408	        if (wacDebit.applied) {
   409	          wacDebits.push({
   410	            lp_id: lp.lp_id,
   411	            item_id: lp.product_id,
   412	            qty_kg: wacDebit.qtyKg,
   413	            wac_value: wacDebit.valueDebited,
   414	          });
   415	        } else if (wacDebit.excluded === 'unresolved_uom') {
   416	          wacDebits.push({
   417	            lp_id: lp.lp_id,
   418	            item_id: lp.product_id,
   419	            wac_excluded: 'unresolved_uom',
   420	          });
   421	        }
   422	      }
   423	
   424	      await ctx.client.query(
   425	        `update public.inventory_allocations ia
   426	            set status = 'released',
   427	                released_at = now(),
   428	                ext_data = coalesce(ia.ext_data, '{}'::jsonb) || jsonb_build_object('closed_reason', $3::text),
   429	                updated_by = $2::uuid
   430	           from public.shipment_box_contents sbc
   431	           join public.shipment_boxes sb on sb.id = sbc.shipment_box_id
   432	            and sb.org_id = app.current_org_id()
   433	            and sb.shipment_id = $1::uuid
   434	            and sb.deleted_at is null
   435	          where ia.license_plate_id = sbc.license_plate_id
   436	            and sbc.org_id = app.current_org_id()
   437	            and sbc.deleted_at is null
   438	            and ia.org_id = app.current_org_id()
   439	            and ${LIVE_ALLOCATION_SQL}`,
   440	        [shipmentId, userId, SHIP_CLOSED_ALLOCATION_REASON],
   441	      );
   442	
   443	      const { rows: shippedLineRows } = await ctx.client.query<{
   444	        sales_order_line_id: string;
   445	        shipped_qty: string;
   446	      }>(
   447	        `select sbc.sales_order_line_id::text,
   448	                sum(sbc.quantity)::text as shipped_qty
   449	           from public.shipment_box_contents sbc
   450	           join public.shipment_boxes sb on sb.id = sbc.shipment_box_id
   451	            and sb.org_id = app.current_org_id()
   452	            and sb.shipment_id = $1::uuid
   453	            and sb.deleted_at is null
   454	          where sbc.org_id = app.current_org_id()
   455	            and sbc.deleted_at is null
   456	            and sbc.quantity is not null
   457	            and sbc.quantity > 0
   458	          group by sbc.sales_order_line_id`,
   459	        [shipmentId],
   460	      );
   461	      for (const line of shippedLineRows) {
   462	        await ctx.client.query(
   463	          `update public.sales_order_lines
   464	              set quantity_allocated = greatest(0, quantity_allocated - $2::numeric),
   465	                  updated_by = $3::uuid
   466	            where org_id = app.current_org_id()
   467	              and id = $1::uuid`,
   468	          [line.sales_order_line_id, line.shipped_qty, userId],
   469	        );
   470	      }
   471	
   472	      const { rowCount: snapshotRowCount } = await ctx.client.query(
   473	        `update public.shipments
   474	            set ext_data = coalesce(ext_data, '{}'::jsonb) || $2::jsonb,
   475	                updated_at = now(),
   476	                updated_by = $3::uuid
   477	          where org_id = app.current_org_id()
   478	            and id = $1::uuid
   479	            and status = 'shipped'
   480	            and deleted_at is null`,
   481	        [
   482	          shipmentId,
   483	          JSON.stringify({
   484	            shipped_license_plates: updatedLpRows.map((row) => ({
   485	              lp_id: row.id,
   486	              shipped_qty: row.shipped_qty,
   487	              prior_status: row.prior_status,
   488	              prior_reserved_qty: row.prior_reserved_qty,
   489	            })),
   490	            ...(wacDebits.length > 0 ? { wac_debits: wacDebits } : {}),
   491	          }),
   492	          userId,
   493	        ],
   494	      );
   495	      if (snapshotRowCount !== 1) throw new ActionError('persistence_failed');
   496	
   497	      for (const lpId of lpIds) {
   498	        await ctx.client.query(
   499	          `insert into public.outbox_events
   500	             (org_id, event_type, aggregate_type, aggregate_id, payload, app_version)
   501	           values
   502	             (app.current_org_id(), '${LP_SHIPPED_EVENT_TYPE}', 'license_plate', $1::uuid, $2::jsonb, coalesce(current_setting('app.app_version', true), 'dev'))`,
   503	          [
   504	            lpId,
   505	            JSON.stringify({
   506	              lp_id: lpId,
   507	              shipment_id: shipmentId,
   508	              so_id: shipment.sales_order_id,
   509	              org_id: orgId,
   510	            }),
   511	          ],
   512	        );
   513	      }
   514	
   515	      const { rows: remainingRows } = await ctx.client.query<{ remaining_count: number | string | bigint | null }>(
   516	        `select count(*)::int as remaining_count
   517	           from public.shipments
   518	          where org_id = app.current_org_id()
   519	            and sales_order_id = $1::uuid
   520	            and deleted_at is null
   521	            and status not in ('shipped', 'cancelled')`,
   522	        [shipment.sales_order_id],
   523	      );
   524	
   525	      if (toNumber(remainingRows[0]?.remaining_count) === 0) {
   526	        const soWrite = await writeSalesOrderStatusInContext(ctx, shipment.sales_order_id, 'shipped', {
   527	          currentStatus: soStatus,
   528	        });
   529	        if (soWrite !== 'ok') throw new ActionError('invalid_state');
   530	      }
   531	
   532	      return { ok: true };
   533	    });
   534	  } catch (err) {
   535	    return { ok: false, error: errorCode(err) };
   536	  }
   537	}
   538	
   539	export async function generateBol(input: GenerateBolInput): Promise<GenerateBolResult> {
   540	  try {
   541	    return await withOrgContext(async ({ userId, orgId, client }): Promise<GenerateBolResult> => {
   542	      const ctx: ShippingContext = { userId, orgId, client: client as QueryClient };
   543	      const forbidden = await requirePermission(ctx, SHIP_SHIP_CONFIRM);
   544	      if (forbidden) return forbidden;
   545	
   546	      const { rows: shipmentRows } = await ctx.client.query<{
   547	        id: string;
   548	        status: string;
   549	        box_count: number | string | bigint | null;
   550	      }>(
   551	        `select sh.id::text,
   552	                sh.status,
   553	                count(distinct sb.id)::int as box_count
   554	           from public.shipments sh
   555	           left join public.shipment_boxes sb on sb.shipment_id = sh.id
   556	            and sb.org_id = app.current_org_id()
   557	            and sb.deleted_at is null
   558	          where sh.org_id = app.current_org_id()
   559	            and sh.id = $1::uuid
   560	            and sh.deleted_at is null
   561	          group by sh.id, sh.status
   562	          limit 1`,
   563	        [input.shipmentId],
   564	      );
   565	      const shipment = shipmentRows[0];
   566	      if (!shipment || !['packed', 'shipped'].includes(shipment.status)) {
   567	        return { ok: false, error: 'invalid_state' };
   568	      }
   569	      if (toNumber(shipment.box_count) < 1) {
   570	        return { ok: false, error: 'no_boxes' };
   571	      }
   572	
   573	      const lpRows = await fetchShipmentLps(ctx, input.shipmentId);
   574	      const bolPayload = {
   575	        shipmentId: input.shipmentId,
   576	        orgId,
   577	        carrier: input.carrier ?? null,
   578	        serviceLevel: input.serviceLevel ?? null,
   579	        trackingNumber: input.trackingNumber ?? null,
   580	        generatedAt: new Date().toISOString(),
   581	        licensePlates: lpRows.map((lp) => ({
   582	          lpId: lp.lp_id,
   583	          lpNumber: lp.lp_number,
   584	        })),
   585	      };
   586	      const serializedPayload = JSON.stringify(bolPayload);
   587	      const bolHash = createHash('sha256').update(serializedPayload).digest('hex');
   588	
   589	      const { rows } = await ctx.client.query<{ id: string }>(
   590	        `update public.shipments
   591	            set carrier = $2::text,
   592	                service_level = $3::text,
   593	                tracking_number = $4::text,
   594	                bol_pdf_url = $5::text,
   595	                ext_data = coalesce(ext_data, '{}'::jsonb) || $6::jsonb,
   596	                updated_at = now(),
   597	                updated_by = $7::uuid
   598	          where org_id = app.current_org_id()
   599	            and id = $1::uuid
   600	            and deleted_at is null
   601	          returning id::text`,
   602	        [
   603	          input.shipmentId,
   604	          input.carrier ?? null,
   605	          input.serviceLevel ?? null,
   606	          input.trackingNumber ?? null,
   607	          serializedPayload,
   608	          JSON.stringify({ bol_sha256: bolHash }),
   609	          userId,
   610	        ],
   611	      );
   612	      if (!rows[0]) return { ok: false, error: 'not_found' };
   613	
   614	      return { ok: true, bolRef: bolHash };
   615	    });
   616	  } catch (err) {
   617	    return { ok: false, error: errorCode(err) };
   618	  }
   619	}
   620	
     1	'use server';
     2	
     3	import { randomUUID } from 'node:crypto';
     4	import { signEvent } from '@monopilot/e-sign';
     5	import { z } from 'zod';
     6	
     7	import { hasPermission } from '../../../../../../lib/auth/has-permission';
     8	import { withOrgContext } from '../../../../../../lib/auth/with-org-context';
     9	import {
    10	  deriveSalesOrderStatusFromProgress,
    11	  isLegalShipmentTransition,
    12	  isShipmentStatus,
    13	  LIVE_ALLOCATION_SQL,
    14	  type SalesOrderProgressSnapshot,
    15	  type SalesOrderStatus,
    16	  type ShipmentStatus,
    17	} from './so-transitions';
    18	import { releaseShipmentLiveAllocationsInContext, voidShipmentBoxesInContext } from './so-shipment-release';
    19	import { readLockedSalesOrderStatus, writeSalesOrderStatusInContext, writeShipmentStatusInContext } from './so-status-write';
    20	import { applyShipmentWacCancelCredits } from '../../../../../../lib/finance/upsert-wac';
    21	
    22	type QueryClient = {
    23	  query<T = Record<string, unknown>>(
    24	    sql: string,
    25	    params?: readonly unknown[],
    26	  ): Promise<{ rows: T[]; rowCount?: number | null }>;
    27	};
    28	
    29	type ShippingContext = { userId: string; orgId: string; client: QueryClient };
    30	
    31	type ShippingReversalError =
    32	  | 'forbidden'
    33	  | 'not_found'
    34	  | 'invalid_input'
    35	  | 'invalid_state'
    36	  | 'illegal_transition'
    37	  | 'downstream_financial_record'
    38	  | 'esign_failed'
    39	  | 'persistence_failed';
    40	
    41	export type ShippingReversalInput = {
    42	  shipmentId: string;
    43	  reasonCode?: string | null;
    44	  note?: string | null;
    45	  signature: {
    46	    password: string;
    47	    nonce?: string | null;
    48	  };
    49	};
    50	
    51	export type ShippingReversalResult =
    52	  | { ok: true }
    53	  | { ok: false; error: ShippingReversalError; message?: string };
    54	
    55	type ShipmentRow = {
    56	  id: string;
    57	  status: string;
    58	  sales_order_id: string | null;
    59	  sales_order_status: string | null;
    60	  shipment_number: string | null;
    61	  delivered_at: string | null;
    62	  bol_signed_pdf_url: string | null;
    63	  ext_data: unknown;
    64	};
    65	
    66	type ShipmentLpRow = {
    67	  lp_id: string;
    68	  site_id: string | null;
    69	  from_status: string;
    70	  shipped_qty: string;
    71	  reserved_qty: string;
    72	  prior_reserved_qty: string;
    73	};
    74	
    75	type AllocationRow = {
    76	  id: string;
    77	  lp_id: string;
    78	  qty: string;
    79	  status: string;
    80	};
    81	
    82	type FinancialTableRow = {
    83	  table_name: string;
    84	  has_shipment_id: boolean;
    85	  has_sales_order_id: boolean;
    86	  has_so_id: boolean;
    87	};
    88	
    89	const SHIP_SO_CANCEL = 'ship.so.cancel';
    90	const SHIP_PACK_CLOSE = 'ship.pack.close';
    91	const SHIP_SHIP_CONFIRM = 'ship.ship.confirm';
    92	const SHIP_BOL_SIGN = 'ship.bol.sign';
    93	
    94	const CANCEL_SHIPMENT_INTENT = 'cancel_shipment';
    95	const UNPACK_SHIPMENT_INTENT = 'unpack_shipment';
    96	const VOID_POD_INTENT = 'void_pod';
    97	
    98	const SHIPPING_SO_CANCELLED_EVENT = 'shipping.so.cancelled';
    99	const SHIPPING_SHIPMENT_PACKED_EVENT = 'shipping.shipment.packed';
   100	const SHIPPING_SHIPMENT_CONFIRMED_EVENT = 'shipping.shipment.confirmed';
   101	const WAREHOUSE_LP_TRANSITIONED_EVENT = 'warehouse.lp.transitioned';
   102	
   103	const CANCEL_BLOCKED_SO_STATUSES = new Set(['delivered', 'partially_delivered', 'cancelled']);
   104	const UNPACK_BLOCKED_SHIPMENT_STATUSES = new Set(['shipped', 'delivered', 'cancelled']);
   105	const PRE_SHIP_CANCEL_STATUSES = new Set<ShipmentStatus>(['pending', 'packing', 'packed', 'manifested']);
   106	
   107	const reversalInputSchema = z.object({
   108	  shipmentId: z.string().uuid(),
   109	  reasonCode: z.string().trim().min(1).max(64).optional().nullable(),
   110	  note: z.string().trim().max(1000).optional().nullable(),
   111	  signature: z.object({
   112	    password: z.string().min(1),
   113	    nonce: z.string().trim().min(1).optional().nullable(),
   114	  }),
   115	});
   116	
   117	class ActionError extends Error {
   118	  constructor(readonly code: ShippingReversalError) {
   119	    super(code);
   120	  }
   121	}
   122	
   123	class CancelShipmentAbort extends Error {
   124	  constructor(readonly result: Extract<ShippingReversalResult, { ok: false }>) {
   125	    super(result.error);
   126	  }
   127	}
   128	
   129	function parseInput(input: ShippingReversalInput): z.infer<typeof reversalInputSchema> | null {
   130	  const parsed = reversalInputSchema.safeParse(input);
   131	  return parsed.success ? parsed.data : null;
   132	}
   133	
   134	function errorCode(error: unknown): ShippingReversalError {
   135	  if (error instanceof CancelShipmentAbort) return error.result.error;
   136	  if (error instanceof ActionError) return error.code;
   137	  const code = (error as { code?: string } | null)?.code;
   138	  if (code === '22P02' || code === '23503' || code === '23514') return 'invalid_input';
   139	  return 'persistence_failed';
   140	}
   141	
   142	async function requireAnyPermission(
   143	  ctx: ShippingContext,
   144	  permissions: readonly string[],
   145	): Promise<ShippingReversalResult | null> {
   146	  for (const permission of permissions) {
   147	    if (await hasPermission(ctx, permission)) return null;
   148	  }
   149	  return { ok: false, error: 'forbidden' };
   150	}
   151	
   152	async function requirePermission(ctx: ShippingContext, permission: string): Promise<ShippingReversalResult | null> {
   153	  return requireAnyPermission(ctx, [permission]);
   154	}
   155	
   156	async function lockShipment(ctx: ShippingContext, shipmentId: string): Promise<ShipmentRow | null> {
   157	  const { rows: previewRows } = await ctx.client.query<{ sales_order_id: string | null }>(
   158	    `select sales_order_id::text
   159	       from public.shipments
   160	      where org_id = app.current_org_id()
   161	        and id = $1::uuid
   162	        and deleted_at is null`,
   163	    [shipmentId],
   164	  );
   165	  const soId = previewRows[0]?.sales_order_id ?? null;
   166	  if (!previewRows[0]) return null;
   167	
   168	  let salesOrderStatus: string | null = null;
   169	  if (soId) {
   170	    const { rows: salesOrderRows } = await ctx.client.query<{ status: string }>(
   171	      `select status
   172	         from public.sales_orders
   173	        where org_id = app.current_org_id()
   174	          and id = $1::uuid
   175	          and deleted_at is null
   176	        for update`,
   177	      [soId],
   178	    );
   179	    salesOrderStatus = salesOrderRows[0]?.status ?? null;
   180	  }
   181	
   182	  const { rows } = await ctx.client.query<ShipmentRow>(
   183	    `select sh.id::text,
   184	            sh.status,
   185	            sh.sales_order_id::text,
   186	            null::text as sales_order_status,
   187	            sh.shipment_number,
   188	            sh.delivered_at::text,
   189	            sh.bol_signed_pdf_url,
   190	            sh.ext_data
   191	       from public.shipments sh
   192	      where sh.org_id = app.current_org_id()
   193	        and sh.id = $1::uuid
   194	        and sh.deleted_at is null
   195	      for update of sh`,
   196	    [shipmentId],
   197	  );
   198	  const shipment = rows[0] ?? null;
   199	  if (!shipment) return null;
   200	  shipment.sales_order_status = salesOrderStatus;
   201	  return shipment;
   202	}
   203	
   204	async function lockShipmentLps(ctx: ShippingContext, shipmentId: string): Promise<ShipmentLpRow[]> {
   205	  const { rows } = await ctx.client.query<ShipmentLpRow>(
   206	    `with shipment_lps as (
   207	       select sbc.license_plate_id,
   208	              sum(sbc.quantity)::numeric as shipped_qty
   209	       from public.shipment_box_contents sbc
   210	       join public.shipment_boxes sb on sb.id = sbc.shipment_box_id
   211	        and sb.org_id = app.current_org_id()
   212	        and sb.deleted_at is null
   213	      where sbc.org_id = app.current_org_id()
   214	        and sbc.deleted_at is null
   215	        and sbc.quantity is not null
   216	        and sbc.quantity > 0
   217	        and sb.shipment_id = $1::uuid
   218	      group by sbc.license_plate_id
   219	     ),
   220	     shipment_lp_snapshots as (
   221	       select snapshot.lp_id::uuid as lp_id,
   222	              snapshot.shipped_qty::numeric as shipped_qty,
   223	              snapshot.prior_status,
   224	              snapshot.prior_reserved_qty::numeric as prior_reserved_qty
   225	         from public.shipments sh
   226	        cross join lateral jsonb_to_recordset(coalesce(sh.ext_data->'shipped_license_plates', '[]'::jsonb))
   227	          as snapshot(lp_id text, shipped_qty text, prior_status text, prior_reserved_qty text)
   228	        where sh.org_id = app.current_org_id()
   229	          and sh.id = $1::uuid
   230	          and sh.deleted_at is null
   231	     )
   232	     select lp.id::text as lp_id,
   233	            lp.site_id::text,
   234	            coalesce(snapshot.prior_status, case when lp.status = 'shipped' then 'available' else lp.status end) as from_status,
   235	            coalesce(snapshot.shipped_qty, shipment_lps.shipped_qty)::text as shipped_qty,
   236	            lp.reserved_qty::text,
   237	            coalesce(snapshot.prior_reserved_qty, lp.reserved_qty)::text as prior_reserved_qty
   238	       from shipment_lps
   239	       join public.license_plates lp on lp.id = shipment_lps.license_plate_id
   240	        and lp.org_id = app.current_org_id()
   241	       left join shipment_lp_snapshots snapshot on snapshot.lp_id = lp.id
   242	      for update of lp`,
   243	    [shipmentId],
   244	  );
   245	
   246	  const byId = new Map<string, ShipmentLpRow>();
   247	  for (const row of rows) byId.set(row.lp_id, row);
   248	  return Array.from(byId.values());
   249	}
   250	
   251	async function lockShipmentAllocations(ctx: ShippingContext, shipment: ShipmentRow): Promise<AllocationRow[]> {
   252	  if (!shipment.sales_order_id) return [];
   253	  const { rows } = await ctx.client.query<AllocationRow>(
   254	    `select ia.id::text,
   255	            ia.license_plate_id::text as lp_id,
   256	            ia.quantity_allocated::text as qty,
   257	            ia.status
   258	       from public.inventory_allocations ia
   259	       join public.sales_order_lines sol on sol.id = ia.sales_order_line_id
   260	        and sol.org_id = app.current_org_id()
   261	        and sol.sales_order_id = $1::uuid
   262	        and sol.deleted_at is null
   263	       join public.shipment_box_contents sbc on sbc.license_plate_id = ia.license_plate_id
   264	        and sbc.org_id = app.current_org_id()
   265	        and sbc.deleted_at is null
   266	       join public.shipment_boxes sb on sb.id = sbc.shipment_box_id
   267	        and sb.org_id = app.current_org_id()
   268	        and sb.shipment_id = $2::uuid
   269	        and sb.deleted_at is null
   270	      where ia.org_id = app.current_org_id()
   271	        and ia.deleted_at is null
   272	        and ${LIVE_ALLOCATION_SQL}
   273	      for update of ia`,
   274	    [shipment.sales_order_id, shipment.id],
   275	  );
   276	  const byId = new Map<string, AllocationRow>();
   277	  for (const row of rows) byId.set(row.id, row);
   278	  return Array.from(byId.values());
   279	}
   280	
   281	async function signReversal(
   282	  ctx: ShippingContext,
   283	  parsed: z.infer<typeof reversalInputSchema>,
   284	  intent: string,
   285	  subject: Record<string, unknown>,
   286	): Promise<string> {
   287	  try {
   288	    const receipt = await signEvent(
   289	      {
   290	        signerUserId: ctx.userId,
   291	        pin: parsed.signature.password,
   292	        intent,
   293	        reason: parsed.reasonCode ?? undefined,
   294	        nonce: parsed.signature.nonce ?? undefined,
   295	        subject,
   296	      },
   297	      { client: ctx.client as never },
   298	    );
   299	    return receipt.signatureId;
   300	  } catch {
   301	    throw new ActionError('esign_failed');
   302	  }
   303	}
