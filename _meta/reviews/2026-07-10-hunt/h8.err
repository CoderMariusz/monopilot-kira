   593	      `select public.next_sales_order_document_number($1::uuid) as so_number`,
   594	      [orgId],
   595	    );
   596	    const soNumber = numberRows[0]?.so_number;
   597	    if (!soNumber) return { ok: false, error: 'persistence_failed', message: 'Unable to generate sales order number' };
   598	
   599	    const { rows } = await ctx.client.query<{ id: string }>(
   600	      `insert into public.sales_orders
   601	        (org_id, order_number, customer_id, order_date, promised_ship_date, status, ext_data, created_by, updated_by)
   602	       values ($1::uuid, $2, $3::uuid, current_date, $4::date, 'draft', jsonb_build_object('notes', $5::text), $6::uuid, $6::uuid)
   603	       returning id::text`,
   604	      [orgId, soNumber, input.customer_id, input.requested_date ?? null, input.notes ?? null, userId],
   605	    );
   606	    const soId = rows[0]?.id;
   607	    if (!soId) return { ok: false, error: 'persistence_failed', message: 'Unable to create sales order' };
   608	
   609	    for (const [index, line] of resolvedLines.entries()) {
   610	      await ctx.client.query(
   611	        `insert into public.sales_order_lines
   612	          (org_id, sales_order_id, line_number, product_id, quantity_ordered, quantity_allocated,
   613	           unit_price_gbp, line_total_gbp, ext_data, created_by, updated_by)
   614	         values ($1::uuid, $2::uuid, $3::integer, $4::uuid, $5::numeric, 0,
   615	                 $6::numeric, ($5::numeric * $6::numeric), jsonb_build_object('order_uom', $7::text), $8::uuid, $8::uuid)`,
   616	        [orgId, soId, index + 1, line.item_id, line.qty, line.unitPriceGbp, line.uom, userId],
   617	      );
   618	    }
   619	
   620	    const created = await fetchSalesOrder(ctx, soId);
   621	    revalidateLocalized('/shipping');
   622	    return { ok: true, data: created };
   623	  });
   624	}
