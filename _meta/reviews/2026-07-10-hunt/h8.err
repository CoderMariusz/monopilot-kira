   551	
   552	-- bill_of_lading retention_until (BRCGS 7y from COALESCE(signed_at, created_at)) — trigger-maintained
   553	-- (timestamptz::date + interval is not immutable, so not a GENERATED STORED column).
   554	create or replace function public.bill_of_lading_set_updated_at_retention()
   555	returns trigger
   556	language plpgsql
   557	as $$
   558	begin
   559	  new.updated_at := pg_catalog.now();
   560	  new.retention_until := (coalesce(new.signed_at, new.created_at)::date + interval '7 years')::date;
   561	  return new;
   562	end;
   563	$$;
   564	
   565	-- ===========================================================================
   566	-- sscc_counters + SSCC functions (T-018, §13.1).
   567	--   next_sscc_serial(org)  — atomic per-org serial (row-locked UPDATE ... RETURNING; no gaps).
   568	--   sscc_mod10(sscc17)     — GS1 mod-10 check digit (server-side only; V-SHIP-LBL-03).
   569	--   generate_sscc(org,ext) — 18-digit SSCC: ext(1) + gs1_prefix(7) + serial(9) + mod10.
   570	-- ===========================================================================
   571	create table if not exists public.sscc_counters (
   572	  org_id      uuid primary key references public.organizations(id) on delete cascade,
   573	  last_serial bigint not null default 0,
   574	  updated_at  timestamptz not null default pg_catalog.now()
   575	);
   576	
   577	create or replace function public.next_sscc_serial(p_org_id uuid)
   578	returns bigint
   579	language plpgsql
   580	security definer
   581	set search_path = pg_catalog, public
   582	as $$
   583	declare
   584	  v_serial bigint;
   585	begin
   586	  -- Tenant-isolation: SECURITY DEFINER bypasses RLS, so the caller-supplied p_org_id MUST match
   587	  -- the session org or an app_user could mutate another org's SSCC counter / read its GS1 prefix.
   588	  if p_org_id is null or p_org_id <> app.current_org_id() then
   589	    raise exception 'next_sscc_serial: cross-org access denied' using errcode = '42501';
   590	  end if;
   591	  -- Insert-on-first-call then atomic increment via UPDATE ... RETURNING (row lock = no gaps,
   592	  -- no duplicates under concurrency). NEVER nextval() — that is a global sequence, not per-org.
   593	  insert into public.sscc_counters (org_id) values (p_org_id)
   594	    on conflict (org_id) do nothing;
   595	  update public.sscc_counters
   596	     set last_serial = last_serial + 1,
   597	         updated_at  = pg_catalog.now()
   598	   where org_id = p_org_id
   599	   returning last_serial into v_serial;
   600	  return v_serial;
   601	end;
   602	$$;
   603	
   604	create or replace function public.sscc_mod10(p_sscc17 text)
   605	returns integer
   606	language plpgsql
   607	immutable
   608	set search_path = pg_catalog
   609	as $$
   610	declare
   611	  v_sum    integer := 0;
   612	  v_digit  integer;
   613	  v_weight integer;
   614	  i        integer;
   615	begin
   616	  if p_sscc17 is null or p_sscc17 !~ '^[0-9]{17}$' then
   617	    raise exception 'sscc_mod10: input must be exactly 17 digits';
   618	  end if;
   619	  -- GS1 SSCC-18 check digit: weight the 17 digits 3,1,3,1,... from the LEFT, sum, then the
   620	  -- check digit is (10 - (sum mod 10)) mod 10.
   621	  for i in 1..17 loop
   622	    v_digit  := substr(p_sscc17, i, 1)::integer;
   623	    v_weight := case when (i % 2) = 1 then 3 else 1 end;
   624	    v_sum    := v_sum + v_digit * v_weight;
   625	  end loop;
   626	  return (10 - (v_sum % 10)) % 10;
   627	end;
   628	$$;
   629	
   630	-- GS1 SSCC-18 integrity: app_user has insert/update on shipment_boxes, so an SSCC stored outside
   631	-- generate_sscc() must still carry a valid mod-10 check digit (added after sscc_mod10 is defined).
   632	alter table public.shipment_boxes drop constraint if exists shipment_boxes_sscc_mod10_check;
   633	alter table public.shipment_boxes add constraint shipment_boxes_sscc_mod10_check
   634	  check (sscc is null or public.sscc_mod10(left(sscc, 17)) = substr(sscc, 18, 1)::integer);
   635	
   636	create or replace function public.generate_sscc(p_org_id uuid, p_extension integer default 0)
   637	returns varchar(18)
   638	language plpgsql
   639	security definer
   640	set search_path = pg_catalog, public
   641	as $$
   642	declare
   643	  v_prefix  text;
   644	  v_serial  bigint;
   645	  v_body    text;
   646	  v_check   integer;
   647	begin
   648	  -- Tenant-isolation guard (SECURITY DEFINER bypasses RLS); next_sscc_serial re-checks too.
   649	  if p_org_id is null or p_org_id <> app.current_org_id() then
   650	    raise exception 'generate_sscc: cross-org access denied' using errcode = '42501';
   651	  end if;
   652	  if p_extension is null or p_extension < 0 or p_extension > 9 then
   653	    raise exception 'generate_sscc: extension digit must be 0-9';
   654	  end if;
   655	  -- gs1_prefix sourced from organizations (02-SETTINGS §12.1) — NEVER env config.
   656	  select gs1_prefix into v_prefix from public.organizations where id = p_org_id;
   657	  if v_prefix is null or v_prefix = '' then
   658	    raise exception 'V-SHIP-PACK-03 missing GS1 company prefix for org %', p_org_id;
   659	  end if;
   660	  -- P1 enforces exactly 7-digit GS1 company prefix (V-SHIP-PACK-03 7-10; P2 widens).
   661	  if v_prefix !~ '^[0-9]{7}$' then
   662	    raise exception 'V-SHIP-PACK-03 GS1 company prefix must be exactly 7 digits (got %)', v_prefix;
   663	  end if;
   664	  v_serial := public.next_sscc_serial(p_org_id);
   665	  -- body = ext(1) + prefix(7) + serial(9) = 17 digits.
   666	  v_body  := p_extension::text || v_prefix || lpad(v_serial::text, 9, '0');
   667	  v_check := public.sscc_mod10(v_body);
   668	  return (v_body || v_check::text)::varchar(18);
   669	end;
   670	$$;
   671	
   672	revoke all on function public.next_sscc_serial(uuid) from public;
   673	revoke all on function public.generate_sscc(uuid, integer) from public;
   674	grant execute on function public.next_sscc_serial(uuid) to app_user;
   675	grant execute on function public.sscc_mod10(text) to app_user;
   676	grant execute on function public.generate_sscc(uuid, integer) to app_user;
   677	
   678	-- ===========================================================================
   679	-- RLS + FORCE RLS + grants + updated_at triggers for every operational table.
   680	-- Policies <table>_org_context USING/WITH CHECK (org_id = app.current_org_id()) — no GUC reads.
   681	-- ===========================================================================
   682	do $$
   683	declare
   684	  t text;
   685	  shipping_tables text[] := array[
     1	-- F1 fix: refuse invalid prefix / serial-capacity exhaustion BEFORE next_sscc_serial()
     2	-- so a failed mint does not burn sscc_counters. Pack routes through generate_sscc (canonical).
     3	
     4	create or replace function public.generate_sscc(p_org_id uuid, p_extension integer default 0)
     5	returns varchar(18)
     6	language plpgsql
     7	security definer
     8	set search_path = pg_catalog, public
     9	as $$
    10	declare
    11	  v_prefix      text;
    12	  v_last_serial bigint;
    13	  v_serial      bigint;
    14	  v_body        text;
    15	  v_check       integer;
    16	begin
    17	  if p_org_id is null or p_org_id <> app.current_org_id() then
    18	    raise exception 'generate_sscc: cross-org access denied' using errcode = '42501';
    19	  end if;
    20	  if p_extension is null or p_extension < 0 or p_extension > 9 then
    21	    raise exception 'generate_sscc: extension digit must be 0-9';
    22	  end if;
    23	
    24	  select trim(gs1_prefix) into v_prefix from public.organizations where id = p_org_id;
    25	  if v_prefix is null or v_prefix = '' then
    26	    raise exception 'V-SHIP-PACK-03 missing GS1 company prefix for org %', p_org_id;
    27	  end if;
    28	  -- P1: exactly 7-digit company prefix (matches shipment_boxes_sscc_mod10_check callers).
    29	  if v_prefix !~ '^[0-9]{7}$' then
    30	    raise exception 'V-SHIP-PACK-03 GS1 company prefix must be exactly 7 digits (got %)', v_prefix;
    31	  end if;
    32	
    33	  -- Serial field is 9 digits (ext + prefix + serial = 17). Refuse before increment when the
    34	  -- next value would not fit — otherwise lpad does not truncate and sscc_mod10 raises after burn.
    35	  select c.last_serial into v_last_serial
    36	    from public.sscc_counters c
    37	   where c.org_id = p_org_id;
    38	  if coalesce(v_last_serial, 0) >= 999999999 then
    39	    raise exception 'V-SHIP-PACK-03 SSCC serial capacity exhausted for org %', p_org_id;
    40	  end if;
    41	
    42	  v_serial := public.next_sscc_serial(p_org_id);
    43	  v_body := p_extension::text || v_prefix || lpad(v_serial::text, 9, '0');
    44	  if length(v_body) <> 17 then
    45	    raise exception 'V-SHIP-PACK-03 SSCC body length invalid for org %', p_org_id;
    46	  end if;
    47	  v_check := public.sscc_mod10(v_body);
    48	  return (v_body || v_check::text)::varchar(18);
    49	end;
    50	$$;
     1	'use server';
     2	
     3	import { randomUUID } from 'node:crypto';
     4	import { signEvent } from '@monopilot/e-sign';
     5	import { z } from 'zod';
     6	
     7	import { hasPermission } from '../../../../../../lib/auth/has-permission';
     8	import { withOrgContext } from '../../../../../../lib/auth/with-org-context';
     9	import {
    10	  deriveSalesOrderStatusFromProgress,
    11	  isLegalShipmentTransition,
