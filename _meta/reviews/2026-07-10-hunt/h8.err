   626	export async function transitionSalesOrderStatus(
   627	  id: string,
   628	  newStatus: TransitionTarget,
   629	): Promise<TransitionSalesOrderStatusResult> {
   630	  try {
   631	    return await withOrgContext(async ({ userId, orgId, client }): Promise<TransitionSalesOrderStatusResult> => {
   632	      const ctx: ShippingContext = { userId, orgId, client: client as QueryClient };
   633	      const forbidden = await requirePermission(ctx, permissionForTransition(newStatus));
   634	      if (forbidden) return forbidden;
   635	      const result = await transitionSalesOrderStatusInContext(ctx, id, newStatus);
   636	      if (result && 'error' in result) return result;
   637	      return { ok: true, data: result };
   638	    });
   639	  } catch (err) {
   640	    if (err instanceof SoActionError && err.code === 'so_cancel_blocked_shipped') {
   641	      return { ok: false, error: 'so_cancel_blocked_shipped' };
   642	    }
   643	    throw err;
   644	  }
   645	}
