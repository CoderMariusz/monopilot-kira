   305	async function writeAuditEvent(
   306	  ctx: ShippingContext,
   307	  params: {
   308	    action: string;
   309	    shipment: ShipmentRow;
   310	    beforeState: Record<string, unknown>;
   311	    afterState: Record<string, unknown>;
   312	  },
   313	): Promise<number> {
   314	  const { rows } = await ctx.client.query<{ id: number }>(
   315	    `insert into public.audit_events (
   316	       org_id,
   317	       actor_user_id,
   318	       actor_type,
   319	       action,
   320	       resource_type,
   321	       resource_id,
   322	       before_state,
   323	       after_state,
   324	       request_id,
   325	       retention_class
   326	     )
   327	     values (
   328	       app.current_org_id(),
   329	       $1::uuid,
   330	       'user',
   331	       $2,
   332	       'shipment',
   333	       $3,
   334	       $4::jsonb,
   335	       $5::jsonb,
   336	       $6::uuid,
   337	       'operational'
   338	     )
   339	     returning id`,
   340	    [
   341	      ctx.userId,
   342	      params.action,
   343	      params.shipment.id,
   344	      JSON.stringify(params.beforeState),
   345	      JSON.stringify(params.afterState),
   346	      randomUUID(),
   347	    ],
   348	  );
   349	  const auditId = rows[0]?.id;
   350	  if (typeof auditId !== 'number') throw new ActionError('persistence_failed');
   351	  return auditId;
   352	}
   353	
   354	async function emitOutboxEvent(
   355	  ctx: ShippingContext,
   356	  params: {
   357	    eventType: string;
   358	    aggregateType: string;
   359	    aggregateId: string;
   360	    payload: Record<string, unknown>;
   361	  },
   362	): Promise<void> {
   363	  const { rowCount } = await ctx.client.query(
   364	    `insert into public.outbox_events
   365	       (org_id, event_type, aggregate_type, aggregate_id, payload, app_version, dedup_key)
   366	     values
   367	       (app.current_org_id(), $1, $2, $3, $4::jsonb, coalesce(current_setting('app.app_version', true), 'dev'), $5)
   368	     on conflict (org_id, dedup_key) where dedup_key is not null do nothing`,
   369	    [
   370	      params.eventType,
   371	      params.aggregateType,
   372	      params.aggregateId,
   373	      JSON.stringify(params.payload),
   374	      `${params.eventType}:${params.aggregateType}:${params.aggregateId}:${params.payload.signature_id ?? randomUUID()}`,
   375	    ],
   376	  );
   377	  if (rowCount == null) throw new ActionError('persistence_failed');
   378	}
   379	
   380	async function writeLpTransition(
   381	  ctx: ShippingContext,
   382	  shipment: ShipmentRow,
   383	  lp: ShipmentLpRow,
   384	  toStatus: string,
   385	  reasonCode: string | null,
   386	  note: string | null,
   387	): Promise<void> {
   388	  if (lp.from_status === toStatus) return;
   389	
   390	  const transactionId = randomUUID();
   391	  const { rowCount } = await ctx.client.query(
   392	    `insert into public.lp_state_history (
   393	       org_id,
   394	       site_id,
   395	       lp_id,
   396	       from_state,
   397	       to_state,
   398	       reason_code,
   399	       reason_text,
   400	       source_so_id,
   401	       transaction_id,
   402	       ext_jsonb,
   403	       created_by
   404	     )
   405	     values (
   406	       app.current_org_id(),
   407	       $1::uuid,
   408	       $2::uuid,
   409	       $3,
   410	       $4,
   411	       $5,
   412	       $6,
   413	       $7::uuid,
   414	       $8::uuid,
   415	       $9::jsonb,
   416	       $10::uuid
   417	     )`,
   418	    [
   419	      lp.site_id,
   420	      lp.lp_id,
     1	/**
     2	 * Shared "pack a license plate into a shipment box" core.
     3	 *
     4	 * Extracted from the desktop `packLpIntoBox` Server Action so the SCANNER
     5	 * pack-to-SO flow (FEAT-2 / map dead-end #13) can reuse the EXACT same
     6	 * allocation + food-safety validation. Both callers pass their own
     7	 * org-scoped client:
     8	 *   - desktop  → withOrgContext  (Supabase JWT user session)
     9	 *   - scanner  → withScannerOrg  (bearer scanner session)
    10	 *
    11	 * This module is intentionally NOT `'use server'` — it is plain TS shared by
    12	 * a Server Action and a route handler. The permission gate lives in the
    13	 * callers (desktop requirePermission / scanner hasPermission).
    14	 */
    15	
    16	export type PackQueryClient = {
    17	  query<T = Record<string, unknown>>(
    18	    sql: string,
    19	    params?: readonly unknown[],
    20	  ): Promise<{ rows: T[]; rowCount?: number | null }>;
    21	};
    22	
    23	export type PackContext = { userId: string; orgId: string; client: PackQueryClient };
    24	
    25	export type PackLpInput = { shipmentId: string; lpId: string; boxId?: string };
    26	
    27	export type PackLpResult = { ok: true; boxId: string } | { ok: false; error: string };
    28	
    29	const UUID_PATTERN = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
    30	
    31	/** Aligned with OPEN_SHIPMENT_STATUSES in shipping/_actions/so-transitions.ts */
    32	const PACKABLE_SHIPMENT_STATUSES = new Set(['pending', 'packing']);
    33	
    34	function toNumber(value: unknown): number {
    35	  if (typeof value === 'number') return value;
    36	  if (typeof value === 'bigint') return Number(value);
    37	  return Number(value ?? 0);
    38	}
    39	
    40	/** Resolve a scanned barcode (UUID, lp_number, or lp_code) to the LP UUID. */
    41	export async function resolveLicensePlateId(ctx: PackContext, input: string): Promise<string | null> {
    42	  const candidate = input.trim();
    43	  if (!candidate) return null;
    44	  if (UUID_PATTERN.test(candidate)) return candidate;
    45	
    46	  const { rows } = await ctx.client.query<{ id: string }>(
    47	    `select id::text as id
    48	       from public.license_plates
    49	      where (lp_number = $1 or lp_code = $1)
    50	        and org_id = app.current_org_id()
    51	      limit 1`,
    52	    [candidate],
    53	  );
    54	  return rows[0]?.id ?? null;
    55	}
    56	
    57	export async function packLpIntoBoxCore(ctx: PackContext, input: PackLpInput): Promise<PackLpResult> {
    58	  const { userId, orgId } = ctx;
    59	
    60	  const { rows: shipmentRows } = await ctx.client.query<{
    61	    id: string;
    62	    sales_order_id: string;
    63	    site_id: string | null;
    64	    status: string;
    65	  }>(
    66	    `select sh.id::text,
    67	            sh.sales_order_id::text,
    68	            sh.site_id::text,
    69	            sh.status
    70	       from public.shipments sh
    71	      where sh.org_id = app.current_org_id()
    72	        and sh.id = $1::uuid
    73	        and sh.deleted_at is null
    74	      limit 1`,
    75	    [input.shipmentId],
    76	  );
    77	  const shipment = shipmentRows[0];
    78	  if (!shipment?.sales_order_id || !PACKABLE_SHIPMENT_STATUSES.has(shipment.status)) {
    79	    return { ok: false, error: 'invalid_state' };
    80	  }
    81	
    82	  const licensePlateId = await resolveLicensePlateId(ctx, input.lpId);
    83	  if (!licensePlateId) return { ok: false, error: 'lp_not_found' };
    84	
    85	  const { rows: alreadyPackedRows } = await ctx.client.query<{ id: string }>(
    86	    `select sbc.id::text
    87	       from public.shipment_box_contents sbc
    88	      where sbc.org_id = app.current_org_id()
    89	        and sbc.license_plate_id = $1::uuid
    90	        and sbc.deleted_at is null
    91	      limit 1`,
    92	    [licensePlateId],
    93	  );
    94	  if (alreadyPackedRows.length > 0) return { ok: false, error: 'already_packed' };
    95	
    96	  const { rows: allocationRows } = await ctx.client.query<{
    97	    sales_order_line_id: string;
    98	    site_id: string | null;
    99	    product_id: string;
   100	    lot_number: string | null;
   101	    quantity_allocated: string;
   102	  }>(
   103	    `select ia.sales_order_line_id::text,
   104	            coalesce(ia.site_id, sol.site_id, lp.site_id)::text as site_id,
   105	            coalesce(sol.product_id, lp.product_id)::text as product_id,
   106	            lp.batch_number as lot_number,
   107	            ia.quantity_allocated::text
   108	       from public.inventory_allocations ia
   109	       join public.sales_order_lines sol on sol.id = ia.sales_order_line_id and sol.org_id = app.current_org_id()
   110	       left join public.license_plates lp on lp.id = ia.license_plate_id and lp.org_id = app.current_org_id()
   111	      where ia.org_id = app.current_org_id()
   112	        and ia.license_plate_id = $1::uuid
   113	        and sol.sales_order_id = $2::uuid
   114	        and ia.status in ('allocated', 'picked')
   115	        and ia.deleted_at is null
   116	        and sol.deleted_at is null
   117	      order by ia.allocated_at desc
   118	      limit 1`,
   119	    [licensePlateId, shipment.sales_order_id],
   120	  );
   121	  const allocation = allocationRows[0];
   122	  if (!allocation) return { ok: false, error: 'lp_not_allocated' };
   123	
   124	  // Food-safety re-assert at PACK time (owner per-rule = HARD BLOCK): a quality
   125	  // hold, QA-status reversion, or expiry can land AFTER allocation but before
   126	  // the LP is packed into a shipment box. Held / QA-unreleased / expired goods
   127	  // must not be packed for shipment. Mirrors the ship-time guard in
   128	  // shipShipment (v_active_holds T-064 + qa_status + expiry_date), so the
   129	  // egress path is blocked at both pack and ship.
   130	  const { rows: blockedRows } = await ctx.client.query<{ reason: string }>(
   131	    `select case when h.hold_id is not null then 'hold'
   132	                 when lp.qa_status is distinct from 'released' then 'qa'
   133	                 else 'expired' end as reason
   134	       from public.license_plates lp
   135	       left join lateral (
   136	         select hold_id from public.v_active_holds h
   137	          where h.org_id = app.current_org_id()
   138	            and h.reference_type = 'lp' and h.reference_id = lp.id
   139	          limit 1
   140	       ) h on true
   141	      where lp.id = $1::uuid
   142	        and lp.org_id = app.current_org_id()
   143	        and ( h.hold_id is not null
   144	              or lp.qa_status is distinct from 'released'
   145	              or (lp.expiry_date is not null and lp.expiry_date < current_date) )
   146	      limit 1`,
   147	    [licensePlateId],
   148	  );
   149	  if (blockedRows.length > 0) return { ok: false, error: 'lp_blocked_for_pack' };
   150	
   151	  let boxId = input.boxId;
   152	  let boxSiteId: string | null = null;
   153	
   154	  if (boxId) {
   155	    const { rows: boxRows } = await ctx.client.query<{ site_id: string | null }>(
   156	      `select sb.site_id::text
   157	         from public.shipment_boxes sb
   158	        where sb.org_id = app.current_org_id()
   159	          and sb.id = $1::uuid
   160	          and sb.shipment_id = $2::uuid
   161	          and sb.deleted_at is null
   162	        limit 1`,
   163	      [boxId, input.shipmentId],
   164	    );
   165	    if (!boxRows[0]) return { ok: false, error: 'invalid_box' };
   166	    boxSiteId = boxRows[0].site_id;
   167	  } else {
   168	    // Canonical SSCC mint: public.generate_sscc validates prefix + serial capacity BEFORE
   169	    // incrementing sscc_counters (migration 459). Pack uses the 7-digit-prefix SQL layout so
   170	    // shipment_boxes_sscc_mod10_check agrees with the mint path. @monopilot/gs1 generateSscc18
   171	    // remains for validation/formatting (supports 7–10 digit prefixes) but is not used here.
   172	    let sscc: string;
   173	    try {
   174	      const { rows: ssccRows } = await ctx.client.query<{ sscc: string }>(
   175	        `select public.generate_sscc($1::uuid, 0)::text as sscc`,
   176	        [orgId],
   177	      );
   178	      sscc = ssccRows[0]?.sscc ?? '';
   179	      if (!sscc) throw new Error('generate_sscc returned no SSCC');
   180	    } catch (err) {
   181	      const msg = err instanceof Error ? err.message : String(err);
   182	      if (/V-SHIP-PACK-03.*missing GS1 company prefix/i.test(msg)) {
   183	        return { ok: false, error: 'missing_gs1_prefix' };
   184	      }
   185	      if (/V-SHIP-PACK-03/i.test(msg)) {
   186	        return { ok: false, error: 'invalid_gs1_prefix' };
   187	      }
   188	      throw err;
   189	    }
   190	
   191	    const { rows: boxNumberRows } = await ctx.client.query<{ next_box_number: number | string | bigint }>(
   192	      `select coalesce(max(sb.box_number), 0) + 1 as next_box_number
   193	         from public.shipment_boxes sb
   194	        where sb.org_id = app.current_org_id()
   195	          and sb.shipment_id = $1::uuid
   196	          and sb.deleted_at is null`,
   197	      [input.shipmentId],
   198	    );
   199	    const nextBoxNumber = toNumber(boxNumberRows[0]?.next_box_number) || 1;
   200	    boxSiteId = allocation.site_id ?? shipment.site_id;
   201	
   202	    const { rows: boxRows } = await ctx.client.query<{ id: string }>(
   203	      `insert into public.shipment_boxes
   204	         (org_id, site_id, shipment_id, box_number, sscc, created_by, updated_by)
   205	       values ($1::uuid, $2::uuid, $3::uuid, $4::integer, $5::varchar(18), $6::uuid, $6::uuid)
   206	       returning id::text`,
   207	      [orgId, boxSiteId, input.shipmentId, nextBoxNumber, sscc, userId],
   208	    );
   209	    boxId = boxRows[0]?.id;
   210	    if (!boxId) throw new Error('persistence_failed');
   211	  }
   212	
   213	  await ctx.client.query(
   214	    `insert into public.shipment_box_contents
   215	       (org_id, site_id, shipment_box_id, sales_order_line_id, product_id, license_plate_id,
   216	        lot_number, quantity, created_at, created_by, updated_by)
   217	     values ($1::uuid, $2::uuid, $3::uuid, $4::uuid, $5::uuid, $6::uuid,
   218	             $7::text, $8::numeric, now(), $9::uuid, $9::uuid)`,
   219	    [
   220	      orgId,
   221	      allocation.site_id ?? boxSiteId ?? shipment.site_id,
   222	      boxId,
   223	      allocation.sales_order_line_id,
   224	      allocation.product_id,
   225	      licensePlateId,
   226	      allocation.lot_number,
   227	      allocation.quantity_allocated,
   228	      userId,
   229	    ],
   230	  );
   231	
   232	  const { rowCount: linkedLpCount } = await ctx.client.query(
   233	    `update public.license_plates
   234	        set source_so_id = $2::uuid,
   235	            updated_at = now(),
   236	            updated_by = $3::uuid
   237	      where org_id = app.current_org_id()
   238	        and id = $1::uuid`,
   239	    [licensePlateId, shipment.sales_order_id, userId],
   240	  );
   241	  if (linkedLpCount !== 1) throw new Error('source_so_link_failed');
   242	
   243	  return { ok: true, boxId };
   244	}

