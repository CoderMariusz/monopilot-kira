   361	async function writeConsumptionReverseStockMove(
   362	  ctx: ProductionContext,
   363	  params: { original: ConsumptionRow; lp: LicensePlateRow; correctionId: string; reasonCode: CorrectionReasonCode; note: string | null },
   364	): Promise<void> {
   365	  const transactionId = correctionTransactionId({
   366	    orgId: ctx.orgId,
   367	    table: 'wo_material_consumption',
   368	    originalId: params.original.id,
   369	    reasonCode: params.reasonCode,
   370	  });
   371	  await ctx.client.query(
   372	    `insert into public.stock_moves (
   373	       org_id, site_id, move_number, lp_id, move_type, from_location_id,
   374	       quantity, uom, reason_code, reason_text, transaction_id, wo_id, wo_material_id,
   375	       status, ext_jsonb, created_by, updated_by
   376	     )
   377	     values (
   378	       app.current_org_id(), $1::uuid, $2, $3::uuid, 'adjustment', $4::uuid,
   379	       $5::numeric, $6, 'consumption_reversed', $7,
   380	       $8::uuid, $9::uuid, $10::uuid, 'completed', $11::jsonb, $12::uuid, $12::uuid
   381	     )
   382	     on conflict (org_id, transaction_id) do nothing`,
   383	    [
   384	      params.lp.site_id ?? params.original.site_id,
   385	      makeStockMoveNumber(transactionId),
   386	      params.lp.id,
   387	      params.lp.location_id,
   388	      negateDecimalString(params.original.qty_consumed),
   389	      params.original.uom,
   390	      params.note,
   391	      transactionId,
   392	      params.original.wo_id,
   393	      materialIdFromConsumptionExt(params.original) ?? params.original.component_id,
   394	      JSON.stringify({
   395	        source: 'scannerReverseConsumption',
   396	        consumption_id: params.original.id,
   397	        correction_id: params.correctionId,
   398	        correction_reason_code: params.reasonCode,
   399	      }),
   400	      ctx.userId,
   401	    ],
   402	  );
   403	}
   404	
   405	async function decrementConsumedQty(ctx: ProductionContext, original: ConsumptionRow): Promise<boolean> {
   406	  const materialId = materialIdFromConsumptionExt(original);
   407	
   408	  if (!materialId) {
   409	    const { rows } = await ctx.client.query<{ id: string }>(
   410	      `with locked_materials as (
   411	         select id
   412	           from public.wo_materials
   413	          where org_id = app.current_org_id()
   414	            and wo_id = $1::uuid
   415	            and product_id = $2::uuid
   416	            and exists (
   417	              select 1
   418	                from public.work_orders wo
   419	               where wo.org_id = app.current_org_id()
   420	                 and wo.id = wo_materials.wo_id
   421	                 and app.user_can_see_site(wo.site_id)
   422	            )
   423	          for update
   424	       ),
   425	       single_material as (
   426	         select id
   427	           from locked_materials
   428	          where (select count(*) from locked_materials) = 1
   429	       )
   430	       update public.wo_materials wm
   431	          set consumed_qty = wm.consumed_qty - $3::numeric,
   432	              updated_at = now()
   433	         from single_material sm
   434	        where wm.org_id = app.current_org_id()
   435	          and wm.id = sm.id
   436	          and wm.consumed_qty - $3::numeric >= 0
   437	        returning wm.id::text as id`,
   438	      [original.wo_id, original.component_id, original.qty_consumed],
   439	    );
   440	    return rows.length === 1;
   441	  }
   442	
   443	  const { rows } = await ctx.client.query<{ id: string }>(
   444	    `update public.wo_materials
   445	        set consumed_qty = consumed_qty - $3::numeric,
   446	            updated_at = now()
   447	      where org_id = app.current_org_id()
   448	        and wo_id = $1::uuid
   449	        and ${materialId ? 'id' : 'product_id'} = $2::uuid
   450	        and consumed_qty - $3::numeric >= 0
   451	        and exists (
   452	          select 1
   453	            from public.work_orders wo
   454	           where wo.org_id = app.current_org_id()
   455	             and wo.id = wo_materials.wo_id
   456	             and app.user_can_see_site(wo.site_id)
   457	        )
   458	      returning id::text as id`,
   459	    [original.wo_id, materialId ?? original.component_id, original.qty_consumed],
   460	  );
   461	  return rows.length > 0;
   462	}
