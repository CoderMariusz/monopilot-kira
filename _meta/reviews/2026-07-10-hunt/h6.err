    37	export function toBaseQty(snap: UomSnapshot, qty: number, uom: OutputUom): number {
    38	  if (uom === 'base') return qty;
    39	  if (uom === 'each') return qty * requireFactor(snap.netQtyPerEach);
    40	  return qty * requireFactor(snap.eachPerBox) * requireFactor(snap.netQtyPerEach);
    41	}
    42	
    43	export function fromBaseQty(snap: UomSnapshot, baseQty: number, uom: OutputUom): number {
    44	  if (uom === 'base') return baseQty;
    45	  if (uom === 'each') return baseQty / requireFactor(snap.netQtyPerEach);
    46	  return baseQty / (requireFactor(snap.eachPerBox) * requireFactor(snap.netQtyPerEach));
    47	}
    48	
    49	export function snapshotFromItemRow(row: ItemLike): UomSnapshot {
    50	  const outputUom = (row.output_uom ?? row.outputUom ?? 'base') as OutputUom;
    51	  const weightMode = (row.weight_mode ?? row.weightMode ?? 'fixed') as 'fixed' | 'catch';
    52	  return {
    53	    outputUom,
    54	    uomBase: row.uom_base ?? row.uomBase ?? 'kg',
    55	    netQtyPerEach: nullableNumber(row.net_qty_per_each ?? row.netQtyPerEach),
    56	    eachPerBox: nullableNumber(row.each_per_box ?? row.eachPerBox),
    57	    boxesPerPallet: nullableNumber(row.boxes_per_pallet ?? row.boxesPerPallet),
    58	    weightMode,
    59	  };
    60	}
    61	
    62	/**
    63	 * Pre-production pack-hierarchy completeness gate.
    64	 *
    65	 * A Finished-Good item that is physically packed in `each` or `box` units must
    66	 * have the factors needed to convert that pack unit to its base (kg/liquid)
    67	 * quantity, otherwise output/consumption conversion fails later at production
    68	 * time (`uom_conversion_unavailable`). This pure check lets callers (e.g. WO
    69	 * release) fail fast with an actionable message instead.
    70	 *
    71	 * Rules:
    72	 *  - `base`  → always complete (bulk FG is legitimate, never blocked).
    73	 *  - `each`  → requires net_qty_per_each > 0.
    74	 *  - `box`   → requires net_qty_per_each > 0 AND each_per_box > 0.
    75	 */
    76	export function packHierarchyComplete(snap: UomSnapshot): boolean {
    77	  if (snap.outputUom === 'base') return true;
    78	  if (snap.outputUom === 'each') return positiveFactor(snap.netQtyPerEach);
    79	  if (snap.outputUom === 'box') {
    80	    return positiveFactor(snap.netQtyPerEach) && positiveFactor(snap.eachPerBox);
    81	  }
    82	  return false;
    83	}
    84	
    85	function positiveFactor(value: number | null): boolean {
    86	  return value !== null && Number.isFinite(value) && value > 0;
    87	}
    88	
    89	function nullableNumber(value: string | number | null | undefined): number | null {
    90	  if (value === null || value === undefined || value === '') return null;
    91	  return Number(value);
    92	}
    93	
    94	function requireFactor(value: number | null): number {
    95	  if (value === null || !Number.isFinite(value) || value <= 0) {
    96	    throw new TypedError('uom_conversion_unavailable');
    97	  }
    98	  return value;
    99	}
