    51	  const qtyKgRaw = body.qtyKg;
    52	  if (!categoryCode || qtyKgRaw === undefined || qtyKgRaw === null) {
    53	    return scannerValidationError(request, body, operation, 'missing_fields', 400, { woId });
    54	  }
    55	  const qtyKg = typeof qtyKgRaw === 'string' ? qtyKgRaw.trim() : null;
    56	  if (!qtyKg) return scannerValidationError(request, body, operation, 'invalid_qty', 422, { woId, clientOpId });
    57	  if (!isDecimalString(qtyKg) || qtyKg === '0' || /^0+(\.0+)?$/.test(qtyKg)) {
    58	    return scannerValidationError(request, body, operation, 'invalid_qty', 422, { woId, clientOpId });
    59	  }
    60	
    61	  const result = await requireScannerSession(request, body, operation, async ({ client, session }) => {
    62	    let txnOrgContextToken: string | null = null;
    63	    try {
    64	      await client.query('begin');
    65	      txnOrgContextToken = await registerTxnOrgContext(client, session.org_id, session.user_id);
    66	      await acquireScannerIdempotencyLock(client, session.org_id, clientOpId);
    67	
    68	      const replay = await findServerReplay(client, session.org_id, clientOpId, operation);
    69	      if (replay) {
    70	        await client.query('commit');
    71	        await auditAttempt(client, session, operation, 'replay', { woId, clientOpId });
    72	        if (replay.result_code === 'ok') return wasteReplayResponse(replay.ext);
    73	        const { error, status, extra } = reconstructServerReplayError(replay);
    74	        return scannerError(error, status, extra);
    75	      }
    76	
    77	      const woRes = await client.query<{ id: string }>(
    78	        `select id
    79	           from public.work_orders
    80	          where org_id = app.current_org_id()
    81	            and id = $1::uuid
    82	            and ${scannerWorkOrderVisibleOnLineSql(2)}
    83	            and app.user_can_see_site(site_id)
    84	          limit 1`,
    85	        [woId, session.line_id],
    86	      );
    87	      if (!woRes.rows[0]) {
    88	        await insertServerReplay(client, session, {
    89	          operation,
    90	          clientOpId,
    91	          resultCode: 'not_found',
    92	          woId,
    93	          ext: { woId, clientOpId, status: 404 },
    94	        });
    95	        await client.query('commit');
    96	        await auditAttempt(client, session, operation, 'not_found', { woId, clientOpId });
    97	        return scannerError('not_found', 404);
    98	      }
    99	
   100	      const transactionId = scannerTransactionId('waste', clientOpId);
   101	      const data = await withScannerOrg(session, (ctx) =>
   102	        recordWaste(ctx, woId, {
   103	          transaction_id: transactionId,
   104	          category_code: categoryCode,
   105	          qty_kg: qtyKg,
   106	          reason_notes: stringField(body, 'reason') ?? undefined,
   107	          shift_id: session.shift ?? 'scanner',
   108	        }),
   109	      );
   110	
   111	      await insertServerReplay(client, session, {
   112	        operation,
   113	        clientOpId,
   114	        resultCode: 'ok',
   115	        woId,
   116	        ext: {
   117	          woId,
   118	          clientOpId,
   119	          transactionId,
   120	          wasteId: data.waste_id,
   121	          waste: data,
   122	        },
   123	      });
   124	      await client.query('commit');
   125	      await auditAttempt(client, session, operation, 'ok', {
   126	        woId,
   127	        clientOpId,
   128	        transactionId,
   129	        wasteId: data.waste_id,
   130	      });
   131	      return scannerOk({ waste: data, transactionId, replay: false });
   132	    } catch (error) {
   133	      if (error instanceof QualityHoldError || error instanceof ProductionActionError) {
   134	        try {
   135	          await insertServerReplay(client, session, {
   136	            operation,
   137	            clientOpId,
   138	            resultCode: error.code,
   139	            woId,
   140	            ext: {
   141	              woId,
   142	              clientOpId,
   143	              status: error.status,
   144	              ...(error.details ?? {}),
   145	            },
   146	          });
   147	          await client.query('commit');
   148	        } catch {
   149	          try {
   150	            await client.query('rollback');
   151	          } catch {
   152	            /* noop */
   153	          }
   154	        }
   155	        if (error instanceof QualityHoldError) {
   156	          await withScannerOrg(session, (ctx) => emitConsumeBlocked(ctx, error));
   157	        }
   158	        await auditAttempt(client, session, operation, error instanceof Error ? error.message : 'error', {
   159	          woId,
   160	          clientOpId,
   161	        });
   162	        return productionErrorResponse(error);
   163	      }
   164	      try {
   165	        await client.query('rollback');
   166	      } catch {
   167	        /* noop */
   168	      }
   169	      await auditAttempt(client, session, operation, error instanceof Error ? error.message : 'error', {
   170	        woId,
   171	        clientOpId,
   172	      });
   173	      return productionErrorResponse(error);
   174	    } finally {
   175	      await cleanupTxnOrgContext(client, txnOrgContextToken);
   176	    }
   177	  });
   178	
   179	  if ('guardError' in result) return scannerError(result.error, result.status);
   180	  return result;
   181	}
     1	/**
     2	 * Waste recording (08-production E3) — write a categorized waste row into
     3	 * public.wo_waste_log and emit production.waste.recorded. Feeds the yield gate
     4	 * (output_yield_gate_v1), finance loss accounting, and reporting analytics.
     5	 *
     6	 * Flow (atomic, single txn supplied by the route's withOrgContext):
     7	 *   1. zod-validate the body.
     8	 *   2. RBAC: caller must hold production.waste.write.
     9	 *   3. Load the WO (RLS-scoped); WO must be in a recordable lifecycle state.
    10	 *   4. Resolve category_code → waste_categories.id (02-Settings taxonomy shell,
    11	 *      migration 183). An unknown/inactive code is an invalid reference (V-PROD-05).
    12	 *   5. holdsGuard(lpId, lotId) FIRST — active 09-quality hold ⇒ 409 +
    13	 *      production.consume.blocked outbox event.
    14	 *   6. INSERT wo_waste_log (qty_kg > 0 enforced by schema; R14 idempotency on
    15	 *      transaction_id).
    16	 *   7. emit production.waste.recorded in the SAME txn.
    17	 *
    18	 * NUMERIC-exact: qty_kg is a decimal string straight into NUMERIC(12,3); never
    19	 * coerced through a binary float.
    20	 */
    21	import { z } from 'zod';
    22	
    23	import { createHash } from 'node:crypto';
    24	
    25	import { microToDecimal, toMicro } from '../../shared/decimal';
    26	import { makeStockMoveNumber } from '../../warehouse/lp-create';
    27	import {
    28	  PRODUCTION_WASTE_RECORDED_EVENT,
    29	  PRODUCTION_WASTE_WRITE_PERMISSION,
    30	  OUTPUT_RECORDABLE_STATES,
    31	  ProductionActionError,
    32	  QualityHoldError,
    33	  emitOutbox,
    34	  hasPermission,
    35	  holdsGuard,
    36	  readWoExecutionStatus,
    37	  type OrgContextLike,
    38	} from '../shared';
    39	
    40	// REGULATED QUANTITY BOUNDARY (food-MES, NUMERIC-exact): qty_kg is a decimal STRING ONLY.
    41	// JS `number` is rejected — it cannot represent an exact decimal (IEEE-754 drift) and
    42	// String(number) can emit exponential notation, corrupting a regulated weight before the
    43	// NUMERIC column. Bound straight to ::numeric in SQL (mirrors register-output; Codex round-2).
    44	const DecimalString = z
    45	  .string()
    46	  .transform((v) => v.trim())
    47	  .refine((s) => /^-?\d+(\.\d+)?$/.test(s), {
    48	    message: 'must be a plain decimal string (no JS number / exponential notation)',
    49	  });
    50	
    51	export const RecordWasteInput = z.object({
    52	  transaction_id: z.string().uuid(),
    53	  category_code: z.string().min(1).max(64),
    54	  qty_kg: DecimalString,
    55	  reason_code: z.string().min(1).max(64).optional(),
    56	  reason_notes: z.string().max(2000).optional(),
    57	  operator_id: z.string().uuid().optional(),
    58	  shift_id: z.string().min(1).max(64),
    59	  lp_id: z.string().uuid().optional(),
    60	  lot_id: z.string().uuid().optional(),
    61	  scan_event_id: z.string().uuid().optional(),
    62	});
    63	
    64	export type RecordWasteInputType = z.infer<typeof RecordWasteInput>;
    65	
    66	export type RecordWasteResult = {
    67	  waste_id: string;
    68	  category_id: string;
    69	  category_code: string;
    70	  qty_kg: string;
    71	};
    72	
    73	type WoRow = { id: string; wo_number: string; site_id: string | null };
    74	
    75	type LpGateRow = {
    76	  id: string;
    77	  quantity: string;
    78	  reserved_qty: string;
    79	  has_available: boolean;
    80	  status: string;
    81	  qa_status: string;
    82	  uom: string | null;
    83	  location_id: string | null;
    84	  site_id: string | null;
    85	};
    86	
    87	/** wo_waste_log qty_kg subtracts 1:1 from license_plates.quantity — LP uom must be kg. */
    88	function isKgMassUom(uom: string | null | undefined): boolean {
    89	  if (uom == null || uom.trim() === '') return true;
    90	  return uom.trim().toLowerCase() === 'kg';
    91	}
    92	
    93	function deterministicLedgerTransactionId(seed: string): string {
    94	  const hex = createHash('md5').update(seed).digest('hex');
    95	  const v = hex.slice(0, 12) + '3' + hex.slice(13, 16) + ((parseInt(hex[16], 16) & 0x3) | 0x8).toString(16) + hex.slice(17, 32);
    96	  return `${v.slice(0, 8)}-${v.slice(8, 12)}-${v.slice(12, 16)}-${v.slice(16, 20)}-${v.slice(20, 32)}`;
    97	}
    98	
    99	async function loadWo(ctx: OrgContextLike, woId: string): Promise<WoRow> {
   100	  const { rows } = await ctx.client.query<WoRow>(
   101	    `select id, wo_number, site_id::text as site_id
   102	       from public.work_orders
   103	      where id = $1::uuid
   104	        and org_id = app.current_org_id()
   105	      limit 1`,
   106	    [woId],
   107	  );
   108	  const wo = rows[0];
   109	  if (!wo) throw new ProductionActionError('not_found', 404);
   110	  return wo;
   111	}
   112	
   113	async function resolveCategoryId(ctx: OrgContextLike, categoryCode: string): Promise<string> {
   114	  const { rows } = await ctx.client.query<{ id: string }>(
   115	    `select id
   116	       from public.waste_categories
   117	      where org_id = app.current_org_id()
   118	        and code = $1
   119	        and is_active = true
   120	      limit 1`,
   121	    [categoryCode],
   122	  );
   123	  const cat = rows[0];
   124	  if (!cat) throw new ProductionActionError('invalid_reference', 422, { field: 'category_code' });
   125	  return cat.id;
   126	}
   127	
   128	export async function recordWaste(
   129	  ctx: OrgContextLike,
   130	  woId: string,
   131	  rawBody: unknown,
   132	): Promise<RecordWasteResult> {
   133	  // 1. validate
   134	  const parsed = RecordWasteInput.safeParse(rawBody);
   135	  if (!parsed.success) {
   136	    throw new ProductionActionError('invalid_input', 422, {
   137	      fields: parsed.error.issues.map((i) => i.path.join('.')),
   138	      message: parsed.error.message,
   139	    });
   140	  }
   141	  const input = parsed.data;
   142	
   143	  // V-PROD-05 red-line: waste qty must be strictly positive.
   144	  if (toMicro(input.qty_kg) <= 0n) {
   145	    throw new ProductionActionError('invalid_input', 422, { fields: ['qty_kg'] });
   146	  }
   147	
   148	  // 2. RBAC
   149	  if (!(await hasPermission(ctx, PRODUCTION_WASTE_WRITE_PERMISSION))) {
   150	    throw new ProductionActionError('forbidden', 403);
   151	  }
   152	
   153	  // 3. load WO + lifecycle gate
   154	  const wo = await loadWo(ctx, woId);
   155	  const status = await readWoExecutionStatus(ctx, woId);
   156	  if (status === null || !OUTPUT_RECORDABLE_STATES.has(status)) {
   157	    throw new ProductionActionError('wo_not_recordable', 409, { status });
   158	  }
   159	
   160	  // 4. category taxonomy resolve (V-PROD-05).
   161	  const categoryId = await resolveCategoryId(ctx, input.category_code);
   162	
   163	  // 5. quality consume gate FIRST. Active hold ⇒ QualityHoldError; the route
   164	  //    emits production.consume.blocked on a committed connection.
   165	  const hold = await holdsGuard(ctx, { lpId: input.lp_id, lotId: input.lot_id });
   166	  if (hold) {
   167	    throw new QualityHoldError({
   168	      hold,
   169	      woId,
   170	      blockedPath: 'waste',
   171	      transactionId: input.transaction_id,
   172	      lpId: input.lp_id ?? null,
   173	      lotId: input.lot_id ?? null,
   174	    });
   175	  }
   176	
   177	  let lpLocationId: string | null = null;
   178	  if (input.lp_id) {
   179	    const lpGate = await ctx.client.query<LpGateRow>(
   180	      `select id::text as id,
   181	              quantity::text as quantity,
   182	              reserved_qty::text as reserved_qty,
   183	              (quantity - reserved_qty >= $2::numeric) as has_available,
   184	              status,
   185	              qa_status,
   186	              uom,
   187	              location_id::text as location_id,
   188	              site_id::text as site_id
   189	         from public.license_plates
   190	        where id = $1::uuid
   191	          and org_id = $3::uuid
   192	        limit 1
   193	        for update`,
   194	      [input.lp_id, input.qty_kg, ctx.orgId],
   195	    );
   196	    const lp = lpGate.rows[0];
   197	    if (!lp) {
   198	      throw new ProductionActionError('invalid_reference', 422, { field: 'lp_id' });
   199	    }
   200	    // Mirror assertLpConsumableForProduction (lp-safety-guard.ts) — only released + available LPs.
   201	    if (lp.qa_status !== 'released') {
   202	      throw new ProductionActionError('lp_not_released', 409);
   203	    }
   204	    if (lp.status !== 'available') {
   205	      throw new ProductionActionError('lp_not_wasteable', 409, { status: lp.status });
   206	    }
   207	    if (!isKgMassUom(lp.uom)) {
   208	      throw new ProductionActionError('uom_mismatch', 409, { uom: lp.uom });
   209	    }
   210	    if (!lp.has_available) {
   211	      throw new ProductionActionError('insufficient_lp_quantity', 409, {
   212	        message: 'Insufficient available quantity on license plate for waste quantity.',
   213	      });
   214	    }
   215	
   216	    const lpRes = await ctx.client.query<{ id: string; quantity: string }>(
   217	      `update public.license_plates
   218	          set quantity = quantity - $3::numeric,
   219	              status = case when quantity - $3::numeric <= 0 then 'destroyed' else status end,
   220	              updated_at = now()
   221	        where org_id = $1::uuid
   222	          and id = $2::uuid
   223	          and quantity - $3::numeric >= reserved_qty
   224	        returning id::text, quantity::text as quantity`,
   225	      [ctx.orgId, input.lp_id, input.qty_kg],
   226	    );
   227	    if (!lpRes.rows[0]) {
   228	      throw new Error('recordWaste: LP decrement failed after availability gate');
   229	    }
   230	    lpLocationId = lp.location_id;
   231	
   232	    const fullyDestroyed = toMicro(lpRes.rows[0].quantity) <= 0n;
   233	    if (fullyDestroyed) {
   234	      await ctx.client.query(
   235	        `insert into public.lp_state_history (
   236	           org_id, site_id, lp_id, from_state, to_state, reason_code, reason_text,
   237	           wo_id, transaction_id, ext_jsonb, created_by
   238	         )
   239	         values (
   240	           app.current_org_id(), $1::uuid, $2::uuid, $3, 'destroyed', 'production_waste',
   241	           'Production waste LP fully destroyed', $4::uuid, $5::uuid, $6::jsonb, $7::uuid
   242	         )
   243	         on conflict (org_id, transaction_id) do nothing`,
   244	        [
   245	          // F2: stamp the LP's own site_id, not the WO's — mirrors the
   246	          // reverse-consume writer (route.ts writeLpRestoredHistory, params.lp.site_id).
   247	          // A cross-site LP would otherwise get the WO's site stamped here while
   248	          // the DB trigger only derives site_id from the LP when the column is NULL.
   249	          lp.site_id,
   250	          input.lp_id,
   251	          lp.status,
   252	          woId,
   253	          deterministicLedgerTransactionId(`${input.transaction_id}:lp_state`),
   254	          JSON.stringify({ source: 'production_waste', wo_id: woId, category_code: input.category_code }),
   255	          ctx.userId,
   256	        ],
   257	      );
   258	    }
   259	  }
   260	
   261	  // 6. INSERT wo_waste_log (+ ledger-visible LP decrement when lp_id present).
   262	  let wasteId: string;
   263	  try {
   264	    if (input.lp_id) {
   265	      const signedQty = microToDecimal(-toMicro(input.qty_kg));
   266	      await ctx.client.query(
   267	        `insert into public.stock_moves (
   268	           org_id, site_id, move_number, lp_id, move_type, from_location_id, to_location_id,
   269	           quantity, uom, reason_code, reason_text, transaction_id, wo_id, status, ext_jsonb,
   270	           created_by, updated_by
   271	         )
   272	         values (
   273	           app.current_org_id(), $1::uuid, $2, $3::uuid, 'adjustment', $4::uuid, null,
   274	           $5::numeric, $6, $7, $8, $9::uuid, $10::uuid, 'completed', $11::jsonb, $12::uuid, $12::uuid
   275	         )
   276	         on conflict (org_id, transaction_id) do nothing`,
   277	        [
   278	          wo.site_id,
   279	          makeStockMoveNumber(input.transaction_id),
   280	          input.lp_id,
   281	          lpLocationId,
   282	          signedQty,
   283	          'kg',
   284	          'production_waste',
   285	          'Production waste LP decrement',
   286	          input.transaction_id,
   287	          woId,
   288	          JSON.stringify({ source: 'production_waste', wo_id: woId, category_code: input.category_code }),
   289	          ctx.userId,
   290	        ],
   291	      );
   292	    }
   293	
   294	    const { rows } = await ctx.client.query<{ id: string }>(
   295	      `insert into public.wo_waste_log
   296	         (org_id, site_id, transaction_id, wo_id, category_id, qty_kg, reason_code,
   297	          reason_notes, operator_id, shift_id, scan_event_id, lp_id)
   298	       values
   299	         (app.current_org_id(), $11::uuid, $1::uuid, $2::uuid, $3::uuid, $4::numeric, $5,
   300	          $6, $7::uuid, $8, $9::uuid, $10::uuid)
   301	       returning id`,
   302	      [
   303	        input.transaction_id,
   304	        woId,
   305	        categoryId,
   306	        input.qty_kg,
   307	        input.reason_code ?? null,
   308	        input.reason_notes ?? null,
   309	        input.operator_id ?? ctx.userId,
   310	        input.shift_id,
   311	        input.scan_event_id ?? null,
   312	        input.lp_id ?? null,
   313	        wo.site_id,
   314	      ],
   315	    );
   316	    const row = rows[0];
   317	    if (!row) throw new ProductionActionError('persistence_failed', 500);
   318	    wasteId = row.id;
   319	  } catch (err) {
   320	    if (err instanceof ProductionActionError) throw err;
   321	    const code = (err as { code?: string }).code;
   322	    if (code === '23505') throw new ProductionActionError('already_recorded', 409);
   323	    if (code === '23514' || code === '23503') {
   324	      throw new ProductionActionError('invalid_reference', 422);
   325	    }
   326	    throw err;
   327	  }
   328	
   329	  // 7. outbox (same txn) — feeds yield gate + finance loss + reporting.
   330	  await emitOutbox(ctx, {
   331	    eventType: PRODUCTION_WASTE_RECORDED_EVENT,
   332	    aggregateType: 'wo',
   333	    aggregateId: woId,
   334	    payload: {
   335	      org_id: ctx.orgId,
   336	      waste_id: wasteId,
   337	      wo_id: woId,
   338	      category_id: categoryId,
   339	      category_code: input.category_code,
   340	      qty_kg: input.qty_kg,
   341	      reason_code: input.reason_code ?? null,
   342	      shift_id: input.shift_id,
   343	      actor_user_id: ctx.userId,
   344	    },
   345	    dedupKey: `${PRODUCTION_WASTE_RECORDED_EVENT}:${input.transaction_id}`,
   346	  });
   347	
   348	  return {
   349	    waste_id: wasteId,
   350	    category_id: categoryId,
   351	    category_code: input.category_code,
   352	    qty_kg: input.qty_kg,
   353	  };
   354	}
   280	     ),
   281	     allowed_products as (
   282	       select wo.product_id as item_id, 'primary'::text as role
   283	         from wo
   284	       union
   285	       select so.product_id, so.output_role
   286	         from public.schedule_outputs so
   287	        where so.org_id = app.current_org_id()
   288	          and so.planned_wo_id = $1::uuid
   289	       union
   290	       select bcp.co_product_item_id,
   291	              case when bcp.is_byproduct then 'byproduct' else 'co_product' end
   292	         from public.bom_co_products bcp
   293	         join wo on wo.active_bom_header_id = bcp.bom_header_id
   294	        where bcp.org_id = app.current_org_id()
   295	     )
   296	     select exists (
   297	       select 1
   298	         from allowed_products ap
   299	        where ap.item_id = $2::uuid
   300	          and (
   301	            ($3 = 'primary' and ap.role = 'primary')
   302	            or ($3 = 'co_product' and ap.role = 'co_product')
   303	            or ($3 = 'by_product' and ap.role in ('byproduct', 'by_product'))
   304	          )
   305	     ) as allowed`,
   306	    [woId, productId, outputType],
   307	  );
   308	  if (!rows[0]?.allowed) {
   309	    throw new ProductionActionError('invalid_reference', 422, {
   310	      field: 'product_id',
   311	      output_type: outputType,
   312	      message: 'Output product is not declared on this work order or its active BOM.',
   313	    });
   314	  }
   315	}
   316	
   317	async function nextBatchNumber(
   318	  ctx: OrgContextLike,
   319	  woId: string,
   320	  woNumber: string,
   321	  outputType: string,
   322	): Promise<string> {
   323	  await ctx.client.query(
   324	    `select pg_advisory_xact_lock(hashtext($1::text || '::' || $2::text))`,
   325	    [woId, outputType],
   326	  );
   327	  const { rows } = await ctx.client.query<{ seq: string }>(
   328	    `select count(*)::text as seq
   329	       from public.wo_outputs
   330	      where wo_id = $1::uuid
   331	        and org_id = app.current_org_id()
   332	        and output_type = $2
   333	        and correction_of_id is null`,
   334	    [woId, outputType],
   335	  );
   336	  const seq = Number(rows[0]?.seq ?? '0') + 1;
   337	  return `${woNumber}-OUT-${String(seq).padStart(3, '0')}`;
   338	}
   339	
   340	/**
   341	 * Genealogy source (F-B08): the LPs this WO consumed, from the canonical
   342	 * consumption ledger (wo_material_consumption — the only consume writer),
   343	 * ordered by first consumption so [0] is the primary parent.
   344	 */
   345	async function loadConsumedLpIds(ctx: OrgContextLike, woId: string): Promise<string[]> {
   346	  const { rows } = await ctx.client.query<{ lp_id: string }>(
   347	    // Exclude the sentinel nil UUID that no-LP consumes write
   348	    // (consume-material-actions.ts: lp_id coalesces to
   349	    // '00000000-0000-0000-0000-000000000000'). Without this filter a WO whose
   350	    // only consumes were LP-less would give the output a phantom parent_lp_id
   351	    // pointing at a license_plates row that does not exist — corrupting
   352	    // genealogy. Filtering here keeps parent_lp_id null instead.
   353	    `select lp_id::text as lp_id
   354	       from public.wo_material_consumption
   355	      where org_id = app.current_org_id()
   356	        and wo_id = $1::uuid
   357	        and lp_id <> '00000000-0000-0000-0000-000000000000'::uuid
   358	      group by lp_id
   359	      order by min(consumed_at) asc, lp_id asc`,
   360	    [woId],
   361	  );
   362	  return rows.map((r) => r.lp_id);
   363	}
   364	
   365	async function evaluateMassBalanceGate(
   366	  ctx: OrgContextLike,
   367	  woId: string,
   368	  qtyKg: string,
   369	): Promise<MassBalanceWarning | undefined> {
   370	  const { rows } = await ctx.client.query<MassBalanceGateRow>(
   371	    `with cfg as (
   372	       select coalesce(
   373	                case
   374	                  when (tv.feature_flags->>'massbalance_threshold_pct') ~ '^[0-9]+(\\.[0-9]+)?$'
   375	                    then (tv.feature_flags->>'massbalance_threshold_pct')::numeric
   376	                  else 0
   377	                end,
   378	                0
   379	              ) as block_pct
   380	         from public.tenant_variations tv
   381	        where tv.org_id = app.current_org_id()
   382	     ),
   383	     yield_ctx as (
   384	       select coalesce(
   385	                (
   386	                  select wop.expected_yield_percent
   387	                    from public.wo_operations wop
   388	                   where wop.org_id = app.current_org_id()
   389	                     and wop.wo_id = wo.id
   390	                     and wop.expected_yield_percent is not null
   391	                   order by wop.sequence asc
   392	                   limit 1
   393	                ),
   394	                bh.yield_pct,
   395	                -- Missing yield data falls back to factor 1.0.
   396	                100::numeric
   397	              ) as effective_yield_pct
   398	         from public.work_orders wo
   399	         left join public.bom_headers bh
   400	           on bh.org_id = wo.org_id
   401	          and bh.id = wo.active_bom_header_id
   402	        where wo.org_id = app.current_org_id()
   403	          and wo.id = $1::uuid
   404	        limit 1
   405	     ),
   406	     totals as (
   407	       select coalesce(
   408	                (select sum(o.qty_kg)
   409	                   from public.wo_outputs o
   410	                  where o.org_id = app.current_org_id()
   411	                    and o.wo_id = $1::uuid),
   412	                0::numeric
   413	              ) + $2::numeric as running_output_kg,
   414	              coalesce(
   415	                (select sum(c.qty_consumed)
   416	                  from public.wo_material_consumption c
   417	                  where c.org_id = app.current_org_id()
   418	                    and c.wo_id = $1::uuid
   419	                    and c.uom = 'kg'),
   420	                0::numeric
   421	              ) as posted_consumption_kg
   422	     )
   423	     select case
   424	              when y.effective_yield_pct > 0
   425	                then (t.running_output_kg / (y.effective_yield_pct / 100.0))::text
   426	              else null
   427	            end as expected_input_kg,
   428	            t.posted_consumption_kg::text as posted_consumption_kg,
   429	            y.effective_yield_pct::text as effective_yield_pct,
   430	            coalesce((select block_pct from cfg), 0)::text as block_pct,
   431	            t.posted_consumption_kg > 0
   432	              and y.effective_yield_pct > 0
   433	              and t.running_output_kg
   434	                    > (t.posted_consumption_kg * (y.effective_yield_pct / 100.0) * (1 + $3::numeric)) as warn,
   435	            t.posted_consumption_kg > 0
   436	              and y.effective_yield_pct > 0
   437	              and coalesce((select block_pct from cfg), 0) > 0
   438	              and t.running_output_kg
   439	                    > (t.posted_consumption_kg * (y.effective_yield_pct / 100.0) * (1 + coalesce((select block_pct from cfg), 0) / 100)) as block
   440	       from yield_ctx y
   441	       cross join totals t`,
   442	    [woId, qtyKg, MASS_BALANCE_WARN_PCT],
   443	  );
   444	  const gate = rows[0];
   445	  if (!gate || gate.posted_consumption_kg === '0' || gate.expected_input_kg === null) return undefined;
   446	
   447	  if (gate.block) {
   448	    throw new ProductionActionError('insufficient_input_for_output', 409, {
   449	      message: `Insufficient posted input for output: expected ${gate.expected_input_kg} kg, posted ${gate.posted_consumption_kg} kg, yield ${gate.effective_yield_pct}%, threshold ${gate.block_pct}%.`,
   450	      expected_input_kg: gate.expected_input_kg,
   451	      posted_consumption_kg: gate.posted_consumption_kg,
   452	      effective_yield_pct: gate.effective_yield_pct,
   453	      block_pct: gate.block_pct,
   454	    });
   455	  }
   456	
   457	  if (!gate.warn) return undefined;
   458	  return {
   459	    expected_input_kg: gate.expected_input_kg,
   460	    posted_consumption_kg: gate.posted_consumption_kg,
   461	    effective_yield_pct: gate.effective_yield_pct,
   462	    warn_pct: MASS_BALANCE_WARN_PCT,
   463	  };
   464	}
   465	
   466	async function resolveWarehouseForSessionSite(ctx: OrgContextLike): Promise<SiteWarehouseTarget | null> {
   467	  // Resilient resolution for the output LP's warehouse: prefer a warehouse
   468	  // linked to the active site, then the org default, then the org's first
   469	  // warehouse. The previous version filtered strictly on `w.site_id = ctx.siteId`
   470	  // AND returned null when the WO/session had no site — so every desktop output
   471	  // 409'd 'no_warehouse_for_site' in orgs that hadn't wired site↔warehouse yet
   472	  // (the common state: warehouses with site_id NULL + no default). Now returns
   473	  // null only when the org genuinely has zero warehouses.
   474	  const { rows } = await ctx.client.query<SiteWarehouseTarget>(
   475	    `select w.id,
   476	            (select l.id
   477	               from public.locations l
   478	              where l.org_id = w.org_id
   479	                and l.warehouse_id = w.id
   480	              order by l.level asc, l.code asc
   481	              limit 1) as default_location_id
   482	       from public.warehouses w
   483	      where w.org_id = app.current_org_id()
   484	      order by (case when $1::uuid is not null and w.site_id = $1::uuid then 0 else 1 end) asc,
   485	               w.is_default desc nulls last,
   486	               w.name asc,
   487	               w.id asc
   488	      limit 1`,
   489	    [ctx.siteId ?? null],
   490	  );
   491	  return rows[0] ?? null;
   492	}
   493	
   494	/**
   495	 * 8b (F-A04/F-B08): materialize the output as INVENTORY. Creates the output LP
   496	 * in the SAME transaction as the wo_outputs row:
   497	 *   - warehouse/location = the scanner session site's default warehouse and
   498	 *     its first location;
   499	 *   - status 'received' + qa_status 'pending' — the LP is NOT born 'available';
   500	 *     it flows through the QA release → available promotion path;
   501	 *   - genealogy: parent_lp_id = FIRST consumed LP (license_plates models a
   502	 *     SINGLE parent); ALL consumed LPs are recorded in ext_jsonb.consumed_lp_ids.
   503	 *     MODELLING GAP (reported): N consumed parents cannot be expressed
   504	 *     relationally without a junction table (future lp_genealogy migration).
   505	 * Idempotency: on replay the wo_outputs transaction_id unique (23505) fires
   506	 * BEFORE this block and aborts the whole txn — no duplicate/orphan LP.
   507	 */
   508	async function createOutputLp(
   509	  ctx: OrgContextLike,
   510	  input: {
   511	    woId: string;
   512	    productId: string;
   513	    quantity: string;
   514	    uom: string;
   515	    batchNumber: string;
   516	    expiryDate: string | null; // 'YYYY-MM-DD' from the wo_outputs insert
   517	    transactionId: string;
   518	    actorUserId: string;
   519	    siteId: string | null;
   520	  },
   521	): Promise<{ id: string; lp_number: string }> {
   522	  const warehouse = await resolveWarehouseForSessionSite(ctx);
   523	  if (!warehouse) {
   524	    throw new ProductionActionError('no_warehouse_for_site', 409, {
   525	      reason: 'no_warehouse_for_site',
   526	      message: NO_WAREHOUSE_FOR_SITE_MESSAGE,
   527	    });
   528	  }
   529	
   530	  const consumedLpIds = await loadConsumedLpIds(ctx, input.woId);
   531	  const parentLpId = consumedLpIds[0] ?? null;
   532	  const lpNumber = makeLpNumber();
   533	
   534	  const { rows } = await ctx.client.query<{ id: string }>(
   535	    `insert into public.license_plates (
   536	       org_id, site_id, warehouse_id, location_id, lp_number, product_id, quantity, uom,
   537	       status, qa_status, batch_number, expiry_date, best_before_date,
   538	       origin, wo_id, parent_lp_id, ext_jsonb, created_by, updated_by
   539	     )
   540	     values (
   541	       app.current_org_id(), $1::uuid, $2::uuid, $3::uuid, $4, $5::uuid, $6::numeric, $7,
   542	       'received', 'pending', $8, $9::timestamptz, $9::timestamptz,
   543	       'production', $10::uuid, $11::uuid,
   544	       jsonb_build_object('consumed_lp_ids', $12::jsonb), $13::uuid, $13::uuid
   545	     )
   546	     returning id`,
   547	    [
   548	      input.siteId,
   549	      warehouse.id,
   550	      warehouse.default_location_id,
   551	      lpNumber,
   552	      input.productId,
   553	      input.quantity,
   554	      input.uom,
   555	      input.batchNumber,
   556	      input.expiryDate,
   557	      input.woId,
   558	      parentLpId,
   559	      JSON.stringify(consumedLpIds),
   560	      input.actorUserId,
   561	    ],
   562	  );
   563	  const lp = rows[0];
   564	  if (!lp) throw new ProductionActionError('persistence_failed', 500);
   565	
   566	  if (consumedLpIds.length > 0) {
   567	    for (const consumedLpId of consumedLpIds) {
   568	      await ctx.client.query(
   569	        `insert into public.lp_genealogy (
   570	           org_id, child_lp_id, parent_lp_id, relation_type, qty, uom
   571	         )
   572	         values (app.current_org_id(), $1::uuid, $2::uuid, 'consumed', $3::numeric, $4)
   573	         on conflict (org_id, child_lp_id, parent_lp_id, relation_type) do nothing`,
   574	        [lp.id, consumedLpId, input.quantity, input.uom],
   575	      );
   576	    }
   577	  }
   578	
   579	  // Genesis row in the LP transition ledger (same contract as the GRN flow).
   580	  await ctx.client.query(
   581	    `insert into public.lp_state_history (
   582	       org_id, lp_id, from_state, to_state, reason_code, reason_text,
   583	       wo_id, transaction_id, created_by
   584	     )
   585	     values (app.current_org_id(), $1::uuid, null, 'received', 'production_output',
   586	             'WO output registration', $2::uuid, $3::uuid, $4::uuid)
   587	     on conflict (org_id, transaction_id) do nothing`,
   588	    [lp.id, input.woId, input.transactionId, input.actorUserId],
   589	  );
   590	
   591	  return { id: lp.id, lp_number: lpNumber };
   592	}
   593	
   594	/**
   595	 * Register a single output row for a WO. The route supplies an OrgContextLike
   596	 * bound to a withOrgContext transaction; this function never opens its own.
   597	 */
   598	export async function registerOutput(
   599	  ctx: OrgContextLike,
   600	  woId: string,
   601	  rawBody: unknown,
   602	): Promise<RegisterOutputResult> {
   603	  // 1. validate
   604	  const parsed = RegisterOutputInput.safeParse(rawBody);
   605	  if (!parsed.success) {
   606	    throw new ProductionActionError('invalid_input', 422, {
   607	      fields: parsed.error.issues.map((i) => i.path.join('.')),
   608	      message: parsed.error.message,
   609	    });
   610	  }
   611	  const input = parsed.data;
   612	
   613	  // 2. RBAC
   614	  if (!(await hasPermission(ctx, PRODUCTION_OUTPUT_WRITE_PERMISSION))) {
   615	    throw new ProductionActionError('forbidden', 403);
   616	  }
   617	
   618	  // 3. load WO + item
   619	  const wo = await loadWo(ctx, woId);
   620	  await assertOutputProductAllowed(ctx, woId, input.product_id, input.output_type);
   621	  const resolvedQtyKg = resolveQtyKg(wo, input);
   622	  // V-PROD-03: registered output quantity must be > 0.
   623	  if (toMicro(resolvedQtyKg) <= 0n) {
   624	    throw new ProductionActionError('invalid_input', 422, { fields: ['qty_kg'] });
   625	  }
   626	  const item = await loadItem(ctx, input.product_id);
   627	
   628	  // 4. WO must be in a recordable lifecycle state (read-only).
   629	  const status = await readWoExecutionStatus(ctx, woId);
   630	  if (status === null || !OUTPUT_RECORDABLE_STATES.has(status)) {
   631	    throw new ProductionActionError('wo_not_recordable', 409, { status });
   632	  }
   633	
   634	  // 5. quality consume gate FIRST (on the consumed/output LP + lot). On an active
   635	  //    hold we throw QualityHoldError; the route emits production.consume.blocked
   636	  //    on a committed connection (this txn rolls back — no output row written).
   637	  const hold = await holdsGuard(ctx, { lpId: input.lp_id, lotId: input.lot_id });
   638	  if (hold) {
   639	    throw new QualityHoldError({
   640	      hold,
   641	      woId,
   642	      blockedPath: 'output',
   643	      transactionId: input.transaction_id,
   644	      lpId: input.lp_id ?? null,
   645	      lotId: input.lot_id ?? null,
   646	    });
   647	  }
   648	
   649	  // 6. batch_number + expiry_date (V-PROD-04).
   650	  const batchNumber =
   651	    input.batch_number ?? (await nextBatchNumber(ctx, woId, wo.wo_number, input.output_type));
   652	
   653	  // 7. catch-weight (T-032).
   654	  let catchSummary: CatchWeightSummary | null = null;
   655	  let catchDetailsJson: string | null = null;
   656	  if (item.weight_mode === 'catch') {
   657	    if (!input.catch_weight_kg_per_unit || input.catch_weight_kg_per_unit.length === 0) {
   658	      throw new ProductionActionError('invalid_input', 422, {
   659	        fields: ['catch_weight_kg_per_unit'],
   660	      });
   661	    }
   662	    const reference = item.nominal_weight ?? '0';
   663	    const tolerance =
   664	      input.catch_weight_tolerance_pct ??
   665	      (item.variance_tolerance_pct != null
   666	        ? Number(item.variance_tolerance_pct) / 100
   667	        : DEFAULT_CATCH_WEIGHT_TOLERANCE);
   668	    catchSummary = computeCatchWeightSummary(
   669	      input.catch_weight_kg_per_unit,
   670	      reference,
   671	      tolerance,
   672	    );
   673	    catchDetailsJson = JSON.stringify({
   674	      per_unit_kg: input.catch_weight_kg_per_unit,
   675	      avg_kg: catchSummary.avg_kg,
   676	      total_kg: catchSummary.total_kg,
   677	      variance_pct: catchSummary.variance_pct,
   678	      variance_warning: catchSummary.warning,
   679	      reference_kg: reference,
   680	      tolerance,
   681	    });
   682	  } else if (input.catch_weight_kg_per_unit && input.catch_weight_kg_per_unit.length > 0) {
   683	    // Red-line: do not require/accept catch weights for non-catch items silently;
   684	    // a caller sending them against a 'fixed' item is an input error.
   685	    throw new ProductionActionError('invalid_input', 422, {
   686	      fields: ['catch_weight_kg_per_unit'],
   687	      message: "item.weight_mode is 'fixed' — catch weights not accepted",
   688	    });
   689	  }
   690	
   691	  const massBalanceWarning = await evaluateMassBalanceGate(ctx, woId, resolvedQtyKg);
   692	
   693	  // 8. INSERT wo_outputs (V-PROD-24 unique-per-org-per-year enforced by index).
   694	  let outputId: string;
   695	  let lpId: string | null;
   696	  let expiryDate: string | null;
   697	  try {
   698	    const { rows } = await ctx.client.query<{ id: string; lp_id: string | null; expiry_date: string | null }>(
   699	      `insert into public.wo_outputs
   700	         (org_id, site_id, transaction_id, wo_id, output_type, product_id, lp_id,
   701	          batch_number, qty_kg, uom, catch_weight_details, registered_by, created_by,
   702	          expiry_date, qty_units, units_uom, actual_weight_kg)
   703	       values
   704	         (app.current_org_id(), $15::uuid, $1::uuid, $2::uuid, $3, $4::uuid, $5::uuid,
   705	          $6, $7::numeric, $8, $9::jsonb, $10::uuid, $10::uuid,
   706	          case when $11::int is not null then (current_date + ($11::int || ' days')::interval)::date else null end,
   707	          $12::numeric, $13, $14::numeric)
   708	       returning id, lp_id, to_char(expiry_date, 'YYYY-MM-DD') as expiry_date`,
   709	      [
   710	        input.transaction_id,
   711	        woId,
   712	        input.output_type,
   713	        input.product_id,
   714	        input.lp_id ?? null,
   715	        batchNumber,
   716	        resolvedQtyKg,
   717	        input.uom ?? wo.uom,
   718	        catchDetailsJson,
   719	        input.operator_id ?? ctx.userId,
   720	        item.shelf_life_days,
   721	        input.qtyUnits ?? null,
   722	        input.unitsUom ?? null,
   723	        input.actualWeightKg ?? null,
   724	        wo.site_id,
   725	      ],
   726	    );
   727	    const row = rows[0];
   728	    if (!row) throw new ProductionActionError('persistence_failed', 500);
   729	    outputId = row.id;
   730	    lpId = row.lp_id;
   731	    expiryDate = row.expiry_date;
   732	  } catch (err) {
   733	    if (err instanceof ProductionActionError) throw err;
   734	    const code = (err as { code?: string }).code;
   735	    if (code === '23505') {
   736	      // transaction_id unique (R14 idempotency replay) OR V-PROD-24 batch+year.
   737	      throw new ProductionActionError('already_recorded', 409);
   738	    }
   739	    if (code === '23514' || code === '23503') {
   740	      throw new ProductionActionError('invalid_reference', 422);
   741	    }
   742	    throw err;
   743	  }
   744	
   745	  // Owner policy (mig 336): mass-balance over-production is WARN + FLAG, never a hard
   746	  // block. When the warn tier fired (registered output exceeds what the yield-adjusted
   747	  // consumed input could yield), persist a flag on the WO — in the SAME transaction as
   748	  // the output — so over-produced orders are visible on the list/detail. Idempotent:
   749	  // keeps the FIRST flag timestamp; not cleared when an output is later voided (the
   750	  // over-production event still happened and stays on the record).
   751	  if (massBalanceWarning) {
   752	    await ctx.client.query(
   753	      `update public.work_orders
   754	          set over_production_flagged = true,
   755	              over_production_flagged_at = coalesce(over_production_flagged_at, now())
   756	        where id = $1::uuid
   757	          and org_id = app.current_org_id()`,
   758	      [woId],
   759	    );
   760	  }
   761	
   762	  // 8b. Output → LP (F-A04/F-B08): when the caller did not hand us an existing
   763	  // LP, create the output LP atomically in this same txn and back-link it.
   764	  let lpNumber: string | null = null;
   765	  if (!lpId) {
   766	    const createdLp = await createOutputLp(ctx, {
   767	      woId,
   768	      productId: input.product_id,
   769	      quantity: resolvedQtyKg,
   770	      uom: input.uom ?? wo.uom,
   771	      batchNumber,
   772	      expiryDate,
   773	      transactionId: input.transaction_id,
   774	      actorUserId: input.operator_id ?? ctx.userId,
   775	      siteId: wo.site_id,
   776	    });
   777	    lpId = createdLp.id;
   778	    lpNumber = createdLp.lp_number;
   779	    await ctx.client.query(
   780	      `update public.wo_outputs
   781	          set lp_id = $2::uuid,
   782	              updated_by = $3::uuid,
   783	              updated_at = now()
   784	        where org_id = app.current_org_id()
   785	          and id = $1::uuid`,
   786	      [outputId, lpId, input.operator_id ?? ctx.userId],
   787	    );
   788	  }
   789	
   790	  const outputLp = await ctx.client.query<OutputLpMoveRow>(
   791	    `select site_id::text as site_id,
   792	            location_id::text as location_id
   793	       from public.license_plates
   794	      where org_id = app.current_org_id()
   795	        and id = $1::uuid
   796	      limit 1`,
   797	    [lpId],
   798	  );
   799	  const outputLpMove = outputLp.rows[0];
   800	  if (!outputLpMove) {
   801	    throw new ProductionActionError('invalid_reference', 422);
   802	  }
   803	  await ctx.client.query(
   804	    `insert into public.stock_moves (
   805	       org_id, site_id, move_number, lp_id, move_type, to_location_id,
   806	       quantity, uom, reason_code, reason_text, transaction_id, wo_id,
   807	       status, ext_jsonb, created_by, updated_by
   808	     )
   809	     values (
   810	       app.current_org_id(), $1::uuid, $2, $3::uuid, 'receipt', $4::uuid,
   811	       $5::numeric, $6, 'production_output', 'WO output receipt',
   812	       $7::uuid, $8::uuid, 'completed', $9::jsonb, $10::uuid, $10::uuid
   813	     )
   814	     on conflict (org_id, transaction_id) do nothing`,
   815	    [
   816	      outputLpMove.site_id,
   817	      makeStockMoveNumber(input.transaction_id),
   818	      lpId,
   819	      outputLpMove.location_id,
   820	      resolvedQtyKg,
   821	      input.uom ?? wo.uom,
   822	      input.transaction_id,
   823	      woId,
   824	      JSON.stringify({ source: 'production_output', wo_id: woId, output_id: outputId }),
   825	      input.operator_id ?? ctx.userId,
   826	    ],
