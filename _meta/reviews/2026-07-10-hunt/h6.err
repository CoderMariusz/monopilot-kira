 succeeded in 0ms:
     1	/**
     2	 * T-028 / T-032 — POST /:locale/.../production/work-orders/:id/outputs
     3	 *
     4	 * Registers a primary / co_product / by_product output into the canonical
     5	 * wo_outputs table (08-production owns this — NOT 04-planning). Catch-weight
     6	 * details (T-032) are captured when the item's weight_mode='catch'.
     7	 *
     8	 * withOrgContext (RLS + org scope) → registerOutput service → wo_outputs INSERT
     9	 * + production.output.recorded outbox event, all in one transaction. The quality
    10	 * consume gate (holdsGuard) runs FIRST; an active hold ⇒ 409 +
    11	 * production.consume.blocked.
    12	 *
    13	 * Red lines (MON-domain-production): no duplicate wo_outputs table, no direct
    14	 * wo_executions.status write (read-only seam), no inline D365 calls, outbox INSERT
    15	 * inside the state-change txn.
    16	 */
    17	import { withOrgContext } from '../../../../../../../../lib/auth/with-org-context';
    18	import { getActiveSiteId } from '../../../../../../../../lib/site/site-context';
    19	import {
    20	  ProductionActionError,
    21	  QualityHoldError,
    22	  emitConsumeBlocked,
    23	  type OrgContextLike,
    24	  type QueryClient,
    25	} from '../../../../../../../../lib/production/shared';
    26	import { registerOutput } from '../../../../../../../../lib/production/output/register-output';
    27	
    28	function json(body: unknown, status: number): Response {
    29	  return new Response(JSON.stringify(body), {
    30	    status,
    31	    headers: { 'content-type': 'application/json' },
    32	  });
    33	}
    34	
    35	export async function POST(
    36	  req: Request,
    37	  ctx: { params: Promise<{ id: string }> },
    38	): Promise<Response> {
    39	  const { id: woId } = await ctx.params;
    40	
    41	  let body: unknown;
    42	  try {
    43	    body = await req.json();
    44	  } catch {
    45	    return json({ error: 'invalid_input' }, 422);
    46	  }
    47	
    48	  try {
    49	    return await withOrgContext(async ({ userId, orgId, client }): Promise<Response> => {
    50	      const siteId = await getActiveSiteId();
    51	      const orgCtx: OrgContextLike = { userId, orgId, siteId, client: client as unknown as QueryClient };
    52	      const result = await registerOutput(orgCtx, woId, body);
    53	      return json({ data: result }, 200);
    54	    });
    55	  } catch (err) {
    56	    // Active quality hold: the mutating txn rolled back; emit the blocked audit
    57	    // event on a fresh committed txn, then surface 409.
    58	    if (err instanceof QualityHoldError) {
    59	      try {
    60	        await withOrgContext(async ({ userId, orgId, client }) => {
    61	          await emitConsumeBlocked(
    62	            { userId, orgId, client: client as unknown as QueryClient },
    63	            err,
    64	          );
    65	        });
    66	      } catch (emitErr) {
    67	        console.error('[production/outputs] consume_blocked_emit_failed', {
    68	          woId,
    69	          err: emitErr instanceof Error ? emitErr.message : String(emitErr),
    70	        });
    71	      }
    72	      return json({ error: err.code, ...(err.details ?? {}) }, err.status);
    73	    }
    74	    if (err instanceof ProductionActionError) {
    75	      return json({ error: err.code, ...(err.details ?? {}) }, err.status);
    76	    }
    77	    console.error('[production/outputs] POST persistence_failed', {
    78	      woId,
    79	      err: err instanceof Error ? err.message : String(err),
    80	    });
    81	    return json({ error: 'persistence_failed' }, 500);
    82	  }
    83	}
