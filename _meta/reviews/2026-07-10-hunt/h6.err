   317	async function nextBatchNumber(
   318	  ctx: OrgContextLike,
   319	  woId: string,
   320	  woNumber: string,
   321	  outputType: string,
   322	): Promise<string> {
   323	  await ctx.client.query(
   324	    `select pg_advisory_xact_lock(hashtext($1::text || '::' || $2::text))`,
   325	    [woId, outputType],
   326	  );
   327	  const { rows } = await ctx.client.query<{ seq: string }>(
   328	    `select count(*)::text as seq
   329	       from public.wo_outputs
   330	      where wo_id = $1::uuid
   331	        and org_id = app.current_org_id()
   332	        and output_type = $2
   333	        and correction_of_id is null`,
   334	    [woId, outputType],
   335	  );
   336	  const seq = Number(rows[0]?.seq ?? '0') + 1;
   337	  return `${woNumber}-OUT-${String(seq).padStart(3, '0')}`;
   338	}
   339	
   340	/**
   341	 * Genealogy source (F-B08): the LPs this WO consumed, from the canonical
   342	 * consumption ledger (wo_material_consumption — the only consume writer),
   343	 * ordered by first consumption so [0] is the primary parent.
   344	 */
   345	async function loadConsumedLpIds(ctx: OrgContextLike, woId: string): Promise<string[]> {
   346	  const { rows } = await ctx.client.query<{ lp_id: string }>(
   347	    // Exclude the sentinel nil UUID that no-LP consumes write
   348	    // (consume-material-actions.ts: lp_id coalesces to
   349	    // '00000000-0000-0000-0000-000000000000'). Without this filter a WO whose
   350	    // only consumes were LP-less would give the output a phantom parent_lp_id
   351	    // pointing at a license_plates row that does not exist — corrupting
   352	    // genealogy. Filtering here keeps parent_lp_id null instead.
   353	    `select lp_id::text as lp_id
   354	       from public.wo_material_consumption
   355	      where org_id = app.current_org_id()
   356	        and wo_id = $1::uuid
   357	        and lp_id <> '00000000-0000-0000-0000-000000000000'::uuid
   358	      group by lp_id
   359	      order by min(consumed_at) asc, lp_id asc`,
   360	    [woId],
   361	  );
   362	  return rows.map((r) => r.lp_id);
   363	}
