    23	export type PrintFgLabelAction = (input: OutputPrintLabelInput) => Promise<OutputPrintLabelResult>;
    24	
    25	// ── Register output ───────────────────────────────────────────────────────────
    26	
    27	const OUTPUT_TYPES = ['primary', 'co_product', 'by_product'] as const;
    28	
    29	/**
    30	 * P0-UOM — the per-WO output-unit snapshot threaded from the detail screen header
    31	 * (itemCode / productName / output_uom + pack fields). Null/absent → the modal
    32	 * falls back to entering quantity directly in base kg (legacy qty_kg payload).
    33	 */
    34	export type OutputUomContext = {
    35	  /** READ-ONLY product identity surfaced instead of an editable UUID textbox. */
    36	  productCode: string | null;
    37	  productName: string | null;
    38	  /** The product's output unit. Absent ⇒ treated as 'base'. */
    39	  outputUom?: OutputUom;
    40	  uomBase?: string;
    41	  netQtyPerEach?: number | null;
    42	  eachPerBox?: number | null;
    43	  weightMode?: 'fixed' | 'catch';
    44	  /**
    45	   * SOFT-warning (owner decision — warn, NEVER block): set when the WO currently
    46	   * has no real material consumption recorded. The Register-output modal then
    47	   * shows a non-blocking notice before submit with a [Continue anyway]
    48	   * affordance — registering an output now gives the resulting LP no
    49	   * genealogy/traceability parent. Null/absent ⇒ no warning. Copy is resolved
    50	   * server-side (i18n) and threaded in — never authored in the modal.
    51	   */
    52	  noConsumptionWarning?: { message: string; continueLabel: string } | null;
    53	};
    54	
    55	function fmtKg(n: number): string {
    56	  return n.toLocaleString('en-US', { minimumFractionDigits: 3, maximumFractionDigits: 3 });
    57	}
    58	
    59	function fmtMassBalanceNumber(value: string, digits = 3): string {
    60	  const n = Number(value);
    61	  if (!Number.isFinite(n)) return value;
    62	  return n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: digits });
    63	}
    64	
    65	function formatMassBalanceWarning(template: string, warning: NonNullable<WoActionData['massBalanceWarning']>): string {
    66	  const expectedKg = Number(warning.expected_input_kg);
    67	  const yieldPct = Number(warning.effective_yield_pct);
    68	  const outputKg =
    69	    Number.isFinite(expectedKg) && Number.isFinite(yieldPct)
    70	      ? String((expectedKg * yieldPct) / 100)
    71	      : warning.expected_input_kg;
    72	  return template
    73	    .replace('{outputKg}', fmtMassBalanceNumber(outputKg))
    74	    .replace('{expectedKg}', fmtMassBalanceNumber(warning.expected_input_kg))
    75	    .replace('{yieldPct}', fmtMassBalanceNumber(warning.effective_yield_pct, 2))
    76	    .replace('{consumedKg}', fmtMassBalanceNumber(warning.posted_consumption_kg));
    77	}
    78	
    79	// B-3 catch-weight: per-unit input cap. Beyond this we refuse the dynamic grid
    80	// (an honest "reduce the quantity" message) rather than rendering 100s of inputs.
    81	const CATCH_WEIGHT_MAX_UNITS = 50;
    82	
    83	const DECIMAL_RE = /^\d+(\.\d+)?$/;
    84	function isPositiveDecimal(s: string): boolean {
    85	  const t = s.trim();
    86	  return DECIMAL_RE.test(t) && Number(t) > 0;
    87	}
    88	
    89	/**
    90	 * Exact 3-dp sum of catch-weight decimal STRINGS using integer micro-units
    91	 * (1e-6) so the live Σ line never drifts on binary-float addition. Mirrors the
    92	 * service's toMicro/microToDecimal contract (register-output.ts). Skips blanks.
    93	 */
    94	function sumCatchWeightsKg(weights: readonly string[]): string {
    95	  const SCALE = 1_000_000n;
    96	  let micro = 0n;
    97	  for (const w of weights) {
    98	    const t = w.trim();
    99	    if (t === '' || !DECIMAL_RE.test(t)) continue;
   100	    const [intPart, fracRaw = ''] = t.split('.');
   101	    const frac = (fracRaw + '000000').slice(0, 6);
   102	    micro += BigInt(intPart || '0') * SCALE + BigInt(frac || '0');
   103	  }
   104	  const intPart = micro / SCALE;
   105	  const frac = (micro % SCALE).toString().padStart(6, '0').slice(0, 3);
   106	  return `${intPart}.${frac}`;
   107	}
   108	
   109	export function OutputModal({
   110	  open,
   111	  woId,
   112	  labels,
   113	  run,
   114	  onClose,
   115	  defaultProductId,
   116	  uom,
   117	  printLabelAction,
   118	  canPrintFgLabel = false,
   119	}: BaseModalProps & {
   120	  defaultProductId: string | null;
   121	  uom?: OutputUomContext | null;
   122	  /**
   123	   * E1 — print the created FG LP label. OWNED by the printers settings actions
   124	   * (settings/infra/printers/_actions/printers.ts → printLabel) and threaded in by
   125	   * the page; never imported here directly. RBAC is re-enforced server-side.
   126	   */
   127	  printLabelAction?: PrintFgLabelAction;
   128	  /** Server-resolved settings.org.update; false ⇒ Print button disabled + tooltip. */
   129	  canPrintFgLabel?: boolean;
   130	}) {
   131	  const [outputType, setOutputType] = useState<(typeof OUTPUT_TYPES)[number]>('primary');
   132	  const [qty, setQty] = useState('');
   133	  const [actualWeight, setActualWeight] = useState('');
   134	  const [batch, setBatch] = useState('');
   135	  // E1 — success state: the created FG LP (id/number) + the print result.
   136	  const [output, setOutput] = useState<WoActionData | null>(null);
   137	  const [printBusy, setPrintBusy] = useState(false);
   138	  const [printResult, setPrintResult] = useState<OutputPrintLabelResult | null>(null);
   139	  const [printError, setPrintError] = useState<string | null>(null);
   140	  // B-3 catch-weight per-unit captures. `catchUnits` backs the dynamic per-unit
   141	  // grid (each/box catch items); `catchText` backs the base-uom textarea fallback
   142	  // (one weight per line) where the unit count is unknown up front.
   143	  const [catchUnits, setCatchUnits] = useState<string[]>([]);
   144	  const [catchText, setCatchText] = useState('');
   145	  const [busy, setBusy] = useState(false);
   146	  const [error, setError] = useState<string | null>(null);
   147	  const submittingRef = useRef(false);
   148	  const transactionIdRef = useRef(freshTransactionId());
   149	  // SOFT-warning acknowledgement (owner decision — warn, never block). When the
   150	  // WO has no recorded material consumption we surface a non-blocking notice; the
   151	  // operator clicks [Continue anyway] to acknowledge before submitting. Submit is
   152	  // never disabled by anything other than the normal field validity.
   153	  const [noConsumptionAck, setNoConsumptionAck] = useState(false);
   154	
   155	  useEffect(() => {
   156	    if (!open) return;
   157	    submittingRef.current = false;
   158	    transactionIdRef.current = freshTransactionId();
   159	  }, [open]);
   160	
   161	  // Product id is FIXED to the WO's FG product — never an editable textbox. We
   162	  // surface the read-only code + name and keep the id in the payload.
   163	  const productId = (defaultProductId ?? '').trim();
   164	
   165	  // Resolve the output unit. With no snapshot (or 'base') the modal behaves like
   166	  // the legacy kg entry; for each/box we enter units + convert to base kg.
   167	  const outputUom: OutputUom = uom?.outputUom ?? 'base';
   168	  const snap: UomSnapshot = {
   169	    outputUom,
   170	    uomBase: uom?.uomBase ?? 'kg',
   171	    netQtyPerEach: uom?.netQtyPerEach ?? null,
   172	    eachPerBox: uom?.eachPerBox ?? null,
   173	    boxesPerPallet: null,
   174	    weightMode: uom?.weightMode ?? 'fixed',
   175	  };
   176	  const isBase = outputUom === 'base';
   177	
   178	  // qty must be a plain decimal string (the handler REJECTS JS numbers).
   179	  const qtyValid = /^\d+(\.\d+)?$/.test(qty.trim()) && Number(qty.trim()) > 0;
   180	  const weightTrimmed = actualWeight.trim();
   181	  const weightValid = weightTrimmed === '' || (/^\d+(\.\d+)?$/.test(weightTrimmed) && Number(weightTrimmed) > 0);
   182	
   183	  // ── B-3 catch-weight ────────────────────────────────────────────────────────
   184	  // The service (register-output.ts) REQUIRES catch_weight_kg_per_unit for any
   185	  // item whose weight_mode === 'catch' and 422s without it. We surface a per-unit
   186	  // capture section: for each/box the qty (units) determines N compact inputs; for
   187	  // base (N unknown) a textarea taking one weight per line. Nothing changes for
   188	  // 'fixed' items.
   189	  const isCatch = snap.weightMode === 'catch';
   190	  // N from qty for the dynamic grid (each/box). Whole units only.
   191	  const catchN = !isBase && qtyValid ? Math.floor(Number(qty.trim())) : 0;
   192	  const catchOverCap = isCatch && !isBase && catchN > CATCH_WEIGHT_MAX_UNITS;
   193	
   194	  // The per-unit list, sized to N. We keep entered values stable as N grows/shrinks.
   195	  const catchInputs: string[] = isCatch && !isBase && !catchOverCap
   196	    ? Array.from({ length: catchN }, (_, i) => catchUnits[i] ?? '')
   197	    : [];
   198	
   199	  // Parse the base-uom textarea into trimmed non-empty lines.
   200	  const catchTextLines = isCatch && isBase
   201	    ? catchText.split('\n').map((l) => l.trim()).filter((l) => l !== '')
   202	    : [];
   203	
   204	  // The effective per-unit weight strings for sum/payload/validation.
   205	  const catchWeights = isCatch ? (isBase ? catchTextLines : catchInputs) : [];
   206	  const catchSumKg = isCatch ? sumCatchWeightsKg(catchWeights) : '0';
   207	  const catchValid = isCatch
   208	    ? !catchOverCap &&
   209	      catchWeights.length > 0 &&
   210	      catchWeights.every(isPositiveDecimal) &&
   211	      // each/box: every rendered slot must be filled (length already === N).
   212	      (isBase || catchWeights.length === catchN)
   213	    : true;
   214	
   215	  // SOFT-warning: a non-blocking acknowledgement gate. When present, the operator
   216	  // must click [Continue anyway] once before Confirm enables — but nothing here
   217	  // can hard-block the submit beyond a single acknowledging click.
   218	  const noConsumptionWarning = uom?.noConsumptionWarning ?? null;
   219	  const consumptionAcknowledged = noConsumptionWarning == null || noConsumptionAck;
   220	  const canConfirm =
   221	    productId !== '' && qtyValid && weightValid && catchValid && consumptionAcknowledged && !busy;
   222	
   223	  const cw = labels.output.catchWeight;
   224	  // E1 — print-FG-label copy with EN fallbacks (staged keys; injected by the page).
   225	  const p = labels.output.print ?? {
   226	    successTitle: 'Output registered',
   227	    successBody: 'The finished-goods license plate was created.',
   228	    lpLine: 'FG label — {lp}',
   229	    action: 'Print FG label',
   230	    printing: 'Printing…',
   231	    queued: 'Print job queued for the printer.',
   232	    sent: 'Label sent — download the rendered output below.',
   233	    download: 'Download label',
   234	    error: 'Label could not be printed. Try again or contact an administrator.',
   235	    forbidden: 'Insufficient permissions: settings.org.update is required to print labels.',
   236	    close: 'Done',
   237	  };
   238	  const fgLpCode = output?.lpNumber ?? null;
   239	  const massBalanceWarning = output?.massBalanceWarning ?? null;
   240	  const massBalanceWarningText = massBalanceWarning
   241	    ? formatMassBalanceWarning(
   242	        labels.output.mass_balance_warning ??
   243	          'Registered output ({outputKg} kg) requires approx {expectedKg} kg of components at {yieldPct}% yield, but {consumedKg} kg consumed so far.',
   244	        massBalanceWarning,
   245	      )
   246	    : null;
   247	  const catchSumLine = cw ? cw.sumLabel.replace('{total}', catchSumKg) : `Σ ${catchSumKg} kg`;
   248	  const catchTooManyLine = cw
   249	    ? cw.tooMany.replace('{max}', String(CATCH_WEIGHT_MAX_UNITS))
   250	    : `Too many units (max ${CATCH_WEIGHT_MAX_UNITS}).`;
   251	
   252	  // Live nominal conversion preview for each/box (hidden for base). When the pack
   253	  // factors are missing the preview shows the conversion-unavailable copy.
   254	  const qtyUnitLabel =
   255	    outputUom === 'box'
   256	      ? labels.output.qtyUom?.box
   257	      : outputUom === 'each'
   258	        ? labels.output.qtyUom?.each
   259	        : labels.output.qtyUom?.base;
   260	  // The legacy base label already carries its unit ("Quantity (kg)") — only
   261	  // append a suffix for each/box, else live renders "Quantity (kg) (kg)".
   262	  const qtyLabel =
   263	    !isBase && qtyUnitLabel ? `${labels.output.qty} (${qtyUnitLabel})` : labels.output.qty;
   264	
   265	  let preview: string | null = null;
   266	  if (!isBase && qtyValid) {
   267	    try {
   268	      const baseKg = toBaseQty(snap, Number(qty.trim()), outputUom);
   269	      preview =
   270	        labels.output.conversionPreview
   271	          ?.replace('{qty}', qty.trim())
   272	          .replace('{unit}', qtyUnitLabel ?? outputUom)
   273	          .replace('{kg}', fmtKg(baseKg))
   274	          .replace('{base}', snap.uomBase) ?? null;
   275	    } catch {
   276	      preview = labels.errors.uom_conversion_unavailable ?? labels.errorFallback;
   277	    }
   278	  }
   279	
   280	  async function handleConfirm() {
   281	    if (submittingRef.current || !canConfirm) return;
   282	    submittingRef.current = true;
   283	    setBusy(true);
   284	    setError(null);
   285	    const transactionId = transactionIdRef.current;
   286	
   287	    // For base, post the legacy { qty_kg } shape. For each/box, post units +
   288	    // unitsUom + the OPTIONAL actualWeightKg; if the conversion factors are
   289	    // missing, surface uom_conversion_unavailable verbatim before the round-trip.
   290	    let body: Record<string, unknown>;
   291	    if (isBase) {
   292	      body = {
   293	        transaction_id: transactionId,
   294	        output_type: outputType,
   295	        product_id: productId,
   296	        qty_kg: qty.trim(),
   297	        // REGULATED WEIGHT: decimal STRING, never a JS number — the route's
   298	        // DecimalString schema rejects numbers by design (live 422 otherwise).
   299	        ...(weightTrimmed ? { actualWeightKg: weightTrimmed } : {}),
   300	        ...(batch.trim() ? { batch_number: batch.trim() } : {}),
   100	}
   101	
   102	function lpRestoreTargetState(lp: LicensePlateRow): string {
   103	  if (lp.status !== 'consumed') return lp.status;
   104	  return lp.qa_status === 'released' ? 'available' : 'received';
   105	}
   106	
   107	function replayResponse(ext: Record<string, unknown>) {
   108	  const reverseConsumptionId = typeof ext.reverse_consumption_id === 'string' ? ext.reverse_consumption_id : null;
   109	  return scannerOk({
   110	    success: true,
   111	    replay: true,
   112	    consumption_id: typeof ext.consumption_id === 'string' ? ext.consumption_id : null,
   113	    reverse_consumption_id: reverseConsumptionId,
   114	    lp_status_after: typeof ext.lp_status_after === 'string' ? ext.lp_status_after : null,
   115	  });
   116	}
   117	
   118	async function readReplay(client: ProductionContext['client'], orgId: string, clientOpId: string): Promise<Record<string, unknown> | null> {
   119	  const replay = await findServerReplay(client, orgId, clientOpId, OPERATION);
   120	  if (!replay || replay.result_code !== 'ok') return null;
   121	  return replay.ext;
   122	}
   123	
   124	async function loadConsumptionForUpdate(
   125	  ctx: ProductionContext,
   126	  params: { woId: string; consumptionId: string | null; woMaterialId: string | null; lpId: string | null; qty: string | null },
   127	): Promise<ConsumptionRow | null> {
   128	  const selectSql = `select c.id::text as id,
   129	                           c.transaction_id::text as transaction_id,
   130	                           c.site_id::text as site_id,
   131	                           c.wo_id::text as wo_id,
   132	                           c.component_id::text as component_id,
   133	                           c.lp_id::text as lp_id,
   134	                           c.qty_consumed::text as qty_consumed,
   135	                           c.uom,
   136	                           c.operator_id::text as operator_id,
   137	                           c.fefo_adherence_flag,
   138	                           c.fefo_deviation_reason,
   139	                           c.over_consumption_flag,
   140	                           c.over_consumption_approved_by::text as over_consumption_approved_by,
   141	                           c.over_consumption_approved_at::text as over_consumption_approved_at,
   142	                           c.over_consumption_reason_code,
   143	                           c.ext_jsonb,
   144	                           c.consumed_at::text as consumed_at,
   145	                           coalesce(we.status, wo.status)::text as wo_status
   146	                      from public.wo_material_consumption c
   147	                      join public.work_orders wo on wo.id = c.wo_id and wo.org_id = c.org_id
   148	                      left join public.wo_executions we on we.wo_id = c.wo_id and we.org_id = c.org_id`;
   149	
   150	  if (params.consumptionId) {
   151	    const { rows } = await ctx.client.query<ConsumptionRow>(
   152	      `${selectSql}
   153	       where c.org_id = app.current_org_id()
   154	         and c.wo_id = $1::uuid
   155	         and c.id = $2::uuid
   156	         and app.user_can_see_site(c.site_id)
   157	         and c.correction_of_id is null
   158	       limit 1
   159	       for update of c`,
   160	      [params.woId, params.consumptionId],
   161	    );
   162	    return rows[0] ?? null;
   163	  }
   164	
   165	  const { rows } = await ctx.client.query<ConsumptionRow>(
   166	    `${selectSql}
   167	       join public.wo_materials wm
   168	         on wm.org_id = c.org_id
   169	        and wm.wo_id = c.wo_id
   170	        and (
   171	          ((c.ext_jsonb->>'materialId') ~* '^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$'
   172	            and wm.id = (c.ext_jsonb->>'materialId')::uuid)
   173	          or ((c.ext_jsonb->>'materialId') is null and wm.product_id = c.component_id)
   174	        )
   175	      where c.org_id = app.current_org_id()
   176	        and c.wo_id = $1::uuid
   177	        and wm.id = $2::uuid
   178	        and c.lp_id = $3::uuid
   179	        and c.qty_consumed = $4::numeric
   180	        and app.user_can_see_site(c.site_id)
   181	        and c.correction_of_id is null
   182	      order by c.consumed_at desc, c.id desc
   183	      limit 1
   184	      for update of c`,
   185	    [params.woId, params.woMaterialId, params.lpId, params.qty],
   186	  );
   187	  return rows[0] ?? null;
   188	}
   189	
   190	async function hasConsumptionCorrection(ctx: ProductionContext, consumptionId: string): Promise<boolean> {
   191	  const { rows } = await ctx.client.query<{ ok: boolean }>(
   192	    `select true as ok
   193	       from public.wo_material_consumption
   194	      where org_id = app.current_org_id()
   195	        and correction_of_id = $1::uuid
   196	      limit 1`,
   197	    [consumptionId],
   198	  );
   199	  return rows.length > 0;
   200	}
   201	
   202	async function loadLicensePlateForUpdate(ctx: ProductionContext, lpId: string): Promise<LicensePlateRow | null> {
   203	  const { rows } = await ctx.client.query<LicensePlateRow>(
   204	    `select id::text as id,
   205	            site_id::text as site_id,
   206	            location_id::text as location_id,
   207	            status,
   208	            qa_status,
   209	            quantity::text as quantity,
   210	            reserved_qty::text as reserved_qty
   211	       from public.license_plates
   212	      where org_id = app.current_org_id()
   213	        and id = $1::uuid
   214	        and app.user_can_see_site(site_id)
   215	      limit 1
   216	      for update`,
   217	    [lpId],
   218	  );
   219	  return rows[0] ?? null;
   220	}
   221	
   222	async function lockWoMaterialsAndValidateDecrement(ctx: ProductionContext, original: ConsumptionRow): Promise<boolean> {
   223	  const materialId = materialIdFromConsumptionExt(original);
   224	
   225	  if (!materialId) {
   226	    const { rows } = await ctx.client.query<{ id: string; can_decrement: boolean; matching_line_count: string }>(
   227	      `with locked_materials as (
   228	         select id,
   229	                consumed_qty
   230	           from public.wo_materials
   231	          where org_id = app.current_org_id()
   232	            and wo_id = $1::uuid
   233	            and product_id = $2::uuid
   234	            and exists (
   235	              select 1
   236	                from public.work_orders wo
   237	               where wo.org_id = app.current_org_id()
   238	                 and wo.id = wo_materials.wo_id
   239	                 and app.user_can_see_site(wo.site_id)
   240	            )
   241	          for update
   242	       )
   243	       select id::text as id,
   244	              (consumed_qty - $3::numeric >= 0) as can_decrement,
   245	              (select count(*) from locked_materials)::text as matching_line_count
   246	         from locked_materials`,
   247	      [original.wo_id, original.component_id, original.qty_consumed],
   248	    );
   249	    return rows.length === 1 && rows[0]?.matching_line_count === '1' && rows[0].can_decrement;
   250	  }
   251	
   252	  const { rows } = await ctx.client.query<{ id: string; can_decrement: boolean }>(
   253	    `select id::text as id,
   254	            (consumed_qty - $3::numeric >= 0) as can_decrement
   255	       from public.wo_materials
   256	      where org_id = app.current_org_id()
   257	        and wo_id = $1::uuid
   258	        and ${materialId ? 'id' : 'product_id'} = $2::uuid
   259	        and consumed_qty - $3::numeric >= 0
   260	        and exists (
   261	          select 1
   262	            from public.work_orders wo
   263	           where wo.org_id = app.current_org_id()
   264	             and wo.id = wo_materials.wo_id
   265	             and app.user_can_see_site(wo.site_id)
   266	        )
   267	      for update`,
   268	    [original.wo_id, materialId ?? original.component_id, original.qty_consumed],
   269	  );
   270	  return rows.length > 0 && rows.every((row) => row.can_decrement);
   271	}
   272	
   273	async function supervisorPinRequired(ctx: ProductionContext): Promise<boolean> {
   274	  const { rows } = await ctx.client.query<{ require_supervisor: string | null }>(
   275	    `select feature_flags->>'scanner_reverse_require_supervisor_pin' as require_supervisor
   276	       from public.tenant_variations
   277	      where org_id = $1::uuid
   278	      limit 1`,
   279	    [ctx.orgId],
   280	  );
   281	  return rows[0]?.require_supervisor?.toLowerCase() !== 'false';
   282	}
   283	
   284	async function insertCounterEntry(
   285	  ctx: ProductionContext,
   286	  params: { original: ConsumptionRow; reasonCode: CorrectionReasonCode; note: string | null },
   287	): Promise<{ id: string }> {
   288	  const transactionId = correctionTransactionId({
   289	    orgId: ctx.orgId,
   290	    table: 'wo_material_consumption',
   291	    originalId: params.original.id,
