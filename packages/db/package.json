{
  "name": "@monopilot/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./test-utils/*.js": "./test-utils/*.ts",
    "./test-utils/*": "./test-utils/*.ts",
    "./*.js": "./src/*.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:integration": "vitest run",
    "migrate": "tsx scripts/migrate.ts",
    "check:drift": "bash -c 'set -euo pipefail; tmp=$(mktemp /tmp/monopilot-schema.XXXXXX); pg_dump --schema-only --no-owner --no-privileges \"${DATABASE_URL:?DATABASE_URL is required}\" | sed \"/^-- Dumped from database version /d;/^-- Dumped by pg_dump version /d;/^\\\\\\\\restrict /d;/^\\\\\\\\unrestrict /d\" > \"$tmp\"; diff -u __expected__/schema.sql \"$tmp\"'",
    "lint": "eslint ."
  },
  "dependencies": {
    "drizzle-kit": "0.31.1",
    "drizzle-orm": "0.40.0",
    "pg": "8.16.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
