{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @monopilot/db migrate && cd apps/web && pnpm build",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/internal/cron/drift",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/internal/cron/catch-weight-variance",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/internal/cron/outbox",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/internal/cron/reporting-refresh",
      "schedule": "30 3 * * *"
    }
  ]
}
