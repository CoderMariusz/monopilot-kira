    "@monopilot/e-sign": "workspace:*",
    "@monopilot/observability": "workspace:*",
    "@monopilot/ops": "workspace:*",
    "@monopilot/queries": "workspace:*",
    "@monopilot/rbac": "workspace:*",
    "@monopilot/ui": "workspace:*",
    "@monopilot/validation": "workspace:*",
    "@sentry/nextjs": "^10.56.0",
    "@serwist/next": "^9.5.11",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "argon2": "^0.31.2",
    "json-schema-to-zod": "^2.8.1",
    "next": "^16.0.0",
    "next-intl": "^4.11.0",
    "pg": "8.16.0",
    "posthog-node": "^5.33.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.75.0",
    "server-only": "^0.0.1",
    "serwist": "^9.5.11",
