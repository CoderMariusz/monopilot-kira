# API Keys (Required to enable respective provider)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional, for OpenAI models. Format: sk-proj-...
GOOGLE_API_KEY="your_google_api_key_here"             # Optional, for Google Gemini models.
MISTRAL_API_KEY="your_mistral_key_here"               # Optional, for Mistral AI models.
XAI_API_KEY="YOUR_XAI_KEY_HERE"                       # Optional, for xAI AI models.
GROQ_API_KEY="YOUR_GROQ_KEY_HERE"                     # Optional, for Groq models.
OPENROUTER_API_KEY="YOUR_OPENROUTER_KEY_HERE"         # Optional, for OpenRouter models.
AZURE_OPENAI_API_KEY="your_azure_key_here"            # Optional, for Azure OpenAI models (requires endpoint in .taskmaster/config.json).
OLLAMA_API_KEY="your_ollama_api_key_here"             # Optional: For remote Ollama servers that require authentication.
GITHUB_API_KEY="your_github_api_key_here"             # Optional: For GitHub import/export features. Format: ghp_... or github_pat_...

# Local development database (used by packages/db tests and migrate)
# Matches docker-compose.yml postgres service; copy to .env.local or export before running db scripts.
DATABASE_URL="postgres://monopilot:monopilot@localhost:5432/monopilot"

# ─── Database ─────────────────────────────────────────────────────────────────
# Required: Primary connection string used by packages/db, SAML Jackson, and
# the drift cron job (falls back to DATABASE_URL when the more specific vars
# are unset).
DATABASE_URL="postgres://monopilot:monopilot@localhost:5432/monopilot"

# Required: Owner-role (BYPASSRLS) connection string. Used by withOrgContext to
# INSERT into app.session_org_contexts before the app-role transaction, and by
# the drift cron route. Falls back to DATABASE_URL when unset.
DATABASE_URL_OWNER="postgres://monopilot:monopilot@localhost:5432/monopilot"

# Required: App-role (RLS-enforcing) connection string for the app_user Postgres
# role. Used by withOrgContext for the data-plane transaction. Falls back to
# DATABASE_URL (rewriting username to app_user) when unset.
DATABASE_URL_APP="postgres://app_user:app-user-test-password@localhost:5432/monopilot"

# Required (when DATABASE_URL_APP is unset): Password for the app_user Postgres
# role, used to synthesise the app-role connection string at runtime.
APP_USER_PASSWORD="app-user-test-password"

# ─── Supabase Auth ────────────────────────────────────────────────────────────
# Required: Public URL of your Supabase project (used by the Next.js client and
# SAML Jackson's external URL configuration).
NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"

# Required: Public anon key for the Supabase project (client-side auth flows).
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# ─── App config ───────────────────────────────────────────────────────────────
# Required: Node environment. Controls fail-closed vs fail-open security paths
# (e.g. SAML policy enforcement is strictly fail-closed in production).
NODE_ENV="development"

# Required: Canonical public URL of the app (e.g. https://app.monopilot.com).
# Used by SAML Jackson for the SP entity ID and redirect URI construction.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Alternate public site URL, used for canonical link generation and
# SEO-facing redirects; can differ from NEXT_PUBLIC_APP_URL (e.g. marketing
# domain vs. app subdomain). Defaults to NEXT_PUBLIC_APP_URL when unset.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: Semantic version string injected at build time, exposed via
# /api/version and feature-flag context payloads.
APP_VERSION="0.0.0-local"

# Optional: Idle session timeout in minutes. When unset the app uses its
# compiled-in default. Set to 0 to disable idle timeout.
IDLE_TIMEOUT_MIN="30"

# ─── Security / Auth ──────────────────────────────────────────────────────────
# Required (production): 32-byte hex HMAC key used to sign RBAC approval tokens
# (packages/rbac grant.ts). Generate with: openssl rand -hex 32
RBAC_APPROVAL_HMAC_KEY="change-me-generate-with-openssl-rand-hex-32"

# Required (production): Bearer secret for the internal cron routes
# (e.g. GET /api/internal/cron/drift). Vercel platform cron requests are
# accepted via the x-vercel-cron header; this secret covers non-Vercel callers.
# Generate with: openssl rand -hex 32
# Note: when unset and NODE_ENV=development and VERCEL_ENV is unset, the cron
# route accepts any non-empty bearer (local dev convenience only).
CRON_SECRET="change-me-generate-with-openssl-rand-hex-32"

# Optional (non-production only): Set to "true" to allow SAML policy enforcement
# to fail-open when the database is unreachable. NEVER set in production — the
# codebase explicitly ignores this flag when NODE_ENV=production. Useful for
# local development without a running DB.
ALLOW_SAML_POLICY_FAIL_OPEN_IN_DEV="false"

# Optional (non-production only): Set to the literal string "true" to bypass
# page-routing auth middleware in local development/e2e when stale Supabase
# cookies would otherwise 401 protected pages. Ignored when NODE_ENV=production.
DEV_AUTH_BYPASS="false"

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Required in production: Upstash Redis REST credentials used by
# @monopilot/rate-limit for auth, SAML, SCIM, magic-link, and PIN throttles.
# Tests and local non-production runs fall back to an in-memory edge-safe store
# with a single warning; production fails closed when these are unset.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Password policy ──────────────────────────────────────────────────────────
# Optional: Set to "true" to skip HaveIBeenPwned (HIBP) password breach checks.
# Useful in offline/dev environments where HIBP is unreachable.
HIBP_DISABLED="false"

# Optional: Set to "true" to treat HIBP API errors as a hard failure (reject
# the password). When "false" (default) HIBP errors allow the password through
# (fail-open). Enable in production for maximum breach protection.
HIBP_FAIL_HARD="false"

# ─── Observability ────────────────────────────────────────────────────────────
# Optional: Sentry DSN for web and worker error reporting. Leave blank to
# disable the SDK transport while keeping startup non-blocking.
SENTRY_DSN=""

# Optional: Sentry environment override. Defaults to NODE_ENV when unset.
SENTRY_ENV=""

# Optional: Release identifier for Sentry events. CI should set this to the
# deployment commit SHA; falls back to VERCEL_GIT_COMMIT_SHA or GIT_SHA.
SENTRY_RELEASE=""

# Optional: Sentry auth token for source-map uploads. When unset, Next.js Sentry
# source-map upload is forced to dryRun:true.
SENTRY_AUTH_TOKEN=""

# Optional: PostHog project API key for product analytics. Leave blank to
# disable analytics entirely.
POSTHOG_API_KEY=""

# Optional: PostHog ingest host (defaults to https://app.posthog.com).
# Override for EU data-residency or self-hosted PostHog instances.
POSTHOG_HOST="https://app.posthog.com"

# ─── Vercel runtime (auto-set by Vercel — do NOT set manually) ───────────────
# Auto-set: Vercel deployment environment ("production", "preview", "development").
# Used by the cron route to detect Vercel-hosted previews and enforce
# CRON_SECRET even when NODE_ENV != "production".
# VERCEL_ENV=""

# Auto-set: Vercel deployment URL (e.g. my-app-abc123.vercel.app). Used for
# constructing absolute URLs in server-side code when NEXT_PUBLIC_APP_URL is
# not explicitly set.
# VERCEL_URL=""

# ─── Test-only (NEVER set in production) ─────────────────────────────────────
# These vars are read only when NODE_ENV=test AND the VITEST env var is set.
# They allow integration tests to bypass Supabase JWT verification and inject a
# known actor/org context into withOrgContext (apps/web/lib/auth/with-org-context.ts).

# Test-only: Supabase user UUID to inject as the authenticated actor.
# NEXT_SERVER_ACTION_ACTOR_USER_ID="00000000-0000-0000-0000-000000000001"

# Test-only: Organisation UUID to inject as the active org context.
# NEXT_SERVER_ACTION_ORG_ID="00000000-0000-0000-0000-000000000002"

# Test-only: Set automatically by vitest runner; do not set manually.
# VITEST="true"
