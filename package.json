{
  "name": "@monopilot/monopilot-kira",
  "private": true,
  "scripts": {
    "build": "pnpm --filter web build",
    "test:smoke": "pnpm --filter web test:smoke",
    "test:e2e:pwa": "PLAYWRIGHT_WEB_SERVER=1 pnpm exec playwright test apps/web/e2e/pwa.spec.ts --project=chromium",
    "lint": "node scripts/lint-no-hardcoded-strings.mjs && pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "ci": "pnpm build && pnpm test:smoke && pnpm lint",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:test": "pnpm --filter @monopilot/db test",
    "db:migrate": "pnpm --filter @monopilot/db migrate",
    "db:verify": "pnpm db:test && pnpm db:migrate",
    "db:test:local": "DATABASE_URL=postgres://monopilot:monopilot@127.0.0.1:5432/monopilot pnpm db:test",
    "db:migrate:local": "DATABASE_URL=postgres://monopilot:monopilot@127.0.0.1:5432/monopilot pnpm db:migrate",
    "db:verify:local": "DATABASE_URL=postgres://monopilot:monopilot@127.0.0.1:5432/monopilot pnpm db:verify",
    "drill": "pnpm --filter @monopilot/restore-drill drill"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.17.0",
    "playwright": "^1.58.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
