{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@monopilot/*": ["packages/*/src"]
    },
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "incremental": true,
    "esModuleInterop": true,
    "allowJs": false,
    "types": ["vitest/globals", "node"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next",
    "coverage",
    "prototypes",
    "_archive"
  ]
}
